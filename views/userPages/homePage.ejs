<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <title>Tech Gadgets | Premium Electronics</title>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
    .gradient-text { background: linear-gradient(to right, #7c3aed, #db2777); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  </style>
</head>

<body class="bg-slate-50 text-slate-900 selection:bg-purple-100 selection:text-purple-700">

<%- include('./partials/headerPartial') %>

<section class="relative px-4 md:px-12 pt-8 pb-12 overflow-hidden">
  <div class="relative bg-slate-900 rounded-[2.5rem] p-8 md:p-20 shadow-2xl flex flex-col lg:flex-row items-center justify-between overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-purple-600/30 rounded-full blur-[100px] -mr-20 -mt-20"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-600/20 rounded-full blur-[100px] -ml-20 -mb-20"></div>

    <div class="relative text-center lg:text-left max-w-2xl z-10">
      <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-purple-400 uppercase bg-purple-500/10 rounded-full border border-purple-500/20">
        New Generation Tech
      </span>
      <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.1] text-white tracking-tight">
        Unleash the <br> <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-400">Future of Tech</span>
      </h1>
      <p class="text-lg mt-6 text-slate-400 leading-relaxed max-w-lg">
        Explore a curated collection of high-performance gadgets and workspace essentials designed for the modern enthusiast.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4 mt-10">
        <a href="/shop" class="w-full sm:w-auto flex items-center justify-center px-10 py-4 bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-2xl font-bold shadow-lg shadow-purple-500/30 hover:scale-105 hover:shadow-purple-500/40 transition-all duration-300">
          Start Shopping <i class="fas fa-shopping-cart ml-3"></i>
        </a>
        <a href="#trending" class="w-full sm:w-auto flex items-center justify-center px-10 py-4 bg-white/5 text-white rounded-2xl font-bold border border-white/10 hover:bg-white/10 transition-all">
          View Trends
        </a>
      </div>
    </div>

    <div class="relative mt-16 lg:mt-0 group">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-pink-500 rounded-3xl blur-2xl opacity-20 group-hover:opacity-40 transition duration-500"></div>
      <img src="https://img.freepik.com/free-photo/top-view-set-gadgets-purple-neon-light-pink-background-laptop-keyboard-headphones-smartphone-with-black-screen-copyspace-your-advertising-tech-modern-gadgets_155003-25550.jpg" 
           class="relative w-full lg:w-[480px] rounded-[2rem] shadow-2xl transform lg:rotate-3 hover:rotate-0 transition duration-500" />
    </div>
  </div>
</section>

<section class="px-4 md:px-12 -mt-10 relative z-20">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <% const features=[
      ['fa-truck-fast','Lightning Delivery','Free shipping on orders above ₹999'],
      ['fa-shield-halved','Easy Returns','Hassle-free 7-day money back guarantee'],
      ['fa-lock','Secure Checkout','AES-256 bit encrypted payment gateway'],
      ['fa-headset','Premium Support','Dedicated 24/7 technical assistance']
    ] %>
    <% features.forEach(f=>{ %>
    <div class="glass p-8 rounded-[2rem] hover:bg-white hover:-translate-y-2 transition-all duration-300 shadow-xl shadow-slate-200/50 group">
      <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-500 text-white flex items-center justify-center rounded-2xl mb-6 shadow-lg shadow-purple-200 group-hover:scale-110 transition-transform">
        <i class="fas <%=f[0]%> text-xl"></i>
      </div>
      <h5 class="font-extrabold text-slate-800 text-lg mb-2"><%=f[1]%></h5>
      <p class="text-sm text-slate-500 leading-relaxed"><%=f[2]%></p>
    </div>
    <% }) %>
  </div>
</section>

<section id="trending" class="px-4 md:px-12 py-20">
  <div class="flex flex-col md:flex-row items-end justify-between mb-12 gap-4">
    <div class="max-w-xl">
      <h2 class="text-4xl font-extrabold text-slate-900 tracking-tight">Trending Now</h2>
      <p class="text-slate-500 mt-3 italic">Our community's most loved tech essentials this week.</p>
    </div>
    <a href="/shop" class="group flex items-center text-purple-600 font-bold hover:text-pink-600 transition-colors">
      View All Catalog <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
    <% products.slice(0,8).forEach(function(product, index){ %>
    <% if(product.category && product.category.status==='listed'){ %>
    <div class="group bg-white rounded-[2rem] p-4 shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-purple-200/50 transition-all duration-500 flex flex-col h-full">
      <div class="relative aspect-square rounded-[1.5rem] overflow-hidden bg-slate-50 mb-6">
        <% if(product.best_offer) { %>
        <div class="absolute top-4 left-4 z-10 bg-pink-600 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-tighter shadow-lg shadow-pink-200">
          HOT DEAL
        </div>
        <% } %>
        
     <img src="<%= product.imageUrl %>"
     class="w-full h-full object-cover group-hover:scale-110 transition duration-700 ease-in-out" 
     onerror="this.src='/img/placeholder.jpg'" />
        
        <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <a href="/product/<%=product._id%>" class="w-full py-3 glass bg-white/90 text-slate-900 rounded-xl font-bold text-sm flex items-center justify-center gap-2 hover:bg-slate-900 hover:text-white transition-all">
            Quick View <i class="fas fa-eye"></i>
          </a>
        </div>
      </div>

      <div class="px-2 flex flex-col flex-1">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-none"><%= product.brand %></span>
            <div class="flex text-amber-400 text-[10px]"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star text-slate-200"></i></div>
        </div>
        <h4 class="font-bold text-slate-800 line-clamp-1 group-hover:text-purple-600 transition-colors"><%=product.name%></h4>
        
        <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between mt-auto">
          <div>
  
    <p class="text-xs text-slate-400 font-medium line-through">
      ₹<%= (product.price * 1.2).toFixed(0) %>
    </p>
    <p class="text-xl font-black text-slate-900 tracking-tight">
      ₹<%= product.price.toLocaleString('en-IN') %>
    </p>
 
</div>
          
        </div>
      </div>
    </div>
    <% }}); %>
  </div>
</section>

<section class="px-4 md:px-12 py-10 bg-slate-100/50">
    <div class="text-center mb-16">
        <h3 class="text-3xl font-extrabold text-slate-900 tracking-tight">Shop by Category</h3>
        <p class="text-slate-500 mt-2">Finely tuned categories for your tech stack</p>
    </div>

    <div class="flex flex-wrap justify-center gap-6">
        <% categories.filter(c=>c.status==='listed').forEach((c, i)=>{ %>
        <a href="/shop?category=<%=c.name%>" class="group relative w-64 h-80 rounded-[2.5rem] overflow-hidden shadow-xl shadow-slate-200 transition-all duration-500 hover:-translate-y-3">
            <img src="/<%=c.imageUrl%>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent"></div>
            <div class="absolute bottom-0 inset-x-0 p-8">
                <p class="text-white text-xl font-black tracking-tight"><%=c.name%></p>
                <p class="text-purple-400 text-xs font-bold uppercase tracking-widest mt-1 opacity-0 group-hover:opacity-100 transition-opacity">Explore Collections <i class="fas fa-chevron-right ml-1"></i></p>
            </div>
        </a>
        <% }) %>
    </div>
</section>

<%- include('./partials/footer') %>

</body>
</html>