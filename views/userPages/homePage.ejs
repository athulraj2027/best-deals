<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="/userCSS/full-width-product-card.css" />
    <link rel="stylesheet" href="/userCSS/homePage.css" />
    <link rel="stylesheet" href="/userCSS/category-card.css" />
    <link rel="stylesheet" href="/userCSS/product-card.css" />
    <title>Home Page</title>
  </head>
  <body>
    <!-- Include the header partial -->
    <%- include('./partials/headerPartial') %>

    <section class="main-body">
      <div class="hero-section d-flex align-items-center justify-content-between  text-white p-5" style="background-color: #b538cd;border-radius: 10px;">
        <!-- Text Content -->
        <div class="hero-text">
          <h1 class="display-4 fw-bold">Level Up Your Shopping Experience</h1>
          <p class="lead">Discover the ultimate gadgets and accessories that redefine entertainment.</p>
          <button class="btn btn-success btn-lg mt-3">Shop Now</button>
        </div>
      
        <!-- Image Content -->
        <div class="hero-image">
          <img 
            src="https://img.freepik.com/free-photo/top-view-set-gadgets-purple-neon-light-pink-background-laptop-keyboard-headphones-smartphone-with-black-screen-copyspace-your-advertising-tech-modern-gadgets_155003-25550.jpg?semt=ais_incoming" 
            alt="Gaming Console" 
            class="img-fluid rounded shadow" 
          />
        </div>
      </div>
      
      <div class="container w-85 features d-flex justify-content-around text-white">
        <div class="">
          <h5>FAST DELIVERY</h5>
          <P>Delivery within 24 hrs</P>
        </div>
        <div class="">
          <h5>24 HOURS RETURN</h5>
          <P>100% money-back guarantee</P>
        </div>
        <div class="">
          <h5>SECURE PAYMENT</h5>
          <P>Your money is safe</P>
        </div>
        <div class="">
          <h5>CUSTOMER SUPPORT</h5>
          <P>Available 24 hrs</P>
        </div>
      </div>

      <div class="product-heading">
        <h4>BestDeals</h4>
        <p>ending soon</p>
      </div>

      <div class="products d-flex justify-content-around flex-wrap">
        <% products.forEach(function(product) { %>
          <div class="product-card" style="background-color: #b538cd; width: 220px; margin: 10px;">
            <div class="product-image">
              <img 
                src="<%= product.imageUrl %>" 
                alt="<%= product.name %>" 
                onerror="this.src='/images/product-placeholder.jpg'"
              />
            </div>
            <div class="product-info">
              <div class="product-name"><%= product.name %></div>
              <div class="product-description">$<%= product.price.toFixed(2) %></div>
              <div class="product-brand text-white-50 mb-2"><%= product.brand %></div>
              <a href="/product/<%= product._id %>" class="product-btn">Buy Now</a>
            </div>
          </div>
        <% }); %>
      </div>
      
      
      <div class="browse-products text-center text-decoration-none text-dark">
        <a href="/shop">Browse all products</a>
        <hr />
      </div>
      

      <div class="browse-products text-center text-decoration-none text-dark">
        <a href="/shop" >Browse all products</a>
        <hr />
      </div>
      <h3 class="text-center">Shop with Categories</h3>
      <div class="categories-list-div d-flex">
        <% categories.filter(category => category.status === 'listed').slice(0, 5).forEach(category => { %>  <!-- Filter and then iterate -->
          <div class="category-card">
            <div class="category-image">
              <img src="/<%= category.imageUrl ? category.imageUrl : 'path_to_default_image.jpg' %>" alt="<%= category.name %> Image" />

            </div>
            <div class="category-name"><%= category.name %></div>
          </div>
        <% }); %>
      </div>
      

    <!-- Include the footer partial -->
    <%- include('./partials/footer') %>
  </body>
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"
  ></script>
</html>
