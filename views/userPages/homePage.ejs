<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />
  <title>Tech Gadgets</title>
</head>

<body class="bg-gradient-to-br from-purple-50 to-pink-50 font-sans">

<%- include('./partials/headerPartial') %>

<section class="px-4 md:px-12">

<!-- HERO -->
<div class="relative overflow-hidden bg-gradient-to-br from-purple-700 via-fuchsia-600 to-pink-500 rounded-3xl p-8 md:p-14 shadow-2xl flex flex-col md:flex-row items-center justify-between text-white mt-8">

  <div class="absolute -top-20 -right-20 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 -left-20 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>

  <div class="relative text-center md:text-left max-w-xl">
    <h1 class="text-4xl md:text-6xl font-extrabold leading-tight">
      Level Up Your <br> Tech Game
    </h1>

    <p class="text-lg mt-5 opacity-90">
      Premium gadgets, smart accessories & exclusive flash deals.
    </p>

    <a href="/shop?category=all"
      class="inline-flex items-center mt-8 bg-white text-purple-700 px-8 py-3 rounded-full font-semibold shadow-lg hover:scale-105 transition">
      Shop Now <i class="fas fa-arrow-right ml-3"></i>
    </a>
  </div>

  <img
    src="https://img.freepik.com/free-photo/top-view-set-gadgets-purple-neon-light-pink-background-laptop-keyboard-headphones-smartphone-with-black-screen-copyspace-your-advertising-tech-modern-gadgets_155003-25550.jpg"
    class="relative w-full md:w-[420px] rounded-2xl shadow-xl mt-10 md:mt-0 hover:scale-105 transition"
  />
</div>

<!-- FEATURES -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 mt-12">

<% const features=[
  ['fa-truck-fast','Fast Delivery','Free shipping'],
  ['fa-rotate-left','Easy Returns','Money back'],
  ['fa-lock','Secure Payment','Protected checkout'],
  ['fa-headset','24/7 Support','Live help']
] %>

<% features.forEach(f=>{ %>
<div class="backdrop-blur bg-white/70 p-6 rounded-2xl shadow-lg hover:-translate-y-2 transition">
  <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-pink-500 text-white flex items-center justify-center rounded-xl mb-4">
    <i class="fas <%=f[0]%>"></i>
  </div>
  <h5 class="font-bold"><%=f[1]%></h5>
  <p class="text-sm text-gray-600"><%=f[2]%></p>
</div>
<% }) %>

</div>

<!-- FLASH DEAL -->
<div class="flex flex-wrap items-center gap-4 mt-16 border-l-4 border-pink-500 pl-4">
  <h4 class="text-3xl font-bold text-purple-700">⚡ Flash Deals</h4>

  <div class="flex bg-pink-100 px-6 py-2 rounded-full gap-6 shadow">
    <div class="text-center">
      <p class="font-bold text-pink-600" id="h">23</p>
      <span class="text-xs">HRS</span>
    </div>
    <div class="text-center">
      <p class="font-bold text-pink-600" id="m">45</p>
      <span class="text-xs">MIN</span>
    </div>
    <div class="text-center">
      <p class="font-bold text-pink-600" id="s">19</p>
      <span class="text-xs">SEC</span>
    </div>
  </div>
</div>

<!-- PRODUCTS -->
<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 mt-10">

<% products.forEach(function(product,index){ %>
<% if(product.category && product.category.status==='listed'){ %>

<div class="group bg-white rounded-3xl shadow-lg hover:shadow-2xl transition overflow-hidden">

  <div class="relative h-48 overflow-hidden">
    <% if(index%3===0){ %>
    <span class="absolute top-3 right-3 bg-pink-500 text-white text-xs px-4 py-1 rounded-full">-25%</span>
    <% } %>

    <img src="<%=product.imageUrl%>"
      class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
  </div>

  <div class="p-5">
    <h4 class="font-semibold line-clamp-2"><%=product.name%></h4>

    <div class="flex items-center justify-between mt-2">
      <p class="text-xl font-bold text-purple-700">
        $<%=product.price.toFixed(2)%>
      </p>
      <p class="text-xs text-gray-500"><%=product.brand%></p>
    </div>

    <a href="/product/<%=product._id%>"
      class="block mt-5 bg-gradient-to-r from-purple-600 to-pink-500 text-white text-center py-2 rounded-full hover:scale-105 transition">
      Buy Now
    </a>
  </div>
</div>

<% }}); %>
</div>

<!-- BROWSE -->
<div class="text-center my-14">
  <a href="/shop?category=all"
    class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 px-8 py-3 rounded-full shadow hover:bg-purple-200">
    Browse All Products <i class="fas fa-arrow-right"></i>
  </a>
</div>

<!-- CATEGORIES -->
<div class="text-center">
  <h3 class="text-3xl font-bold text-purple-700 mb-10">
    Shop by Categories
  </h3>

  <div class="flex flex-wrap justify-center gap-8">

<% categories.filter(c=>c.status==='listed').slice(0,5).forEach(c=>{ %>

<div class="group bg-white w-44 rounded-2xl shadow-lg hover:-translate-y-2 transition">

  <img src="/<%=c.imageUrl%>"
    class="w-full h-32 object-cover rounded-t-2xl group-hover:scale-105 transition" />

  <p class="font-semibold py-4"><%=c.name%></p>
</div>

<% }) %>

  </div>
</div>

</section>

<%- include('./partials/footer') %>

<script>
function updateCountdown(){
  const now=new Date()
  document.getElementById('h').innerText=23-now.getHours()
  document.getElementById('m').innerText=59-now.getMinutes()
  document.getElementById('s').innerText=59-now.getSeconds()
}
setInterval(updateCountdown,1000)
</script>

</body>
</html>
