<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="userCSS/product-page.css" />
    <title><%= product.name %> - Product Details</title>
    <style>
      body{
        color:white;
      }
      .zoom {
        transition: transform 0.2s; /* Animation */
      }

      .zoom:hover {
        transform: scale(1.5);
      }
      /* Ensure footer spans the entire width */
      footer {
        width: 100%;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial') %>

    <div class="container mt-5">
      <!-- Breadcrumbs -->
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-item">
            <a href="/category/<%= product.category %>"
              ><%= product.category.name %></a
            >
          </li>
          <li class="breadcrumb-item active" aria-current="page">
            <%= product.name %>
          </li>
        </ol>
      </nav>

      <!-- Product Details -->
      <div class="row">
        <!-- Adjust column width to make it more responsive -->
        <div class="col-md-6 col-lg-5">
          <div class="product-image">
            <img
              src="<%= product.imageUrls[0] %>"
              alt="Product Image"
              class="img-fluid rounded zoom"
              onerror="this.src='https://via.placeholder.com/300x200'"
            />
            <!-- Fallback image -->
          </div>
        </div>
        <div class="col-md-6 col-lg-7">
          <h1><%= product.name %></h1>

          <!-- Rating -->
          <div>
            <strong>Ratings:</strong>
            <span>
              <%= product.rating %>
              <i class="fa fa-star" style="color: gold"></i>
            </span>
          </div>

          <!-- Price and Discounts -->
          <div>
            <strong>Price:</strong>
            <span class="text-success"><%= product.price %> </span>
            <% if (product.discount) { %>
            <span class="text-danger"
              ><del><%= product.originalPrice %></del> Save <%= product.discount
              %>%</span
            >
            <% } %>
          </div>

          <!-- Stock Availability -->
          <div>
            <strong>Stock Status:</strong>
            <% if (product.stock > 0) { %>
            <span class="text-success"
              >In Stock: <%= product.stock %> units</span
            >
            <% } else { %>
            <span class="text-danger">Sold Out</span>
            <% } %>
          </div>

          <!-- Highlights/Specs -->

          <!-- Reviews -->
          <div>
            <h4>Customer Reviews:</h4>
            <ul>
              <li>
                <strong>John Doe</strong>: Great phone, excellent display and
                battery life! <br />
                <span
                  >Rating: 5 <i class="fa fa-star" style="color: gold"></i
                ></span>
              </li>
              <li>
                <strong>Jane Smith</strong>: The camera is amazing! Very
                satisfied. <br />
                <span
                  >Rating: 4 <i class="fa fa-star" style="color: gold"></i
                ></span>
              </li>
            </ul>
          </div>

          <!-- Add to Cart -->
          <div class="mt-3">
            <button class="btn btn-success">Add to Cart</button>
          </div>
        </div>
      </div>

      <!-- Related Products -->
      <div class="mt-5">
  <h3>Related Products</h3>

  <div class="row">
    <% relatedProducts.forEach(relatedProduct => { %>
      <div class="col-md-3">
        <div class="card text-center bg-dark text-white">
          <img
            src="<%= relatedProduct.imageUrl || 'https://via.placeholder.com/300x200' %>"
            class="card-img-top"
            alt="<%= relatedProduct.name %>"
          />
          <div class="card-body">
            <h5 class="card-title"><%= relatedProduct.name %></h5>
            <p class="card-text">$<%= relatedProduct.price.toFixed(2) %></p>
            <a href="/product/<%= relatedProduct._id %>" class="btn btn-primary">View Details</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

    </div>

    <%- include('./partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
