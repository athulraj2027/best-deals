<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> - Product Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    h1 { font-family: 'DM Serif Display', serif; }
    body { background: #f8f7f5; }

    .product-img-wrap {
      position: relative; overflow: hidden; border-radius: 16px; background: #fff;
      height: 340px; display: flex; align-items: center; justify-content: center;
    }
    .product-img-wrap img { transition: transform 0.4s ease; cursor: zoom-in; max-height: 320px; max-width: 100%; object-fit: contain; }
    .product-img-wrap:hover img { transform: scale(1.06); }

    .thumb-img { border: 2px solid transparent; border-radius: 10px; cursor: pointer; transition: all 0.2s; opacity: 0.65; height: 64px; width: 64px; object-fit: cover; }
    .thumb-img.active, .thumb-img:hover { border-color: #1d4ed8; opacity: 1; }

    .color-swatch { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 3px solid transparent; outline: 2px solid transparent; transition: all 0.2s; box-shadow: 0 1px 4px rgba(0,0,0,0.15); display: inline-block; }
    .color-swatch.active { outline: 2px solid #1d4ed8; outline-offset: 3px; transform: scale(1.15); }

    .size-btn { padding: 8px 18px; border-radius: 8px; border: 1.5px solid #d1d5db; cursor: pointer; font-weight: 500; font-size: 0.9rem; transition: all 0.2s; background: #fff; color: #374151; min-width: 54px; text-align: center; display: inline-block; }
    .size-btn.active { background: #1d4ed8; color: #fff; border-color: #1d4ed8; }
    .size-btn:hover:not(.active) { background: #eff6ff; border-color: #1d4ed8; }

    .qty-btn { width: 38px; height: 38px; border-radius: 8px; background: #1d4ed8; color: white; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
    .qty-btn:hover { background: #1e40af; }
    #qty-value { width: 52px; text-align: center; font-weight: 700; font-size: 1.1rem; border: none; background: transparent; }

    .btn-cart { background: #1d4ed8; color: white; border: none; border-radius: 10px; font-weight: 600; font-size: 0.95rem; padding: 13px 28px; transition: all 0.2s; cursor: pointer; display: flex; align-items: center; gap: 8px; justify-content: center; flex: 1; }
    .btn-cart:hover { background: #1e40af; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(29,78,216,0.3); }
    .btn-cart:disabled { background: #93c5fd; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-wish { background: #fff; color: #1d4ed8; border: 1.5px solid #1d4ed8; border-radius: 10px; font-weight: 600; font-size: 0.95rem; padding: 13px 28px; transition: all 0.2s; cursor: pointer; display: flex; align-items: center; gap: 8px; justify-content: center; flex: 1; }
    .btn-wish:hover { background: #eff6ff; transform: translateY(-1px); }
    .btn-wish:disabled { color: #93c5fd; border-color: #93c5fd; cursor: not-allowed; transform: none; }

    .badge-offer { background: #dc2626; color: white; border-radius: 20px; padding: 3px 10px; font-size: 0.75rem; font-weight: 700; }
    .badge-cat { background: #dbeafe; color: #1d4ed8; border-radius: 6px; padding: 3px 10px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

    .info-card { background: white; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); padding: 28px; }
    .section-title { font-size: 1rem; font-weight: 700; color: #1d4ed8; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .divider { height: 1px; background: #f3f4f6; margin: 20px 0; }

    .spec-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f3f4f6; font-size: 0.92rem; }
    .spec-row:last-child { border-bottom: none; }
    .spec-label { color: #6b7280; display: flex; align-items: center; gap: 8px; }
    .spec-value { font-weight: 600; color: #111827; }

    .ship-item { display: flex; align-items: center; gap: 10px; padding: 9px 0; border-bottom: 1px solid #f3f4f6; font-size: 0.9rem; color: #374151; }
    .ship-item:last-child { border-bottom: none; }
    .ship-item i { color: #1d4ed8; width: 16px; }

    .stock-in { color: #16a34a; font-weight: 600; font-size: 0.9rem; }
    .stock-out { color: #dc2626; font-weight: 600; font-size: 0.9rem; }

    .breadcrumb a { color: #1d4ed8; text-decoration: none; font-size: 0.85rem; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb .sep { color: #9ca3af; margin: 0 6px; font-size: 0.85rem; }
    .breadcrumb .current { color: #374151; font-size: 0.85rem; }
  </style>
</head>
<body>
  <%- include('./partials/headerPartial') %>

  <div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Breadcrumb -->
    <nav class="breadcrumb flex items-center flex-wrap mb-8">
      <a href="/"><i class="fas fa-home mr-1"></i>Home</a>
      <span class="sep">/</span>
      <a href="/shop?category=<%= product.category.name %>"><%= product.category.name %></a>
      <span class="sep">/</span>
      <span class="current"><%= product.name %></span>
    </nav>

    <!-- Main Product Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 mb-8">

      <!-- Images (2/5) -->
      <div class="lg:col-span-2">
        <div class="info-card p-4">
          <div class="product-img-wrap mb-4">
            <img
              id="main-product-image"
              src="<%= product.variants?.[0]?.images?.[0]?.url ?? 'https://via.placeholder.com/400x400?text=No+Image' %>"
              alt="<%= product.name %>"
            />
          </div>
          <div id="image-thumbnails" class="flex gap-2 flex-wrap py-1">
            <% if (product.variants?.[0]?.images?.length) { %>
              <% product.variants[0].images.sort((a,b)=>a.order-b.order).forEach((img,i) => { %>
                <img src="<%= img.url %>" alt="thumb <%= i+1 %>"
                  class="thumb-img <%= i===0?'active':'' %>"
                  data-url="<%= img.url %>"
                  onclick="changeMainImage(this)">
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Info (3/5) -->
      <div class="lg:col-span-3">
        <div class="info-card">
          <div class="flex items-center gap-2 mb-3">
            <span class="badge-cat"><%= product.category.name %></span>
          </div>
          <h1 class="text-3xl mb-1"><%= product.name %></h1>
          <p class="text-gray-500 text-sm mb-4">
            <i class="fas fa-industry mr-1"></i>Brand: <strong class="text-gray-700"><%= product.brand %></strong>
          </p>

          <!-- Price -->
          <div class="flex items-center gap-3 mb-1">
            <span id="display-price" class="text-3xl font-bold text-green-600"></span>
            <span id="original-price" class="text-lg text-gray-400 line-through" style="display:none;"></span>
            <span id="discount-badge" class="badge-offer" style="display:none;"></span>
          </div>
          <% if (product.best_offer) { %>
            <p class="text-xs text-gray-400 mb-4">
              <i class="fas fa-tag mr-1"></i><%= product.best_offer.name %> &middot;
              Valid until <%= new Date(product.best_offer.valid_until).toDateString() %>
            </p>
          <% } %>

          <div class="divider"></div>

          <!-- Color -->
          <div class="mb-5">
            <div class="section-title"><i class="fas fa-palette"></i> Color</div>
            <div id="color-options" class="flex flex-wrap gap-3">
              <%
                const uniqueColors = product.variants ? [...new Set(product.variants.map(v => v.color))] : [];
              %>
              <% uniqueColors.forEach((color, ci) => { %>
                <div class="color-swatch <%= ci===0?'active':'' %>"
                  style="background-color:<%= color %>;"
                  data-color="<%= color %>"
                  onclick="selectColor(this)"
                  title="<%= color %>"></div>
              <% }) %>
            </div>
          </div>

          <!-- Size -->
          <div class="mb-5">
            <div class="section-title"><i class="fas fa-ruler"></i> Size</div>
            <div id="size-options" class="flex flex-wrap gap-2">
              <%
                const fc = product.variants?.[0]?.color;
                const fs = product.variants ? product.variants.filter(v=>v.color===fc).map(v=>v.size) : [];
              %>
              <% fs.forEach((size, si) => { %>
                <div class="size-btn <%= si===0?'active':'' %>" data-size="<%= size %>" onclick="selectSize(this)"><%= size %></div>
              <% }) %>
            </div>
          </div>

          <!-- Quantity -->
          <div class="mb-6">
            <div class="section-title"><i class="fas fa-cubes"></i> Quantity</div>
            <div class="flex items-center gap-4">
              <div class="flex items-center gap-2" style="background:#f9fafb; border:1.5px solid #e5e7eb; border-radius:10px; padding:4px 8px;">
                <button class="qty-btn" onclick="decrementQuantity()"><i class="fas fa-minus" style="font-size:0.7rem;"></i></button>
                <input type="number" id="qty-value" value="1" min="1" max="5" readonly>
                <button class="qty-btn" onclick="incrementQuantity()"><i class="fas fa-plus" style="font-size:0.7rem;"></i></button>
              </div>
              <span id="stock-info"></span>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button id="add-to-cart-btn" class="btn-cart" onclick="addToCart()">
              <i class="fas fa-shopping-cart"></i> Add to Cart
            </button>
            <button id="wishlist-btn" class="btn-wish" onclick="addToWishlist()">
              <i class="fas fa-heart"></i> Wishlist
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="info-card">
        <div class="section-title"><i class="fas fa-clipboard-list"></i> Specifications</div>
        <div class="spec-row"><span class="spec-label"><i class="fas fa-industry"></i> Brand</span><span class="spec-value"><%= product.brand %></span></div>
        <div class="spec-row"><span class="spec-label"><i class="fas fa-tags"></i> Category</span><span class="spec-value"><%= product.category.name %></span></div>
        <div class="spec-row"><span class="spec-label"><i class="fas fa-palette"></i> Colors</span><span class="spec-value"><%= product.variants ? [...new Set(product.variants.map(v=>v.color))].join(', ') : 'N/A' %></span></div>
        <div class="spec-row"><span class="spec-label"><i class="fas fa-ruler"></i> Sizes</span><span class="spec-value"><%= product.variants ? [...new Set(product.variants.map(v=>v.size))].join(', ') : 'N/A' %></span></div>
      </div>
      <div class="info-card">
        <div class="section-title"><i class="fas fa-truck"></i> Shipping Information</div>
        <div class="ship-item"><i class="fas fa-box"></i> Free shipping on orders over ₹999</div>
        <div class="ship-item"><i class="fas fa-calendar-alt"></i> Estimated delivery: 3–5 business days</div>
        <div class="ship-item"><i class="fas fa-undo-alt"></i> Easy 30-day returns</div>
        <div class="ship-item"><i class="fas fa-globe-americas"></i> International shipping available</div>
      </div>
    </div>
  </div>

  <%- include('./partials/footer') %>

  <script>
    const product = <%- JSON.stringify(product) %>;
    const bestOffer = product.best_offer || null;

    let selectedVariant = null;
    let selectedColor = null;
    let selectedSize = null;
    let currentQuantity = 1;

    function findVariant(color, size) {
      return product.variants?.find(v => v.color === color && v.size === size) || null;
    }

    /**
     * Pricing logic:
     * - Each variant has its own `discountedPrice` computed by the backend.
     * - If a best_offer exists AND the variant has a discountedPrice, use it.
     * - Otherwise show the variant's base price with no strikethrough.
     */
    function getPricing(variant) {
      if (!variant) return { display: 0, original: null, badge: null };
      const original = variant.price;
      if (bestOffer && variant.discountedPrice != null) {
        const discounted = Number(variant.discountedPrice);
        const badge = bestOffer.discount_type === 'percentage'
          ? bestOffer.discount_value + '% OFF'
          : 'Save ₹' + (original - discounted).toFixed(2);
        return { display: discounted, original, badge };
      }
      return { display: original, original: null, badge: null };
    }

    function updatePriceUI() {
      const p = getPricing(selectedVariant);
      document.getElementById('display-price').textContent = '₹ ' + p.display.toFixed(2);
      const orig = document.getElementById('original-price');
      const badge = document.getElementById('discount-badge');
      if (p.original) {
        orig.textContent = '₹ ' + p.original.toFixed(2);
        orig.style.display = '';
        badge.textContent = p.badge;
        badge.style.display = '';
      } else {
        orig.style.display = 'none';
        badge.style.display = 'none';
      }
    }

    function updateStockUI() {
      const stockEl = document.getElementById('stock-info');
      const cartBtn = document.getElementById('add-to-cart-btn');
      const wishBtn = document.getElementById('wishlist-btn');
      const qtyInput = document.getElementById('qty-value');

      if (!selectedVariant || selectedVariant.quantity <= 0) {
        stockEl.innerHTML = '<span class="stock-out"><i class="fas fa-times-circle mr-1"></i>Out of stock</span>';
        cartBtn.disabled = true;
        wishBtn.disabled = true;
      } else {
        const qty = selectedVariant.quantity;
        stockEl.innerHTML = `<span class="stock-in"><i class="fas fa-check-circle mr-1"></i>${qty} in stock</span>`;
        cartBtn.disabled = false;
        wishBtn.disabled = false;
        const maxQty = Math.min(qty, 5);
        qtyInput.max = maxQty;
        if (currentQuantity > maxQty) {
          currentQuantity = maxQty;
          qtyInput.value = currentQuantity;
        }
      }
    }

    function updateImagesUI() {
      const mainImg = document.getElementById('main-product-image');
      const thumbWrap = document.getElementById('image-thumbnails');
      if (!selectedVariant?.images?.length) {
        mainImg.src = 'https://via.placeholder.com/400x400?text=No+Image';
        thumbWrap.innerHTML = '';
        return;
      }
      const sorted = [...selectedVariant.images].sort((a, b) => a.order - b.order);
      mainImg.src = sorted[0].url;
      thumbWrap.innerHTML = '';
      sorted.forEach((img, i) => {
        const el = document.createElement('img');
        el.src = img.url;
        el.alt = 'thumb ' + (i + 1);
        el.className = 'thumb-img' + (i === 0 ? ' active' : '');
        el.dataset.url = img.url;
        el.onclick = function () { changeMainImage(this); };
        thumbWrap.appendChild(el);
      });
    }

    function updateVariantUI() {
      updatePriceUI();
      updateStockUI();
      updateImagesUI();
    }

    function changeMainImage(thumb) {
      document.querySelectorAll('#image-thumbnails .thumb-img').forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
      document.getElementById('main-product-image').src = thumb.dataset.url;
    }

    function selectColor(el) {
      document.querySelectorAll('#color-options .color-swatch').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      selectedColor = el.dataset.color;

      const sizes = product.variants.filter(v => v.color === selectedColor).map(v => v.size);
      const sizeWrap = document.getElementById('size-options');
      sizeWrap.innerHTML = '';
      sizes.forEach((size, i) => {
        const btn = document.createElement('div');
        btn.className = 'size-btn' + (i === 0 ? ' active' : '');
        btn.dataset.size = size;
        btn.textContent = size;
        btn.onclick = function () { selectSize(this); };
        sizeWrap.appendChild(btn);
      });

      selectedSize = sizes[0] || null;
      selectedVariant = findVariant(selectedColor, selectedSize);
      updateVariantUI();
    }

    function selectSize(el) {
      document.querySelectorAll('#size-options .size-btn').forEach(b => b.classList.remove('active'));
      el.classList.add('active');
      selectedSize = el.dataset.size;
      selectedVariant = findVariant(selectedColor, selectedSize);
      updateVariantUI();
    }

    function incrementQuantity() {
      const input = document.getElementById('qty-value');
      const max = parseInt(input.max) || 5;
      if (currentQuantity < max) { currentQuantity++; input.value = currentQuantity; }
    }

    function decrementQuantity() {
      if (currentQuantity > 1) { currentQuantity--; document.getElementById('qty-value').value = currentQuantity; }
    }

    function addToCart() {
      if (!selectedVariant || selectedVariant.quantity < currentQuantity) {
        return Swal.fire({ icon: 'error', title: 'Oops!', text: 'Product unavailable or insufficient stock.' });
      }
      fetch(`/product/cart/add/${selectedVariant._id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productId: product._id, variantId: selectedVariant._id,
          name: product.name, color: selectedColor, size: selectedSize,
          price: selectedVariant.price, quantity: currentQuantity,
          image: selectedVariant.images?.[0]?.url || 'https://via.placeholder.com/100'
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.status === 'success') {
          Swal.fire({
            icon: 'success', title: 'Added to Cart!',
            text: `${currentQuantity} × ${product.name} (${selectedColor}, ${selectedSize})`,
            confirmButtonText: 'View Cart', showCancelButton: true, cancelButtonText: 'Continue Shopping'
          }).then(r => { if (r.isConfirmed) location.href = '/cart'; });
          const cc = document.getElementById('cart-count');
          if (cc && data.cartCount !== undefined) cc.textContent = data.cartCount;
        } else {
           if(data.title === 'Not Logged in'){
          location.href ='/signin'
        }
          Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Could not add to cart.' });
        }
      })
      .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Network error. Please try again.' }));
    }

    function addToWishlist() {
      if (!selectedVariant) return Swal.fire({ icon: 'error', title: 'Oops!', text: 'Please select a variant.' });
      fetch(`/product/wishlist/add/${selectedVariant._id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          productId: product._id, variantId: selectedVariant._id,
          name: product.name, color: selectedColor, size: selectedSize,
          price: selectedVariant.price,
          image: selectedVariant.images?.[0]?.url || 'https://via.placeholder.com/100'
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.status === 'success') {
          Swal.fire({
            icon: 'success', title: 'Added to Wishlist!',
            text: `${product.name} (${selectedColor}, ${selectedSize})`,
            confirmButtonText: 'View Wishlist', showCancelButton: true, cancelButtonText: 'Continue Shopping'
          }).then(r => { if (r.isConfirmed) location.href = '/wishlist'; });
        } else {
          Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Could not add to wishlist.' });
        }
      })
      .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Network error. Please try again.' }));
    }

    document.addEventListener('DOMContentLoaded', () => {
      if (product.variants?.length) {
        selectedVariant = product.variants[0];
        selectedColor = selectedVariant.color;
        selectedSize = selectedVariant.size;
        updateVariantUI();
      }
    });
  </script>
</body>
</html>
