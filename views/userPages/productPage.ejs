<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> - Product Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/drift-zoom/1.5.0/Drift.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/drift-zoom/1.5.0/drift-basic.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-white text-gray-800">
  <%- include('./partials/headerPartial') %>

  <div class="container mx-auto px-4 py-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6">
      <ol class="flex flex-wrap items-center text-sm">
        <li class="flex items-center">
          <a href="/" class="text-blue-700 hover:text-blue-800">
            <i class="fas fa-home mr-1"></i> Home
          </a>
          <span class="mx-2">/</span>
        </li>
        <li class="flex items-center">
          <a href="/category/<%= product.category %>" class="text-blue-700 hover:text-blue-800">
            <%= product.category.name %>
          </a>
          <span class="mx-2">/</span>
        </li>
        <li class="text-gray-600"><%= product.name %></li>
      </ol>
    </nav>

    <!-- Product Details -->
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Product Images -->
      <div class="w-full lg:w-5/12">
        <div class="bg-white rounded-lg shadow-md border border-gray-200 p-4">
          <div class="bg-gray-100 h-96 rounded-lg flex items-center justify-center mb-4 overflow-hidden">
            <img
              id="main-product-image"
              src="<%= product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0 ? product.variants[0].images[0].url : 'https://via.placeholder.com/400x400?text=No+Image' %>"
              alt="<%= product.name %>"
              class="max-h-80 max-w-full object-contain transition-transform duration-300 cursor-zoom-in hover:scale-105"
              data-zoom="<%= product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0 ? product.variants[0].images[0].url : 'https://via.placeholder.com/800x800?text=No+Image' %>"
            />
          </div>
          
          <div id="image-thumbnails" class="flex overflow-x-auto space-x-2 py-2">
            <% if (product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0) { %>
              <% product.variants[0].images.sort((a, b) => a.order - b.order).forEach((image, index) => { %>
                <img 
                  src="<%= image.url %>" 
                  alt="Product thumbnail <%= index + 1 %>" 
                  class="h-16 w-16 object-cover rounded cursor-pointer <%= index === 0 ? 'border-2 border-blue-700 opacity-100' : 'border border-gray-300 opacity-70' %> hover:opacity-100 transition-all" 
                  data-image-url="<%= image.url %>"
                  data-zoom-url="<%= image.url %>"
                  onclick="changeMainImage(this)"
                >
              <% }) %>
            <% } else { %>
              <img 
                src="https://via.placeholder.com/70x70?text=No+Image" 
                alt="No image available" 
                class="h-16 w-16 object-cover rounded border-2 border-blue-700"
              >
            <% } %>
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="w-full lg:w-7/12">
        <div class="bg-white rounded-lg shadow-md border border-gray-200 p-6">
          <span class="inline-block bg-blue-700 text-white px-3 py-1 rounded text-xs font-semibold uppercase tracking-wide mb-2"><%= product.category.name %></span>
          <h1 class="text-2xl font-bold mb-2"><%= product.name %></h1>
          <p class="text-gray-600 mb-4"><i class="fas fa-industry mr-2"></i>Brand: <span class="font-semibold"><%= product.brand %></span></p>

          <!-- Price display -->
          <div class="flex items-center mb-6">
            <span id="variant-price" class="text-2xl font-bold text-green-600 mr-2">
              $<%= product.variants && product.variants.length > 0 && product.variants[0].price ? product.variants[0].price.toFixed(2) : (product.actualPrice ? product.actualPrice.toFixed(2) : '0.00') %>
            </span>
            <% if (product.variants && product.variants.length > 0 && product.variants[0].price && product.actualPrice && product.variants[0].price < product.actualPrice) { %>
              <span class="text-lg text-gray-500 line-through mr-2">$<%= product.actualPrice.toFixed(2) %></span>
              <span class="bg-red-600 text-white px-2 py-1 rounded-full text-xs font-semibold">
                <%= Math.round((1 - product.variants[0].price / product.actualPrice) * 100) %>% OFF
              </span>
            <% } %>
          </div>

          <!-- Color Selection -->
          <div class="mb-6">
            <h5 class="text-lg font-medium mb-3 border-b border-gray-200 pb-2 text-blue-700"><i class="fas fa-palette mr-2"></i>Color</h5>
            <div id="color-options" class="flex flex-wrap gap-2">
              <% 
                const uniqueColors = product.variants && product.variants.length > 0 ? 
                  [...new Set(product.variants.map(variant => variant.color))] : [];
              %>
              <% uniqueColors.forEach(color => { %>
                <div 
                  class="h-8 w-8 rounded-full cursor-pointer <%= product.variants && product.variants.length > 0 && color === product.variants[0].color ? 'ring-2 ring-blue-700 ring-offset-2 scale-110' : '' %>" 
                  style="background-color: <%= color %>;" 
                  data-color="<%= color %>"
                  onclick="selectColor(this)"
                  title="<%= color %>"
                ></div>
              <% }) %>
            </div>
          </div>

          <!-- Size Selection -->
          <div class="mb-6">
            <h5 class="text-lg font-medium mb-3 border-b border-gray-200 pb-2 text-blue-700"><i class="fas fa-ruler mr-2"></i>Size</h5>
            <div id="size-options" class="flex flex-wrap gap-2">
              <% 
                let sizesForFirstColor = [];
                if (product.variants && product.variants.length > 0 && product.variants[0].color) {
                  const firstColor = product.variants[0].color;
                  sizesForFirstColor = product.variants
                    .filter(v => v.color === firstColor)
                    .map(v => v.size);
                }
              %>
              <% sizesForFirstColor.forEach(size => { %>
                <div 
                  class="px-4 py-2 border rounded cursor-pointer text-center min-w-[50px] <%= product.variants && product.variants.length > 0 && size === product.variants[0].size ? 'bg-blue-700 text-white' : 'bg-white text-gray-800 border-gray-300 hover:bg-gray-100' %>" 
                  data-size="<%= size %>"
                  onclick="selectSize(this)"
                >
                  <%= size %>
                </div>
              <% }) %>
            </div>
          </div>

          <!-- Quantity Selector -->
          <div class="mb-6">
            <h5 class="text-lg font-medium mb-3 border-b border-gray-200 pb-2 text-blue-700"><i class="fas fa-cubes mr-2"></i>Quantity</h5>
            <div class="flex items-center">
              <div class="flex items-center bg-gray-100 rounded-lg mr-4">
                <button onclick="decrementQuantity()" class="h-10 w-10 flex items-center justify-center bg-blue-700 text-white rounded-l-lg">
                  <i class="fas fa-minus"></i>
                </button>
                <input type="number" id="quantity" value="1" min="1" max="5" readonly class="h-10 w-16 text-center bg-transparent border-none font-bold">
                <button onclick="incrementQuantity()" class="h-10 w-10 flex items-center justify-center bg-blue-700 text-white rounded-r-lg">
                  <i class="fas fa-plus"></i>
                </button>
              </div>
              <span id="stock-info">
                <% if (product.variants && product.variants.length > 0 && product.variants[0].quantity > 0) { %>
                  <span class="text-green-600 flex items-center"><i class="fas fa-check-circle mr-1"></i> <%= product.variants[0].quantity %> in stock</span>
                <% } else { %>
                  <span class="text-red-600 flex items-center"><i class="fas fa-times-circle mr-1"></i> Out of stock</span>
                <% } %>
              </span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <button 
              id="add-to-cart-btn" 
              class="py-3 px-6 bg-blue-700 text-white rounded-lg font-semibold flex items-center justify-center sm:w-40 hover:bg-blue-800 transition-colors"
              <%= !product.variants || !product.variants.length || !product.variants[0] || product.variants[0].quantity <= 0 ? 'disabled' : '' %>
              onclick="addToCart()"
            >
              <i class="fas fa-shopping-cart mr-2"></i> Add to Cart
            </button>
            <button 
              id="wishlist-btn" 
              class="py-3 px-6 bg-blue-700 text-white rounded-lg font-semibold flex items-center justify-center sm:w-40 hover:bg-blue-800 transition-colors"
              <%= !product.variants || !product.variants.length || !product.variants[0] || product.variants[0].quantity <= 0 ? 'disabled' : '' %>
              onclick="addToWishlist()"
            >
              <i class="fas fa-heart mr-2"></i> Wishlist
            </button>
          </div>           
        </div>
      </div>
    </div>

    <!-- Product Details Section -->
    <div class="mt-10 bg-white rounded-lg shadow-md border border-gray-200 p-6">
      <h3 class="text-xl font-bold mb-6 text-blue-700 pb-2 border-b border-gray-200">Product Details</h3>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h5 class="text-lg font-medium mb-3 flex items-center"><i class="fas fa-clipboard-list mr-2 text-blue-700"></i>Specifications</h5>
          <ul class="space-y-2 divide-y divide-gray-200">
            <li class="py-2 flex justify-between items-center"><span><i class="fas fa-industry mr-2 text-blue-700"></i>Brand:</span> <span class="font-semibold"><%= product.brand %></span></li>
            <li class="py-2 flex justify-between items-center"><span><i class="fas fa-tags mr-2 text-blue-700"></i>Category:</span> <span class="font-semibold"><%= product.category.name %></span></li>
            <li class="py-2 flex justify-between items-center"><span><i class="fas fa-palette mr-2 text-blue-700"></i>Available Colors:</span> <span class="font-semibold"><%= product.variants && product.variants.length > 0 ? [...new Set(product.variants.map(v => v.color))].join(', ') : 'None' %></span></li>
            <li class="py-2 flex justify-between items-center"><span><i class="fas fa-ruler mr-2 text-blue-700"></i>Available Sizes:</span> <span class="font-semibold"><%= product.variants && product.variants.length > 0 ? [...new Set(product.variants.map(v => v.size))].join(', ') : 'None' %></span></li>
          </ul>
        </div>
        <div>
          <h5 class="text-lg font-medium mb-3 flex items-center"><i class="fas fa-truck mr-2 text-blue-700"></i>Shipping Information</h5>
          <ul class="space-y-2 divide-y divide-gray-200">
            <li class="py-2"><i class="fas fa-box mr-2 text-blue-700"></i>Free shipping on orders over $50</li>
            <li class="py-2"><i class="fas fa-calendar-alt mr-2 text-blue-700"></i>Estimated delivery: 3-5 business days</li>
            <li class="py-2"><i class="fas fa-undo-alt mr-2 text-blue-700"></i>Easy 30-day returns</li>
            <li class="py-2"><i class="fas fa-globe-americas mr-2 text-blue-700"></i>International shipping available</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%- include('./partials/footer') %>

  <script>
    // Store the product data in a JavaScript variable
    const product = <%- JSON.stringify(product) %>;
    let selectedVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
    let selectedColor = selectedVariant?.color;
    let selectedSize = selectedVariant?.size;
    let currentQuantity = 1;
    let driftInstance = null;

    // Function to find the variant based on color and size
    function findVariant(color, size) {
      if (!product.variants || !Array.isArray(product.variants)) {
        return null;
      }
      return product.variants.find(v => v.color === color && v.size === size) || null;
    }

    // Initialize zoom functionality
    function initializeZoom() {
      if (driftInstance) {
        try {
          driftInstance.destroy();
        } catch (error) {
          console.error("Error destroying Drift instance:", error);
        }
      }
      
      const mainImage = document.getElementById('main-product-image');
      if (!mainImage) return;
      
      const container = document.querySelector('.product-image-container');
      if (!container) return;
      
      if (mainImage && mainImage.src && !mainImage.src.includes('placeholder')) {
        try {
          const isMobile = window.innerWidth < 768;
          
          driftInstance = new Drift(mainImage, {
            paneContainer: container,
            inlinePane: isMobile,
            inlineOffsetY: isMobile ? -150 : 0,
            containInline: true,
            hoverBoundingBox: false,
            zoomFactor: 2.5,
            sourceAttribute: 'src',
            touchDelay: 100
          });
        } catch (error) {
          console.error("Error initializing Drift:", error);
        }
      }
    }

    // Function to update the UI based on the selected variant
    function updateVariantUI() {
      const priceElement = document.getElementById('variant-price');
      const stockInfoElement = document.getElementById('stock-info');
      const addToCartButton = document.getElementById('add-to-cart-btn');
      const wishlistButton = document.getElementById('wishlist-btn');
      
      if (!priceElement || !stockInfoElement || !addToCartButton) return;
      
      if (!selectedVariant) {
        priceElement.textContent = '$' + (product.actualPrice ? product.actualPrice.toFixed(2) : '0.00');
        stockInfoElement.innerHTML = '<span class="text-red-600 flex items-center"><i class="fas fa-times-circle mr-1"></i> Unavailable</span>';
        addToCartButton.disabled = true;
        wishlistButton.disabled = true;
        return;
      }

      // Update price
      priceElement.textContent = '$' + (selectedVariant.price ? selectedVariant.price.toFixed(2) : '0.00');
      
      // Update stock info
      if (selectedVariant.quantity > 0) {
        stockInfoElement.innerHTML = 
          `<span class="text-green-600 flex items-center"><i class="fas fa-check-circle mr-1"></i> ${selectedVariant.quantity} in stock</span>`;
        addToCartButton.disabled = false;
        wishlistButton.disabled = false;
      } else {
        stockInfoElement.innerHTML = 
          `<span class="text-red-600 flex items-center"><i class="fas fa-times-circle mr-1"></i> Out of stock</span>`;
        addToCartButton.disabled = true;
        wishlistButton.disabled = true;
      }

      // Update quantity input max
      const quantityInput = document.getElementById('quantity');
      if (quantityInput) {
        quantityInput.max = selectedVariant.quantity || 0;
        if (currentQuantity > selectedVariant.quantity) {
          currentQuantity = Math.max(1, selectedVariant.quantity || 0);
          quantityInput.value = currentQuantity;
        }
      }

      // Update images
      updateVariantImages();
    }

    // Function to change the main image when clicking on a thumbnail
    function changeMainImage(thumbnailElement) {
      if (!thumbnailElement) return;
      
      // Update main image
      const mainImage = document.getElementById('main-product-image');
      if (!mainImage) return;
      
      if (thumbnailElement.dataset.imageUrl) {
        mainImage.src = thumbnailElement.dataset.imageUrl;
        
        if (thumbnailElement.dataset.zoomUrl) {
          mainImage.setAttribute('data-zoom', thumbnailElement.dataset.zoomUrl);
        }
      }
      
      // Update active state on thumbnails
      const thumbnails = document.querySelectorAll('.thumbnail');
      thumbnails.forEach(thumb => {
        thumb.classList.remove('border-blue-700', 'border-2', 'opacity-100');
        thumb.classList.add('border-gray-300', 'border', 'opacity-70');
      });
      
      thumbnailElement.classList.remove('border-gray-300', 'border', 'opacity-70');
      thumbnailElement.classList.add('border-blue-700', 'border-2', 'opacity-100');
      
      // Reinitialize zoom for the new image
      initializeZoom();
    }

    function updateVariantImages() {
      const thumbnailContainer = document.getElementById('image-thumbnails');
      const mainImage = document.getElementById('main-product-image');
      
      if (!thumbnailContainer || !mainImage) return;
      
      if (selectedVariant && selectedVariant.images && Array.isArray(selectedVariant.images) && selectedVariant.images.length > 0) {
        // Clear existing thumbnails
        thumbnailContainer.innerHTML = '';
        
        // Add new thumbnails sorted by order
        selectedVariant.images
          .sort((a, b) => a.order - b.order)
          .forEach((image, index) => {
            const thumbnail = document.createElement('img');
            thumbnail.src = image.url;
            thumbnail.alt = `Product thumbnail ${index + 1}`;
            thumbnail.classList.add('h-16', 'w-16', 'object-cover', 'rounded', 'cursor-pointer', 'hover:opacity-100', 'transition-all');
            
            if (index === 0) {
              thumbnail.classList.add('border-2', 'border-blue-700', 'opacity-100');
            } else {
              thumbnail.classList.add('border', 'border-gray-300', 'opacity-70');
            }
            
            thumbnail.dataset.imageUrl = image.url;
            thumbnail.dataset.zoomUrl = image.url;
            thumbnail.onclick = function() { changeMainImage(this); };
            thumbnailContainer.appendChild(thumbnail);
          });
        
        // Set the main image to the first image of the variant
        mainImage.src = selectedVariant.images[0].url;
        mainImage.setAttribute('data-zoom', selectedVariant.images[0].url);
      } else {
        // Use placeholder if no images
        thumbnailContainer.innerHTML = `
          <img 
            src="https://via.placeholder.com/70x70?text=No+Image" 
            alt="No image available" 
            class="h-16 w-16 object-cover rounded border-2 border-blue-700"
          >
        `;
        mainImage.src = 'https://via.placeholder.com/400x400?text=No+Image';
        mainImage.setAttribute('data-zoom', 'https://via.placeholder.com/800x800?text=No+Image');
      }
      
      // Reinitialize zoom
      initializeZoom();
    }

    // Function to handle color selection
    function selectColor(colorElement) {
      if (!colorElement) return;
      
      // Update UI for color selection
      const colorOptions = document.querySelectorAll('#color-options > div');
      colorOptions.forEach(option => {
        option.classList.remove('ring-2', 'ring-blue-700', 'ring-offset-2', 'scale-110');
      });
      
      colorElement.classList.add('ring-2', 'ring-blue-700', 'ring-offset-2', 'scale-110');
      
      // Update selected color
      selectedColor = colorElement.dataset.color;
      
      // Get available sizes for this color
      const availableSizes = product.variants
        .filter(v => v.color === selectedColor)
        .map(v => v.size);
      
      // Update size options
      const sizeOptionsContainer = document.getElementById('size-options');
      sizeOptionsContainer.innerHTML = '';
      
      availableSizes.forEach(size => {
        const sizeOption = document.createElement('div');
        sizeOption.className = 'px-4 py-2 border rounded cursor-pointer text-center min-w-[50px] bg-white text-gray-800 border-gray-300 hover:bg-gray-100';
        sizeOption.dataset.size = size;
        sizeOption.textContent = size;
        sizeOption.onclick = function() { selectSize(this); };
        sizeOptionsContainer.appendChild(sizeOption);
      });
      
      // Select the first size by default
      if (availableSizes.length > 0) {
        selectedSize = availableSizes[0];
        const firstSizeOption = sizeOptionsContainer.querySelector('div');
        if (firstSizeOption) {
          firstSizeOption.classList.remove('bg-white', 'text-gray-800', 'border-gray-300', 'hover:bg-gray-100');
          firstSizeOption.classList.add('bg-blue-700', 'text-white');
        }
      } else {
        selectedSize = null;
      }
      
      // Find and update selected variant
      selectedVariant = findVariant(selectedColor, selectedSize);
      updateVariantUI();
    }

    // Function to handle size selection
    function selectSize(sizeElement) {
      if (!sizeElement) return;
      
      // Update UI for size selection
      const sizeOptions = document.querySelectorAll('#size-options > div');
      sizeOptions.forEach(option => {
        option.classList.remove('bg-blue-700', 'text-white');
        option.classList.add('bg-white', 'text-gray-800', 'border-gray-300', 'hover:bg-gray-100');
      });
      
      sizeElement.classList.remove('bg-white', 'text-gray-800', 'border-gray-300', 'hover:bg-gray-100');
      sizeElement.classList.add('bg-blue-700', 'text-white');
      
      // Update selected size
      selectedSize = sizeElement.dataset.size;
      
      // Find and update selected variant
      selectedVariant = findVariant(selectedColor, selectedSize);
      updateVariantUI();
    }

    // Quantity increment function
    function incrementQuantity() {
      const quantityInput = document.getElementById('quantity');
      if (!quantityInput) return;
      
      if (currentQuantity < 5) {
        currentQuantity++;
        quantityInput.value = currentQuantity;
      }
    }

    // Quantity decrement function
    function decrementQuantity() {
      const quantityInput = document.getElementById('quantity');
      if (!quantityInput) return;
      
      if (currentQuantity > 1) {
        currentQuantity--;
        quantityInput.value = currentQuantity;
      }
    }

    // Add to cart function
    function addToCart() {
      if (!selectedVariant || selectedVariant.quantity < currentQuantity) {
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: 'This product is out of stock or the requested quantity exceeds available stock',
        });
        return;
      }
      
      // Prepare cart item
      const cartItem = {
        productId: product._id,
        variantId: selectedVariant._id,
        name: product.name,
        color: selectedColor,
        size: selectedSize,
        price: selectedVariant.price,
        quantity: currentQuantity,
        image: selectedVariant.images && selectedVariant.images.length > 0 ? 
          selectedVariant.images[0].url : 'https://via.placeholder.com/100x100?text=No+Image'
      };
      
      // Add to cart API call
      fetch(`/product/cart/add/${selectedVariant._id}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(cartItem)
      })
      .then(response => response.json())
      .then(data => {
        if (data.status==="success") {
          Swal.fire({
            icon: 'success',
            title: 'Added to Cart!',
            text: `${currentQuantity} x ${product.name} (${selectedColor}, ${selectedSize}) added to your cart`,
            showConfirmButton: true,
            confirmButtonText: 'View Cart',
            showCancelButton: true,
            cancelButtonText: 'Continue Shopping'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/cart';
            }
          });
          
          // Update cart count in the header
          updateCartCount(data.cartCount);
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: data.message || 'There was a problem adding the item to your cart'
          });
        }
      })
      .catch(error => {
        console.error('Error adding to cart:', error);
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: 'There was a problem connecting to the server. Please try again.'
        });
      });
    }

    function addToWishlist() {
      if (!selectedVariant || selectedVariant.quantity < currentQuantity) {
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: 'This product is out of stock or the requested quantity exceeds available stock',
        });
        return;
      }

      const wishListItem = {
        productId: product._id,
        variantId: selectedVariant._id,
        name: product.name,
        color: selectedColor,
        size: selectedSize,
        price: selectedVariant.price,
        image: selectedVariant.images && selectedVariant.images.length > 0 ? 
        selectedVariant.images[0].url : 'https://via.placeholder.com/100x100?text=No+Image'
      }
      
      fetch(`/product/wishlist/add/${selectedVariant._id}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(wishListItem)
      })
      .then(response => response.json())
      .then(data => {
        if (data.status==="success") {
          Swal.fire({
            icon: 'success',
            title: 'Added to Wishlist!',
            text: `${product.name} (${selectedColor}, ${selectedSize}) added to your wishlist`,
            showConfirmButton: true,
            confirmButtonText: 'View Wishlist',
            showCancelButton: true,
            cancelButtonText: 'Continue Shopping'
          }).then((result) => {
            if (result.isConfirmed) {
              window.location.href = '/wishlist';
            }
          });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: data.message || 'There was a problem adding the item to your wishlist'
          });
        }
      })
      .catch(error => {
        console.error('Error adding to wishlist:', error);
        Swal.fire({
          icon: 'error',
          title: 'Error',
          text: 'There was a problem connecting to the server. Please try again.'
        });
      });
    }

    function updateCartCount(count) {
      const cartCountElement = document.getElementById('cart-count');
      if (cartCountElement) {
        cartCountElement.textContent = count;
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      //
  initializeZoom();
  
  if (product.variants && product.variants.length > 0) {
    selectedVariant = product.variants[0];
    selectedColor = selectedVariant.color;
    selectedSize = selectedVariant.size;
    
    // Initialize UI
    updateVariantUI();
  }
});
</script>
  </body>
