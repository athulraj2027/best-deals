<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <style>
      :root {
        --primary-color: #6c5ce7;
        --secondary-color: #a29bfe;
        --accent-color: #00cec9;
        --dark-bg: #121212;
        --card-bg: #1e1e1e;
        --text-primary: #f5f5f5;
        --text-secondary: #b3b3b3;
      }

      body {
        background-color: var(--dark-bg);
        color: var(--text-primary);
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }

      .page-header {
        padding: 3rem 0;
        background: linear-gradient(135deg, #6c5ce7, #00cec9);
        margin-bottom: 2rem;
        border-radius: 0 0 30px 30px;
        box-shadow: 0 4px 20px rgba(108, 92, 231, 0.2);
      }

      .page-header h1 {
        font-weight: 700;
        letter-spacing: 1px;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
      }

      .filter-section {
        background-color: var(--card-bg);
        padding: 1.5rem;
        border-radius: 15px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        border-left: 4px solid var(--primary-color);
      }

      .filter-section h5 {
        color: var(--accent-color);
        margin-bottom: 1.5rem;
        font-weight: 600;
        border-bottom: 1px solid #333;
        padding-bottom: 10px;
      }

      .filter-section label {
        color: var(--text-secondary);
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.9rem;
      }

      .form-select,
      .form-control {
        background-color: #252525;
        border: 1px solid #444;
        color: var(--text-primary);
        border-radius: 8px;
        transition: all 0.3s ease;
      }

      .form-select:focus,
      .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 2px rgba(108, 92, 231, 0.25);
        background-color: #2a2a2a;
      }

      .price-range {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .price-divider {
        color: var(--text-secondary);
      }

      .card {
        width: 100%;
        background-color: var(--card-bg);
        color: var(--text-primary);
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
      }

      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
      }

      .card-img-wrapper {
        height: 200px;
        overflow: hidden;
        position: relative;
      }

      .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .card:hover img {
        transform: scale(1.05);
      }

      .card-body {
        padding: 1.25rem;
        border-top: 1px solid #333;
      }

      .card-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
      }

      .product-price {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-color);
        margin-bottom: 1rem;
      }

      .btn-primary {
        background-color: var(--primary-color);
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        transition: all 0.3s ease;
        font-weight: 500;
        width: 100%;
      }

      .btn-primary:hover {
        background-color: #5649c0;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(108, 92, 231, 0.3);
      }

      .btn-filter {
        background-color: var(--accent-color);
        color: #121212;
        font-weight: 600;
        margin-top: 1rem;
      }

      .btn-filter:hover {
        background-color: #00b2af;
        color: #121212;
      }

      .product-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: var(--accent-color);
        color: #121212;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
      }

      .no-products {
        background-color: var(--card-bg);
        padding: 3rem;
        border-radius: 15px;
        text-align: center;
      }

      .no-products i {
        font-size: 3rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial') %>

    <div class="page-header">
      <div class="container">
        <h1 class="text-center">PREMIUM TECH SHOP</h1>
        <p class="text-center text-white-50">
          Find the latest gadgets at amazing prices
        </p>
      </div>
    </div>

    <div class="container my-5">
      <div class="row">
        <!-- Filter Section -->
        <div class="col-md-3">
          <div class="filter-section">
            <h5><i class="fas fa-filter me-2"></i>FILTERS</h5>
            <form id="filterForm" method="GET" action="/shop">
              <div class="mb-4">
                <label for="category" class="form-label">Category</label>
                <select class="form-select" id="category" name="category">
                  <option value="">All Categories</option>
                  <option value="electronics">Smart Phones</option>
                  <option value="fashion">Laptops</option>
                  <option value="home">Earbuds</option>
                </select>
              </div>
              <div class="mb-4">
                <label for="brand" class="form-label">Brand</label>
                <select class="form-select" id="brand" name="brand">
                  <option value="">All Brands</option>
                  <option value="apple">Apple</option>
                  <option value="samsung">Samsung</option>
                  <option value="nike">Nike</option>
                </select>
              </div>
              <div class="mb-4">
                <label for="priceRange" class="form-label">Price Range</label>
                <div class="price-range">
                  <input
                    type="number"
                    class="form-control"
                    id="minPrice"
                    name="minPrice"
                    placeholder="Min"
                  />
                  <span class="price-divider">-</span>
                  <input
                    type="number"
                    class="form-control"
                    id="maxPrice"
                    name="maxPrice"
                    placeholder="Max"
                  />
                </div>
              </div>
              <div class="mb-4">
                <label for="sort" class="form-label">Sort By</label>
                <select class="form-select" id="sort" name="sort">
                  <option value="">Default</option>
                  <option value="price-asc">Price: Low to High</option>
                  <option value="price-desc">Price: High to Low</option>
                  <option value="name-asc">Name: A-Z</option>
                  <option value="name-desc">Name: Z-A</option>
                </select>
              </div>
              <button type="submit" class="btn btn-filter w-100">
                <i class="fas fa-search me-2"></i>Apply Filters
              </button>
            </form>
          </div>
        </div>

        <!-- Product Grid -->
        <div class="col-md-9">
          <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            <% products.forEach(product => { %>
            <div class="col">
              <div class="card h-100">
                <div class="card-img-wrapper">
                  <img
                    src="<%= product.imageUrl || 'https://via.placeholder.com/300x200' %>"
                    src="<%= product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0 ? product.variants[0].images[0].url : 'https://via.placeholder.com/400x400?text=No+Image' %>"
                    alt="<%= product.name %>"
                    class="card-img-top"
                  />
                  <% if (Math.random() > 0.7) { %>
                  <div class="product-badge">NEW</div>
                  <% } %>
                </div>
                <div class="card-body">
                  <h5 class="card-title"><%= product.name %></h5>
                  <div class="product-price">$<%= product.actualPrice %></div>
                  <a href="/product/<%= product._id %>" class="btn btn-primary">
                    <i class="fas fa-shopping-cart me-2"></i>View Details
                  </a>
                </div>
              </div>
            </div>
            <% }) %>
          </div>

          <% if (products.length === 0) { %>
          <div class="no-products">
            <i class="fas fa-box-open"></i>
            <h4>No products available</h4>
            <p class="text-secondary">
              Try adjusting your filters or check back later for new items.
            </p>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <%- include('./partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
