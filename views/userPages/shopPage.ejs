<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"/>

  <title>Shop | BestDeals</title>
</head>

<body class="bg-gray-100">

<%- include('./partials/headerPartial') %>

<!-- PAGE HEADER -->
<div class="bg-indigo-600 text-white py-6 rounded-b-3xl shadow">
  <h1 class="text-center text-3xl font-bold">Shop Products</h1>
</div>

<div class="max-w-7xl mx-auto px-4 py-6 grid md:grid-cols-4 gap-6">

<!-- FILTER -->
<div class="bg-white p-5 rounded-xl shadow-md">

<form id="filterForm" action="/shop" method="GET" class="space-y-4">

<h3 class="font-bold text-lg text-indigo-600 flex justify-between">
  Filters
  <a href="/shop" class="text-sm text-gray-500 hover:text-red-500">Clear</a>
</h3>

<!-- Search -->
<input name="search" placeholder="Search..."
class="w-full px-3 py-2 border rounded focus:ring-2 ring-indigo-400"
value="<%= filters?.search || '' %>">

<!-- Category -->
<div>
<p class="font-medium mb-2">Category</p>
<div class="flex flex-wrap gap-2">
<span data-value=""
class="chip px-3 py-1 rounded-full border cursor-pointer bg-indigo-600 text-white">All</span>

<% categories.forEach(c => { %>
<span data-value="<%= c.name %>"
class="chip px-3 py-1 rounded-full border cursor-pointer hover:bg-indigo-100">
<%= c.name %>
</span>
<% }) %>
</div>
<input type="hidden" name="category" id="categoryInput">
</div>

<!-- Price -->
<div>
<p class="font-medium mb-2">Max Price</p>
<input type="range" min="0" max="2000" step="50"
id="priceRange" class="w-full">

<p class="text-indigo-600 font-semibold">
₹ <span id="priceText">1000</span>
</p>

<input type="hidden" name="maxPrice" id="maxPrice" value="1000">
</div>

<!-- Sort -->
<select name="sort"
class="w-full border px-3 py-2 rounded">

<option value="">Recommended</option>
<option value="price-asc">Low to High</option>
<option value="price-desc">High to Low</option>
<option value="newest">Newest</option>
</select>

<button class="w-full bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700">
Apply Filters
</button>

</form>
</div>

<!-- PRODUCTS -->
<div class="md:col-span-3">

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

<% products.forEach(product => { %>

<div class="bg-white rounded-xl shadow hover:-translate-y-1 transition">

<img
src="<%= product.variants?.[0]?.images?.[0]?.url || 'https://via.placeholder.com/300' %>"
class="w-full h-48 object-cover rounded-t-xl">

<div class="p-4 space-y-2">

<h3 class="font-semibold truncate">
<%= product.name %>
</h3>

<div class="flex justify-between items-center">
<p class="text-xl font-bold text-indigo-600">
₹ <%= product.actualPrice %>
</p>

<div class="text-yellow-400">
<i class="fas fa-star"></i>
<i class="fas fa-star"></i>
<i class="fas fa-star"></i>
<i class="fas fa-star-half-alt"></i>
</div>
</div>

<a href="/product/<%= product._id %>"
class="block text-center bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700">
View Product
</a>

</div>
</div>

<% }) %>

</div>

<!-- EMPTY -->
<% if(products.length === 0){ %>
<div class="bg-white p-10 rounded-xl text-center">
<i class="fas fa-box-open text-5xl text-gray-400"></i>
<p class="mt-4 text-gray-600">No products found</p>
</div>
<% } %>

<!-- PAGINATION -->
<div class="flex justify-center mt-8 gap-2">

<% if(currentPage>1){ %>
<a href="?page=<%=currentPage-1%>"
class="px-3 py-1 bg-white rounded shadow">‹</a>
<% } %>

<% for(let i=1;i<=totalPages;i++){ %>
<a href="?page=<%=i%>"
class="px-3 py-1 rounded shadow
<%= i===currentPage ? 'bg-indigo-600 text-white':'bg-white' %>">
<%= i %>
</a>
<% } %>

<% if(currentPage<totalPages){ %>
<a href="?page=<%=currentPage+1%>"
class="px-3 py-1 bg-white rounded shadow">›</a>
<% } %>

</div>

</div>
</div>

<%- include('./partials/footer') %>

<script>
/* Category chips */
document.querySelectorAll('.chip').forEach(chip=>{
chip.onclick=()=>{
document.querySelectorAll('.chip').forEach(c=>c.classList.remove('bg-indigo-600','text-white'))
chip.classList.add('bg-indigo-600','text-white')
document.getElementById('categoryInput').value=chip.dataset.value
}
})

/* Price */
const slider=document.getElementById('priceRange')
const text=document.getElementById('priceText')
const input=document.getElementById('maxPrice')

slider.oninput=()=>{
text.textContent=slider.value
input.value=slider.value
}
</script>

</body>
</html>
