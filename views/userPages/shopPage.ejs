    <%- include('./partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Script for managing filter chips
      document.addEventListener('DOMContentLoaded', function() {
        // Category filter chips
        const categoryChips = document.querySelectorAll('.chip-container .filter-chip');
        const categoryInput = document.getElementById('categoryInput');
        
        categoryChips.forEach(chip => {
          chip.addEventListener('click', function() {
            // Remove active class from all chips
            categoryChips.forEach(c => c.classList.remove('active'));
            // Add active class to clicked chip
            this.classList.add('active');
            // Update hidden input
            categoryInput.value = this.getAttribute('data-value');
          });
        });
        
        // Price range slider
        const priceSlider = document.getElementById('priceRange');
        const minPriceDisplay = document.getElementById('minPriceDisplay');
        const maxPriceDisplay = document.getElementById('maxPriceDisplay');
        const minPriceInput = document.getElementById('minPrice');
        const maxPriceInput = document.getElementById('maxPrice');
        
        priceSlider.addEventListener('input', function() {
          const value = this.value;
          maxPriceInput.value = value;
          maxPriceDisplay.textContent = '$' + value;
        });
        
        // Color options in product cards and modal
        const colorOptions = document.querySelectorAll('.color-option');
        colorOptions.forEach(option => {
          option.addEventListener('click', function() {
            // Find all color options in the same container
            const container = this.closest('.color-options');
            const siblings = container.querySelectorAll('.color-option');
            
            // Remove selected class from all siblings
            siblings.forEach(sib => sib.classList.remove('selected'));
            // Add selected class to clicked option
            this.classList.add('selected');
          });
        });
        
        // Mobile filter toggle animation
        const filterToggle = document.querySelector('.filter-toggle');
        const filterCollapse = document.getElementById('filterCollapse');
        
        filterCollapse.addEventListener('shown.bs.collapse', function () {
          filterToggle.innerHTML = '<i class="fas fa-times"></i> Hide Filters';
        });
        
        filterCollapse.addEventListener('hidden.bs.collapse', function () {
          filterToggle.innerHTML = '<i class="fas fa-sliders-h"></i> Show Filters';
        });
      });
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Handle category chip selection
        const categoryChips = document.querySelectorAll('.filter-chip');
        const categoryInput = document.getElementById('categoryInput');
        
        // Set initial state based on URL params
        const urlParams = new URLSearchParams(window.location.search);
        const categoryParam = urlParams.get('category');
        if (categoryParam) {
          categoryChips.forEach(chip => {
            if (chip.dataset.value === categoryParam) {
              chip.classList.add('active');
            } else {
              chip.classList.remove('active');
            }
          });
          categoryInput.value = categoryParam;
        }
        
        categoryChips.forEach(chip => {
          chip.addEventListener('click', function() {
            categoryChips.forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            categoryInput.value = this.dataset.value;
          });
        });
        
        // Handle price range slider
        const priceSlider = document.getElementById('priceRange');
        const minPriceDisplay = document.getElementById('minPriceDisplay');
        const maxPriceDisplay = document.getElementById('maxPriceDisplay');
        const minPriceInput = document.getElementById('minPrice');
        const maxPriceInput = document.getElementById('maxPrice');
        
        // Set initial state from URL params
        const minPriceParam = urlParams.get('minPrice');
        const maxPriceParam = urlParams.get('maxPrice');
        if (minPriceParam) minPriceInput.value = minPriceParam;
        if (maxPriceParam) {
          maxPriceInput.value = maxPriceParam;
          priceSlider.value = maxPriceParam;
          maxPriceDisplay.textContent = '$' + maxPriceParam;
        }
        
        priceSlider.addEventListener('input', function() {
          maxPriceInput.value = this.value;
          maxPriceDisplay.textContent = '$' + this.value;
        });
        
        // Set other form elements based on URL params
        const brandSelect = document.getElementById('brand');
        const brandParam = urlParams.get('brand');
        if (brandParam) brandSelect.value = brandParam;
        
        const inStockCheck = document.getElementById('inStock');
        inStockCheck.checked = urlParams.get('inStock') !== 'false';
        
        const dealsCheck = document.getElementById('deals');
        dealsCheck.checked = urlParams.get('deals') === 'true';
        
        const sortSelect = document.getElementById('sort');
        const sortParam = urlParams.get('sort');
        if (sortParam) sortSelect.value = sortParam;
      });
    </script>
  </body>
</html> 