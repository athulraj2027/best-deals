<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <style>
      :root {
        --primary-color: #6c5ce7;
        --secondary-color: #a29bfe;
        --accent-color: #00cec9;
        --dark-bg: #121212;
        --card-bg: #37404d;
        --text-primary: #f5f5f5;
        --text-secondary: #b3b3b3;
      }

      body {
        /* background-color: var(--dark-bg); */
        color: var(--text-primary);
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }

      .page-header {
        padding: 3rem 0;
        background: linear-gradient(135deg, #6c5ce7, #00cec9);
        margin-bottom: 2rem;
        border-radius: 0 0 30px 30px;
        box-shadow: 0 4px 20px rgba(108, 92, 231, 0.2);
      }

      .page-header h1 {
        font-weight: 700;
        letter-spacing: 1px;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
      }

      /* Filter Panel Styles */
      .filter-toggle {
        display: none;
        width: 100%;
        background-color: var(--primary-color);
        color: white;
        border: none;
        padding: 12px;
        margin-bottom: 15px;
        border-radius: 10px;
        font-weight: 600;
        text-align: left;
      }

      .filter-toggle i {
        margin-right: 8px;
        transition: transform 0.3s;
      }

      .filter-toggle.collapsed i {
        transform: rotate(-90deg);
      }

      .filter-section {
        background-color: var(--card-bg);
        padding: 1.5rem;
        border-radius: 15px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        border-left: 4px solid var(--primary-color);
        transition: all 0.3s ease;
      }

      .filter-section h5 {
        color: var(--accent-color);
        margin-bottom: 1.5rem;
        font-weight: 600;
        border-bottom: 1px solid #333;
        padding-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .filter-section label {
        color: var(--text-secondary);
        font-weight: 500;
        margin-bottom: 8px;
        font-size: 0.9rem;
      }

      .form-select,
      .form-control {
        background-color: #252525;
        border: 1px solid #444;
        color: var(--text-primary);
        border-radius: 8px;
        transition: all 0.3s ease;
      }

      .form-select:focus,
      .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 2px rgba(108, 92, 231, 0.25);
        background-color: #2a2a2a;
      }

      /* Price Range Slider */
      .price-range-container {
        padding: 10px 5px;
      }

      .price-display {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        color: var(--accent-color);
        font-weight: 600;
      }
/* 
      .range-slider {
        .-webkit-appearance: none;
        width: 100%;
        height: 5px;
        background: #333;
        border-radius: 5px;
        margin-bottom: 15px;
      } */

      .range-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--primary-color);
        cursor: pointer;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
      }

      .range-slider::-moz-range-thumb {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--primary-color);
        cursor: pointer;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
      }

      /* Chip-style Filters */
      .chip-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
      }

      .filter-chip {
        background-color: #252525;
        border: 1px solid #444;
        color: var(--text-secondary);
        border-radius: 50px;
        padding: 6px 14px;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .filter-chip:hover {
        border-color: var(--accent-color);
        color: var(--accent-color);
      }

      .filter-chip.active {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
      }

      /* Product Cards */
      .card {
        width: 100%;
        background-color: var(--card-bg);
        color: var(--text-primary);
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
      }

      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
      }

      .card-img-wrapper {
        height: 200px;
        overflow: hidden;
        position: relative;
      }

      .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .card:hover img {
        transform: scale(1.05);
      }

      .card-body {
        padding: 1.25rem;
        border-top: 1px solid #333;
      }

      .card-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .product-price {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--accent-color);
        margin-bottom: 1rem;
      }

      .product-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: var(--accent-color);
        color: #121212;
        font-weight: bold;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
      }

      .sale-badge {
        top: 10px;
        left: 10px;
        background-color: #ff6b6b;
      }

      .btn-primary {
        background-color: var(--primary-color);
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        transition: all 0.3s ease;
        font-weight: 500;
        width: 100%;
      }

      .btn-primary:hover {
        background-color: #5649c0;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(108, 92, 231, 0.3);
      }

      .btn-filter {
        background-color: var(--accent-color);
        color: #121212;
        font-weight: 600;
        margin-top: 1rem;
      }

      .btn-filter:hover {
        background-color: #00b2af;
        color: #121212;
      }

      .clear-filter {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: color 0.2s;
      }

      .clear-filter:hover {
        color: var(--accent-color);
      }

      .no-products {
        background-color: var(--card-bg);
        padding: 3rem;
        border-radius: 15px;
        text-align: center;
      }

      .no-products i {
        font-size: 3rem;
        color: var(--text-secondary);
        margin-bottom: 1rem;
      }

      /* Pagination */
      .pagination-container {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
      }

      .pagination {
        display: flex;
        gap: 5px;
        background-color: var(--card-bg);
        padding: 10px 15px;
        border-radius: 50px;
      }

      .pagination a {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #252525;
        color: var(--text-secondary);
        border-radius: 50%;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .pagination a:hover {
        background-color: #333;
        color: var(--text-primary);
      }

      .pagination a.active {
        background-color: var(--primary-color);
        color: white;
      }

      /* Responsive Styles */
      @media (max-width: 991.98px) {
        .row-cols-lg-3 {
          --bs-gutter-x: 10px;
        }
      }

      @media (max-width: 767.98px) {
        .filter-toggle {
          display: block;
        }

        .filter-section {
          margin-bottom: 20px;
        }

        .filter-collapse {
          display: none;
        }

        .filter-collapse.show {
          display: block;
        }

        .page-header {
          padding: 2rem 0;
          border-radius: 0 0 20px 20px;
        }

        .page-header h1 {
          font-size: 1.8rem;
        }

        .card-img-wrapper {
          height: 180px;
        }
      }

      @media (max-width: 575.98px) {
        .row-cols-1 {
          --bs-gutter-x: 0;
        }
        
        .container {
          padding-left: 10px;
          padding-right: 10px;
        }

        .card-img-wrapper {
          height: 160px;
        }

        .pagination a {
          width: 32px;
          height: 32px;
          font-size: 0.85rem;
        }
      }

      /* Quick View Modal */
      .modal-content {
        background-color: var(--card-bg);
        color: var(--text-primary);
        border-radius: 15px;
        border: none;
      }

      .modal-header {
        border-bottom: 1px solid #333;
      }

      .modal-footer {
        border-top: 1px solid #333;
      }

      .close {
        color: var(--text-primary);
        opacity: 0.8;
      }

      .close:hover {
        opacity: 1;
      }

      /* Color Options */
      .color-options {
        display: flex;
        gap: 8px;
        margin-top: 10px;
      }

      .color-option {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        cursor: pointer;
        position: relative;
      }

      .color-option.selected::after {
        content: "";
        position: absolute;
        top: -4px;
        left: -4px;
        right: -4px;
        bottom: -4px;
        border: 2px solid var(--accent-color);
        border-radius: 50%;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial') %>

    <div class="container my-4">
      <div class="row">
        <!-- Mobile Filter Toggle -->
        <div class="col-12 d-md-none mb-3">
          <button class="filter-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
            <i class="fas fa-sliders-h"></i> Show Filters
          </button>
        </div>

        <!-- Filter Section -->
        <div class="col-md-3">
          <div class="filter-collapse collapse d-md-block" id="filterCollapse">
            <div class="filter-section">
              <h5>
                <span><i class="fas fa-filter me-2"></i>FILTERS</span>
                <a href="/shop" class="clear-filter"><i class="fas fa-times me-1"></i> Clear</a>
              </h5>
              
              <form id="filterForm" method="GET" action="/shop">
                <!-- Category Chips -->
                <div class="mb-4">
                  <label class="form-label">Category</label>
                  <div class="chip-container">
                    <div class="filter-chip active" data-value="">All</div>
                    <% categories.forEach(function(category) { %>
                      <div class="filter-chip" data-value="<%= category.name %>"><%= category.name %></div>
                    <% }); %>
                  </div>
                  <input type="hidden" name="category" id="categoryInput" value="">
                </div>
                
                <!-- Brand Selection -->
                <div class="mb-4">
                  <label for="brand" class="form-label">Brand</label>
                  <select class="form-select" id="brand" name="brand">
                    <option value="">All Brands</option>
                    <option value="apple">Apple</option>
                    <option value="samsung">Samsung</option>
                    <option value="sony">Sony</option>
                    <option value="google">Google</option>
                    <option value="microsoft">Microsoft</option>
                  </select>
                </div>
                
                <!-- Price Range Slider -->
                <div class="mb-4">
                  <label for="priceRange" class="form-label">Price Range</label>
                  <div class="price-range-container">
                    <div class="price-display">
                      <span id="minPriceDisplay">$0</span>
                      <span id="maxPriceDisplay">$2000</span>
                    </div>
                    <input type="range" class="range-slider" id="priceRange" min="0" max="2000" step="50" value="1000">
                    <input type="hidden" id="minPrice" name="minPrice" value="0">
                    <input type="hidden" id="maxPrice" name="maxPrice" value="1000">
                  </div>
                </div>
                
                <!-- Ratings Filter -->
                <!-- <div class="mb-4">
                  <label class="form-label">Rating</label>
                  <div class="rating-filter d-flex align-items-center gap-2 mb-2">
                    <input type="checkbox" class="form-check-input" id="rating4plus" name="rating" value="4">
                    <label for="rating4plus" class="form-check-label">
                      <i class="fas fa-star text-warning"></i>
                      <i class="fas fa-star text-warning"></i>
                      <i class="fas fa-star text-warning"></i>
                      <i class="fas fa-star text-warning"></i>
                      <i class="far fa-star text-warning"></i>
                      & Up
                    </label>
                  </div>
                  <div class="rating-filter d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input" id="rating3plus" name="rating" value="3">
                    <label for="rating3plus" class="form-check-label">
                      <i class="fas fa-star text-warning"></i>
                      <i class="fas fa-star text-warning"></i>
                      <i class="fas fa-star text-warning"></i>
                      <i class="far fa-star text-warning"></i>
                      <i class="far fa-star text-warning"></i>
                      & Up
                    </label>
                  </div> -->
                <!-- </div> -->
                
                <!-- Availability Filter -->
                <div class="mb-4">
                  <label class="form-label">Availability</label>
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <input type="checkbox" class="form-check-input" id="inStock" name="inStock" value="true" checked>
                    <label for="inStock" class="form-check-label">In Stock</label>
                  </div>
                  <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input" id="deals" name="deals" value="true">
                    <label for="deals" class="form-check-label">Special Deals</label>
                  </div>
                </div>
                
                <!-- Sort By -->
                <div class="mb-4">
                  <label for="sort" class="form-label">Sort By</label>
                  <select class="form-select" id="sort" name="sort">
                    <option value="">Recommended</option>
                    <option value="price-asc">Price: Low to High</option>
                    <option value="price-desc">Price: High to Low</option>
                    <option value="newest">Newest First</option>
                    <option value="popular">Most Popular</option>
                  </select>
                </div>
                
                <button type="submit" class="btn btn-filter w-100">
                  <i class="fas fa-search me-2"></i>Apply Filters
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Product Grid -->
        <div class="col-md-9">
          <!-- Active Filters Display -->
          <div class="active-filters mb-3">
            <div class="d-flex flex-wrap gap-2">
              <span class="filter-chip active">
                All Products <i class="fas fa-times-circle ms-1"></i>
              </span>
              <span class="filter-chip active">
                Price: $0 - $1000 <i class="fas fa-times-circle ms-1"></i>
              </span>
            </div>
          </div>
          
          <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
            <% products.forEach((product, index) => { %>
              <% if (product.category && product.category.status ==='listed') { %>
                <div class="col">
                  <div class="card h-100">
                    <div class="card-img-wrapper">
                      <img
                        src="<%= product.variants && product.variants.length > 0 && product.variants[0].images && product.variants[0].images.length > 0 ? product.variants[0].images[0].url : 'https://via.placeholder.com/400x400?text=No+Image' %>"
                        alt="<%= product.name %>"
                        class="card-img-top"
                      />
                      <% if (Math.random() > 0.7) { %>
                        <div class="product-badge">NEW</div>
                      <% } %>
                      <% if (Math.random() > 0.8) { %>
                        <div class="product-badge sale-badge">SALE</div>
                      <% } %>
                    </div>
                    <div class="card-body">
                      <h5 class="card-title" title="<%= product.name %>"><%= product.name %></h5>
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="product-price">$<%= product.actualPrice %></div>
                        <div class="rating">
                          <% for(let i=0; i<Math.floor(3.5 + Math.random() * 1.5); i++) { %>
                            <i class="fas fa-star text-warning small"></i>
                          <% } %>
                          <% for(let i=0; i<5-Math.floor(3.5 + Math.random() * 1.5); i++) { %>
                            <i class="far fa-star text-warning small"></i>
                          <% } %>
                        </div>
                      </div>
                      
                      <!-- Color options if available -->
                      <% if (Math.random() > 0.5) { %>
                        <div class="color-options">
                          <div class="color-option selected" style="background-color: #000000;"></div>
                          <div class="color-option" style="background-color: #f5f5f5;"></div>
                          <div class="color-option" style="background-color: #0071e3;"></div>
                        </div>
                      <% } %>
                      
                      <div class="mt-3 d-flex gap-2">
                        <a href="/product/<%= product._id %>" class="btn btn-primary flex-grow-1">
                          <i class="fas fa-shopping-cart me-2"></i>View
                        </a>
                        <!-- <button class="btn btn-outline-secondary" style="width: 46px; padding: 0;" 
                                data-bs-toggle="modal" data-bs-target="#quickViewModal">
                          <i class="fas fa-eye"></i>
                        </button> -->
                      </div>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }) %>
          </div>

          <% if (products.length === 0) { %>
          <div class="no-products">
            <i class="fas fa-box-open"></i>
            <h4>No products available</h4>
            <p class="text-secondary">
              Try adjusting your filters or check back later for new items.
            </p>
          </div>
          <% } %>
          
          <!-- Improved Pagination -->
          <div class="pagination-container">
            <div class="pagination">
              <% if (currentPage > 1) { %>
              <a href="?page=<%= currentPage - 1 %>&limit=10"><i class="fas fa-chevron-left"></i></a>
              <% } %>
              
              <% let startPage = Math.max(1, currentPage - 2);
                 let endPage = Math.min(totalPages, startPage + 4);
                 if (endPage - startPage < 4) {
                   startPage = Math.max(1, endPage - 4);
                 }
              %>
              
              <% for (let i = startPage; i <= endPage; i++) { %>
              <a href="?page=<%= i %>&limit=10" class="<%= i === currentPage ? 'active' : '' %>">
                <%= i %>
              </a>
              <% } %>
              
              <% if (currentPage < totalPages) { %>
              <a href="?page=<%= currentPage + 1 %>&limit=10"><i class="fas fa-chevron-right"></i></a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

