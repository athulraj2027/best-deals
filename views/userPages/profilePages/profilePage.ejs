<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Profile</title>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('../partials/headerPartial') %>

    <div
      class="flex flex-col md:flex-row max-w-6xl mx-auto mt-8 px-4 md:px-0 gap-6"
    >
      <!-- Sidebar -->
      <div class="w-full md:w-1/4"><%- include('./partial') %></div>

      <!-- Profile Container -->
      <div
        class="w-full md:w-3/4 bg-white rounded-xl shadow-lg p-6"
        id="profileContainer"
      >
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-gray-800 view-only">Profile</h2>
          <button
            id="editToggleBtn"
            class="px-4 py-2 rounded-md border border-blue-600 text-blue-600 font-medium hover:bg-blue-600 hover:text-white transition"
          >
            Edit Profile
          </button>
        </div>

        <div class="space-y-4">
          <!-- View Mode -->
          <div class="view-only space-y-3">
            <p><span class="font-semibold">Name:</span> <%= user.name %></p>
            <p><span class="font-semibold">Email:</span> <%= user.email %></p>
            <p>
              <span class="font-semibold">Phone:</span> <%= user.phone || 'Not provided' %>
            </p>
            <p class="font-semibold">Referral Code:</p>
            <div class="flex items-center gap-2 max-w-xs">
              <input
                type="text"
                readonly
                id="referralCode"
                value="<%= user.referralCode %>"
                class="w-full border border-gray-300 rounded px-3 py-1 bg-gray-100"
              />
              <button
                onclick="copyReferralCode()"
                class="px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition"
              >
                Copy
              </button>
            </div>
            <div class="mt-6">
              <h3 class="text-xl font-semibold">Wallet Savings</h3>
              <p class="text-2xl font-bold text-green-600">
                $ <%= user.wallet.toFixed(2) %>
              </p>
            </div>
          </div>

          <!-- Edit Mode -->
          <form id="editProfileForm" class="edit-field hidden space-y-4">
            <div>
              <label
                for="nameInput"
                class="block font-medium text-gray-700 mb-1"
                >Name</label
              >
              <input
                type="text"
                id="nameInput"
                name="name"
                value="<%= user.name %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label
                for="phoneInput"
                class="block font-medium text-gray-700 mb-1"
                >Phone</label
              >
              <input
                type="tel"
                id="phoneInput"
                name="phone"
                value="<%= user.phone || '' %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div class="flex gap-2 mt-4">
              <button
                type="submit"
                class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition"
              >
                Save Changes
              </button>
              <button
                type="button"
                id="cancelBtn"
                class="px-4 py-2 bg-gray-300 text-gray-700 rounded hover:bg-gray-400 transition"
              >
                Cancel
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const profileContainer = document.getElementById("profileContainer");
        const editToggleBtn = document.getElementById("editToggleBtn");
        const cancelBtn = document.getElementById("cancelBtn");
        const viewOnly = profileContainer.querySelector(".view-only");
        const editField = profileContainer.querySelector(".edit-field");

        editToggleBtn.addEventListener("click", function () {
          const isEditing = !editField.classList.contains("hidden");
          editField.classList.toggle("hidden");
          viewOnly.classList.toggle("hidden");
          editToggleBtn.textContent = isEditing
            ? "Edit Profile"
            : "View Profile";
        });

        cancelBtn.addEventListener("click", function () {
          editField.classList.add("hidden");
          viewOnly.classList.remove("hidden");
          editToggleBtn.textContent = "Edit Profile";
        });

        $("#editProfileForm").submit(function (e) {
          e.preventDefault();
          let phone = $("#phoneInput").val().trim();
          $.ajax({
            url: "/profile",
            type: "PATCH",
            contentType: "application/json",
            data: JSON.stringify({ phone }),
            success: function (response) {
              if (response.status === "success") {
                Swal.fire({ icon: "success", text: response.message }).then(
                  () => location.reload()
                );
              } else {
                Swal.fire({
                  icon: "error",
                  title: response.title || "Error",
                  text: response.message,
                });
              }
            },
            error: function (xhr) {
              let errorMessage =
                xhr.responseJSON?.message || "An unexpected error occurred.";
              Swal.fire({ icon: "error", title: "Oops!", text: errorMessage });
            },
          });
        });
      });

      function copyReferralCode() {
        const input = document.getElementById("referralCode");
        input.select();
        input.setSelectionRange(0, 99999);
        document.execCommand("copy");
        Swal.fire({
          icon: "success",
          title: "Referral Copied",
          text: "Referral code copied to clipboard",
        });
      }
    </script>
  </body>
</html>
