<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Profile</title>
    <link rel="stylesheet" href="/styles/profile.css" />
    <!-- Link to your CSS file -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <style>
      .profile-container {
        max-width: 800px;
        margin: 30px auto;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        background-color: #37404d;
        color: white;
      }
      .profile-header {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
      }
      .profile-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 20px;
      }
      .edit-mode-toggle {
        margin-left: auto;
      }
      .edit-field {
        display: none;
      }
      .view-only {
        margin-bottom: 20px;
      }
      .edit-mode .edit-field {
        display: block;
      }
      .edit-mode .view-only {
        display: none;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/headerPartial') %>
    <div class="container d-flex m-0">
      <div class="m-35"><%- include('./partial') %></div>
      <div class="container profile-container" id="profileContainer">
        <div class="profile-header">
          <div>
            <h2 class="view-only">Profile</h2>
            <div class="edit-field">
              <div class="mb-3">
                <label for="nameInput" class="form-label">Name</label>
                <input
                  type="text"
                  class="form-control"
                  id="nameInput"
                  name="name"
                  value="<%= user.name %>"
                />
              </div>
            </div>
          </div>
          <div class="edit-mode-toggle">
            <button class="btn btn-outline-primary" id="editToggleBtn">
              Edit Profile
            </button>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6">
            <!-- <h4>Personal Information</h4> -->
            <div class="view-only">
              <p><strong>Name :</strong> <%= user.name %></p>
              <p><strong>Email:</strong> <%= user.email %></p>
              <p><strong>Phone:</strong> <%= user.phone || 'Not provided' %></p>
              <p><strong>Referral Code :</strong></p>
              <div class="referral-box d-flex align-items-center">
                <input
                  type="text"
                  id="referralCode"
                  class="form-control me-2"
                  value="<%= user.referralCode %>"
                  readonly
                  style="max-width: 200px"
                />
                <button
                  class="btn btn-outline-primary"
                  onclick="copyReferralCode()"
                >
                  Copy
                </button>
              </div><br/>
              <h1>Wallet Savings</h1><br>
              <h3>$ <%= user.wallet.toFixed(2) %></h3>
            </div>
            <form id="editProfileForm">
              <div class="edit-field">
                <div class="mb-3">
                  <label for="phoneInput" class="form-label">Phone</label>
                  <input
                    type="tel"
                    class="form-control"
                    id="phoneInput"
                    name="phone"
                    value="<%= user.phone || '' %>"
                  />
                </div>
              </div>

              <div class="mt-4 edit-field">
                <button
                  type="submit"
                  class="btn btn-success me-2"
                  id="saveChangesBtn"
                >
                  Save Changes
                </button>
                <button type="button" class="btn btn-secondary" id="cancelBtn">
                  Cancel
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
    <%-include('../partials/footer') %>

    <!-- Required Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const profileContainer = document.getElementById("profileContainer");
        const editToggleBtn = document.getElementById("editToggleBtn");
        const cancelBtn = document.getElementById("cancelBtn");

        // Toggle edit mode
        editToggleBtn.addEventListener("click", function () {
          profileContainer.classList.toggle("edit-mode");
          editToggleBtn.textContent = profileContainer.classList.contains(
            "edit-mode"
          )
            ? "View Profile"
            : "Edit Profile";
        });

        // jQuery code for form submission
        $(document).ready(function () {
          $("#editProfileForm").submit(function (e) {
            e.preventDefault();

            let phone = $("#phoneInput").val().trim();
            $.ajax({
              url: "/profile",
              type: "PATCH",
              contentType: "application/json",
              data: JSON.stringify({ phone }),
              success: function (response) {
                if (response.status === "success") {
                  Swal.fire({
                    status: "success",
                    text: response.message,
                    icon: response.status,
                    confirmButtonText: "OK",
                  }).then(() => {
                    window.location.href = "/profile"; // Redirect after successful login
                  });
                } else {
                  Swal.fire({
                    title: response.title,
                    text: response.message,
                    icon: response.status, // 'error'
                    confirmButtonText: "OK",
                  });
                }
              },
              error: function (xhr, status, error) {
                console.error("AJAX Error:", status, error);
                console.log("Error Response JSON:", xhr.responseJSON);

                let errorMessage =
                  "An unexpected error occurred. Please try again.";

                if (xhr.responseJSON) {
                  errorMessage = xhr.responseJSON.message || errorMessage;
                }

                Swal.fire({
                  title: "Oops!",
                  text: errorMessage,
                  icon: "error",
                  confirmButtonText: "OK",
                });
              },
            });
          });
        });

        // Cancel editing
        cancelBtn.addEventListener("click", function () {
          profileContainer.classList.remove("edit-mode");
          editToggleBtn.textContent = "Edit Profile";
        });
      });
    </script>
    <script>
      function copyReferralCode() {
        const input = document.getElementById("referralCode");
        input.select();
        input.setSelectionRange(0, 99999); // For mobile
        document.execCommand("copy");

        // Optional feedback

        Swal.fire({
          title: "Referral Copied",
          text: "Referral code has been copied to the clipboard",
          icon: "success",
          confirmButtonText: "OK",
        });
      }
    </script>
  </body>
</html>
