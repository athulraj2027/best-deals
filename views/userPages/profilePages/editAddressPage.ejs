<!-- edit-address.ejs -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Address</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('../partials/headerPartial') %>

    <div class="flex flex-col md:flex-row max-w-6xl mx-auto mt-8 px-4 md:px-0 gap-6">
      <!-- Sidebar -->
      <div class="w-full md:w-1/4">
        <%- include('./partial') %>
      </div>

      <!-- Edit Address Container -->
      <div class="w-full md:w-3/4 bg-white rounded-xl shadow-lg p-6">
        <h2 class="text-2xl font-bold text-gray-800 mb-2">Edit Address</h2>
        <p class="text-gray-600 mb-6">Update your address information below</p>

        <form id="editAddressForm" class="space-y-4">
          <!-- Address Type -->
          <div>
            <label class="block font-medium text-gray-700 mb-2">Address Type</label>
            <div class="flex gap-4">
              <label class="inline-flex items-center gap-2">
                <input
                  type="radio"
                  name="type"
                  value="Home"
                  class="form-radio text-blue-600"
                  <% if(!address.type || address.type === "Home"){ %>checked<% } %>
                />
                <span>Home</span>
              </label>
              <label class="inline-flex items-center gap-2">
                <input
                  type="radio"
                  name="type"
                  value="Work"
                  class="form-radio text-green-600"
                  <% if(address.type === "Work"){ %>checked<% } %>
                />
                <span>Work</span>
              </label>
              <label class="inline-flex items-center gap-2">
                <input
                  type="radio"
                  name="type"
                  value="Other"
                  class="form-radio text-gray-600"
                  <% if(address.type === "Other"){ %>checked<% } %>
                />
                <span>Other</span>
              </label>
            </div>
          </div>

          <!-- Street Address -->
          <div>
            <label for="streetAddress" class="block font-medium text-gray-700 mb-1">
              Street Address <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="streetAddress"
              name="streetAddress"
              value="<%= address.streetAddress %>"
              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <!-- City & State -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="city" class="block font-medium text-gray-700 mb-1">
                City <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="city"
                name="city"
                value="<%= address.city %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label for="state" class="block font-medium text-gray-700 mb-1">
                State <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="state"
                name="state"
                value="<%= address.state %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
          </div>

          <!-- ZIP & Country -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="zipCode" class="block font-medium text-gray-700 mb-1">
                ZIP Code <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="zipCode"
                name="zipCode"
                value="<%= address.zipCode %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label for="country" class="block font-medium text-gray-700 mb-1">
                Country <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="country"
                name="country"
                value="<%= address.country %>"
                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
          </div>

          <!-- Buttons -->
          <div class="flex gap-4 mt-4">
            <a href="/profile/address" class="px-4 py-2 border border-gray-300 rounded hover:bg-gray-100 transition">
              Cancel
            </a>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
              Update Address
            </button>
          </div>
        </form>
      </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
      $(document).ready(function () {
        $("#editAddressForm").on("submit", function (e) {
          e.preventDefault();
          const formData = {
            type: $("input[name='type']:checked").val(),
            streetAddress: $("#streetAddress").val(),
            city: $("#city").val(),
            state: $("#state").val(),
            zipCode: $("#zipCode").val(),
            country: $("#country").val(),
          };

          $.ajax({
            type: "POST",
            url: "/profile/address/edit/<%= address._id %>",
            data: formData,
            dataType: "json",
            success: function (response) {
              if (response.status === "success") {
                Swal.fire({
                  icon: "success",
                  title: response.title,
                  text: response.message,
                }).then(() => {
                  window.location.href = "/profile/address";
                });
              } else {
                Swal.fire({
                  icon: "error",
                  title: response.title,
                  text: response.message,
                });
              }
            },
            error: function (xhr) {
              Swal.fire({
                icon: "error",
                title: "Error",
                text: xhr.responseJSON?.message || "Something went wrong",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>
