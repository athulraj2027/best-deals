<!-- edit-address.ejs -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Address</title>
    <!-- Bootstrap CSS for responsiveness -->

    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      .form-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        box-shadow: 0.5 0.5 0.5 0.5 rgb(85, 81, 81);
      }

      .required-field::after {
        content: "*";
        color: red;
        margin-left: 4px;
      }

      .form-footer {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
      }

      @media (max-width: 768px) {
        .form-footer {
          flex-direction: column;
          gap: 10px;
        }

        .form-footer button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <%- include('../partials/headerPartial') %>
    <div class="container d-flex m-0">
      <%- include('./partial')%>

      <div class="container form-container">
        <div class="row mb-4">
          <div class="col">
            <h2>Edit Address</h2>
            <p class="text-muted">Update your address information below</p>
          </div>
        </div>
        <form action="/profile/address/edit/<%= address._id %>?" method="POST">
          <input type="hidden" name="userId" value="<%= address.userId %>" />

          <div class="mb-3">
            <label class="form-label">Address Type</label>
            <div class="d-flex">
              <div class="form-check me-3">
                <input class="form-check-input" type="radio" name="type"
                id="homeType" value="Home" <% if(!address.type || address.type
                === "Home") { %>checked<% } %> />
                <label class="form-check-label" for="homeType">Home</label>
              </div>
              <div class="form-check me-3">
                <input class="form-check-input" type="radio" name="type"
                id="workType" value="Work" <% if(address.type === "Work") {
                %>checked<% } %> />
                <label class="form-check-label" for="workType">Work</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="type"
                id="otherType" value="Other" <% if(address.type === "Other") {
                %>checked<% } %> />
                <label class="form-check-label" for="otherType">Other</label>
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-12 mb-3">
              <label for="streetAddress" class="form-label required-field"
                >Street Address</label
              >
              <input
                type="text"
                class="form-control"
                id="streetAddress"
                name="streetAddress"
                value="<%= address.streetAddress %>"
                required
              />
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6 mb-3">
              <label for="city" class="form-label required-field">City</label>
              <input
                type="text"
                class="form-control"
                id="city"
                name="city"
                value="<%= address.city %>"
                required
              />
            </div>

            <div class="col-md-6 mb-3">
              <label for="state" class="form-label required-field">State</label>
              <input
                type="text"
                class="form-control"
                id="state"
                name="state"
                value="<%= address.state %>"
                required
              />
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6 mb-3">
              <label for="zipCode" class="form-label required-field"
                >Zip Code</label
              >
              <input
                type="text"
                class="form-control"
                id="zipCode"
                name="zipCode"
                value="<%= address.zipCode %>"
                required
              />
            </div>

            <div class="col-md-6 mb-3">
              <label for="country" class="form-label required-field"
                >Country</label
              >
              <input
                type="text"
                class="form-control"
                id="country"
                name="country"
                value="<%= address.country %>"
                required
              />
            </div>
          </div>

          <div class="form-footer">
            <a href="/profile/address" class="btn btn-outline-secondary"
              >Cancel</a
            >
            <button type="submit" class="btn btn-primary">
              Update Address
            </button>
          </div>
        </form>
      </div>
    </div>
    <%- include('../partials/footer') %>
    <!-- Bootstrap JS (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
