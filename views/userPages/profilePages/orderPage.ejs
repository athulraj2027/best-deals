<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Profile</title>
    <link rel="stylesheet" href="/styles/profile.css" />
    <!-- Link to your CSS file -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <style>
      .profile-container {
        max-width: 800px;
        margin: 30px auto;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        border-radius: 8px;
        background-color: #37404d;
        color: white;
      }
      .profile-header {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
      }
      .profile-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 20px;
      }
      .orders-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }
      .orders-table th,
      .orders-table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #ddd;
      }
      .orders-table th {
        background-color: #f2f2f2;
        color: #333;
      }
      .status {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 4px;
        font-weight: bold;
      }
      .status-processing {
        background-color: #fff3cd;
        color: #856404;
      }
      .status-shipped {
        background-color: #d1ecf1;
        color: #0c5460;
      }
      .status-delivered {
        background-color: #d4edda;
        color: #155724;
      }
      .status-cancelled {
        background-color: #f8d7da;
        color: #721c24;
      }
      .no-orders {
        text-align: center;
        padding: 40px;
        background-color: #f8f9fa;
        border-radius: 8px;
        margin-top: 20px;
        color: #6c757d;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/headerPartial') %>
    <div class="container d-flex m-0" style="gap: 40px">
      <div class="m-35"><%- include('./partial') %></div>
      <div class="container">
        <h1>Your Orders</h1>

        <% if (orders && orders.length > 0) { %>
        <table class="orders-table">
          <thead>
            <tr>
              <th>Ordered Products</th>
              <th>Date</th>
              <th>Products</th>
              <th>Total</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
            <tr>
              <td>#<%= order._id %></td>
              <td><%= new Date(order.orderDate).toLocaleDateString() %></td>
              <td>
                <% if (order.items && order.items.length > 0) { %> <%=
                order.items.length %> item<%= order.items.length > 1 ? 's' : ''
                %> <% } else { %> No items <% } %>
              </td>
              <td>
                $<%= order.items.reduce((sum, item) => sum + (item.price *
                item.quantity), 0).toFixed(2) %>
              </td>
              <td>
                <span class="status status-<%= order.status %>">
                  <%= order.status.charAt(0).toUpperCase() +
                  order.status.slice(1) %>
                </span>
              </td>

              <td>
                <% if(order.status !== 'cancelled'){ %>
                <form
                  action="/profile/orders/cancel/<%= order._id %>"
                  method="post"
                  class="order-cancel-form"
                >
                  <button type="submit" class="cancel-btn">Cancel Order</button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } else { %>
        <div class="no-orders">
          <i class="fas fa-shopping-bag fa-3x mb-3"></i>
          <h3>You don't have any orders yet.</h3>
          <p>Once you place an order, it will appear here.</p>
          <a href="/products" class="btn btn-primary mt-3">Start Shopping</a>
        </div>
        <% } %>
      </div>
    </div>
    <%-include('../partials/footer') %>

    <!-- Required Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      $(document).ready(function () {
        // Use a class instead of ID for multiple forms
        $(".order-cancel-form").on("submit", function (e) {
          e.preventDefault();

          // Get the form that was submitted
          const form = $(this);

          // Get the order ID from the form's action attribute
          const formAction = form.attr("action");

          $.ajax({
            url: formAction,
            type: "POST",
            success: function (response) {
              console.log(response); // Log the response for debugging
              if (response.status === "success") {
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'success'
                  confirmButtonText: "OK",
                }).then(() => {
                  window.location.reload; // Redirect after successful cancellation
                });
              } else {
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'error'
                  confirmButtonText: "OK",
                });
              }
            },
            error: function (xhr, status, error) {
              console.error("AJAX Error:", status, error);
              console.log("Error Response JSON:", xhr.responseJSON);

              Swal.fire({
                title: "Oops!",
                text:
                  xhr.responseJSON?.message ||
                  "An error occurred while cancelling your order.",
                icon: "error",
                confirmButtonText: "OK",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>
