<!-- profile-orders.ejs -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Orders</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('../partials/headerPartial') %>

    <div class="flex flex-col md:flex-row max-w-6xl mx-auto mt-8 px-4 md:px-0 gap-6">
      <!-- Sidebar -->
      <div class="w-full md:w-1/4">
        <%- include('./partial') %>
      </div>

      <!-- Orders Container -->
      <div class="w-full md:w-3/4 space-y-6">
        <h2 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
          <i class="fas fa-shopping-bag"></i> Your Orders
        </h2>

        <% if (orders && orders.length > 0) { %>
          <% orders.sort((a,b) => new Date(b.orderDate)-new Date(a.orderDate)).forEach(order => { %>
          <div class="bg-white rounded-xl shadow-lg p-5 flex flex-col md:flex-row md:items-center justify-between">
            <div class="space-y-1 md:space-y-0 md:flex md:gap-4 md:items-center flex-1">
              <div class="text-gray-500 font-mono font-semibold">#<%= order._id.toString().slice(-8) %></div>
              <div class="text-gray-600"><%= new Date(order.orderDate).toLocaleDateString('en-US', {year:'numeric', month:'short', day:'numeric'}) %></div>
              <div class="text-gray-700">
                <% if(order.items && order.items.length > 0){ %>
                  <%= order.items.length %> item<%= order.items.length > 1 ? 's' : '' %>
                <% } else { %> 
                  No items
                <% } %>
              </div>
              <div class="text-gray-800 font-semibold">$<%= order.grantTotal %></div>
              <div>
                <% 
                  const statusClasses = {
                    pending: 'bg-yellow-100 text-yellow-800',
                    processing: 'bg-sky-100 text-sky-800',
                    delivered: 'bg-green-100 text-green-800',
                    cancelled: 'bg-red-100 text-red-800',
                    'return requested': 'bg-orange-100 text-orange-800',
                    'return accepted': 'bg-green-200 text-green-900',
                    returned: 'bg-gray-200 text-gray-700'
                  };
                %>
                <span class="px-3 py-1 rounded-full font-medium text-sm <%= statusClasses[order.status] || 'bg-gray-100 text-gray-800' %>">
                  <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                </span>
              </div>
            </div>

            <div class="flex mt-3 md:mt-0 gap-2">
              <button type="button" class="bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700 transition" data-bs-toggle="modal" data-bs-target="#orderModal<%= order._id %>">
                <i class="fas fa-eye mr-1"></i> View
              </button>
              <% if(order.status !== 'cancelled' && order.status !== 'delivered' && order.status !== 'return requested' && order.status !== 'return accepted' && order.status !== 'returned'){ %>
                <form action="/profile/orders/cancel/<%= order._id %>" method="post" class="order-cancel-form">
                  <button type="submit" class="bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700 transition">
                    <i class="fas fa-times mr-1"></i> Cancel
                  </button>
                </form>
              <% } else if(order.status === 'delivered'){ %>
                <form action="/profile/orders/return/<%= order._id %>" method="post" class="order-return-form">
                  <button type="submit" class="bg-orange-600 text-white px-3 py-1 rounded hover:bg-orange-700 transition">
                    <i class="fas fa-undo mr-1"></i> Return
                  </button>
                </form>
              <% } %>
            </div>
          </div>

          <!-- Order Modal -->
          <div class="modal fade" id="orderModal<%= order._id %>" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
              <div class="modal-content">
                <div class="modal-header bg-gray-100 border-b">
                  <h5 class="modal-title font-bold text-gray-800">Order #<%= order._id.toString().slice(-8) %></h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body space-y-4">
                  <!-- Order Info -->
                  <div class="border-b pb-3">
                    <h5 class="font-semibold text-gray-700 mb-2">Order Information</h5>
                    <div class="flex justify-between text-gray-600 mb-1">
                      <span>Order Date:</span>
                      <span class="font-medium"><%= new Date(order.orderDate).toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric'}) %></span>
                    </div>
                    <div class="flex justify-between text-gray-600 mb-1">
                      <span>Status:</span>
                      <span class="px-3 py-1 rounded-full text-sm font-medium <%= statusClasses[order.status] || 'bg-gray-100 text-gray-800' %>"><%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %></span>
                    </div>
                    <div class="flex justify-between text-gray-600 mb-1">
                      <span>Payment Status:</span>
                      <span class="font-medium"><%= order.payment_status.charAt(0).toUpperCase() + order.payment_status.slice(1) %></span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                      <span>Payment Method:</span>
                      <span class="font-medium"><%= order.paymentMethod %></span>
                    </div>
                  </div>

                  <!-- Items -->
                  <div>
                    <h5 class="font-semibold text-gray-700 mb-3">Items</h5>
                    <% if(order.items && order.items.length > 0){ %>
                      <% order.items.forEach(item => { %>
                      <div class="flex items-center gap-4 border-b py-2">
                        <img src="<%= item.image %>" alt="<%= item.name %>" class="w-20 h-20 object-cover rounded" />
                        <div class="flex-1">
                          <div class="font-semibold text-gray-800"><%= item.name %></div>
                          <div class="text-gray-500 text-sm">Size: <%= item.size %> | Color: <%= item.color %> | Qty: <%= item.quantity %></div>
                        </div>
                        <div class="font-semibold text-gray-800 text-right">$<%= (item.price*item.quantity).toFixed(2) %></div>
                      </div>
                      <% }); %>

                      <!-- Summary -->
                      <div class="bg-gray-100 rounded p-3 mt-3 space-y-1 text-gray-700">
                        <div class="flex justify-between"><span>Items Total:</span> <span>$<%= order.items.reduce((sum,item)=>sum+(item.price*item.quantity),0).toFixed(2) %></span></div>
                        <div class="flex justify-between"><span>Shipping:</span> <span>$0.00</span></div>
                        <div class="flex justify-between"><span>Tax:</span> <span>Included</span></div>
                        <div class="flex justify-between font-semibold text-gray-800 text-lg mt-2"><span>Order Total:</span> <span>$<%= order.grantTotal %></span></div>
                        <div class="flex justify-between border-t border-dashed pt-2"><span>Payment Method:</span> <span><%= order.paymentMethod %></span></div>
                      </div>
                    <% } else { %>
                      <p class="text-gray-500">No items in this order.</p>
                    <% } %>
                  </div>
                </div>

                <div class="modal-footer flex justify-end gap-2">
                  <button type="button" class="px-4 py-2 bg-gray-300 rounded hover:bg-gray-400" data-bs-dismiss="modal">Close</button>
                  <% if(order.status !== 'cancelled' && order.status !== 'delivered'){ %>
                  <form action="/profile/orders/cancel/<%= order._id %>" method="post">
                    <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700">Cancel Order</button>
                  </form>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <div class="bg-white rounded-xl shadow-lg p-8 text-center space-y-4">
            <i class="fas fa-shopping-bag text-gray-400 text-6xl"></i>
            <h3 class="text-gray-700 font-semibold text-xl">You don't have any orders yet</h3>
            <p class="text-gray-500">Once you place an order, it will appear here with all the details</p>
            <a href="/shop?category=all" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 inline-flex items-center gap-2">
              <i class="fas fa-shopping-cart"></i> Start Shopping
            </a>
          </div>
        <% } %>
      </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      $(document).ready(function () {
        // Cancel order
        $(".order-cancel-form").on("submit", function (e) {
          e.preventDefault();
          const form = $(this);
          const action = form.attr("action");
          Swal.fire({
            title: "Cancel Order?",
            text: "Are you sure you want to cancel this order?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Yes, cancel it!",
            cancelButtonText: "No, keep it",
          }).then((result) => {
            if (result.isConfirmed) {
              $.post(action, function(response){
                if(response.status==='success'){
                  Swal.fire({title:response.title,text:response.message,icon:'success'}).then(()=>window.location.reload());
                }else{
                  Swal.fire({title:response.title,text:response.message,icon:'error'});
                }
              });
            }
          });
        });

        // Return order
        $(".order-return-form").on("submit", function (e) {
          e.preventDefault();
          const form = $(this);
          const action = form.attr("action");
          Swal.fire({
            title: "Return Order?",
            text: "Select reason(s) for return",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            html: `
              <div class="space-y-2 mt-3 text-left">
                <label class="flex items-center gap-2"><input type="checkbox" id="reasonDefective"> Item is defective</label>
                <label class="flex items-center gap-2"><input type="checkbox" id="reasonQuality"> Cheap quality</label>
                <label class="flex items-center gap-2"><input type="checkbox" id="reasonDifferent"> Different product</label>
              </div>
            `,
            preConfirm: () => {
              const reasons = [];
              if(document.getElementById('reasonDefective').checked) reasons.push("Item is defective");
              if(document.getElementById('reasonQuality').checked) reasons.push("Cheap quality");
              if(document.getElementById('reasonDifferent').checked) reasons.push("Different product");
              if(reasons.length===0) Swal.showValidationMessage("Select at least one reason");
              return reasons;
            }
          }).then(result=>{
            if(result.isConfirmed){
              $.ajax({
                url: action,
                type: 'POST',
                data: JSON.stringify({reasons: result.value}),
                contentType: 'application/json',
                success: function(res){
                  if(res.status==='success') Swal.fire({title:res.title,text:res.message,icon:'success'}).then(()=>window.location.reload());
                  else Swal.fire({title:res.title,text:res.message,icon:'error'});
                }
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
