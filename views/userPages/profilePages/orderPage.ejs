<!-- profile-orders.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Orders</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

  <style>
    /* ─── Design Tokens ─────────────────────────────────── */
    :root {
      --ink:           #0c0c0d;
      --ink-2:         #1a1a1f;
      --surface:       #f7f7f6;
      --surface-2:     #f0f0ee;
      --card:          #ffffff;
      --accent:        #2655eb;
      --accent-hover:  #1a46d4;
      --accent-light:  #eef2fd;
      --success:       #0e7a45;
      --success-bg:    #e8f7ef;
      --danger:        #c9251d;
      --danger-bg:     #fdf0ef;
      --warning:       #9a5c00;
      --warning-bg:    #fef5e4;
      --muted:         #767680;
      --muted-2:       #ababab;
      --border:        #e8e8e6;
      --border-2:      #d4d4d0;
      --radius-sm:     8px;
      --radius-md:     12px;
      --radius-lg:     18px;
      --radius-xl:     24px;
      --shadow-card:   0 1px 3px rgba(0,0,0,0.06), 0 4px 12px rgba(0,0,0,0.04);
      --shadow-hover:  0 4px 16px rgba(0,0,0,0.10), 0 10px 32px rgba(0,0,0,0.06);
      --shadow-modal:  0 24px 64px rgba(0,0,0,0.14), 0 8px 24px rgba(0,0,0,0.08);
    }

    /* ─── Base ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink);
      background: var(--surface);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ─── Page Layout ───────────────────────────────────── */
    .page-wrap {
      max-width: 1120px;
      margin: 2.5rem auto 5rem;
      padding: 0 1.25rem;
      display: flex;
      gap: 2rem;
    }

    .sidebar-col  { width: 220px; flex-shrink: 0; }
    .main-col     { flex: 1; min-width: 0; }

    @media (max-width: 768px) {
      .page-wrap { flex-direction: column; }
      .sidebar-col { width: 100%; }
    }

    /* ─── Page Header ───────────────────────────────────── */
    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 1.75rem;
      gap: 1rem;
    }

    .page-title {
      font-family: 'Instrument Serif', serif;
      font-size: 2rem;
      font-weight: 400;
      letter-spacing: -0.02em;
      color: var(--ink);
      line-height: 1.1;
    }

    .page-subtitle {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 4px;
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    .btn-shop-more {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 18px;
      background: var(--ink);
      color: #fff;
      border-radius: var(--radius-md);
      font-size: 0.8rem;
      font-weight: 700;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: 0.02em;
      transition: background 0.18s, transform 0.15s;
      white-space: nowrap;
    }
    .btn-shop-more:hover  { background: var(--accent); transform: translateY(-1px); }
    .btn-shop-more:active { transform: translateY(0); }

    /* ─── Order Card ────────────────────────────────────── */
    .order-list   { display: flex; flex-direction: column; gap: 14px; }

    .order-card {
      background: var(--card);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: box-shadow 0.25s, transform 0.22s, border-color 0.22s;
      animation: fadeUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .order-card:hover {
      box-shadow: var(--shadow-hover);
      transform: translateY(-2px);
      border-color: var(--border-2);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Card Header */
    .order-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 20px 13px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
    }

    .order-id {
      font-size: 0.82rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: 0.01em;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .order-id i { color: var(--accent); font-size: 0.75rem; }

    .order-date {
      font-size: 0.73rem;
      color: var(--muted);
      margin-top: 2px;
      font-weight: 500;
    }

    /* Card Body */
    .order-card-body {
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    /* Thumbnails */
    .item-previews { display: flex; align-items: center; flex-shrink: 0; }

    .item-thumb {
      width: 48px; height: 48px;
      border-radius: var(--radius-sm);
      object-fit: cover;
      border: 2px solid var(--card);
      box-shadow: 0 0 0 1px var(--border);
      margin-right: -8px;
      transition: transform 0.18s;
    }
    .item-thumb:hover { transform: scale(1.05) translateY(-1px); z-index: 2; }

    .item-thumb-more {
      width: 48px; height: 48px;
      border-radius: var(--radius-sm);
      background: var(--accent-light);
      color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.72rem;
      font-weight: 800;
      border: 2px solid var(--card);
      box-shadow: 0 0 0 1px var(--border);
      margin-right: -8px;
      letter-spacing: -0.01em;
    }

    /* Meta */
    .order-meta { flex: 1; min-width: 170px; }

    .meta-row {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.79rem;
      color: var(--muted);
      margin-bottom: 3px;
      font-weight: 500;
    }
    .meta-row i { width: 13px; text-align: center; font-size: 0.72rem; color: var(--muted-2); }
    .meta-row strong { color: var(--ink); font-weight: 700; }

    .grand-total {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
    }

    /* ─── Status Badges ─────────────────────────────────── */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 11px;
      border-radius: 30px;
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      white-space: nowrap;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .status-badge::before {
      content: '';
      width: 5px; height: 5px;
      border-radius: 50%;
      background: currentColor;
      opacity: 0.8;
      flex-shrink: 0;
    }

    .s-pending         { background: var(--warning-bg); color: var(--warning); }
    .s-processing      { background: #e8f0fd;           color: #1a40a8; }
    .s-paid            { background: var(--success-bg); color: var(--success); }
    .s-delivered       { background: var(--success-bg); color: var(--success); }
    .s-cancelled       { background: var(--danger-bg);  color: var(--danger); }
    .s-return-req      { background: #fff3e8;           color: #8a3a00; }
    .s-return-accepted { background: var(--success-bg); color: var(--success); }
    .s-returned        { background: var(--surface-2);  color: var(--muted); }
    .s-default         { background: var(--surface-2);  color: var(--ink); }

    /* ─── Action Buttons ────────────────────────────────── */
    .btn-action {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
      border: none;
      transition: all 0.17s;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: 0.01em;
    }
    .btn-action i { font-size: 0.72rem; }

    .btn-view        { background: var(--ink);    color: #fff; }
    .btn-view:hover  { background: var(--accent); transform: translateY(-1px); }

    .btn-cancel       { background: var(--danger-bg);  color: var(--danger); }
    .btn-cancel:hover { background: #fbe0de; }

    .btn-return       { background: #fff3e8; color: #c25400; }
    .btn-return:hover { background: #ffe9d4; }

    /* ─── Coupon Tag ────────────────────────────────────── */
    .coupon-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--warning-bg);
      border: 1.5px dashed #f0b429;
      color: var(--warning);
      border-radius: 6px;
      padding: 2px 8px;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.03em;
    }

    /* ─── Modal ─────────────────────────────────────────── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(12, 12, 13, 0.65);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.open { display: flex; }

    .modal-box {
      background: var(--card);
      border-radius: var(--radius-xl);
      width: 100%;
      max-width: 660px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: var(--shadow-modal);
      animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      border: 1px solid var(--border);
    }
    .modal-box::-webkit-scrollbar { width: 4px; }
    .modal-box::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 10px; }

    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.94) translateY(18px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 20px 24px 18px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--card);
      z-index: 2;
    }

    .modal-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--ink);
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .modal-title i { color: var(--accent); font-size: 0.9rem; }

    .modal-subtitle {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 4px;
      font-family: 'Plus Jakarta Sans', monospace;
      font-weight: 600;
      letter-spacing: 0.04em;
    }

    .modal-close {
      width: 30px; height: 30px;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid var(--border);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      color: var(--muted);
      transition: all 0.17s;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .modal-close:hover { background: var(--danger-bg); color: var(--danger); border-color: transparent; }

    .modal-body { padding: 20px 24px; }

    .modal-section-title {
      font-weight: 800;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-bottom: 12px;
      margin-top: 22px;
    }
    .modal-section-title:first-child { margin-top: 0; }

    /* Invoice btn */
    .btn-invoice {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent);
      background: var(--accent-light);
      padding: 5px 12px;
      border-radius: var(--radius-sm);
      border: none;
      cursor: pointer;
      transition: all 0.17s;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: 0.01em;
      margin-bottom: 18px;
    }
    .btn-invoice:hover { background: #dce5fd; transform: translateY(-1px); }

    /* Info Grid */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .info-block {
      background: var(--surface);
      border-radius: var(--radius-md);
      padding: 11px 14px;
      border: 1px solid var(--border);
    }

    .info-block-label {
      font-size: 0.67rem;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }

    .info-block-value {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.3;
    }

    /* Modal Item Row */
    .modal-item-row {
      display: flex;
      align-items: center;
      gap: 13px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .modal-item-row:last-child { border-bottom: none; }

    .modal-item-img {
      width: 54px; height: 54px;
      border-radius: var(--radius-sm);
      object-fit: cover;
      flex-shrink: 0;
      border: 1px solid var(--border);
    }

    .modal-item-name {
      font-weight: 700;
      font-size: 0.86rem;
      color: var(--ink);
      margin-bottom: 5px;
      line-height: 1.3;
    }

    .modal-item-meta {
      font-size: 0.72rem;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      font-weight: 600;
    }

    .meta-chip {
      background: var(--surface-2);
      color: var(--ink-2);
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .modal-item-price {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 0.95rem;
      color: var(--ink);
      margin-left: auto;
      flex-shrink: 0;
      letter-spacing: -0.01em;
    }

    /* Price Summary */
    .total-block {
      background: var(--surface);
      border-radius: var(--radius-md);
      padding: 15px 17px;
      margin-top: 14px;
      border: 1px solid var(--border);
    }

    .total-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.83rem;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 8px;
    }
    .total-row:last-child  { margin-bottom: 0; }
    .total-row.saving      { color: var(--success); font-weight: 700; }
    .total-row.grand {
      color: var(--ink);
      font-weight: 800;
      font-size: 1rem;
      padding-top: 11px;
      border-top: 1.5px dashed var(--border-2);
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: -0.01em;
    }

    /* Progress Tracker */
    .progress-track {
      display: flex;
      align-items: center;
      margin-bottom: 6px;
    }

    .prog-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
    }

    .prog-dot {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--border);
      color: var(--muted-2);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.62rem;
      font-weight: 800;
      z-index: 1;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      border: 2px solid transparent;
    }
    .prog-dot.done   { background: var(--accent); color: #fff; border-color: var(--accent); }
    .prog-dot.active { background: var(--accent); color: #fff; border-color: transparent; box-shadow: 0 0 0 5px var(--accent-light); }

    .prog-label {
      font-size: 0.63rem;
      color: var(--muted);
      margin-top: 5px;
      text-align: center;
      font-weight: 700;
      white-space: nowrap;
      letter-spacing: 0.02em;
    }

    .prog-line {
      flex: 1;
      height: 2px;
      background: var(--border-2);
      margin-bottom: 22px;
      border-radius: 2px;
      transition: background 0.3s;
    }
    .prog-line.done { background: var(--accent); }

    /* Modal Footer */
    .modal-footer {
      padding: 15px 24px 20px;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      border-top: 1px solid var(--border);
    }

    .btn-close-modal {
      padding: 9px 20px;
      background: var(--surface);
      border: 1px solid var(--border-2);
      border-radius: var(--radius-sm);
      font-weight: 700;
      font-size: 0.82rem;
      cursor: pointer;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--ink);
      transition: background 0.17s;
    }
    .btn-close-modal:hover { background: var(--surface-2); }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 72px 24px;
      background: var(--card);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-card);
    }

    .empty-icon {
      width: 72px; height: 72px;
      border-radius: var(--radius-lg);
      background: var(--surface-2);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      color: var(--muted-2);
      margin: 0 auto 20px;
    }

    .empty-title {
      font-family: 'Instrument Serif', serif;
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .empty-sub {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 24px;
    }

    .btn-start-shopping {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 26px;
      background: var(--ink);
      color: #fff;
      border-radius: var(--radius-md);
      font-weight: 700;
      text-decoration: none;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.88rem;
      transition: background 0.18s, transform 0.15s;
    }
    .btn-start-shopping:hover { background: var(--accent); transform: translateY(-1px); }

    /* Payment status dot */
    .pay-dot {
      display: inline-block;
      width: 7px; height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* Stagger delays */
    .order-card:nth-child(1)  { animation-delay: 0.00s; }
    .order-card:nth-child(2)  { animation-delay: 0.05s; }
    .order-card:nth-child(3)  { animation-delay: 0.10s; }
    .order-card:nth-child(4)  { animation-delay: 0.15s; }
    .order-card:nth-child(5)  { animation-delay: 0.20s; }
    .order-card:nth-child(n+6){ animation-delay: 0.25s; }
  </style>
</head>
<body>
  <%- include('../partials/headerPartial') %>

  <div class="page-wrap">

    <!-- Sidebar -->
    <div class="sidebar-col">
      <%- include('./partial') %>
    </div>

    <!-- Main Content -->
    <div class="main-col">

      <!-- Page Header -->
      <div class="page-header">
        <div>
          <h1 class="page-title">My Orders</h1>
          <p class="page-subtitle">
            <% if(orders && orders.length > 0){ %>
              <%= orders.length %> order<%= orders.length > 1 ? 's' : '' %> placed
            <% } else { %>No orders yet<% } %>
          </p>
        </div>
        <a href="/shop" class="btn-shop-more">
          <i class="fas fa-shopping-bag"></i> Shop More
        </a>
      </div>

      <% if (orders && orders.length > 0) { %>
        <%
          const sorted = orders.slice().sort((a,b) => new Date(b.orderDate) - new Date(a.orderDate));

          const statusClass = s => ({
            pending:           's-pending',
            processing:        's-processing',
            paid:              's-paid',
            delivered:         's-delivered',
            cancelled:         's-cancelled',
            'return requested':'s-return-req',
            'return accepted': 's-return-accepted',
            returned:          's-returned'
          }[s] || 's-default');

          const statusLabel = s => ({
            pending:           'Pending',
            processing:        'Processing',
            paid:              'Paid',
            delivered:         'Delivered',
            cancelled:         'Cancelled',
            'return requested':'Return Requested',
            'return accepted': 'Return Accepted',
            returned:          'Returned'
          }[s] || s.charAt(0).toUpperCase() + s.slice(1));

          const trackSteps  = ['pending','processing','paid','delivered'];
          const trackLabels = ['Placed','Processing','Confirmed','Delivered'];
          const trackIcons  = ['clock','cog','check-circle','box'];
        %>

        <div class="order-list">
          <% sorted.forEach((order, oi) => {
            const itemCount      = order.items ? order.items.length : 0;
            const itemSubtotal   = order.items ? order.items.reduce((s,i) => s + (i.price * i.quantity), 0) : 0;
            const couponDiscount = order.coupon?.discountAmount || 0;
            const couponCode     = order.coupon?.code || null;
            const tax            = order.tax || 0;
            const grandTotal     = order.grandTotal || 0;
            const curTrackIdx    = trackSteps.indexOf(order.status);
            const isCancelled    = order.status === 'cancelled';
            const isSpecial      = ['return_requested','return_accepted','returned'].includes(order.status);
            const showTracker    = !isCancelled && !isSpecial;
            const canCancel      = !['cancelled','delivered','return_requested','return_accepted','returned'].includes(order.status);
            const canReturn      = order.status === 'delivered';
            const isPaid         = order.payment_status === 'paid';
          %>

          <!-- ── ORDER CARD ── -->
          <div class="order-card">

            <!-- Header -->
            <div class="order-card-header">
              <div>
                <div class="order-id">
                  <i class="fas fa-receipt"></i>
                  <%= order.orderId || ('#' + order._id.toString().slice(-8).toUpperCase()) %>
                </div>
                <div class="order-date">
                  <i class="far fa-calendar-alt"></i>
                  <%= new Date(order.orderDate).toLocaleDateString('en-IN', {year:'numeric', month:'short', day:'numeric'}) %>
                  &nbsp;·&nbsp;
                  <%= new Date(order.orderDate).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit', hour12:true}) %>
                </div>
              </div>
              <span class="status-badge <%= statusClass(order.status) %>">
                <%= statusLabel(order.status) %>
              </span>
            </div>

            <!-- Body -->
            <div class="order-card-body">

              <!-- Thumbnails -->
              <div class="item-previews">
                <% const previewItems = order.items ? order.items.slice(0, 3) : []; %>
                <% previewItems.forEach(item => { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>" class="item-thumb"
                    onerror="this.src='https://placehold.co/48x48/f0f0ee/ababab?text=?'">
                <% }) %>
                <% if (order.items && order.items.length > 3) { %>
                  <div class="item-thumb-more">+<%= order.items.length - 3 %></div>
                <% } %>
              </div>

              <!-- Meta -->
              <div class="order-meta">
                <div class="meta-row">
                  <i class="fas fa-box"></i>
                  <strong><%= itemCount %> item<%= itemCount !== 1 ? 's' : '' %></strong>
                </div>
                <div class="meta-row">
                  <i class="fas fa-credit-card"></i>
                  <span><%= order.paymentMethod === 'cod' ? 'Cash on Delivery' : order.paymentMethod %></span>
                </div>
                <div class="meta-row">
                  <span class="pay-dot" style="background:<%= isPaid ? '#0e7a45' : '#d97706' %>"></span>
                  <span style="text-transform:capitalize;"><%= order.payment_status %></span>
                </div>
                <% if (couponCode) { %>
                <div class="meta-row" style="margin-top:4px;">
                  <span class="coupon-tag"><i class="fas fa-tag" style="font-size:0.6rem;"></i> <%= couponCode %></span>
                  <span style="color:var(--success);font-size:0.75rem;font-weight:700;">−₹<%= couponDiscount.toFixed(2) %></span>
                </div>
                <% } %>
              </div>

              <!-- Total -->
              <div style="text-align:right;margin-left:auto;flex-shrink:0;">
                <div style="font-size:0.63rem;color:var(--muted);font-weight:800;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2px;">Total</div>
                <div class="grand-total">₹<%= grandTotal.toFixed(2) %></div>
              </div>

              <!-- Actions -->
              <div style="display:flex;gap:7px;flex-wrap:wrap;flex-shrink:0;">
                <button class="btn-action btn-view" onclick="openModal('<%= order._id %>')">
                  <i class="fas fa-eye"></i> View
                </button>
                <% if (canCancel) { %>
                  <form action="/profile/orders/cancel/<%= order._id %>" method="post" class="order-cancel-form">
                    <button type="submit" class="btn-action btn-cancel">
                      <i class="fas fa-times"></i> Cancel
                    </button>
                  </form>
                <% } else if (canReturn) { %>
                  <form action="/profile/orders/return/<%= order._id %>" method="post" class="order-return-form">
                    <button type="submit" class="btn-action btn-return">
                      <i class="fas fa-undo"></i> Return
                    </button>
                  </form>
                <% } %>
              </div>

            </div>
          </div>
          <!-- end order card -->

          <!-- ── ORDER MODAL ── -->
          <div class="modal-overlay" id="modal-<%= order._id %>">
            <div class="modal-box">

              <div class="modal-header">
                <div>
                  <div class="modal-title">
                    <i class="fas fa-receipt"></i> Order Details
                  </div>
                  <div class="modal-subtitle"><%= order.orderId || order._id.toString() %></div>
                </div>
                <button class="modal-close" onclick="closeModal('<%= order._id %>')">
                  <i class="fas fa-times"></i>
                </button>
              </div>

              <div class="modal-body">

                <button class="btn-invoice" onclick="downloadInvoice('<%= order._id %>')">
                  <i class="fas fa-file-invoice"></i> Download Invoice
                </button>

                <!-- Progress Tracker -->
                <% if (showTracker) { %>
                <div class="modal-section-title">Order Progress</div>
                <div class="progress-track">
                  <% trackSteps.forEach((step, si) => { %>
                    <div class="prog-step">
                      <div class="prog-dot <%= si < curTrackIdx ? 'done' : (si === curTrackIdx ? 'active' : '') %>">
                        <i class="fas fa-<%= trackIcons[si] %>" style="font-size:0.6rem;"></i>
                      </div>
                      <div class="prog-label"><%= trackLabels[si] %></div>
                    </div>
                    <% if (si < trackSteps.length - 1) { %>
                      <div class="prog-line <%= si < curTrackIdx ? 'done' : '' %>"></div>
                    <% } %>
                  <% }) %>
                </div>
                <% } %>

                <!-- Order Info -->
                <div class="modal-section-title">Order Info</div>
                <div class="info-grid">
                  <div class="info-block">
                    <div class="info-block-label">Order Status</div>
                    <div class="info-block-value">
                      <span class="status-badge <%= statusClass(order.status) %>" style="font-size:0.68rem;padding:3px 9px;">
                        <%= statusLabel(order.status) %>
                      </span>
                    </div>
                  </div>
                  <div class="info-block">
                    <div class="info-block-label">Payment Method</div>
                    <div class="info-block-value" style="text-transform:capitalize;">
                      <%= order.paymentMethod === 'cod' ? 'Cash on Delivery' : order.paymentMethod %>
                    </div>
                  </div>
                  <div class="info-block">
                    <div class="info-block-label">Payment Status</div>
                    <div class="info-block-value" style="color:<%= isPaid ? 'var(--success)' : '#c27c00' %>;text-transform:capitalize;">
                      <i class="fas fa-<%= isPaid ? 'check-circle' : 'clock' %>" style="margin-right:4px;font-size:0.75rem;"></i>
                      <%= order.payment_status %>
                    </div>
                  </div>
                  <div class="info-block">
                    <div class="info-block-label">Order Date</div>
                    <div class="info-block-value" style="font-size:0.8rem;">
                      <%= new Date(order.orderDate).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                    </div>
                  </div>
                  <% if (couponCode) { %>
                  <div class="info-block" style="grid-column:span 2;">
                    <div class="info-block-label">Coupon Applied</div>
                    <div class="info-block-value" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                      <span class="coupon-tag"><i class="fas fa-tag" style="font-size:0.6rem;"></i> <%= couponCode %></span>
                      <span style="color:var(--success);font-weight:700;font-size:0.82rem;">You saved ₹<%= couponDiscount.toFixed(2) %></span>
                    </div>
                  </div>
                  <% } %>
                </div>

                <!-- Items -->
                <div class="modal-section-title">Items Ordered (<%= itemCount %>)</div>
                <% if (order.items && order.items.length > 0) { %>
                  <% order.items.forEach(item => {
                    const lineTotal = (item.price * item.quantity).toFixed(2);
                  %>
                  <div class="modal-item-row">
                    <img src="<%= item.image %>" alt="<%= item.name %>" class="modal-item-img"
                      onerror="this.src='https://placehold.co/54x54/f0f0ee/ababab?text=?'">

                    <div style="flex:1;min-width:0;">
                      <div class="modal-item-name"><%= item.name %></div>
                      <div class="modal-item-meta">
                        <% if (item.color) { %><span class="meta-chip">🎨 <%= item.color %></span><% } %>
                        <% if (item.size)  { %><span class="meta-chip">📏 <%= item.size %></span><% } %>
                        <span class="meta-chip">× <%= item.quantity %></span>
                        <span class="meta-chip" style="background:#fff3e8;color:#8a3a00;">₹<%= item.price.toFixed(2) %> each</span>
                      </div>
                    </div>

                    <div class="modal-item-price">₹<%= lineTotal %></div>

                    <% if(item.status === "pending" && order.status !== 'delivered') { %>
                      <button
                        class="cancel-item-btn meta-chip"
                        style="background:var(--danger-bg);color:var(--danger);cursor:pointer;border:none;"
                        data-product-id="<%= item.productId %>"
                        data-variant-id="<%= item.variantId %>"
                        data-order-id="<%= order._id %>">
                        Cancel
                      </button>
                    <% } else if(item.status === "delivered") { %>
                      <button
                        class="return-item-btn meta-chip"
                        style="background:var(--success-bg);color:var(--success);cursor:pointer;border:none;"
                        data-product-id="<%= item.productId %>"
                        data-variant-id="<%= item.variantId %>"
                        data-order-id="<%= order._id %>">
                        Return
                      </button>
                    <% } else if(item.status === "cancelled") { %>
                      <button class="meta-chip" style="background:var(--danger-bg);color:var(--danger);cursor:default;border:none;" disabled>
                        Cancelled
                      </button>
                   <% } else if(item.status === "returned") { %>
                      <button class="meta-chip" style="background:var(--danger-bg);color:var(--danger);cursor:default;border:none;" disabled>
                        Returned
                      </button>
                    <% } %>
                  </div>
                  <% }) %>

                  <!-- Price Breakdown -->
                  <div class="total-block">
                    <div class="total-row">
                      <span>Subtotal (<%= itemCount %> items)</span>
                      <span>₹<%= itemSubtotal.toFixed(2) %></span>
                    </div>
                    <div class="total-row">
                      <span>Shipping</span>
                      <span style="color:var(--success);font-weight:700;">Free</span>
                    </div>
                    <% if (tax > 0) { %>
                    <div class="total-row">
                      <span>Tax</span>
                      <span>₹<%= tax.toFixed(2) %></span>
                    </div>
                    <% } %>
                    <% if (couponDiscount > 0) { %>
                    <div class="total-row saving">
                      <span><i class="fas fa-tag" style="margin-right:5px;font-size:0.72rem;"></i>Coupon (<%= couponCode %>)</span>
                      <span>−₹<%= couponDiscount.toFixed(2) %></span>
                    </div>
                    <% } %>
                    <div class="total-row grand">
                      <span>Grand Total</span>
                      <span>₹<%= grandTotal.toFixed(2) %></span>
                    </div>
                  </div>

                <% } else { %>
                  <p style="color:var(--muted);font-size:0.88rem;padding:14px 0;">No items found in this order.</p>
                <% } %>

              </div>

              <!-- Modal Footer -->
              <div class="modal-footer">
                <button class="btn-close-modal" onclick="closeModal('<%= order._id %>')">Close</button>
                <% if (canCancel) { %>
                <form action="/profile/orders/cancel/<%= order._id %>" method="post" class="order-cancel-form">
                  <button type="submit" class="btn-action btn-cancel">
                    <i class="fas fa-times"></i> Cancel Order
                  </button>
                </form>
                <% } %>
              </div>

            </div>
          </div>
          <!-- end modal -->

          <% }) %>
        </div>

      <% } else { %>
        <!-- Empty State -->
        <div class="empty-state">
          <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
          <h3 class="empty-title">No orders yet</h3>
          <p class="empty-sub">Once you place an order, it'll show up here.</p>
          <a href="/shop" class="btn-start-shopping">
            <i class="fas fa-shopping-cart"></i> Start Shopping
          </a>
        </div>
      <% } %>

    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    function downloadInvoice(orderId) {
      window.open(`/profile/orders/invoice/${orderId}`, "_blank");
    }

    function openModal(id) {
      const el = document.getElementById('modal-' + id);
      if (el) { el.classList.add('open'); document.body.style.overflow = 'hidden'; }
    }
    function closeModal(id) {
      const el = document.getElementById('modal-' + id);
      if (el) { el.classList.remove('open'); document.body.style.overflow = ''; }
    }

    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', function(e) {
        if (e.target === this) { this.classList.remove('open'); document.body.style.overflow = ''; }
      });
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.open').forEach(m => {
          m.classList.remove('open'); document.body.style.overflow = '';
        });
      }
    });

    function cancelReasonHtml() {
      return `
        <div style="text-align:left;margin-top:14px;display:flex;flex-direction:column;gap:8px;font-family:'Plus Jakarta Sans',sans-serif;">
          ${[
            ['cr1','fa-exchange-alt','#2655eb','Changed my mind'],
            ['cr2','fa-clock','#c27c00','Delivery taking too long'],
            ['cr3','fa-tag','#0e7a45','Found a better price elsewhere'],
            ['cr4','fa-times-circle','#c9251d','Ordered by mistake'],
            ['cr5','fa-ellipsis-h','#767680','Other']
          ].map(([id,icon,col,label]) => `
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:9px 13px;border-radius:10px;border:1.5px solid #e8e8e6;font-weight:600;font-size:0.88rem;transition:border-color 0.15s;">
              <input type="checkbox" id="${id}" style="width:16px;height:16px;accent-color:#2655eb;">
              <i class="fas ${icon}" style="color:${col};font-size:0.78rem;width:14px;"></i>
              <span>${label}</span>
            </label>`).join('')}
        </div>`;
    }

    function cancelReasonPreConfirm() {
      const map = { cr1:'Changed my mind', cr2:'Delivery taking too long', cr3:'Found a better price elsewhere', cr4:'Ordered by mistake', cr5:'Other' };
      const reasons = Object.entries(map).filter(([id]) => document.getElementById(id)?.checked).map(([,v]) => v);
      if (!reasons.length) { Swal.showValidationMessage("Please select at least one reason"); return false; }
      return reasons;
    }

    function returnReasonHtml() {
      return `
        <div style="text-align:left;margin-top:14px;display:flex;flex-direction:column;gap:8px;font-family:'Plus Jakarta Sans',sans-serif;">
          ${[
            ['rr1','fa-exclamation-triangle','#c9251d','Item is defective'],
            ['rr2','fa-thumbs-down','#c27c00','Cheap quality'],
            ['rr3','fa-exchange-alt','#2655eb','Different product received']
          ].map(([id,icon,col,label]) => `
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:9px 13px;border-radius:10px;border:1.5px solid #e8e8e6;font-weight:600;font-size:0.88rem;">
              <input type="checkbox" id="${id}" style="width:16px;height:16px;accent-color:#2655eb;">
              <i class="fas ${icon}" style="color:${col};font-size:0.78rem;width:14px;"></i>
              <span>${label}</span>
            </label>`).join('')}
        </div>`;
    }

    function returnReasonPreConfirm() {
      const map = { rr1:'Item is defective', rr2:'Cheap quality', rr3:'Different product' };
      const reasons = Object.entries(map).filter(([id]) => document.getElementById(id)?.checked).map(([,v]) => v);
      if (!reasons.length) { Swal.showValidationMessage("Please select at least one reason"); return false; }
      return reasons;
    }

    $(document).ready(function () {
      $(".order-cancel-form").on("submit", function (e) {
        e.preventDefault();
        const form   = $(this);
        const action = form.attr("action");
        Swal.fire({
          title: "Cancel this order?",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#c9251d",
          cancelButtonColor: "#767680",
          confirmButtonText: "Yes, cancel it",
          cancelButtonText: "Keep order",
          html: cancelReasonHtml(),
          preConfirm: cancelReasonPreConfirm
        }).then(result => {
          if (result.isConfirmed) {
            $.post(action, { reasons: result.value }, function (response) {
              Swal.fire({ title: response.title, text: response.message, icon: 'success' })
                .then(() => window.location.reload());
            });
          }
        });
      });

      $(".order-return-form").on("submit", function (e) {
        e.preventDefault();
        const form   = $(this);
        const action = form.attr("action");
        Swal.fire({
          title: "Request a Return",
          icon: "question",
          showCancelButton: true,
          confirmButtonColor: "#c25400",
          cancelButtonColor: "#767680",
          confirmButtonText: "Submit Return",
          html: returnReasonHtml(),
          preConfirm: returnReasonPreConfirm
        }).then(result => {
          if (result.isConfirmed) {
            $.ajax({
              url: action, type: 'POST',
              data: JSON.stringify({ reasons: result.value }),
              contentType: 'application/json',
              success: res => {
                if (res.status === 'success')
                  Swal.fire({ title: res.title, text: res.message, icon: 'success' }).then(() => window.location.reload());
                else
                  Swal.fire({ title: res.title, text: res.message, icon: 'error' });
              }
            });
          }
        });
      });
    });

    function handleOrderAction(button, url, title, html, preConfirm, confirmText, successText, badgeHtml) {
      const productId = button.data("product-id");
      const variantId = button.data("variant-id");
      const orderId   = button.data("order-id");

      Swal.fire({
        title, icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#ef4444",
        cancelButtonColor: "#767680",
        confirmButtonText: confirmText,
        html, preConfirm
      }).then((result) => {
        if (!result.isConfirmed) return;
        $.ajax({
          url, method: "POST",
          data: { productId, variantId, orderId, reasons: result.value },
          success: function () {
            Swal.fire({ icon: "success", title: successText, timer: 1500, showConfirmButton: false });
            button.replaceWith(badgeHtml);
          },
          error: function () {
            Swal.fire("Error", "Something went wrong", "error");
          }
        });
      });
    }

    $(document).on("click", ".cancel-item-btn", function () {
      handleOrderAction(
        $(this),
        "/profile/orders/cancel-item",
        "Cancel this item?",
        cancelReasonHtml(),
        cancelReasonPreConfirm,
        "Yes, cancel it",
        "Item cancelled",
        `<span class="meta-chip" style="background:var(--danger-bg);color:var(--danger);">Cancelled</span>`
      );
    });

    $(document).on("click", ".return-item-btn", function () {
      handleOrderAction(
        $(this),
        "/profile/orders/return-item",
        "Return this item?",
        returnReasonHtml(),
        returnReasonPreConfirm,
        "Request Return",
        "Return requested",
        `<span class="meta-chip" style="background:var(--warning-bg);color:var(--warning);">Return Requested</span>`
      );
    });
  </script>
</body>
</html>
