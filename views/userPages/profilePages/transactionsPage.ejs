<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wallet Transactions</title>
    <link rel="stylesheet" href="/styles/profile.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <style>
      body {
        background-color: #f8f9fa;
      }

      .transactions-container {
        max-width: 1000px;
        margin: 30px auto;
        background-color: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        padding: 25px;
      }

      .transactions-heading {
        color: #343a40;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
        font-weight: 600;
      }

      .wallet-balance {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
      }

      .balance-label {
        font-size: 0.9rem;
        opacity: 0.9;
        margin-bottom: 5px;
      }

      .balance-amount {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
      }

      .transactions-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-top: 20px;
      }

      .transactions-table th,
      .transactions-table td {
        padding: 16px;
        text-align: left;
        vertical-align: middle;
      }

      .transactions-table th {
        background-color: #f8f9fa;
        color: #495057;
        font-weight: 600;
        border-bottom: 2px solid #dee2e6;
      }

      .transactions-table tbody tr {
        border-bottom: 1px solid #f0f0f0;
        transition: background-color 0.2s;
      }

      .transactions-table tbody tr:hover {
        background-color: #f8f9fa;
      }

      .transaction-type {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 500;
        font-size: 0.9rem;
        text-align: center;
        min-width: 80px;
        text-transform: capitalize;
      }

      .transaction-type.credit {
        background-color: #d4edda;
        color: #155724;
      }

      .transaction-type.debit {
        background-color: #f8d7da;
        color: #721c24;
      }

      .transaction-amount {
        font-weight: 600;
        font-size: 1.1rem;
      }

      .transaction-amount.credit {
        color: #28a745;
      }

      .transaction-amount.debit {
        color: #dc3545;
      }

      .transaction-amount.credit::before {
        content: '+';
      }

      .transaction-amount.debit::before {
        content: '-';
      }

      .transaction-description {
        color: #6c757d;
        font-style: italic;
      }

      .transaction-date {
        color: #495057;
        font-size: 0.9rem;
      }

      .no-transactions {
        text-align: center;
        padding: 50px 20px;
        background-color: #f8f9fa;
        border-radius: 12px;
        margin-top: 20px;
        color: #6c757d;
      }

      .no-transactions i {
        color: #adb5bd;
        margin-bottom: 20px;
      }

      .no-transactions .btn {
        padding: 10px 25px;
        border-radius: 25px;
        font-weight: 500;
      }

      .table-responsive-container {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .transactions-table {
        width: 100%;
        min-width: 700px;
      }

      .transactions-container {
        flex: 1;
        min-width: 0;
        max-width: 100%;
      }

      @media (max-width: 992px) {
        .sidebar-container {
          max-width: 100%;
          margin-bottom: 0;
        }

        .container-fluid {
          flex-direction: column;
        }

        .transactions-container {
          max-width: 100%;
          margin: 0 auto;
        }
      }

      @media (max-width: 1000px) {
        .table-responsive-container {
          overflow-x: auto;
        }

        .transactions-container {
          padding: 15px;
        }

        .balance-amount {
          font-size: 1.5rem;
        }
      }

      @media (max-width: 576px) {
        .transactions-table th,
        .transactions-table td {
          padding: 12px 8px;
          font-size: 0.9rem;
        }

        .transaction-type {
          font-size: 0.8rem;
          padding: 4px 8px;
        }

        .transaction-amount {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <%- include('../partials/headerPartial') %>
    <div
      class="container-fluid d-flex flex-wrap"
      style="gap: 20px; padding: 20px"
    >
      <div class="m-35"><%- include('./partial') %></div>
      <div class="transactions-container">
        <h2 class="transactions-heading">
          <i class="fas fa-wallet me-2"></i> Wallet Transactions
        </h2>

        <!-- Wallet Balance Display -->
        <div class="wallet-balance">
          <div class="balance-label">Current Wallet Balance</div>
          <h3 class="balance-amount">₹ <%= walletBalance || '0.00' %></h3>
        </div>

        <% if (transactions && transactions.length > 0) { %>
        <div class="table-responsive-container">
          <table class="transactions-table">
            <thead>
              <tr>
                <th><i class="fas fa-exchange-alt me-2"></i>Type</th>
                <th><i class="fas fa-dollar-sign me-2"></i>Amount</th>
                <th><i class="fas fa-info-circle me-2"></i>Description</th>
                <th><i class="fas fa-calendar me-2"></i>Date</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(txn => { %>
              <tr>
                <td>
                  <span class="transaction-type <%= txn.type %>">
                    <% if (txn.type === 'credit') { %>
                      <i class="fas fa-arrow-down me-1"></i>
                    <% } else { %>
                      <i class="fas fa-arrow-up me-1"></i>
                    <% } %>
                    <%= txn.type %>
                  </span>
                </td>
                <td>
                  <span class="transaction-amount <%= txn.type %>">
                    ₹<%= txn.amount.toFixed(2) %>
                  </span>
                </td>
                <td class="transaction-description">
                  <%= txn.description || "No description available" %>
                </td>
                <td class="transaction-date">
                  <%= new Date(txn.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="no-transactions">
          <i class="fas fa-wallet fa-4x mb-4"></i>
          <h3>No transactions yet</h3>
          <p class="mb-4">
            Your wallet transaction history will appear here once you make purchases or receive refunds
          </p>
          <a href="/shop" class="btn btn-primary mt-2">
            <i class="fas fa-shopping-cart me-2"></i> Start Shopping
          </a>
        </div>
        <% } %>
      </div>
    </div>
    <%- include('../partials/footer') %>

    <!-- Required Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
  </body>
</html>