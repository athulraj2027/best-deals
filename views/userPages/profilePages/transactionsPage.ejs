<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wallet Transactions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <style>
      /* Optional: Custom scrollbar for table */
      .table-container::-webkit-scrollbar {
        height: 6px;
      }
      .table-container::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.5);
        border-radius: 3px;
      }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-800">
    <%- include('../partials/headerPartial') %>

    <div class="flex flex-wrap md:flex-nowrap gap-6 p-6">
      <!-- Sidebar -->
      <div class="w-full md:w-64">
        <%- include('./partial') %>
      </div>

      <!-- Wallet Transactions -->
      <div class="flex-1 max-w-5xl mx-auto space-y-6">
        <!-- Heading -->
        <h2 class="text-2xl font-semibold text-gray-800 border-b border-gray-200 pb-3 flex items-center">
          <i class="fas fa-wallet mr-2 text-blue-600"></i> Wallet Transactions
        </h2>

        <!-- Wallet Balance Card -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white p-6 rounded-xl shadow-lg text-center">
          <div class="text-sm opacity-90 mb-1">Current Wallet Balance</div>
          <h3 class="text-3xl font-bold">₹ <%= walletBalance || '0.00' %></h3>
        </div>

        <!-- Transactions Table -->
        <% if (transactions && transactions.length > 0) { %>
        <div class="overflow-x-auto table-container rounded-lg shadow-sm bg-white">
          <table class="min-w-[700px] w-full text-left border-separate border-spacing-0">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 font-semibold text-gray-700 border-b border-gray-200">
                  <i class="fas fa-exchange-alt mr-2"></i> Type
                </th>
                <th class="px-6 py-3 font-semibold text-gray-700 border-b border-gray-200">
                  <i class="fas fa-dollar-sign mr-2"></i> Amount
                </th>
                <th class="px-6 py-3 font-semibold text-gray-700 border-b border-gray-200">
                  <i class="fas fa-info-circle mr-2"></i> Description
                </th>
                <th class="px-6 py-3 font-semibold text-gray-700 border-b border-gray-200">
                  <i class="fas fa-calendar mr-2"></i> Date
                </th>
              </tr>
            </thead>
            <tbody>
              <% transactions.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(txn => { %>
              <tr class="hover:bg-gray-50 border-b border-gray-200">
                <td class="px-6 py-4">
                  <span class="inline-block px-3 py-1 rounded-full font-medium text-sm text-center <%= txn.type === 'credit' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %> capitalize">
                    <% if (txn.type === 'credit') { %>
                      <i class="fas fa-arrow-down mr-1"></i>
                    <% } else { %>
                      <i class="fas fa-arrow-up mr-1"></i>
                    <% } %>
                    <%= txn.type %>
                  </span>
                </td>
                <td class="px-6 py-4 font-semibold text-lg <%= txn.type === 'credit' ? 'text-green-600' : 'text-red-600' %>">
                  ₹<%= txn.amount.toFixed(2) %>
                </td>
                <td class="px-6 py-4 text-gray-500 italic">
                  <%= txn.description || "No description available" %>
                </td>
                <td class="px-6 py-4 text-gray-600 text-sm">
                  <%= new Date(txn.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <!-- No Transactions -->
        <div class="bg-white rounded-xl shadow-md text-center p-12 space-y-4">
          <i class="fas fa-wallet fa-4x text-gray-400"></i>
          <h3 class="text-xl font-semibold text-gray-700">No transactions yet</h3>
          <p class="text-gray-500 max-w-md mx-auto">
            Your wallet transaction history will appear here once you make purchases or receive refunds
          </p>
          <a href="/shop" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-full transition">
            <i class="fas fa-shopping-cart mr-2"></i> Start Shopping
          </a>
        </div>
        <% } %>
      </div>
    </div>

    <%- include('../partials/footer') %>
  </body>
</html>
