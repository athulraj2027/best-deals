<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Security Settings | Tech Gadgets</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .input-focus { transition: all 0.3s ease; }
        .input-focus:focus { ring: 4px; ring-color: rgba(79, 70, 229, 0.1); border-color: #4f46e5; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <%- include('../partials/headerPartial') %>

    <div class="max-w-6xl mx-auto mt-10 px-4 pb-16 flex flex-col md:flex-row gap-8">
        
        <div class="w-full md:w-1/4 flex-shrink-0">
            <%- include('./partial') %>
        </div>

        <div class="flex-1 min-w-0">
            <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/50 overflow-hidden animate-in fade-in slide-in-from-bottom-4 duration-500">
                
                <div class="p-8 border-b border-slate-50 bg-slate-50/30 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-indigo-100">
                            <i class="fas fa-shield-halved text-lg"></i>
                        </div>
                        <div>
                            <h2 class="text-2xl font-black tracking-tight text-slate-900">Security Center</h2>
                            <p class="text-slate-400 text-sm font-medium">Protect your account with a high-entropy password</p>
                        </div>
                    </div>
                </div>

                <div class="p-8">
                    <div class="mb-8 p-6 bg-indigo-50 border border-indigo-100 rounded-3xl flex gap-4 items-start">
                        <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-indigo-600 shadow-sm shrink-0">
                            <i class="fas fa-key"></i>
                        </div>
                        <p class="text-sm text-indigo-800 leading-relaxed font-medium">
                            <strong class="block text-indigo-900 mb-1 font-extrabold uppercase tracking-widest text-[10px]">Security Recommendation</strong>
                            Regularly updating your credentials ensures your digital assets and order history remain exclusive to you. Avoid reused passwords.
                        </p>
                    </div>

                    <form id="passwordChangeForm" class="space-y-8">
                        <div class="space-y-6">
                            <div class="group">
                                <label for="currentPassword" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Current Password</label>
                                <div class="relative">
                                    <input type="password" id="currentPassword" name="currentPassword" required 
                                        class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" />
                                    <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 hover:text-indigo-600 toggle-password" data-target="currentPassword">
                                        <i class="far fa-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="group">
                                    <label for="newPassword" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">New Password</label>
                                    <div class="relative">
                                        <input type="password" id="newPassword" name="newPassword" required 
                                            class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" />
                                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 hover:text-indigo-600 toggle-password" data-target="newPassword">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="group">
                                    <label for="confirmPassword" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Verify Password</label>
                                    <div class="relative">
                                        <input type="password" id="confirmPassword" name="confirmPassword" required 
                                            class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" />
                                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 hover:text-indigo-600 toggle-password" data-target="confirmPassword">
                                            <i class="far fa-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-slate-900 rounded-[2rem] p-8 text-white relative overflow-hidden shadow-2xl shadow-indigo-900/20">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/10 rounded-full blur-2xl -mr-16 -mt-16"></div>
                            <h6 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-6">Real-time Entropy Check</h6>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-4 gap-x-8">
                                <div class="flex items-center gap-3 transition-all duration-300" id="lengthReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">8+ Characters</span>
                                </div>
                                <div class="flex items-center gap-3 transition-all duration-300" id="upperReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">Uppercase Letter</span>
                                </div>
                                <div class="flex items-center gap-3 transition-all duration-300" id="lowerReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">Lowercase Letter</span>
                                </div>
                                <div class="flex items-center gap-3 transition-all duration-300" id="numberReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">Numerical Digit</span>
                                </div>
                                <div class="flex items-center gap-3 transition-all duration-300" id="specialReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">Special Symbol</span>
                                </div>
                                <div class="flex items-center gap-3 transition-all duration-300" id="matchReq">
                                    <div class="status-icon w-5 h-5 rounded-full bg-slate-800 flex items-center justify-center text-[8px] border border-slate-700">
                                        <i class="fas fa-circle"></i>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">Checksum Match</span>
                                </div>
                            </div>
                        </div>

                        <div class="flex pt-4">
                            <button type="submit" class="flex-1 md:flex-none px-12 py-5 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95">
                                Synchronize New Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("passwordChangeForm");
            const newPass = document.getElementById("newPassword");
            const confirmPass = document.getElementById("confirmPassword");
            const toggles = document.querySelectorAll(".toggle-password");

            // Password Requirements Config
            const requirements = {
                lengthReq: (v) => v.length >= 8,
                upperReq: (v) => /[A-Z]/.test(v),
                lowerReq: (v) => /[a-z]/.test(v),
                numberReq: (v) => /\d/.test(v),
                specialReq: (v) => /[!@#$%^&*(),.?":{}|<>]/.test(v),
                matchReq: (v, c) => v && v === c,
            };

            // Toggle visibility logic
            toggles.forEach(btn => {
                btn.onclick = () => {
                    const input = document.getElementById(btn.dataset.target);
                    input.type = input.type === "password" ? "text" : "password";
                    btn.innerHTML = `<i class="far fa-eye${input.type === 'text' ? '-slash' : ''}"></i>`;
                };
            });

            // Requirements UI Updater
            function updateChecklist() {
                const v = newPass.value;
                const c = confirmPass.value;
                
                Object.keys(requirements).forEach(id => {
                    const isValid = requirements[id](v, c);
                    const el = document.getElementById(id);
                    const iconWrap = el.querySelector('.status-icon');
                    
                    if (isValid) {
                        el.classList.add('opacity-100');
                        el.querySelector('span').classList.replace('text-slate-400', 'text-emerald-400');
                        iconWrap.classList.replace('bg-slate-800', 'bg-emerald-500');
                        iconWrap.classList.replace('border-slate-700', 'border-emerald-400');
                        iconWrap.innerHTML = '<i class="fas fa-check"></i>';
                    } else {
                        el.classList.remove('opacity-100');
                        el.querySelector('span').classList.replace('text-emerald-400', 'text-slate-400');
                        iconWrap.classList.replace('bg-emerald-500', 'bg-slate-800');
                        iconWrap.classList.replace('border-emerald-400', 'border-slate-700');
                        iconWrap.innerHTML = '<i class="fas fa-circle"></i>';
                    }
                });
            }

            newPass.oninput = updateChecklist;
            confirmPass.oninput = updateChecklist;

            // Form Submit with SweetAlert
            form.onsubmit = async (e) => {
                e.preventDefault();
                
                const allMet = Object.keys(requirements).every(id => 
                    requirements[id](newPass.value, confirmPass.value)
                );

                if (!allMet) {
                    return Swal.fire({
                        icon: 'error',
                        title: 'Weak Security',
                        text: 'Please satisfy all security protocols before updating.',
                        confirmButtonColor: '#4f46e5'
                    });
                }

                Swal.fire({ title: 'Updating Credentials...', didOpen: () => Swal.showLoading() });

                try {
                    const res = await fetch("/profile/password", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            currentPassword: document.getElementById("currentPassword").value,
                            newPassword: newPass.value,
                            confirmPassword: confirmPass.value
                        })
                    });
                    const data = await res.json();

                    if (data.status === "success") {
                        Swal.fire({
                            icon: 'success',
                            title: 'Protocol Updated',
                            text: 'Your new password is now active.',
                            confirmButtonColor: '#10b981'
                        }).then(() => {
                            form.reset();
                            updateChecklist();
                        });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Authentication Failed', text: data.message });
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'System Error', text: 'Cloud connection failed.' });
                }
            };
        });
    </script>
</body>
</html>