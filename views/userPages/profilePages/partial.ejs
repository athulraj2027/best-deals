<div class="w-full max-w-xs p-4">

  <div class="bg-slate-900 rounded-xl shadow-lg p-4">

    <!-- Mobile Toggle -->
    <button 
      id="menuToggle"
      class="md:hidden w-full flex items-center justify-between bg-slate-800 text-white px-4 py-3 rounded-lg mb-3"
    >
      <span class="font-semibold">Account Menu</span>
      <i id="menuIcon" class="fas fa-bars"></i>
    </button>

    <!-- Menu -->
    <ul 
      id="sidebarMenu"
      class="space-y-2 md:block hidden"
    >

      <li>
        <a href="/profile" 
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-200 hover:bg-blue-600 hover:text-white transition">
          <i class="fas fa-user-circle"></i>
          Profile
        </a>
      </li>

      <li>
        <a href="/profile/address" 
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-200 hover:bg-blue-600 hover:text-white transition">
          <i class="fas fa-map-marker-alt"></i>
          Addresses
        </a>
      </li>

      <li>
        <a href="/profile/orders" 
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-200 hover:bg-blue-600 hover:text-white transition">
          <i class="fas fa-shopping-bag"></i>
          Orders
        </a>
      </li>

      <% if(!user.googleId) { %>
      <li>
        <a href="/profile/password" 
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-200 hover:bg-blue-600 hover:text-white transition">
          <i class="fas fa-key"></i>
          Reset Password
        </a>
      </li>
      <% } %>

      <li>
        <a href="/profile/wallet-transactions" 
           class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-200 hover:bg-blue-600 hover:text-white transition">
          <i class="fas fa-star"></i>
          My Wallet
        </a>
      </li>

    </ul>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById("menuToggle");
  const menu = document.getElementById("sidebarMenu");
  const icon = document.getElementById("menuIcon");

  toggleBtn.addEventListener("click", () => {
    menu.classList.toggle("hidden");

    if(menu.classList.contains("hidden")){
      icon.className = "fas fa-bars";
    } else {
      icon.className = "fas fa-times";
    }
  });
</script>
