<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopping Cart</title>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="userCSS/partials/partials_css.css" />
  </head>
  <body class="bg-gray-100">
    <%- include('./partials/headerPartial')%>
    <div class="container mx-auto py-8 px-4">
      <h1 class="text-3xl font-bold mb-8">Shopping Cart</h1>

      <% if (cart && cart.items && cart.items.length > 0) { %>
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Cart Items -->
        <div class="lg:w-2/3">
          <div class="bg-white rounded-lg shadow-md p-6 mb-4">
            <h2 class="text-xl font-semibold mb-4">
              Cart Items (<span id="item-count"
                ><%= cart.getItemCount() %></span
              >
              items)
            </h2>

            <div class="divide-y divide-gray-200">
              <% cart.items.forEach(item => { %>
              <div
                class="py-6 flex flex-col sm:flex-row cart-item"
                id="item-<%= item._id %>"
                data-item-price="<%= item.price %>"
              >
                <div class="sm:w-24 h-24 mb-4 sm:mb-0">
                  <img
                    src="<%= item.image %>"
                    alt="<%= item.name %>"
                    class="w-full h-full object-cover rounded"
                  />
                </div>

                <div class="flex-1 sm:ml-4">
                  <div class="flex flex-col sm:flex-row sm:justify-between">
                    <div>
                      <h3 class="text-lg font-semibold"><%= item.name %></h3>
                      <p class="text-gray-600 mt-1">
                        Color: <%= item.color %> | Size: <%= item.size %>
                      </p>
                      <p class="text-gray-800 font-medium mt-1 item-price">
                        $<%= item.price.toFixed(2) %>
                      </p>
                    </div>

                    <div class="mt-4 sm:mt-0">
                      <div class="flex items-center">
                        <form
                          class="flex items-center quantity-form"
                          data-item-id="<%= item._id %>"
                          data-product-id="<%= item.productId %>"
                          data-variant-id="<%= item.variantId %>"
                        >
                          <button
                            type="button"
                            class="quantity-btn w-8 h-8 bg-gray-200 rounded-l flex items-center justify-center hover:bg-gray-300"
                            data-action="decrease"
                          >
                            <i class="fas fa-minus text-gray-600"></i>
                          </button>

                          <input
                            type="number"
                            name="quantity"
                            value="<%= item.quantity %>"
                            min="1"
                            max="5"
                            class="quantity-input w-12 h-8 text-center border-t border-b border-gray-200"
                            readonly
                          />

                          <button
                            type="button"
                            class="quantity-btn w-8 h-8 bg-gray-200 rounded-r flex items-center justify-center hover:bg-gray-300"
                            data-action="increase"
                          >
                            <i class="fas fa-plus text-gray-600"></i>
                          </button>
                        </form>

                        <button
                          type="button"
                          class="delete-item-btn ml-4 text-red-500 hover:text-red-700"
                          data-item-id="<%= item._id %>"
                          data-product-id="<%= item.productId %>"
                          data-variant-id="<%= item.variantId %>"
                        >
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>

                      <p class="mt-2 text-right font-semibold item-total">
                        $<%= (item.price * item.quantity).toFixed(2) %>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>

            <div class="mt-6 flex justify-between items-center">
              <a href="/shop" class="text-blue-600 hover:text-blue-800">
                <i class="fas fa-arrow-left mr-2"></i>Continue Shopping
              </a>

              <button
                type="button"
                id="clear-cart-btn"
                class="text-red-600 hover:text-red-800"
                data-cart-id="<%= cart._id %>"
              >
                <i class="fas fa-times mr-2"></i>Clear Cart
              </button>
            </div>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:w-1/3">
          <div class="bg-white rounded-lg shadow-md p-6 sticky top-8">
            <h2 class="text-xl font-semibold mb-4">Order Summary</h2>

            <div class="space-y-4">
              <div class="flex justify-between">
                <span class="text-gray-600">Subtotal</span>
                <span class="font-medium" id="cart-subtotal"
                  >$<%= cart.subtotal.toFixed(2) %></span
                >
              </div>

              <div class="flex justify-between">
                <span class="text-gray-600">Tax </span>
                <span id="cart-tax">$<%= cart.tax.toFixed(2) %></span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-600">Shipping</span>
                <span id="cart-shipping">$<%= cart.shipping.toFixed(2) %></span>
              </div>

              <div class="border-t pt-4 mt-4">
                <div class="flex justify-between font-bold">
                  <span>Total</span>
                  <span id="cart-total">$<%= cart.total.toFixed(2) %></span>
                </div>
              </div>

              <a
                href="/checkout/<%= cart._id %>"
                class="block w-full bg-blue-600 text-white text-center py-3 rounded-md font-medium mt-6 hover:bg-blue-700"
              >
                Proceed to Checkout
              </a>
            </div>
          </div>
        </div>
      </div>
      <% } else { %>
      <div class="bg-white rounded-lg shadow-md p-8 text-center">
        <div class="text-gray-600 mb-4">
          <i class="fas fa-shopping-cart text-5xl"></i>
        </div>
        <h2 class="text-2xl font-semibold mb-4">Your cart is empty</h2>
        <p class="text-gray-600 mb-6">
          Looks like you haven't added any items to your cart yet.
        </p>
        <a
          href="/shop"
          class="inline-block bg-blue-600 text-white py-3 px-6 rounded-md font-medium hover:bg-blue-700"
        >
          Start Shopping
        </a>
      </div>
      <% } %>
    </div>

    <%- include('./partials/footer')%>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      $(document).ready(function () {
        // Function to update cart summary
        function updateCartSummary() {
          let subtotal = 0;

          // Calculate subtotal based on current items
          $(".cart-item").each(function () {
            const itemPrice = parseFloat($(this).data("item-price"));
            const quantity = parseInt($(this).find(".quantity-input").val());
            subtotal += itemPrice * quantity;
          });

          // Tax calculation (assuming 10% tax)
          const taxRate = 0.1;
          const tax = subtotal * taxRate;

          // Shipping calculation (assuming flat rate of $5 or free for orders over $50)
          const shipping = subtotal > 50 ? 0 : 5;

          // Total calculation
          const total = subtotal + tax + shipping;

          // Update UI
          $("#cart-subtotal").text("$" + subtotal.toFixed(2));
          $("#cart-tax").text("$" + tax.toFixed(2));
          $("#cart-shipping").text("$" + shipping.toFixed(2));
          $("#cart-total").text("$" + total.toFixed(2));
        }

        // Function to update item total
        function updateItemTotal(itemElement) {
          const itemPrice = parseFloat(itemElement.data("item-price"));
          const quantity = parseInt(itemElement.find(".quantity-input").val());
          const itemTotal = itemPrice * quantity;
          itemElement.find(".item-total").text("$" + itemTotal.toFixed(2));
        }

        // Clear cart functionality
        $("#clear-cart-btn").on("click", function () {
          const cartId = $(this).data("cart-id");

          Swal.fire({
            title: "Are you sure?",
            text: "You're about to clear your entire cart!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, clear it!",
          }).then((result) => {
            if (result.isConfirmed) {
              $.ajax({
                url: `/cart/clear/${cartId}`,
                method: "POST",
                dataType: "json",
                success: function (response) {
                  if (response.status === "success") {
                    Swal.fire({
                      icon: "success",
                      title: "Success!",
                      text: "Cart has been cleared successfully",
                      confirmButtonColor: "#28a745",
                    }).then(() => {
                      window.location.reload();
                    });
                  } else {
                    Swal.fire({
                      icon: "error",
                      title: "Error",
                      text: response.message || "Something went wrong",
                      confirmButtonColor: "#dc3545",
                    });
                  }
                },
                error: function (xhr, status, error) {
                  console.error("AJAX Error:", status, error);
                  Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: "Failed to clear cart. Please try again.",
                    confirmButtonColor: "#dc3545",
                  });
                },
              });
            }
          });
        });

        // Quantity update functionality
        $(".quantity-btn").on("click", function () {
          const form = $(this).closest(".quantity-form");
          const itemId = form.data("item-id");
          const productId = form.data("product-id");
          const variantId = form.data("variant-id");
          const action = $(this).data("action");
          const quantityInput = form.find("input[name='quantity']");
          const currentValue = parseInt(quantityInput.val());
          const itemElement = $(`#item-${itemId}`);

          // Validate input
          if (action === "increase" && currentValue >= 5) {
            Swal.fire({
              icon: "info",
              title: "Maximum Quantity",
              text: "You can't add more than 5 items",
              confirmButtonColor: "#17a2b8",
            });
            return;
          }

          if (action === "decrease" && currentValue <= 1) {
            Swal.fire({
              icon: "info",
              title: "Minimum Quantity",
              text: "Quantity cannot be less than 1",
              confirmButtonColor: "#17a2b8",
            });
            return;
          }

          $.ajax({
            url: `/cart/quantity-update/${itemId}`,
            method: "POST",
            data: {
              productId: productId,
              variantId: variantId,
              action: action,
            },
            dataType: "json",
            success: function (response) {
              if (response.status === "success") {
                // Update quantity input
                let newQuantity;
                if (action === "increase") {
                  newQuantity = currentValue + 1;
                  quantityInput.val(newQuantity);
                } else {
                  newQuantity = currentValue - 1;
                  quantityInput.val(newQuantity);
                }

                // Update item total price
                updateItemTotal(itemElement);

                // Update cart summary
                updateCartSummary();

                // Optional: Update from server response
                if (response.cart) {
                  $("#cart-subtotal").text(
                    `$${response.cart.subtotal.toFixed(2)}`
                  );
                  $("#cart-tax").text(`$${response.cart.tax.toFixed(2)}`);
                  $("#cart-shipping").text(
                    `$${response.cart.shipping.toFixed(2)}`
                  );
                  $("#cart-total").text(`$${response.cart.total.toFixed(2)}`);
                }
              } else {
                Swal.fire({
                  icon: "error",
                  title: "Error",
                  text: response.message || "Failed to update quantity",
                  confirmButtonColor: "#dc3545",
                });
              }
            },
            error: function (xhr, status, error) {
              console.error("AJAX Error:", status, error);
              Swal.fire({
                icon: "error",
                title: "Oops...",
                text: "Failed to update quantity. Please try again.",
                confirmButtonColor: "#dc3545",
              });
            },
          });
        });
        // Delete item functionality
        $(".delete-item-btn").on("click", function () {
          const itemId = $(this).data("item-id");
          const productId = $(this).data("product-id");
          const variantId = $(this).data("variant-id");
          const itemElement = $(`#item-${itemId}`);

          Swal.fire({
            title: "Are you sure?",
            text: "You're about to remove this item from your cart!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, remove it!",
          }).then((result) => {
            if (result.isConfirmed) {
              $.ajax({
                url: `/cart/delete-item/${itemId}`,
                method: "POST",
                data: {
                  productId: productId,
                  variantId: variantId,
                },
                dataType: "json",
                success: function (response) {
                  if (response.status === "success") {
                    // Remove item from DOM
                    itemElement.fadeOut(300, function () {
                      $(this).remove();

                      // Update cart summary
                      updateCartSummary();

                      // Update item count
                      const newItemCount =
                        parseInt($("#item-count").text()) - 1;
                      $("#item-count").text(newItemCount);

                      // If cart is empty, reload page to show empty cart message
                      if (newItemCount === 0) {
                        window.location.reload();
                      }

                      // Optional: Update from server response
                      if (response.cart) {
                        $("#cart-subtotal").text(
                          `$${response.cart.subtotal.toFixed(2)}`
                        );
                        $("#cart-tax").text(`$${response.cart.tax.toFixed(2)}`);
                        $("#cart-shipping").text(
                          `$${response.cart.shipping.toFixed(2)}`
                        );
                        $("#cart-total").text(
                          `$${response.cart.total.toFixed(2)}`
                        );
                        $("#item-count").text(response.cart.getItemCount());
                      }
                    });

                    Swal.fire({
                      icon: "success",
                      title: "Success!",
                      text: "Item has been removed from your cart",
                      confirmButtonColor: "#28a745",
                    });
                  } else {
                    Swal.fire({
                      icon: "error",
                      title: "Error",
                      text: response.message || "Failed to remove item",
                      confirmButtonColor: "#dc3545",
                    });
                  }
                },
                error: function (xhr, status, error) {
                  console.error("AJAX Error:", status, error);
                  Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: "Failed to remove item. Please try again.",
                    confirmButtonColor: "#dc3545",
                  });
                },
              });
            }
          });
        });

        // Initialize cart summary on page load
        updateCartSummary();
      });
    </script>
  </body>
</html>
