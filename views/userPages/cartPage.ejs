<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopping Cart</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <style>
      /* Optional: Scrollbar styling for table/long lists */
      .cart-items::-webkit-scrollbar {
        width: 6px;
      }
      .cart-items::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.5);
        border-radius: 3px;
      }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-800">
    <%- include('./partials/headerPartial') %>

    <div class="container mx-auto py-10 px-4">
      <h1 class="text-3xl font-bold mb-10">Shopping Cart</h1>

      <% if (cart && cart.items && cart.items.length > 0) { %>
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Cart Items -->
        <div class="lg:w-2/3 space-y-6">
          <% cart.items.forEach(item => { %>
          <div
            class="bg-white rounded-xl shadow p-6 flex flex-col sm:flex-row items-center sm:items-start gap-6 cart-item"
            id="item-<%= item._id %>"
            data-item-price="<%= item.price %>"
          >
            <!-- Image -->
            <div class="w-28 h-28 flex-shrink-0">
              <img
                src="<%= item.image %>"
                alt="<%= item.name %>"
                class="w-full h-full object-cover rounded-lg"
              />
            </div>

            <!-- Details -->
            <div class="flex-1 w-full flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              <div>
                <h2 class="text-lg font-semibold"><%= item.name %></h2>
                <p class="text-gray-500 mt-1">Color: <%= item.color %> | Size: <%= item.size %></p>
                <p class="text-gray-800 font-medium mt-1 item-price">₹<%= item.price.toFixed(2) %></p>
              </div>

              <!-- Quantity & Total -->
              <div class="flex flex-col items-end gap-2">
                <div class="flex items-center gap-2">
                  <form
                    class="flex items-center quantity-form"
                    data-item-id="<%= item._id %>"
                    data-product-id="<%= item.productId %>"
                    data-variant-id="<%= item.variantId %>"
                  >
                    <button
                      type="button"
                      class="quantity-btn w-8 h-8 bg-gray-200 rounded-l hover:bg-gray-300 flex items-center justify-center"
                      data-action="decrease"
                    >
                      <i class="fas fa-minus text-gray-600"></i>
                    </button>

                    <input
                      type="number"
                      name="quantity"
                      value="<%= item.quantity %>"
                      min="1"
                      max="5"
                      class="quantity-input w-12 h-8 text-center border-t border-b border-gray-300"
                      readonly
                    />

                    <button
                      type="button"
                      class="quantity-btn w-8 h-8 bg-gray-200 rounded-r hover:bg-gray-300 flex items-center justify-center"
                      data-action="increase"
                    >
                      <i class="fas fa-plus text-gray-600"></i>
                    </button>
                  </form>

                  <button
                    type="button"
                    class="delete-item-btn text-red-500 hover:text-red-700"
                    data-item-id="<%= item._id %>"
                    data-product-id="<%= item.productId %>"
                    data-variant-id="<%= item.variantId %>"
                  >
                    <i class="fas fa-trash"></i>
                  </button>
                </div>

                <p class="font-semibold item-total">₹<%= (item.price * item.quantity).toFixed(2) %></p>
              </div>
            </div>
          </div>
          <% }) %>

          <!-- Continue Shopping / Clear Cart -->
          <div class="flex justify-between items-center mt-4">
            <a href="/shop" class="text-blue-600 hover:text-blue-800 font-medium flex items-center gap-2">
              <i class="fas fa-arrow-left"></i> Continue Shopping
            </a>
            <button
              id="clear-cart-btn"
              class="text-red-600 hover:text-red-800 font-medium flex items-center gap-2"
              data-cart-id="<%= cart._id %>"
            >
              <i class="fas fa-times"></i> Clear Cart
            </button>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:w-1/3">
          <div class="bg-white rounded-xl shadow p-6 sticky top-10 space-y-4">
            <h2 class="text-xl font-semibold mb-4">Order Summary</h2>

            <div class="space-y-2">
              <div class="flex justify-between text-gray-600">
                <span>Subtotal</span>
                <span id="cart-subtotal">₹<%= cart.subtotal %></span>
              </div>
              <div class="flex justify-between text-gray-600">
                <span>Tax</span>
                <span id="cart-tax">₹<%= cart.tax %></span>
              </div>
              <div class="flex justify-between text-gray-600">
                <span>Shipping</span>
                <span id="cart-shipping">Free</span>
              </div>
            </div>

            <div class="border-t pt-4 mt-4 flex justify-between font-bold text-lg">
              <span>Total</span>
              <span id="cart-total">₹<%= cart.total %></span>
            </div>

            <a
              href="/checkout/<%= cart._id %>"
              class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center py-3 rounded-lg font-medium mt-4"
            >
              Proceed to Checkout
            </a>
          </div>
        </div>
      </div>
      <% } else { %>
      <!-- Empty Cart -->
      <div class="bg-white rounded-xl shadow-md p-10 text-center">
        <i class="fas fa-shopping-cart text-6xl text-gray-400 mb-4"></i>
        <h2 class="text-2xl font-semibold mb-3">Your cart is empty</h2>
        <p class="text-gray-500 mb-6">Looks like you haven't added any items to your cart yet.</p>
        <a
          href="/shop"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white py-3 px-6 rounded-lg font-medium"
        >
          Start Shopping
        </a>
      </div>
      <% } %>
    </div>

    <%- include('./partials/footer') %>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function () {
        function updateCartSummary() {
          let subtotal = 0;
          $(".cart-item").each(function () {
            const price = parseFloat($(this).data("item-price"));
            const qty = parseInt($(this).find(".quantity-input").val());
            subtotal += price * qty;
          });
          const tax = subtotal * 0.1;
          const shipping = subtotal > 50 ? 0 : 5;
          const total = subtotal + tax + shipping;

          $("#cart-subtotal").text("₹" + subtotal.toFixed(2));
          $("#cart-tax").text("₹" + tax.toFixed(2));
          $("#cart-shipping").text(shipping === 0 ? "Free" : "₹" + shipping.toFixed(2));
          $("#cart-total").text("₹" + total.toFixed(2));
        }

        function updateItemTotal(itemElement) {
          const price = parseFloat(itemElement.data("item-price"));
          const qty = parseInt(itemElement.find(".quantity-input").val());
          itemElement.find(".item-total").text("₹" + (price * qty).toFixed(2));
        }

        // Quantity buttons
        $(".quantity-btn").on("click", function () {
          const form = $(this).closest(".quantity-form");
          const itemElement = $(`#item-${form.data("item-id")}`);
          const action = $(this).data("action");
          const input = form.find(".quantity-input");
          let qty = parseInt(input.val());

          if (action === "increase" && qty < 5) qty++;
          if (action === "decrease" && qty > 1) qty--;
          input.val(qty);
          updateItemTotal(itemElement);
          updateCartSummary();
        });

        // Initialize summary
        updateCartSummary();
      });
    </script>
  </body>
</html>
