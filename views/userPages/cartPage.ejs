<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shopping Cart</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    rel="stylesheet"
  />
</head>

<body class="bg-gray-100 text-gray-800">

<%- include('./partials/headerPartial') %>

<div class="container mx-auto py-10 px-4">
  <h1 class="text-3xl font-bold mb-10">Shopping Cart</h1>

  <% if (cart && cart.items.length > 0) { %>
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- CART ITEMS -->
    <div class="lg:w-2/3 space-y-6">

      <% cart.items.forEach(item => { %>
      <div
        class="cart-item bg-white rounded-xl shadow p-6 flex gap-6"
        id="item-<%= item._id %>"
        data-price="<%= item.price %>"
      >

        <!-- IMAGE -->
        <img src="<%= item.image %>"
          class="w-28 h-28 rounded-lg object-cover"/>

        <!-- DETAILS -->
        <div class="flex-1 flex justify-between">

          <div>
            <h2 class="font-semibold"><%= item.name %></h2>
            <p class="text-gray-500 text-sm">
              Color: <%= item.color %> | Size: <%= item.size %>
            </p>
            <p class="font-medium mt-1">
              ₹ <%= item.price.toFixed(2) %>
            </p>
          </div>

          <!-- QTY -->
          <div class="text-right">

            <form
  class="quantity-form flex items-center gap-2"
  data-item-id="<%= item._id %>"
  data-product-id="<%= item.productId %>"
  data-variant-id="<%= item.variantId %>"
>

  <button
    type="button"
    class="quantity-btn bg-gray-200 px-3 rounded"
    data-action="decrease">
    -
  </button>

  <input
    class="quantity-input w-12 text-center border rounded"
    value="<%= item.quantity %>"
    readonly
  />

  <button
    type="button"
    class="quantity-btn bg-gray-200 px-3 rounded"
    data-action="increase">
    +
  </button>

</form>


            <p class="item-total font-semibold mt-2">
              ₹ <span class="item-total-price">
              <%= (item.price * item.quantity).toFixed(2) %>
              </span>
            </p>

            <button
              class="delete-item-btn text-red-500 mt-2"
              data-item-id="<%= item._id %>"
              data-product-id="<%= item.productId %>"
  data-variant-id="<%= item.variantId %>">
              
              <i class="fas fa-trash"></i>
            </button>

          </div>
        </div>
      </div>
      <% }) %>

      <!-- FOOTER -->
      <div class="flex justify-between mt-6">
        <a href="/shop" class="text-blue-600">
          ← Continue Shopping
        </a>

        <button id="clear-cart-btn"
          data-cart-id="<%= cart._id %>"
          class="text-red-600">
          Clear Cart
        </button>
      </div>

    </div>

    <!-- SUMMARY -->
    <div class="lg:w-1/3">
      <div class="bg-white rounded-xl shadow p-6 sticky top-10">

        <h2 class="font-semibold mb-4">Order Summary</h2>

        <div class="space-y-2">
          <div class="flex justify-between">
            <span>Subtotal</span>
            <span>₹ <span id="subtotal">0</span></span>
          </div>

          <div class="flex justify-between">
            <span>Tax (10%)</span>
            <span>₹ <span id="tax">0</span></span>
          </div>

          <div class="flex justify-between">
            <span>Shipping</span>
            <span>Free</span>
          </div>
        </div>

        <hr class="my-4">

        <div class="flex justify-between font-bold">
          <span>Total</span>
          <span>₹ <span id="grand-total">0</span></span>
        </div>

        <a href="/checkout/<%= cart._id %>"
          class="block bg-blue-600 text-white text-center py-3 rounded mt-4">
          Checkout
        </a>

      </div>
    </div>

  </div>
  <% } else { %>

  <!-- EMPTY -->
  <div class="bg-white p-10 rounded text-center">
    <i class="fas fa-shopping-cart text-6xl text-gray-400 mb-4"></i>
    <h2 class="text-xl font-semibold">Cart Empty</h2>
    <a href="/shop"
      class="inline-block bg-blue-600 text-white px-6 py-2 rounded mt-4">
      Shop Now
    </a>
  </div>

  <% } %>
</div>

<%- include('./partials/footer') %>

<!-- JS -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
$(document).ready(function () {

function updateItemTotal(item) {
  const price = parseFloat(item.data("price"));
  const qty = parseInt(item.find(".quantity-input").val());

  const total = price * qty;
  item.find(".item-total-price")
      .text(total.toFixed(2));
}

function updateCartSummary() {
  let subtotal = 0;

  $(".cart-item").each(function () {
    const price = parseFloat($(this).data("price"));
    const qty = parseInt($(this)
      .find(".quantity-input").val());
    subtotal += price * qty;
  });

  const tax = subtotal * 0.1;
  const total = subtotal + tax;

  $("#subtotal").text(subtotal.toFixed(2));
  $("#tax").text(tax.toFixed(2));
  $("#grand-total").text(total.toFixed(2));
}
$(".quantity-btn").click(function () {

  const form = $(this).closest(".quantity-form");
  const id = form.data("item-id");
  const item = $("#item-" + id);
  const action = $(this).data("action");
  const input = form.find(".quantity-input");

  const productId = form.data("product-id");
  const variantId = form.data("variant-id");

  let oldQty = parseInt(input.val());
  let newQty = oldQty;

  // 🚨 LIMIT CHECK
  if (action === "increase" && oldQty >= 5) {
    Swal.fire({
      icon: "warning",
      title: "Max limit reached",
      text: "Only 5 items allowed"
    });
    return;
  }

  if (action === "decrease" && oldQty <= 1) {
    Swal.fire({
      icon: "warning",
      title: "Minimum limit",
      text: "Quantity cannot be less than 1"
    });
    return;
  }

  // calculate new qty
  if (action === "increase") newQty++;
  else newQty--;

  // ✅ OPTIMISTIC UI UPDATE
  input.val(newQty);
  updateItemTotal(item);
  updateCartSummary();

  // 🚀 API CALL
  $.post(`/cart/quantity-update/${id}`, {
    quantity: newQty,
    productId,
    variantId,
    action
  })

  .done(function (res) {

    if (!res.success) {
      // ❌ rollback if backend rejects
      input.val(oldQty);
      updateItemTotal(item);
      updateCartSummary();

      Swal.fire({
        icon: "warning",
        title: res.message || "Update failed"
      });
    } else {
      // ✅ success toast (clean UX)
      Swal.fire({
        toast: true,
        position: "top-end",
        icon: "success",
        title: res.message || "Updated",
        showConfirmButton: false,
        timer: 1200
      });
    }

  })

  .fail(function (xhr) {

    // ❌ rollback on error
    input.val(oldQty);
    updateItemTotal(item);
    updateCartSummary();

    let message = xhr.responseJSON?.message || "Server error";

    Swal.fire({
      icon: "error",
      title: "Update Failed",
      text: message
    });

  });

});
$(".delete-item-btn").click(function () {
  const id = $(this).data("item-id");
  const productId = $(this).data("product-id");
  const variantId = $(this).data("variant-id");


  $.post(`/cart/delete-item/${id}`,{
    productId: productId,
    variantId: variantId
  }, () => {
    $("#item-"+id).remove();
    updateCartSummary();
  });
});

$("#clear-cart-btn").click(function () {
  const id = $(this).data("cart-id");

  $.post(`/cart/clear/${id}`, () => {
    location.reload();
  });
});

updateCartSummary();
});
</script>

</body>
</html>
