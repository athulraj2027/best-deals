<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />

    <title>Set New Password</title>

    <style>
      body {
        background-color: #f9fafb;
      }
      .reset-container {
        max-width: 450px;
        margin: 100px auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0px 10px 25px rgba(0, 0, 0, 0.05);
      }
      .form-control-custom {
        width: 100%;
        padding: 12px;
        margin-top: 8px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        outline: none;
        transition: border-color 0.2s;
      }
      .form-control-custom:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
      }
      .btn-update {
        background: #007bff;
        color: white;
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 10px;
        transition: background 0.3s;
      }
      .btn-update:hover {
        background: #0056b3;
        color: white;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial') %>

    <div class="main px-4">
      <div class="reset-container">
        <h2 class="text-2xl font-bold mb-2 text-center">Set New Password</h2>
        <p class="text-gray-500 mb-6 text-center">
          Please enter and confirm your new password below.
        </p>

        <form id="reset-password-form">
          <div class="mb-4">
            <label
              for="password"
              class="block text-sm font-medium text-gray-700"
              >New Password</label
            >
            <input
              type="password"
              class="form-control-custom"
              id="password"
              name="password"
              placeholder="••••••••"
              required
            />
          </div>

          <div class="mb-6">
            <label
              for="confirmPassword"
              class="block text-sm font-medium text-gray-700"
              >Confirm Password</label
            >
            <input
              type="password"
              class="form-control-custom"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="••••••••"
              required
            />
          </div>

          <button type="submit" id="updateBtn" class="btn btn-update">
            Update Password
          </button>
        </form>
      </div>
    </div>

    <%- include('./partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <script>
      $(document).ready(function () {
        const form = $("#reset-password-form");

        form.on("submit", function (e) {
          e.preventDefault();

          const password = $("#password").val();
          const confirmPassword = $("#confirmPassword").val();

          // Client-side validation check before AJAX
          if (password !== confirmPassword) {
            return Swal.fire({
              title: "Oops!",
              text: "Passwords do not match.",
              icon: "error",
              confirmButtonColor: "#007bff",
            });
          }

          const updateBtn = $("#updateBtn");
          updateBtn.prop("disabled", true).text("Updating...");

          $.ajax({
            url: "/forgot-password/new-password",
            type: "POST",
            data: { password, confirmPassword },
            dataType: "json",
            success: function (response) {
              if (response.status === "success") {
                Swal.fire({
                  title: response.title || "Success!",
                  text: response.message,
                  icon: "success",
                  confirmButtonColor: "#007bff",
                  confirmButtonText: "OK",
                }).then(() => {
                  window.location.href = "/signin";
                });
              } else {
                updateBtn.prop("disabled", false).text("Update Password");
                Swal.fire({
                  title: response.title || "Error",
                  text: response.message,
                  icon: "error",
                  confirmButtonColor: "#007bff",
                });
              }
            },
            error: function (xhr) {
              updateBtn.prop("disabled", false).text("Update Password");
              let errorMessage =
                "An unexpected error occurred. Please try again.";
              if (xhr.responseJSON) {
                errorMessage = xhr.responseJSON.message || errorMessage;
              }
              Swal.fire({
                title: "Oops!",
                text: errorMessage,
                icon: "error",
                confirmButtonColor: "#007bff",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>
