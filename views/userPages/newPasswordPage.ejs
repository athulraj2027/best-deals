<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="/userCSS/verify-otpPage.css" />
    <title>Password Reset</title>
  </head>
  <style>
    .container {
      margin: 100px;
    }
  </style>
  <body>
    <%- include('./partials/headerPartial') %>
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="card shadow-lg p-4">
            <h3 class="text-center mb-4">Set New Password</h3>
            <form
              action="/forgot-password/new-password"
              id="reset-password-form"
              method="POST"
            >
              <!-- <input type="hidden" name="token" value="" /> -->

              <div class="mb-3">
                <label for="password" class="form-label">New Password</label>
                <input
                  type="password"
                  class="form-control"
                  id="password"
                  name="password"
                />
              </div>

              <div class="mb-3">
                <label for="confirmPassword" class="form-label"
                  >Confirm Password</label
                >
                <input
                  type="password"
                  class="form-control"
                  id="confirmPassword"
                  name="confirmPassword"
                />
              </div>

              <button type="submit" class="btn btn-primary w-100">
                Update Password
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/footer') %>
  </body>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    $(document).ready(function () {
      const form = $("#reset-password-form");
      form.on("submit", function (e) {
        e.preventDefault();

        const password = $("#password").val();
        const confirmPassword = $("#confirmPassword").val();

        $.ajax({
          url: "/forgot-password/new-password",
          type: "POST",
          data: { password, confirmPassword },
          dataType: "json",
          success: function (response) {
            if (response.status === "success") {
              Swal.fire({
                title: response.title,
                text: response.message,
                icon: response.status, // 'success'
                confirmButtonText: "OK",
              }).then(() => {
                window.location.href = "/signin"; // Redirect after successful login
              });
            } else {
              Swal.fire({
                title: response.title,
                text: response.message,
                icon: response.status, // 'error'
                confirmButtonText: "OK",
              });
            }
          },
          error: function (xhr, status, error) {
            console.error("AJAX Error:", status, error);
            console.log("Error Response JSON:", xhr.responseJSON);

            let errorMessage =
              "An unexpected error occurred. Please try again.";

            if (xhr.responseJSON) {
              errorMessage = xhr.responseJSON.message || errorMessage;
            }

            Swal.fire({
              title: "Oops!",
              text: errorMessage,
              icon: "error",
              confirmButtonText: "OK",
            });
          },
        });
      });
    });
  </script>
</html>
