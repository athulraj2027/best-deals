<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <title>Sign Up | BestDeals</title>
</head>

<body class="bg-white  min-h-screen">

<!-- HEADER -->
<%- include('./partials/headerPartial')%>

<!-- MAIN -->
<div class="flex items-center justify-center min-h-screen px-4">

  <div class="bg-white/95 backdrop-blur-md shadow-2xl rounded-2xl w-full max-w-md p-8">

    <h2 class="text-3xl font-bold text-center mb-6 text-gray-800">
      Create Account 🚀
    </h2>

    <form id="signupForm" action="/signup" method="post" class="space-y-4">

      <% if (error) { %>
      <div class="bg-red-100 text-red-700 p-3 rounded-md text-sm">
        <%= error %>
      </div>
      <% } %>

      <!-- Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Full Name
        </label>
        <input type="text" name="name" id="name"
          placeholder="John Doe"
          class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none">
        <small id="nameError" class="text-red-500 text-xs"></small>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email Address
        </label>
        <input type="email" name="email" id="email"
          placeholder="you@example.com"
          class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none">
        <small id="emailError" class="text-red-500 text-xs"></small>
      </div>

      <!-- Password -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Password
        </label>
        <input type="password" name="password" id="password"
          placeholder="********"
          class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none">
        <small id="passwordError" class="text-red-500 text-xs"></small>
      </div>

      <!-- Confirm Password -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Confirm Password
        </label>
        <input type="password" name="confirmPassword" id="confirm-password"
          placeholder="********"
          class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none">
        <small id="confirmPasswordError" class="text-red-500 text-xs"></small>
      </div>

      <!-- Referral -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Referral Code (optional)
        </label>
        <input type="text" name="referral" id="referral-code"
          placeholder="ABC123"
          class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none">
      </div>

      <!-- Button -->
      <button type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-lg transition">
        Sign Up
      </button>

      <!-- Login -->
      <p class="text-center text-sm mt-4">
        Already have an account?
        <a href="/signin" class="text-indigo-600 font-medium hover:underline">
          Sign In
        </a>
      </p>

    </form>

    <!-- Google -->
    <a href="/auth/google"
      class="mt-6 flex items-center justify-center gap-3 border rounded-lg py-2 hover:bg-gray-100 transition">

      <img src="https://img.icons8.com/color/24/google-logo.png" />
      <span class="font-medium text-gray-700">Sign in with Google</span>
    </a>

  </div>

</div>

<!-- FOOTER -->
<%- include('./partials/footer')%>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
$(document).ready(function () {

  const form = $("#signupForm");

  form.on("submit", function (e) {
    e.preventDefault();

    const name = $("#name").val();
    const email = $("#email").val();
    const password = $("#password").val();
    const confirmPassword = $("#confirm-password").val();
    const referralCode = $("#referral-code").val();

    $(".error-message").text("");

    const passwordRegex =
      /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/;

    if (!passwordRegex.test(password)) {
      Swal.fire({
        title: "Error",
        text: "Password must be strong!",
        icon: "error"
      });
      return;
    }

    $.ajax({
      url: "/signup",
      type: "POST",
      contentType: "application/json",
      data: JSON.stringify({
        name,
        email,
        password,
        confirmPassword,
        referralCode
      }),

      success: function (res) {
        if (res.status === "success") {
          Swal.fire("Success", res.message, "success")
            .then(() => window.location.href = "/verify-otp");
        } else {
          Swal.fire("Error", res.message, "error");
        }
      },

      error: function () {
        Swal.fire("Error", "Something went wrong", "error");
      }
    });

  });

});
</script>

</body>
</html>
