<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />

    <link rel="stylesheet" href="userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="userCSS/signUpPage.css" />
    <title>Sign Up</title>
  </head>
  <body>
    <%- include('./partials/headerPartial')%>
    <div class="signup-container bg-light">
      <h2>Sign Up</h2>

      <form id="signupForm" action="/signup" method="post">
        <% if (error) { %>
        <div class="alert alert-danger">
          <strong>Error:</strong> <%= error %>
        </div>
        <% } %>
        <!-- Name Field -->
        <div class="mb-3">
          <label for="name" class="form-label">Full Name</label>
          <input
            type="text"
            class="form-control"
            id="name"
            name="name"
            placeholder="Enter your full name"
          />
          <small
            class="error-message"
            id="nameError"
            style="color: red"
          ></small>
        </div>
        <!-- Email Field -->
        <div class="mb-3">
          <label for="email" class="form-label">Email Address</label>
          <input
            type="email"
            class="form-control"
            id="email"
            name="email"
            placeholder="Enter your email"
          />
          <small
            class="error-message"
            id="emailError"
            style="color: red"
          ></small>
        </div>
        <!-- Password Field -->
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            type="password"
            class="form-control"
            id="password"
            name="password"
            placeholder="Create a password"
          />
          <small
            class="error-message"
            id="passwordError"
            style="color: red"
          ></small>
        </div>
        <!-- Confirm Password Field -->
        <div class="mb-3">
          <label for="confirm-password" class="form-label"
            >Confirm Password</label
          >
          <input
            type="password"
            class="form-control"
            id="confirm-password"
            name="confirmPassword"
            placeholder="Re-enter your password"
          />
          <small
            class="error-message"
            id="confirmPasswordError"
            style="color: red"
          ></small>
        </div>
        <!-- Sign Up Button -->
        <div class="d-grid">
          <button type="submit" class="btn btn-primary">Sign Up</button>
        </div>
        <!-- Sign In Link -->
        <a href="/signin" class="signin-link"
          >Already have an account? Sign In</a
        >
       
      </form>
      <a href="/auth/google">
        <button style="background-color: #4285F4; color: white; padding: 10px 20px; border: none; border-radius: 4px; font-size: 16px; cursor: pointer;">
          <img src="https://img.icons8.com/color/16/000000/google-logo.png" alt="Google Logo" style="vertical-align: middle; margin-right: 8px;">
          Sign in with Google
        </button>
      </a>
      
    </div>
    <%- include('./partials/footer')%>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      $(document).ready(function () {
        const form = $("#signupForm");

        form.on("submit", function (e) {
          e.preventDefault(); // Prevent form from submitting traditionally

          const name = $("#name").val();
          const email = $("#email").val();
          const password = $("#password").val();
          const confirmPassword = $("#confirm-password").val();

          // Clear previous error messages
          $(".error-message").text("");

          const passwordRegex =
            /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$/;

          if (!passwordRegex.test(password)) {
            Swal.fire({
              title: "Error",
              text: "Password must be at least 8 characters long, include an uppercase letter, a lowercase letter, a number, and a special character.",
              icon: "error",
              confirmButtonText: "OK",
            });
            return;
          }
          // AJAX call for validation
          $.ajax({
            url: "/signup",
            type: "POST",
            data: {
              name: name,
              email: email,
              password: password,
              confirmPassword: confirmPassword,
            },
            success: function (response) {
              if (response.status === "success") {
                // Trigger SweetAlert for success
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'success'
                  confirmButtonText: "OK",
                }).then(() => {
                  form.off("submit").submit() // Submit form traditionally after validation
                }).then(()=>window.location.href = '/verify-otp')
              } else {
                // Trigger SweetAlert for error
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'error'
                  confirmButtonText: "OK",
                });

                // Display error messages returned by the server
                if (response.errors.name) {
                  $("#nameError").text(response.errors.name);
                }
                if (response.errors.email) {
                  $("#emailError").text(response.errors.email);
                }
                if (response.errors.password) {
                  $("#passwordError").text(response.errors.password);
                }
                if (response.errors.confirmPassword) {
                  $("#confirmPasswordError").text(
                    response.errors.confirmPassword
                  );
                }
              }
            },
            error: function () {
              Swal.fire({
                title: "Oops!",
                text: "An error occurred during validation. Please try again.",
                icon: "error",
                confirmButtonText: "OK",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>
