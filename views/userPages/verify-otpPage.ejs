<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />

    
  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="/userCSS/verify-otpPage.css" />
    <title>Verify OTP</title>
  </head>
  <body>
    <%- include('./partials/headerPartial') %>
    <div class="otp-container">
      <h2>OTP Verification</h2>
      <p class="text-center">Enter the 6-digit OTP sent to your email.</p>

      <form id="otpForm" method="POST" action="/verify-otp">
        <div class="d-flex justify-content-center">
          <% for (let i = 0; i < 6; i++) { %>
          <input
            type="text"
            maxlength="1"
            class="otp-input"
            name="otp<%= i + 1 %>"
          />
          <% } %>
        </div>
        <small class="error-message" id="otpError" style="color: red"></small>
        <button type="submit" class="btn mt-3">Verify OTP</button>
      </form>

      <div class="resend-link">
        <p>
          Didn't receive the OTP?
          <a
            id="resendLink"
            onclick="resendOtp()"
            href="#"
            style="pointer-events: none"
            >Resend</a
          >
        </p>
        <div id="timer"></div>
      </div>
    </div>
    <%- include('./partials/footer') %>

    <!-- SweetAlert2 Library -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      // Auto Progression for OTP Fields
      const otpInputs = document.querySelectorAll(".otp-input");
      otpInputs.forEach((input, index) => {
        input.addEventListener("input", () => {
          if (input.value.length === 1 && index < otpInputs.length - 1) {
            otpInputs[index + 1].focus(); // Move to the next field
          }
        });
      });

      // Timer for Resend OTP functionality
      let countdownTimer;
      let countdownValue = 30; // Timer set for 30 seconds

      function startTimer() {
        document.getElementById("resendLink").style.pointerEvents = "none"; // Disable resend link
        countdownValue = 30;
        countdownTimer = setInterval(function () {
          document.getElementById("timer").innerText =
            "You can request a new OTP in " + countdownValue + " seconds";
          countdownValue--;
          if (countdownValue < 0) {
            clearInterval(countdownTimer);
            document.getElementById("resendLink").style.pointerEvents = "auto"; // Enable resend link
            document.getElementById("timer").innerText = ""; // Clear the timer message
          }
        }, 1000);
      }

      // Trigger resend OTP request (currently empty)
      function resendOtp() {
        fetch("/resend-otp", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
        })
          .then((response) => response.json())
          .then((data) => {
            // Display response message using SweetAlert
            Swal.fire({
              title: data.title,
              text: data.message,
              icon: data.status, // 'success' or 'error'
              confirmButtonText: "OK",
            });

            if (data.status === "success") {
              startTimer(); // Restart the timer
            }
          })
          .catch((err) => {
            console.error("Error in resendOtp:", err);
            Swal.fire({
              title: "Error",
              text: "An error occurred. Please try again.",
              icon: "error",
              confirmButtonText: "OK",
            });
          });
      }

      document
        .getElementById("otpForm")
        .addEventListener("submit", async function (event) {
          event.preventDefault(); // Prevent default form submission
          const otp = Array.from(otpInputs)
            .map((input) => input.value)
            .join("");

          if (otp.length !== 6) {
            Swal.fire({
              title: "Invalid OTP",
              text: "Please enter a valid 6-digit OTP.",
              icon: "error",
              confirmButtonText: "OK",
            });
            return;
          }

          try {
            const response = await fetch("/verify-otp", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ otp }),
            });

            const result = await response.json();

            // Handle success or error response
            if (result.status === "success") {
              Swal.fire({
                title: result.title,
                text: result.message,
                icon: result.status, // 'success'
                confirmButtonText: "OK",
              }).then(() => {
                window.location.href = "/signin"; // Redirect to sign-in page
              });
            } else {
              Swal.fire({
                title: result.title,
                text: result.message,
                icon: result.status, // 'error'
                confirmButtonText: "OK",
              });
            }
          } catch (error) {
            Swal.fire({
              title: "Error",
              text: "An error occurred. Please try again ......",
              icon: "error",
              confirmButtonText: "OK",
            });
          }
        });

      // Start the timer when the page loads
      window.onload = function () {
        startTimer();
      };
    </script>
  </body>
</html>
