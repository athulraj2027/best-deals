<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <title>Verify Email</title>
    <style>
      body {
        /* display: flex;
        justify-content: center;
        align-items: center; */
        height: 100vh;
        background-color: #f4f4f4;
      }
      .main {
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .container {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 400px;
        margin: 100px;
      }
      input {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
        border: 1px solid #ccc;
        border-radius: 5px;
      }
      button {
        background: #007bff;
        color: white;
        padding: 10px 15px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
      }
      button:hover {
        background: #0056b3;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial')%>
    <div class="main">
      <div class="container">
        <h2>Verify Email</h2>
        <p>Add the email address linked to your account</p>
        <form id="verify-email-form" action="/forgot-password/verify-email" method="post">
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email"
          />
          <button id="sendCode" type="submit">Send Code</button>
        </form>
      </div>
    </div>

    <%- include('./partials/footer')%>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function () {
        const form = $("#verify-email-form");

        form.on("submit", function (e) {
          e.preventDefault();

          const email = $("#email").val();

          $.ajax({
            url: "/forgot-password/verify-email",
            type: "POST",
            data: { email },
            dataType: "json",

            success: function (response) {
              console.log(response);

              if (response.status === "success") {
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'success'
                  confirmButtonText: "OK",
                }).then(() => {
                  window.location.href = "/forgot-password/verify-otp"; // Redirect after successful login
                });
              } 
            },
            error: function (xhr, status, error) {
              console.error("AJAX Error:", status, error);
              console.log("Error Response JSON:", xhr.responseJSON);

              let errorMessage =
                "An unexpected error occurred. Please try again.";

              if (xhr.responseJSON) {
                errorMessage = xhr.responseJSON.message || errorMessage;

                // Handle different error cases based on status code
                if (xhr.status === 400) {
                  errorMessage = "Invalid email or password.";
                } else if (xhr.status === 403) {
                  errorMessage = "You have been blocked by the admin.";
                } else if (xhr.status === 500) {
                  errorMessage = "Server error. Please try again later.";
                }
              }

              Swal.fire({
                title: "Oops!",
                text: errorMessage,
                icon: "error",
                confirmButtonText: "OK",
              });
            },
          });
        });
      });
    </script>
  </body>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</html>
