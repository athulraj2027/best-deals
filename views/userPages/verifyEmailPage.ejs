<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="/userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="/userCSS/verify-otpPage.css" />

    <title>Verify Email</title>

    <style>
      /* Keeping custom overrides consistent with the OTP container style */
      .email-container {
        max-width: 450px;
        margin: 100px auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0px 10px 25px rgba(0, 0, 0, 0.05);
        text-align: center;
      }

      .email-input {
        width: 100%;
        padding: 12px;
        margin: 20px 0;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        outline: none;
        transition: border-color 0.2s;
      }

      .email-input:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.1);
      }

      .btn-verify {
        background: #007bff;
        color: white;
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        transition: background 0.3s;
      }

      .btn-verify:hover {
        background: #0056b3;
        color: white;
      }
    </style>
  </head>
  <body class="bg-gray-50">
    <%- include('./partials/headerPartial') %>

    <div class="main d-flex align-items-center justify-content-center">
      <div class="email-container">
        <h2 class="text-2xl font-bold mb-2">Verify Email</h2>
        <p class="text-gray-500 mb-6">
          Enter the email address linked to your account to receive a
          verification code.
        </p>

        <form id="verify-email-form">
          <input
            type="email"
            id="email"
            name="email"
            class="email-input"
            placeholder="example@domain.com"
            required
          />
          <button id="sendCode" type="submit" class="btn btn-verify">
            Send Code
          </button>
        </form>

        <div class="mt-4">
          <a href="/signin" class="text-sm text-blue-600 hover:underline"
            >Back to Login</a
          >
        </div>
      </div>
    </div>

    <%- include('./partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <script>
      $(document).ready(function () {
        const form = $("#verify-email-form");

        form.on("submit", function (e) {
          e.preventDefault();
          const email = $("#email").val();

          // Visual feedback for the user
          const submitBtn = $("#sendCode");
          submitBtn.prop("disabled", true).text("Sending...");

          $.ajax({
            url: "/forgot-password/verify-email",
            type: "POST",
            data: { email },
            dataType: "json",

            success: function (response) {
              if (response.status === "success") {
                Swal.fire({
                  title: response.title || "Success!",
                  text: response.message,
                  icon: "success",
                  confirmButtonColor: "#007bff",
                  confirmButtonText: "OK",
                }).then(() => {
                  window.location.href = "/forgot-password/verify-otp";
                });
              }
            },
            error: function (xhr) {
              submitBtn.prop("disabled", false).text("Send Code");

              let errorMessage = "An unexpected error occurred.";
              if (xhr.responseJSON) {
                errorMessage = xhr.responseJSON.message || errorMessage;
              }

              Swal.fire({
                title: "Oops!",
                text: errorMessage,
                icon: "error",
                confirmButtonColor: "#007bff",
                confirmButtonText: "OK",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>
