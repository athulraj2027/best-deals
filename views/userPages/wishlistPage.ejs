<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Wishlist</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('./partials/headerPartial') %>

    <div class="container mx-auto py-10 px-4">
      <h1 class="text-3xl font-bold mb-8 text-gray-800">My Wishlist</h1>

      <% if (wishlist && wishlist.items && wishlist.items.length > 0) { %>
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Wishlist Items -->
        <div class="lg:w-2/3 space-y-6">
          <% wishlist.items.forEach(item => { %>
          <div id="item-<%= item._id %>" class="bg-white rounded-xl shadow-md p-6 flex flex-col sm:flex-row items-center hover:shadow-lg transition-shadow">
            <!-- Image -->
            <div class="w-24 h-24 flex-shrink-0 mb-4 sm:mb-0">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover rounded-lg" />
            </div>

            <!-- Info -->
            <div class="flex-1 sm:ml-6 flex flex-col sm:flex-row sm:justify-between items-start sm:items-center">
              <div>
                <h2 class="text-lg font-semibold text-gray-800"><%= item.name %></h2>
                <p class="text-gray-500 mt-1 text-sm">Color: <%= item.color %> | Size: <%= item.size %></p>
                <p class="text-green-600 font-bold mt-2 text-lg">₹<%= item.price.toFixed(2) %></p>
              </div>

              <!-- Actions -->
              <div class="mt-4 sm:mt-0 flex space-x-2">
                <button
                  type="button"
                  class="add-to-cart-btn bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg flex items-center gap-2 transition"
                  data-product-id="<%= item.productId %>"
                  data-variant-id="<%= item.variantId %>"
                >
                  <i class="fas fa-shopping-cart"></i> Add to Cart
                </button>

                <button
                  type="button"
                  class="delete-wishlist-item-btn bg-red-100 hover:bg-red-200 text-red-600 py-2 px-4 rounded-lg flex items-center gap-2 transition"
                  data-item-id="<%= item._id %>"
                  data-product-id="<%= item.productId %>"
                  data-variant-id="<%= item.variantId %>"
                >
                  <i class="fas fa-trash"></i> Remove
                </button>
              </div>
            </div>
          </div>
          <% }) %>

          <!-- Continue Shopping / Clear Wishlist -->
          <div class="flex justify-between items-center mt-4">
            <a href="/shop" class="text-blue-600 hover:text-blue-800 font-medium flex items-center gap-2">
              <i class="fas fa-arrow-left"></i> Continue Shopping
            </a>

            <button
              id="clear-wishlist-btn"
              class="bg-red-100 hover:bg-red-200 text-red-600 py-2 px-4 rounded-lg flex items-center gap-2 font-medium"
              data-wishlist-id="<%= wishlist._id %>"
            >
              <i class="fas fa-times"></i> Clear Wishlist
            </button>
          </div>
        </div>

        <!-- Wishlist Summary -->
        <div class="lg:w-1/3">
          <div class="bg-white rounded-xl shadow-md p-6 sticky top-8">
            <h2 class="text-xl font-semibold mb-4 text-gray-800">Wishlist Summary</h2>

            <div class="space-y-3">
              <div class="flex justify-between text-gray-600">
                <span>Total Items</span>
                <span id="wishlist-item-count" class="font-medium"><%= wishlist.items.length %></span>
              </div>

              <div class="flex justify-between text-gray-600">
                <span>Total Value</span>
                <span id="wishlist-total-value" class="font-medium">
                  ₹<%= wishlist.getTotalValue ? wishlist.getTotalValue().toFixed(2) : wishlist.items.reduce((sum, item) => sum + item.price, 0).toFixed(2) %>
                </span>
              </div>

              <div class="border-t mt-3 pt-3 text-gray-500 text-sm">
                Items in your wishlist are saved for future purchase. Prices and availability may change.
              </div>

              <button
                id="add-all-to-cart-btn"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-medium mt-4 transition"
                data-wishlist-id="<%= wishlist._id %>"
              >
                Add All to Cart
              </button>
            </div>
          </div>
        </div>
      </div>
      <% } else { %>
      <!-- Empty Wishlist -->
      <div class="bg-white rounded-xl shadow-md p-10 text-center">
        <i class="fas fa-heart text-6xl text-gray-300 mb-4"></i>
        <h2 class="text-2xl font-semibold mb-2 text-gray-800">Your wishlist is empty</h2>
        <p class="text-gray-500 mb-6">Looks like you haven't added any items yet.</p>
        <a
          href="/shop"
          class="bg-blue-600 hover:bg-blue-700 text-white py-3 px-6 rounded-lg font-medium inline-block transition"
        >
          Start Shopping
        </a>
      </div>
      <% } %>
    </div>

    <%- include('./partials/footer') %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
      $(document).ready(function () {
        // Clear wishlist functionality
        $("#clear-wishlist-btn").on("click", function () {
          const wishlistId = $(this).data("wishlist-id");
          Swal.fire({
            title: "Are you sure?",
            text: "You're about to clear your entire wishlist!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, clear it!"
          }).then((result) => {
            if (result.isConfirmed) {
              $.post(`/wishlist/clear/${wishlistId}`, {}, function (response) {
                if (response.status === "success") {
                  Swal.fire("Cleared!", "Wishlist has been cleared.", "success").then(() => window.location.reload());
                } else {
                  Swal.fire("Error!", response.message || "Something went wrong", "error");
                }
              });
            }
          });
        });

        // Delete wishlist item
        $(".delete-wishlist-item-btn").on("click", function () {
          const itemId = $(this).data("item-id");
          const itemElement = $(`#item-${itemId}`);
          Swal.fire({
            title: "Remove this item?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes",
            cancelButtonText: "No",
          }).then((result) => {
            if (result.isConfirmed) {
              $.post(`/wishlist/delete-item/${itemId}`, {}, function (response) {
                if (response.status === "success") {
                  itemElement.remove();
                  const newCount = parseInt($("#wishlist-item-count").text()) - 1;
                  $("#wishlist-item-count").text(newCount);
                  if (newCount === 0) window.location.reload();
                  Swal.fire("Removed!", "Item has been removed.", "success");
                } else {
                  Swal.fire("Error!", response.message || "Failed to remove", "error");
                }
              });
            }
          });
        });

        // Add to cart
        $(".add-to-cart-btn").on("click", function () {
          const button = this;
          const itemElement = $(this).closest(".wishlist-item");
          const name = itemElement.find("h2").text();
          const colorSize = itemElement.find("p.text-gray-500").text();
          const [color, size] = colorSize.split(" | ").map(t => t.split(": ")[1]);
          const price = parseFloat(itemElement.find(".text-green-600").text().replace("$", ""));
          const image = itemElement.find("img").attr("src");
          const productId = $(this).data("product-id");
          const variantId = $(this).data("variant-id");

          const cartItem = { productId, variantId, name, color, size, price, quantity: 1, image };
          fetch(`/product/cart/add`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(cartItem)
          }).then(res => res.json()).then(data => {
            if (data.status === "success") {
              Swal.fire({
                icon: "success",
                title: "Added to Cart",
                html: `1 x ${name}<br>(${color}, ${size})`,
                showConfirmButton: true,
                confirmButtonText: "View Cart",
                showCancelButton: true,
                cancelButtonText: "Continue Shopping"
              }).then(result => {
                if (result.isConfirmed) window.location.href = "/cart";
              });
            } else {
              Swal.fire("Error!", data.message || "Failed to add to cart", "error");
            }
          }).catch(() => Swal.fire("Error!", "Failed to add to cart", "error"));
        });

        // Add all to cart
        $("#add-all-to-cart-btn").on("click", function () {
          const wishlistId = $(this).data("wishlist-id");
          Swal.fire({
            title: "Add all items to cart?",
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Yes",
            cancelButtonText: "No",
          }).then(result => {
            if (result.isConfirmed) {
              $.post(`/wishlist/add-all-to-cart/${wishlistId}`, {}, function (response) {
                if (response.status === "success") {
                  Swal.fire("Success!", "All items added to cart.", "success").then(() => window.location.href = "/cart");
                } else {
                  Swal.fire("Error!", response.message || "Failed to add all items", "error");
                }
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
