<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Wishlist | Tech Gadgets</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .gradient-text { background: linear-gradient(to right, #6366f1, #d946ef); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <%- include('./partials/headerPartial') %>

    <div class="max-w-7xl mx-auto py-12 px-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
            <div>
                <h1 class="text-4xl font-black tracking-tight text-slate-900 flex items-center gap-3">
                    <i class="fas fa-heart text-pink-500"></i> My Wishlist
                </h1>
                <p class="text-slate-500 mt-2 font-medium">Items you've saved for your future tech setup.</p>
            </div>
            <% if (wishlist && wishlist.items && wishlist.items.length > 0) { %>
            <button id="clear-wishlist-btn" data-wishlist-id="<%= wishlist._id %>" 
                class="flex items-center justify-center gap-2 px-6 py-3 bg-red-50 text-red-600 rounded-2xl font-bold text-xs uppercase tracking-widest hover:bg-red-600 hover:text-white transition-all active:scale-95 border border-red-100">
                <i class="fas fa-trash-alt"></i> Clear Wishlist
            </button>
            <% } %>
        </div>

        <% if (wishlist && wishlist.items && wishlist.items.length > 0) { %>
        <div class="flex flex-col lg:flex-row gap-10">
            <div class="lg:w-2/3 space-y-6">
                <% wishlist.items.forEach((item, index) => { %>
                <div id="item-<%= item.productId._id %>" class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-500 p-6 flex flex-col sm:flex-row items-center gap-8 relative overflow-hidden">
                    
                    <div class="w-32 h-32 flex-shrink-0 relative">
                        <div class="absolute inset-0 bg-indigo-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover rounded-2xl shadow-sm group-hover:scale-110 transition-transform duration-500" />
                    </div>

                    <div class="flex-1 text-center sm:text-left">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div>
                                <h2 class="text-xl font-bold text-slate-900 group-hover:text-indigo-600 transition-colors"><%= item.name %></h2>
                                <div class="flex items-center justify-center sm:justify-start gap-3 mt-1">
                                    <span class="px-3 py-1 bg-slate-100 text-slate-500 rounded-lg text-[10px] font-black uppercase tracking-widest border border-slate-200"><%= item.color %></span>
                                    <span class="px-3 py-1 bg-slate-100 text-slate-500 rounded-lg text-[10px] font-black uppercase tracking-widest border border-slate-200"><%= item.size %></span>
                                </div>
                            </div>
                            
                            <div class="text-center sm:text-right">
                                <p class="text-xs text-slate-400 line-through font-bold">₹<%= item.price.toLocaleString('en-IN') %></p>
                                <p class="text-2xl font-black text-slate-900">₹<%= item.finalPrice.toLocaleString('en-IN') %></p>
                                <p class="text-[10px] font-black text-emerald-500 uppercase tracking-tighter mt-1">
                                    <i class="fas fa-tags"></i> Offer Applied
                                </p>
                            </div>
                        </div>

                        <div class="mt-6 pt-6 border-t border-slate-50 flex items-center justify-center sm:justify-end gap-3">
                            <button class="delete-wishlist-item-btn p-3 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all"
                                data-item-id="<%= item._id %>" title="Remove from list">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                            <button class="add-to-cart-btn flex-1 sm:flex-none flex items-center justify-center gap-3 px-8 py-3.5 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-lg shadow-slate-200 hover:bg-indigo-600 transition-all active:scale-95"
                                data-product-id="<%= item.productId._id %>" data-variant-id="<%= item.variantId %>">
                                <i class="fas fa-shopping-cart"></i> Add To Cart
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>

                <div class="pt-4">
                    <a href="/shop" class="inline-flex items-center gap-3 text-slate-400 hover:text-indigo-600 font-bold text-sm transition-all group">
                        <i class="fas fa-arrow-left group-hover:-translate-x-2 transition-transform"></i> 
                        Keep Exploring More Tech
                    </a>
                </div>
            </div>

            <div class="lg:w-1/3">
                <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-xl shadow-slate-200/40 p-8 sticky top-32">
                    <h3 class="text-xl font-black text-slate-900 mb-6 tracking-tight">Setup Value</h3>
                    
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between items-center text-sm">
                            <span class="font-bold text-slate-400 uppercase tracking-widest text-[10px]">Total Gear</span>
                            <span id="wishlist-item-count" class="font-black text-slate-900"><%= wishlist.items.length %> Units</span>
                        </div>
                        <div class="flex justify-between items-center text-sm border-t border-slate-50 pt-4">
                            <span class="font-bold text-slate-400 uppercase tracking-widest text-[10px]">Estimated Total</span>
                            <span id="wishlist-total-value" class="text-2xl font-black text-indigo-600 italic">
                                ₹<%= (wishlist.items.reduce((sum, item) => sum + item.finalPrice, 0)).toLocaleString('en-IN') %>
                            </span>
                        </div>
                    </div>

                    <div class="bg-indigo-50/50 p-5 rounded-2xl border border-indigo-100 mb-8 text-center">
                        <p class="text-[10px] font-bold text-indigo-600 leading-relaxed uppercase tracking-wider">
                            <i class="fas fa-info-circle mr-1"></i> Prices and availability are subject to change based on stock levels.
                        </p>
                    </div>

                    <button id="add-all-to-cart-btn" data-wishlist-id="<%= wishlist._id %>"
                        class="w-full py-5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-2xl font-black text-xs uppercase tracking-[0.3em] shadow-xl shadow-indigo-100 hover:scale-[1.02] transition-all active:scale-95">
                        Purchase Entire Setup
                    </button>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="bg-white rounded-[3rem] p-20 text-center border border-slate-100 shadow-sm max-w-2xl mx-auto mt-10">
            <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-8 text-slate-200 text-4xl shadow-inner animate-pulse">
                <i class="fas fa-heart"></i>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight italic">Wishlist Empty</h2>
            <p class="text-slate-400 mt-4 mb-10 max-w-sm mx-auto font-medium">Your setup is missing its core components. Start hunting for the best tech deals now.</p>
            <a href="/shop" class="inline-block bg-slate-900 text-white px-12 py-5 rounded-[1.5rem] font-black text-xs uppercase tracking-[0.3em] shadow-2xl shadow-slate-200 hover:bg-indigo-600 transition-all active:scale-95">
                Start Building
            </a>
        </div>
        <% } %>
    </div>

    <%- include('./partials/footer') %>

    <script>
        $(document).ready(function () {
            // Toast Notification helper
            const toast = (icon, title) => {
                Swal.fire({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000, icon, title });
            };

            // Clear wishlist
            $("#clear-wishlist-btn").on("click", function () {
                const wishlistId = $(this).data("wishlist-id");
                Swal.fire({
                    title: "Flush Wishlist?",
                    text: "This will remove all items from your saved collection.",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#0f172a",
                    confirmButtonText: "Yes, Clear All",
                    background: "#ffffff",
                    customClass: { confirmButton: 'rounded-xl font-bold', cancelButton: 'rounded-xl font-bold' }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.post(`/wishlist/clear/${wishlistId}`, {}, function (res) {
                            if (res.status === "success") {
                                Swal.fire("Cleared", "Your wishlist is now empty.", "success").then(() => window.location.reload());
                            } else {
                                Swal.fire("Error", res.message, "error");
                            }
                        });
                    }
                });
            });

            // Delete item
            $(".delete-wishlist-item-btn").on("click", function () {
                const itemId = $(this).data("item-id");
                const itemElement = $(`#item-${itemId}`);
                
                $.post(`/wishlist/delete-item/${itemId}`, {}, function (res) {
                    if (res.status === "success") {
                        itemElement.fadeOut(400, function() { 
                            $(this).remove();
                            if ($('[id^="item-"]').length === 0) window.location.reload();
                        });
                        toast("success", "Item removed");
                    }
                });
            });

            // Add to cart
            $(".add-to-cart-btn").on("click", function () {
                const productId = $(this).data("product-id");
                const variantId = $(this).data("variant-id");
                
                Swal.fire({ title: 'Processing...', didOpen: () => Swal.showLoading() });

                fetch(`/product/cart/add/${productId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ variantId, quantity: 1 })
                }).then(res => res.json()).then(data => {
                    Swal.close();
                    if (data.status === "success") {
                        Swal.fire({
                            icon: "success",
                            title: "Transferred to Cart",
                            showConfirmButton: true,
                            confirmButtonText: "Go to Checkout",
                            confirmButtonColor: "#4f46e5",
                            showCancelButton: true,
                            cancelButtonText: "Keep Browsing"
                        }).then(result => {
                            if (result.isConfirmed) window.location.href = "/cart";
                        });
                    } else {
                        Swal.fire("Error", data.message || "Failed to add", "error");
                    }
                });
            });

            // Add all to cart
            $("#add-all-to-cart-btn").on("click", function () {
                const wishlistId = $(this).data("wishlist-id");
                Swal.fire({
                    title: "Transfer Everything?",
                    text: "Move all wishlist items to your shopping cart.",
                    icon: "question",
                    showCancelButton: true,
                    confirmButtonColor: "#4f46e5",
                    confirmButtonText: "Yes, Add All"
                }).then(result => {
                    if (result.isConfirmed) {
                        $.post(`/wishlist/add-all-to-cart/${wishlistId}`, {}, function (res) {
                            if (res.status === "success") {
                                Swal.fire("Success", "All items are now in your cart.", "success")
                                .then(() => window.location.href = "/cart");
                            } else {
                                Swal.fire("Error", res.message, "error");
                            }
                        });
                    }
                });
            });
        });
    </script>
</body>
</html>