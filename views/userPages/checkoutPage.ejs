<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout Form</title>
    <link rel="stylesheet" href="userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="userCSS/partials/partials_css.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }

      body {
        background-color: #f8f9fa;
        color: #212529;
        line-height: 1.5;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
      }

      .checkout-container {
        display: flex;
        flex-direction: column;
        gap: 30px;
      }

      @media (min-width: 768px) {
        .checkout-container {
          flex-direction: row;
        }
      }

      .checkout-form {
        flex: 1;
        background-color: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }

      .order-summary {
        width: 100%;
        background-color: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }

      @media (min-width: 768px) {
        .order-summary {
          width: 350px;
        }
      }

      h2 {
        font-size: 1.5rem;
        margin-bottom: 20px;
        color: #333;
      }

      .form-section {
        margin-bottom: 25px;
      }

      .form-section h3 {
        font-size: 1.1rem;
        margin-bottom: 15px;
        color: #555;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
      }

      .form-row {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
        gap: 15px;
      }

      @media (min-width: 576px) {
        .form-row {
          flex-direction: row;
        }
      }

      .form-group {
        flex: 1;
        margin-bottom: 15px;
      }

      label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
        font-size: 0.9rem;
        color: #555;
      }

      input,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
        transition: border-color 0.2s;
      }

      input:focus,
      select:focus {
        outline: none;
        border-color: #4a90e2;
        box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.2);
      }

      .btn {
        display: inline-block;
        background-color: #4a90e2;
        color: white;
        border: none;
        padding: 14px 24px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.2s;
        width: 100%;
      }

      .btn:hover {
        background-color: #3a7bc8;
      }

      .btn-secondary {
        background-color: #f5f5f5;
        color: #333;
        border: 1px solid #ddd;
      }

      .btn-secondary:hover {
        background-color: #e8e8e8;
      }

      .order-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #eee;
      }

      .order-item:last-child {
        border-bottom: none;
      }

      .order-total {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 2px solid #eee;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
      }

      .payment-icons {
        display: flex;
        gap: 10px;
        margin-top: 15px;
      }

      .payment-icon {
        width: 40px;
        height: 25px;
        background-color: #eee;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: #666;
      }

      .radio-group {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
      }

      .radio-option {
        display: flex;
        align-items: center;
        gap: 5px;
      }

      .radio-option input {
        width: auto;
      }

      .payment-methods {
        margin-top: 20px;
      }

      .payment-tab {
        display: none;
      }

      .payment-tab.active {
        display: block;
      }

      .tab-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 15px;
      }

      .tab-btn {
        padding: 10px 18px;
        border: 1px solid #ddd;
        background-color: #f5f5f5;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
      }

      .tab-btn.active {
        background-color: #4a90e2;
        color: white;
        border-color: #4a90e2;
      }

      .address-card {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 15px;
        margin-bottom: 15px;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
      }

      .address-card:hover {
        border-color: #4a90e2;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .address-card.selected {
        border-color: #4a90e2;
        background-color: rgba(74, 144, 226, 0.05);
      }

      .address-card.selected:before {
        content: "✓";
        position: absolute;
        top: 15px;
        right: 15px;
        color: #4a90e2;
        font-weight: bold;
      }

      .address-details {
        margin-top: 5px;
        font-size: 0.9rem;
        color: #666;
      }

      .address-name {
        font-weight: 600;
        color: #333;
        display: block;
        margin-bottom: 5px;
      }

      .payment-logo {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .payment-logo img {
        height: 30px;
        width: auto;
      }

      .tab-content {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 6px;
      }

      .toggle-form {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
      }

      .upi-options {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 15px;
      }

      .upi-option {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.2s;
      }

      .upi-option:hover {
        border-color: #4a90e2;
      }

      .upi-option.selected {
        border-color: #4a90e2;
        background-color: rgba(74, 144, 226, 0.05);
      }
      .btn.active {
    background-color: #28a745; /* green */
    color: white;
  }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial')%>
    <div class="container">
      <h2>Checkout</h2>

      <div class="checkout-container">
        <div class="checkout-form">
          <form
            action="/checkout/<%= cart._id %>"
            method="post"
            id="checkoutForm"
          >
            <input
              type="hidden"
              name="amount"
              value="<%= Math.round( cart.total ) %>"
            />
            <input
              type="hidden"
              name="items"
              value="<%= JSON.stringify(items) %>"
            />
            <input
              type="hidden"
              id="paymentMethod"
              name="paymentMethod"
              value="cod"
            />
            <input
              type="hidden"
              id="cartId"
              name="cartId"
              value="<%= cart._id %>"
            />

            <div class="form-section">
              <h3>Shipping Address</h3>

              <% if(addresses && addresses.length > 0) { %>
                <input
                  type="hidden"
                  id="selectedAddressId"
                  name="addressId"
                  value=""
                />
                <% addresses.forEach(address => { %>
                <div
                  class="address-card <%= address.type === 'Home' ? 'selected' : '' %>"
                  data-address-id="<%= address._id %>"
                >
                  <span class="address-name"><%= address.type %></span>
                  <div class="address-details">
                    <p>
                      <%= address.streetAddress %><br />
                      <%= address.city %>, <%= address.state %> <%=
                      address.zipCode %><br />
                      <%= address.country %>
                    </p>
                  </div>
                </div>
                <% }); %>
              <% } else { %>
                <p>No saved addresses found. Please add a delivery address.</p>
              <% } %>

              <div class="toggle-form">
                <button
                  type="button"
                  id="addAddressBtn"
                  class="btn btn-secondary"
                >
                  + Add Delivery Address
                </button>
              </div>
            </div>

            <div class="form-section">
              <h3>Payment Method</h3>

              <div class="tab-buttons">
                <div class="tab-btn active" data-tab="cod" data-payment="cod">
                  Cash on Delivery
                </div>
                <div
                  class="tab-btn"
                  data-tab="razorpay"
                  data-payment="razorpay"
                >
                  Razorpay
                </div>
              </div>

              <div class="payment-methods">
                <div class="payment-tab active" id="cod">
                  <div class="tab-content">
                    <p>Pay with cash when your order is delivered.</p>
                    <p style="margin-top: 10px; color: #666; font-size: 0.9rem">
                      Additional fee of ₹2.99 will be applied for Cash on
                      Delivery.
                    </p>
                  </div>
                </div>

                <div class="payment-tab" id="razorpay">
                  <div class="tab-content">
                    <p>
                      You will be redirected to Razorpay's secure payment
                      gateway after placing your order.
                    </p>
                    <p style="margin-top: 10px; color: #666; font-size: 0.9rem">
                      Razorpay supports credit/debit cards, net banking, UPI,
                      and wallet payments.
                    </p>
                    <div class="payment-icons" style="margin-top: 15px">
                      <div class="payment-icon">Visa</div>
                      <div class="payment-icon">MC</div>
                      <div class="payment-icon">UPI</div>
                      <div class="payment-icon">Bank</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <button type="submit" class="btn">Complete Purchase</button>
          </form>
        </div>

        <div class="order-summary">
          <h3>Order Summary</h3>

          <div class="order-items">
            <% if(items && items.length > 0) { %>
              <% items.forEach(item =>{ %>
              <div class="order-item">
                <span><%= item.name %></span>
                <span>$<%= (item.price * item.quantity).toFixed(2) %></span>
              </div>
              <% }) %>
            <% } else { %>
              <p>No items in cart</p>
            <% } %>
          </div>

          <div class="order-item">
            <span>Subtotal</span>
            <span>₹<%= cart.subtotal %></span>
          </div>

          <div class="order-item">
            <span>Shipping</span>
            <span>Free</span>
          </div>

          <div class="order-item">
            <span>Tax</span>
            <span>₹<%= cart.tax %></span>
          </div>

         <div class="order-total">
  <span>Total</span>
  <span id="total-amount">₹<%= newTotal %></span>
</div>

<div>
  Wallet Savings: 
  $<span id="wallet-balance"><%= walletBalance %></span>
</div>
<br />
<input type="hidden" id="walletUsed" name="walletUsed" value="false" />
<input type="hidden" id="walletAmount" name="walletAmount" value="0" />

<button 
  id="useWallet"
  class="btn"
>
  <% if(cart.walletApplied){ %>
    Wallet applied
  <% } else { %>
    Use wallet
  <% } %>
</button>


          <div class="coupon-section" style="margin-top: 20px">
            <% if(coupons && coupons.length > 0) { %>
            <div
              class="available-coupons"
              style="
                margin-top: 15px;
                border-top: 1px dashed #ddd;
                padding-top: 12px;
              "
            >
              <h5 style="font-size: 0.9rem; color: #666; margin-bottom: 8px">
                Available Coupons:
              </h5>
              <div style="display: flex; flex-wrap: wrap; gap: 8px">
                <% coupons.forEach(coupon => { %>
                <div
                  class="coupon-chip"
                  style="
                    background-color: #f5f5f5;
                    border: 1px dashed #aaa;
                    border-radius: 4px;
                    padding: 5px 10px;
                    font-size: 0.85rem;
                    cursor: pointer;
                  "
                  onclick="document.getElementById('couponCode').value='<%= coupon.code %>'"
                >
                  <strong><%= coupon.code %></strong>
                  <% if(coupon.discountType === 'percentage') { %> - <%=
                  coupon.discountValue %>% off <% } else { %> - $<%=
                  coupon.discountValue %> off <% } %>
                </div>
                <% }) %>
              </div>
            </div>
            <% } %>
            <h4 style="font-size: 1rem; margin-bottom: 10px">Have a coupon?</h4>
            <div style="display: flex; gap: 8px; margin-bottom: 15px">
              <input
                type="text"
                id="couponCode"
                name="couponCode"
                placeholder="Enter coupon code"
                style="flex: 1"
              />
              <button
                type="button"
                id="applyCoupon"
                class="btn"
                style="width: auto; padding: 12px 15px"
              >
                Apply
              </button>
            </div>
            <div
              id="couponMessage"
              style="font-size: 0.9rem; margin-top: 5px; display: none"
            ></div>
            <div id="couponDiscount" class="order-item" style="display: none">
              <span>Discount</span>
              <span id="discountAmount">-$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/footer')%>
    <div
      class="modal fade"
      id="addressModal"
      tabindex="-1"
      aria-labelledby="addressModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addressModalLabel">Add New Address</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="newAddressForm" action="/address/add" method="post">
              <div class="form-group mb-3">
                <label for="streetAddress">Street Address</label>
                <input
                  type="text"
                  class="form-control"
                  id="streetAddress"
                  name="streetAddress"
                  required
                />
              </div>

              <div class="row">
                <div class="form-group mb-3 col-md-6">
                  <label for="city">City</label>
                  <input
                    type="text"
                    class="form-control"
                    id="city"
                    name="city"
                    required
                  />
                </div>

                <div class="form-group mb-3 col-md-6">
                  <label for="state">State/Province</label>
                  <input
                    type="text"
                    class="form-control"
                    id="state"
                    name="state"
                    required
                  />
                </div>
              </div>

              <div class="row">
                <div class="form-group mb-3 col-md-6">
                  <label for="zipCode">ZIP/Postal Code</label>
                  <input
                    type="text"
                    class="form-control"
                    id="zipCode"
                    name="zipCode"
                    required
                  />
                </div>

                <div class="form-group mb-3 col-md-6">
                  <label for="country">Country</label>
                  <input
                    type="text"
                    class="form-control"
                    id="country"
                    name="country"
                    required
                  />
                </div>
              </div>

              <div class="form-group mb-3">
                <label for="phoneNumber">Phone Number</label>
                <input
                  type="tel"
                  class="form-control"
                  id="phoneNumber"
                  name="phoneNumber"
                  required
                />
              </div>
              
              <div class="form-group mb-3">
                <label for="addressType">Address Type</label>
                <select class="form-control" id="addressType" name="type" required>
                  <option value="Home">Home</option>
                  <option value="Work">Work</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
            <button type="button" class="btn" id="saveAddressBtn">
              Save Address
            </button>
          </div>
        </div>
      </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

 <script>// Initialize variables
let discountedAmount = null;
let walletUsed = false;
const originalTotal = parseFloat("<%= cart.total.toFixed(2) %>");
const walletBalance = parseFloat("<%= walletBalance.toFixed(2) %>");

document.addEventListener("DOMContentLoaded", function () {
  // Initialize Bootstrap components
  const addressModal = new bootstrap.Modal(document.getElementById("addressModal"));
  
  // Get elements
  const addAddressBtn = document.getElementById("addAddressBtn");
  const saveAddressBtn = document.getElementById("saveAddressBtn");
  const checkoutForm = document.getElementById("checkoutForm");
  const paymentMethodInput = document.getElementById("paymentMethod");
  const tabButtons = document.querySelectorAll(".tab-btn");
  const paymentTabs = document.querySelectorAll(".payment-tab");
  const addressCards = document.querySelectorAll(".address-card");
  const selectedAddressIdInput = document.getElementById("selectedAddressId");
  const useWalletBtn = document.getElementById("useWallet");
  const totalSpan = document.getElementById("total-amount");
  const walletBalanceSpan = document.getElementById("wallet-balance");
  const applyCouponBtn = document.getElementById("applyCoupon");
  const couponCodeInput = document.getElementById("couponCode");
  const couponMessage = document.getElementById("couponMessage");
  const couponDiscount = document.getElementById("couponDiscount");
  const discountAmount = document.getElementById("discountAmount");
  const amountInput = document.querySelector('input[name="amount"]');
  
  // Set up hidden form fields
  createHiddenFormFields();
  
  // Set default selected address if available
  initializeAddressSelection();
  
  // Set up event listeners
  setupEventListeners();
  
  // ====== HELPER FUNCTIONS ======
  
  function createHiddenFormFields() {
    // Create wallet-related hidden fields
    if (!document.getElementById("walletUsed")) {
      const walletUsedInput = document.createElement("input");
      walletUsedInput.type = "hidden";
      walletUsedInput.id = "walletUsed";
      walletUsedInput.name = "walletUsed";
      walletUsedInput.value = "false";
      checkoutForm.appendChild(walletUsedInput);
    }
    
    if (!document.getElementById("walletAmount")) {
      const walletAmountInput = document.createElement("input");
      walletAmountInput.type = "hidden";
      walletAmountInput.id = "walletAmount";
      walletAmountInput.name = "walletAmount";
      walletAmountInput.value = "0";
      checkoutForm.appendChild(walletAmountInput);
    }
  }
  
  function initializeAddressSelection() {
    if (addressCards.length > 0) {
      // Find selected address or use the first one as default
      let selectedCard = document.querySelector(".address-card.selected") || addressCards[0];
      selectedCard.classList.add("selected");
      selectedAddressIdInput.value = selectedCard.getAttribute("data-address-id");
    }
  }
  
  function setupEventListeners() {
    // Payment method tabs
    tabButtons.forEach((button) => {
      button.addEventListener("click", handlePaymentTabChange);
    });

    // Address selection
    addressCards.forEach((card) => {
      card.addEventListener("click", handleAddressSelection);
    });

    // Open address modal
    if (addAddressBtn) {
      addAddressBtn.addEventListener("click", function() {
        addressModal.show();
      });
    }

    // Save new address
    if (saveAddressBtn) {
      saveAddressBtn.addEventListener("click", handleSaveAddress);
    }

    // Form submission
    if (checkoutForm) {
      checkoutForm.addEventListener("submit", handleFormSubmission);
    }
    
    // Wallet toggle
    if (useWalletBtn) {
      useWalletBtn.addEventListener("click", handleWalletToggle);
    }
    
    // Apply coupon
    if (applyCouponBtn) {
      applyCouponBtn.addEventListener("click", handleCouponApplication);
    }
  }
  
  function handlePaymentTabChange() {
    // Remove active class from all buttons and tabs
    tabButtons.forEach((btn) => btn.classList.remove("active"));
    paymentTabs.forEach((tab) => tab.classList.remove("active"));

    // Add active class to clicked button
    this.classList.add("active");

    // Show corresponding tab
    const tabId = this.getAttribute("data-tab");
    document.getElementById(tabId).classList.add("active");

    // Update the payment method hidden input
    const paymentMethod = this.getAttribute("data-payment");
    paymentMethodInput.value = paymentMethod;
  }
  
  function handleAddressSelection() {
    // Remove selected class from all cards
    addressCards.forEach((c) => c.classList.remove("selected"));

    // Add selected class to clicked card
    this.classList.add("selected");

    // Get the selected address ID
    const selectedAddressId = this.getAttribute("data-address-id");

    // Update the hidden input field
    selectedAddressIdInput.value = selectedAddressId;
  }
  
  function handleSaveAddress() {
    const form = document.getElementById("newAddressForm");

    // Check form validity
    if (form.checkValidity()) {
      // Get form data
      const formData = new FormData(form);
      const formDataObj = Object.fromEntries(formData.entries());

      // Submit form data via fetch
      fetch("/checkout/add-delivery-address", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(formDataObj),
      })
        .then((response) => {
          if (!response.ok) {
            throw new Error("Network response was not ok");
          }
          return response.json();
        })
        .then((data) => {
          if (data.status === "success") {
            // Close modal
            addressModal.hide();

            // Show success message
            Swal.fire({
              icon: "success",
              title: "Success",
              text: "Address added successfully!",
              confirmButtonText: "OK",
            }).then(() => {
              // Reload page to show new address
              window.location.reload();
            });
          } else {
            // Show error message
            Swal.fire({
              icon: "error",
              title: "Error",
              text: data.message || "Failed to add address",
              confirmButtonText: "OK",
            });
          }
        })
        .catch((error) => {
          console.error("Error:", error);
          Swal.fire({
            icon: "error",
            title: "Error",
            text: "An unexpected error occurred",
            confirmButtonText: "OK",
          });
        });
    } else {
      // Trigger HTML5 validation
      form.reportValidity();
    }
  }
  
  function handleFormSubmission(e) {
    e.preventDefault(); // Prevent default form submission
    
    // Validate address selection
    if (!selectedAddressIdInput.value) {
      Swal.fire({
        icon: "error",
        title: "Error",
        text: "Please select a delivery address",
        confirmButtonText: "OK",
      });
      return;
    }

    // Gather form data
    const formData = new FormData(checkoutForm);
    const formDataObj = {};

    formData.forEach((value, key) => {
      // For items, parse the JSON string back to an object
      if (key === "items") {
        try {
          formDataObj[key] = JSON.parse(value);
        } catch (err) {
          console.error("Error parsing items JSON", err);
          formDataObj[key] = [];
        }
      } else {
        formDataObj[key] = value;
      }
    });
    
    // Apply discounted amount if a coupon was applied
    if (discountedAmount !== null) {
      formDataObj.amount = Math.round(discountedAmount);
    }
    
    // Check payment method
    if (formDataObj.paymentMethod === "razorpay") {
      processRazorpayPayment(formDataObj);
    } else {
      // For non-Razorpay methods (COD), submit directly
      submitOrder(formDataObj);
    }
  }
  
  function handleWalletToggle() {
    walletUsed = !walletUsed;
    
    // Update hidden form inputs
    document.getElementById("walletUsed").value = walletUsed.toString();
    document.getElementById("walletAmount").value = walletUsed ? Math.min(walletBalance, originalTotal).toString() : "0";

    if (walletUsed) {
      // Apply wallet
      const walletAmount = Math.min(walletBalance, originalTotal);
      const newTotal = Math.max(originalTotal - walletAmount, 0);
      
      // Update display total
      totalSpan.textContent = `$${newTotal.toFixed(2)}`;
      
      // Update hidden amount input for form submission
      if (amountInput) {
        amountInput.value = Math.round(newTotal);
      }
      
      // Update button appearance
      useWalletBtn.textContent = "Wallet Applied";
      useWalletBtn.classList.add("active");
      
      // Call API to apply wallet
      fetch("/use-wallet", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          cartId: document.getElementById("cartId").value
        }),
      })
        .then(response => {
          if (!response.ok) {
            throw new Error("Failed to apply wallet");
          }
          return response.json();
        })
        .then(data => {
          if (data.status === "success") {
            // Show success message
            showCouponMessage("Wallet savings applied successfully!", "success");
            
            // Update display if the server returns different values
            if (data.newTotal !== undefined) {
              totalSpan.textContent = `$${data.newTotal.toFixed(2)}`;
              if (amountInput) {
                amountInput.value = Math.round(data.newTotal);
              }
              
              // Store for later use
              discountedAmount = data.newTotal;
            }
            
            // Show discount if provided
            if (data.discount !== undefined) {
              if (couponDiscount && discountAmount) {
                couponDiscount.style.display = "flex";
                discountAmount.textContent = `-$${data.discount.toFixed(2)}`;
              }
            }
             setTimeout(() => {
    // window.location.reload();
  }, 800); // delay is optional
          } else {
            // Show error message and revert changes
            showCouponMessage(data.message || "Failed to apply wallet.", "error");
            resetWallet();
          }
        })
        .catch(error => {
          console.error("Wallet Error:", error);
          showCouponMessage("An error occurred while applying wallet savings.", "error");
          resetWallet();
        });
    } else {
      // Reset wallet changes
      resetWallet();
      
      // Call API to remove wallet application if needed
      fetch("/remove-wallet", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          cartId: document.getElementById("cartId").value
        }),
      })
      .catch(error => {
        console.error("Wallet Removal Error:", error);
      });
    }
  }
  
  function resetWallet() {
    // Reset display total
    totalSpan.textContent = `$${originalTotal.toFixed(2)}`;
    
    // Reset hidden amount input
    if (amountInput) {
      amountInput.value = Math.round(originalTotal);
    }
    
    // Reset button appearance
    useWalletBtn.textContent = "Use Wallet";
    useWalletBtn.classList.remove("active");
    
    // Reset wallet tracking
    walletUsed = false;
    document.getElementById("walletUsed").value = "false";
    document.getElementById("walletAmount").value = "0";
    
    // Hide discount display if it's being shown
    if (couponDiscount) {
      couponDiscount.style.display = "none";
    }
  }
  
  function handleCouponApplication() {
    const couponCode = couponCodeInput.value.trim();
    
    if (!couponCode) {
      showCouponMessage("Please enter a coupon code.", "error");
      return;
    }
    
    // Validate coupon with server
    fetch("/checkout/apply-coupon", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        couponCode: couponCode,
        cartId: document.getElementById("cartId").value
      }),
    })
      .then(response => {
        if (!response.ok) {
          throw new Error("Server error");
        }
        return response.json();
      })
      .then(data => {
        console.log("📦 Coupon Response Data:", data);
  console.log("🧪 typeof data.newTotal:", typeof data.newTotal);
        if (data.status === "success") {
          // Show success message and update discount display
          showCouponMessage("Coupon applied successfully!", "success");
          
          if (couponDiscount) {
            couponDiscount.style.display = "flex";
          }
          
          // Ensure discount is displayed properly
          const discountValue = typeof data.discount === 'string' ? 
            parseFloat(data.discount) : data.discount;
          
          if (discountAmount) {
            discountAmount.textContent = `-$${discountValue.toFixed(2)}`;
          }
          
          // Update total if provided
          if (data.newTotal !== undefined && data.newTotal !== null) {
  const newTotal = Number(data.newTotal);
  
  if (!isNaN(newTotal)) {
    if (totalSpan) {
      totalSpan.textContent = `$${newTotal.toFixed(2)}`;
    }

    if (amountInput) {
      amountInput.value = Math.round(newTotal);
    }

    discountedAmount = newTotal;

    let couponAppliedInput = document.getElementById("couponApplied");
    if (!couponAppliedInput) {
      couponAppliedInput = document.createElement("input");
      couponAppliedInput.type = "hidden";
      couponAppliedInput.id = "couponApplied";
      couponAppliedInput.name = "couponApplied";
      couponAppliedInput.value = couponCode;
      checkoutForm.appendChild(couponAppliedInput);
    } else {
      couponAppliedInput.value = couponCode;
    }
  } else {
    console.error("Invalid newTotal received (not a number):", data.newTotal);
  }
} else {
  console.error("newTotal is undefined or null");
}

        } else {
          // Show error message
          showCouponMessage(data.message || "Invalid coupon code.", "error");
          
          if (couponDiscount) {
            couponDiscount.style.display = "none";
          }
        }
      })
      .catch(error => {
        console.error("Coupon Error:", error);
        showCouponMessage("An error occurred while validating the coupon.", "error");
      });
  }
  
  function showCouponMessage(message, type) {
    if (!couponMessage) return;
    
    couponMessage.textContent = message;
    couponMessage.style.display = "block";
    
    if (type === "success") {
      couponMessage.style.color = "#28a745";
    } else {
      couponMessage.style.color = "#dc3545";
    }
    
    // Hide message after 5 seconds
    setTimeout(() => {
      couponMessage.style.display = "none";
    }, 5000);
  }
  
  function processRazorpayPayment(formData) {
    // Show loading indicator
    Swal.fire({
      title: 'Processing Payment',
      text: 'Please wait...',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });
    
    // Create Razorpay order
    fetch(`/order/create-razorpay`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        cartId: formData.cartId,
        amount: formData.amount,
        addressId: formData.addressId,
        couponCode: formData.couponApplied || null,
        walletUsed: formData.walletUsed === "true",
        walletAmount: parseFloat(formData.walletAmount || 0)
      }),
    })
      .then(response => {
        if (!response.ok) {
          throw new Error("Failed to create order");
        }
        return response.json();
      })
      .then(orderData => {
        // Close loading indicator
        Swal.close();
        
        if (!orderData.id) {
          throw new Error("Invalid order data received");
        }
        
        formData.backendOrderId = orderData.orderId;
        
        // Configure Razorpay options
        const options = {
          key:  "<%= razorpayKey %>",
          amount: orderData.amount,
          currency: orderData.currency || "INR",
          name: "BestDeals",
          description: "Order Payment",
          order_id: orderData.id,
          handler: function (response) {
            // Add Razorpay payment details to form data
            formData.razorpayPaymentId = response.razorpay_payment_id;
            formData.razorpayOrderId = response.razorpay_order_id;
            formData.razorpaySignature = response.razorpay_signature;

            // Verify payment before completing order
            verifyRazorpayPayment(formData);
          },
          prefill: {
            name: "Customer",
            email: "customer@example.com",
            contact: "",
          },
          theme: {
            color: "#4a90e2",
          },
          modal: {
            ondismiss: function() {
              // Handle payment cancellation
              Swal.fire({
                icon: "info",
                title: "Payment Cancelled",
                text: "Your payment was cancelled. You can try again or choose another payment method.",
                confirmButtonText: "OK",
              });
            }
          }
        };

        // Initialize Razorpay
        const razorpay = new Razorpay(options);
        razorpay.on('payment.failed', function(response) {
          Swal.fire({
            icon: "error",
            title: "Payment Failed",
            text: response.error.description || "Your payment could not be processed. Please try again.",
            confirmButtonText: "OK",
          });
        });
        razorpay.open();
      })
      .catch(error => {
        console.error("Razorpay Error:", error);
        Swal.fire({
          icon: "error",
          title: "Payment Error",
          text: "Failed to initialize payment. Please try again.",
          confirmButtonText: "OK",
        });
      });
  }

  function verifyRazorpayPayment(paymentData) {
    // Show loading indicator
    Swal.fire({
      title: 'Verifying Payment',
      text: 'Please wait...',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });
    
    fetch(`/verify-payment/${paymentData.cartId}`, {
      method: "POST",
      headers: { 
        "Content-Type": "application/json" 
      },
      body: JSON.stringify({
        razorpay_order_id: paymentData.razorpayOrderId,
        razorpay_payment_id: paymentData.razorpayPaymentId,
        razorpay_signature: paymentData.razorpaySignature,
        cartId: paymentData.cartId
      }),
    })
      .then(response => {
        if (!response.ok) {
          throw new Error("Verification failed");
        }
        return response.json();
      })
      .then(verifyData => {
        // Close loading indicator
        Swal.close();
        
        if (verifyData.status === "success") {
          if (verifyData.orderId) {
            // If backend already created order, just redirect
            window.location.href = `/thank-you?orderId=${verifyData.orderId}`;
          } else {
            // Otherwise complete the order submission
            submitOrder(paymentData);
          }
        } else {
          // If payment verification failed
          Swal.fire({
            icon: "error",
            title: "Payment Verification Failed",
            text: verifyData.message || "Your payment could not be verified. Please try again or contact support.",
            confirmButtonText: "OK",
          });
        }
      })
      .catch(error => {
        console.error("Verification Error:", error);
        Swal.close();
        Swal.fire({
          icon: "error",
          title: "Payment Verification Error",
          text: "An error occurred while verifying your payment. Please contact support.",
          confirmButtonText: "OK",
        });
      });
  }
  
  function submitOrder(orderData) {
    // Show loading indicator
    Swal.fire({
      title: 'Processing Order',
      text: 'Please wait...',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });
    
    // Make sure coupon information is included if a coupon was applied
    if (document.getElementById("couponApplied")) {
      orderData.couponCode = document.getElementById("couponApplied").value;
    }
    
    // Make sure wallet information is included if wallet was used
    if (document.getElementById("walletUsed") && document.getElementById("walletUsed").value === "true") {
      orderData.walletUsed = true;
      orderData.walletAmount = parseFloat(document.getElementById("walletAmount").value || 0);
    }

    // Submit order to server
    fetch(`/checkout/${orderData.cartId}`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(orderData),
    })
    .then(response => {
      // First check if the response is ok
      if (!response.ok) {
        return response.text().then(text => {
          // Try to parse as JSON, but if it fails, throw the text
          try {
            return Promise.reject(JSON.parse(text));
          } catch (e) {
            return Promise.reject(new Error(text || "Server error"));
          }
        });
      }
      
      // If response is ok, try to parse as JSON
      return response.text().then(text => {
        try {
          return JSON.parse(text);
        } catch (e) {
          throw new Error("Invalid JSON response from server");
        }
      });
    })
    .then(data => {
      // Close loading indicator
      Swal.close();
      
      if (data.status === "success") {
        // Show success message and redirect to order confirmation
        window.location.href = `/thank-you${data.orderId ? '?orderId=' + data.orderId : ''}`;
      } else {
        // Show error message
        Swal.fire({
          icon: "error",
          title: "Order Failed",
          text: data.message || "Failed to place your order. Please try again.",
          confirmButtonText: "OK",
        });
      }
    })
    .catch(error => {
      console.error("Order Error:", error);
      Swal.close();
      
      // Display a user-friendly error message
      Swal.fire({
        icon: "error",
        title: "Order Error",
        text: error.message || "An unexpected error occurred while placing your order.",
        confirmButtonText: "OK",
      });
    });
  }
});</script>
