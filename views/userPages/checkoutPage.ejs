    <script>
      // Coupon code handling
      const applyCouponBtn = document.getElementById("applyCoupon");
      const couponInput = document.getElementById("couponCode");
      const couponMessage = document.getElementById("couponMessage");
      const couponDiscountDiv = document.getElementById("couponDiscount");
      const discountAmountSpan = document.getElementById("discountAmount");
      const orderTotalElement = document.querySelector(
        ".order-total span:last-child"
      );
      let appliedCoupon = null;
      let originalTotal = parseFloat("<%= cart.total %>");

      applyCouponBtn.addEventListener("click", function () {
        const code = couponInput.value.trim();
        console.log(code);

        if (!code) {
          showCouponMessage("Please enter a coupon code", "error");
          return;
        }

        // Send request to validate coupon
        fetch(`/checkout/apply-coupon`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            code: code,
            cartId: "<%= cart._id %>",
          }),
        })
          .then((response) => response.json())
          .then((data) => {
            if (data.status === "success") {
              appliedCoupon = data.coupon;

              // Calculate discount
              let discount = 0;
              if (appliedCoupon.discountType === "percentage") {
                discount = (originalTotal * appliedCoupon.discountValue) / 100;
              } else {
                discount = appliedCoupon.discountValue;
              }

              // Ensure discount doesn't exceed the total
              discount = Math.min(discount, originalTotal);

              // Update UI with formatted discount
              discountAmountSpan.textContent = `-$${discount.toFixed(2)}`;
              couponDiscountDiv.style.display = "flex";

              // Update total amount
              const newTotal = (originalTotal - discount).toFixed(2);
              orderTotalElement.textContent = `$${newTotal}`;

              // Add hidden input for the coupon
              if (!document.getElementById("appliedCouponInput")) {
                const couponInput = document.createElement("input");
                couponInput.type = "hidden";
                couponInput.id = "appliedCouponInput";
                couponInput.name = "couponCode";
                couponInput.value = code;
                document
                  .getElementById("checkoutForm")
                  .appendChild(couponInput);
              } else {
                document.getElementById("appliedCouponInput").value = code;
              }

              // Add discount amount as hidden input
              if (!document.getElementById("discountAmountInput")) {
                const discountInput = document.createElement("input");
                discountInput.type = "hidden";
                discountInput.id = "discountAmountInput";
                discountInput.name = "discountAmount";
                discountInput.value = discount.toFixed(2);
                document
                  .getElementById("checkoutForm")
                  .appendChild(discountInput);
              } else {
                document.getElementById("discountAmountInput").value =
                  discount.toFixed(2);
              }

              showCouponMessage(
                `Coupon applied! You saved $${discount.toFixed(2)}`,
                "success"
              );
            } else {
              showCouponMessage(data.message || "Invalid coupon code", "error");
              resetCoupon();
            }
          })
          .catch((error) => {
            console.error("Error:", error);
            showCouponMessage(
              "There was an error applying the coupon",
              "error"
            );
            resetCoupon();
          });
      });

      // Function to show coupon status messages
      function showCouponMessage(message, type) {
        couponMessage.textContent = message;
        couponMessage.style.display = "block";

        if (type === "error") {
          couponMessage.style.color = "#dc3545";
        } else {
          couponMessage.style.color = "#28a745";
        }

        // Hide message after 5 seconds
        setTimeout(() => {
          couponMessage.style.display = "none";
        }, 5000);
      }

      // Function to reset coupon if invalid
      function resetCoupon() {
        couponDiscountDiv.style.display = "none";
        orderTotalElement.textContent = `$${originalTotal.toFixed(2)}`;

        // Remove hidden inputs
        const couponInput = document.getElementById("appliedCouponInput");
        const discountInput = document.getElementById("discountAmountInput");

        if (couponInput) couponInput.parentNode.removeChild(couponInput);
        if (discountInput) discountInput.parentNode.removeChild(discountInput);

        appliedCoupon = null;
      }

      // For the clickable coupon chips
      document.querySelectorAll(".coupon-chip").forEach((chip) => {
        chip.addEventListener("click", function () {
          const code = this.querySelector("strong").textContent;
          couponInput.value = code;
          applyCouponBtn.click(); // Automatically apply the selected coupon
        });
      });
    </script>
    <script></script>
  </body>
