                      <div class="payment-icon">UPI</div>
                      <div class="payment-icon">Bank</div>
                    </div>
                  </div>
                </div> -->
              </div>
            </div>

            <button type="submit" class="btn">Complete Purchase</button>
          </form>
        </div>

        <div class="order-summary">
          <h3>Order Summary</h3>

          <div class="order-item">
            <% items.forEach(item =>{ %>
            <span><%= item.name %></span>
            <span><%= item.price * item.quantity %></span>
            <% }) %>
          </div>

          <div class="order-item">
            <span>Subtotal</span>
            <span>$<%= cart.subtotal.toFixed(2) %></span>
          </div>

          <div class="order-item">
            <span>Shipping</span>
            <span><%= cart.shipping.toFixed(2) %></span>
          </div>

          <div class="order-item">
            <span>Tax</span>
            <span>$<%= cart.tax.toFixed(2) %></span>
          </div>

          <div class="order-total">
            <span>Total</span>
            <span>$<%= cart.total.toFixed(2) %></span>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/footer')%>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        // Payment method tabs
        const tabButtons = document.querySelectorAll(".tab-btn");
        const paymentTabs = document.querySelectorAll(".payment-tab");
        const paymentMethodInput = document.getElementById("paymentMethod");

        tabButtons.forEach((button) => {
          button.addEventListener("click", function () {
            // Remove active class from all buttons and tabs
            tabButtons.forEach((btn) => btn.classList.remove("active"));
            paymentTabs.forEach((tab) => tab.classList.remove("active"));

            // Add active class to clicked button
            this.classList.add("active");

            // Show corresponding tab
            const tabId = this.getAttribute("data-tab");
            document.getElementById(tabId).classList.add("active");

            // Update the payment method hidden input
            const paymentMethod = this.getAttribute("data-payment");
            paymentMethodInput.value = paymentMethod;
          });
        });

        // Address selection
        const addressCards = document.querySelectorAll(".address-card");
        let selectedAddressId = null;

        addressCards.forEach((card) => {
          card.addEventListener("click", function () {
            // Remove selected class from all cards
            addressCards.forEach((c) => c.classList.remove("selected"));

            // Add selected class to clicked card
            this.classList.add("selected");

            // Get the selected address ID
            selectedAddressId = this.getAttribute("data-address-id");

            // Update the hidden input field
            document.getElementById("selectedAddressId").value =
              selectedAddressId;
          });
        });

        // Form submission handling
        const checkoutForm = document.getElementById("checkoutForm");

        checkoutForm.addEventListener("submit", function (e) {
          e.preventDefault(); // Prevent default form submission

          // Gather form data
          const formData = new FormData(checkoutForm);
          const formDataObj = {};

          formData.forEach((value, key) => {
            // For items, parse the JSON string back to an object
            if (key === "items") {
              try {
                formDataObj[key] = JSON.parse(value);
              } catch (err) {
                console.error("Error parsing items JSON", err);
                formDataObj[key] = [];
              }
            } else {
              formDataObj[key] = value;
            }
          });

          // Send as JSON to your backend
          fetch(`/checkout/<%= cart._id %>`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(formDataObj),
          })
            .then((response) => response.json())
            .then((data) => {
              if (data.status === "success") {
                // Handle success - redirect to order confirmation
                window.location.href = `/`;
              } else {
                // Handle error
                alert(data.message || "Error placing order. Please try again.");
              }
            })
            .catch((error) => {
              console.error("Error:", error);
              alert(
                "There was an error processing your order. Please try again."
              );
            });
        });

        // UPI option selection remains the same
        const upiOptions = document.querySelectorAll(".upi-option");
        upiOptions.forEach((option) => {
          option.addEventListener("click", function () {
            upiOptions.forEach((o) => o.classList.remove("selected"));
            this.classList.add("selected");
          });
        });
      });
    </script>
  </body>
</html>
