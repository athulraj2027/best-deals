<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Checkout Form</title>
    <link rel="stylesheet" href="userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="userCSS/partials/partials_css.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }

      body {
        background-color: #f8f9fa;
        color: #212529;
        line-height: 1.5;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
      }

      .checkout-container {
        display: flex;
        flex-direction: column;
        gap: 30px;
      }

      @media (min-width: 768px) {
        .checkout-container {
          flex-direction: row;
        }
      }

      .checkout-form {
        flex: 1;
        background-color: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }

      .order-summary {
        width: 100%;
        background-color: white;
        border-radius: 8px;
        padding: 25px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }

      @media (min-width: 768px) {
        .order-summary {
          width: 350px;
        }
      }

      h2 {
        font-size: 1.5rem;
        margin-bottom: 20px;
        color: #333;
      }

      .form-section {
        margin-bottom: 25px;
      }

      .form-section h3 {
        font-size: 1.1rem;
        margin-bottom: 15px;
        color: #555;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
      }

      .form-row {
        display: flex;
        flex-direction: column;
        margin-bottom: 15px;
        gap: 15px;
      }

      @media (min-width: 576px) {
        .form-row {
          flex-direction: row;
        }
      }

      .form-group {
        flex: 1;
        margin-bottom: 15px;
      }

      label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
        font-size: 0.9rem;
        color: #555;
      }

      input,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
        transition: border-color 0.2s;
      }

      input:focus,
      select:focus {
        outline: none;
        border-color: #4a90e2;
        box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.2);
      }

      .btn {
        display: inline-block;
        background-color: #4a90e2;
        color: white;
        border: none;
        padding: 14px 24px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.2s;
        width: 100%;
      }

      .btn:hover {
        background-color: #3a7bc8;
      }

      .btn-secondary {
        background-color: #f5f5f5;
        color: #333;
        border: 1px solid #ddd;
      }

      .btn-secondary:hover {
        background-color: #e8e8e8;
      }

      .order-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #eee;
      }

      .order-item:last-child {
        border-bottom: none;
      }

      .order-total {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 2px solid #eee;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
      }

      .payment-icons {
        display: flex;
        gap: 10px;
        margin-top: 15px;
      }

      .payment-icon {
        width: 40px;
        height: 25px;
        background-color: #eee;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        color: #666;
      }

      .radio-group {
        display: flex;
        gap: 20px;
        margin-bottom: 15px;
      }

      .radio-option {
        display: flex;
        align-items: center;
        gap: 5px;
      }

      .radio-option input {
        width: auto;
      }

      .payment-methods {
        margin-top: 20px;
      }

      .payment-tab {
        display: none;
      }

      .payment-tab.active {
        display: block;
      }

      .tab-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 15px;
      }

      .tab-btn {
        padding: 10px 18px;
        border: 1px solid #ddd;
        background-color: #f5f5f5;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
      }

      .tab-btn.active {
        background-color: #4a90e2;
        color: white;
        border-color: #4a90e2;
      }

      .address-card {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 15px;
        margin-bottom: 15px;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
      }

      .address-card:hover {
        border-color: #4a90e2;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .address-card.selected {
        border-color: #4a90e2;
        background-color: rgba(74, 144, 226, 0.05);
      }

      .address-card.selected:before {
        content: "✓";
        position: absolute;
        top: 15px;
        right: 15px;
        color: #4a90e2;
        font-weight: bold;
      }

      .address-details {
        margin-top: 5px;
        font-size: 0.9rem;
        color: #666;
      }

      .address-name {
        font-weight: 600;
        color: #333;
        display: block;
        margin-bottom: 5px;
      }

      .payment-logo {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .payment-logo img {
        height: 30px;
        width: auto;
      }

      .tab-content {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 6px;
      }

      .toggle-form {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
      }

      .upi-options {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 15px;
      }

      .upi-option {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.2s;
      }

      .upi-option:hover {
        border-color: #4a90e2;
      }

      .upi-option.selected {
        border-color: #4a90e2;
        background-color: rgba(74, 144, 226, 0.05);
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial')%>
    <div class="container">
      <h2>Checkout</h2>

      <div class="checkout-container">
        <div class="checkout-form">
          <form
            action="/checkout/<%= cart._id %>"
            method="post"
            id="checkoutForm"
          >
            <input
              type="hidden"
              name="amount"
              value="<%= Math.round( cart.total ) %>"
            />
            <input
              type="hidden"
              name="items"
              value="<%= JSON.stringify(items) %>"
            />
            <input
              type="hidden"
              id="paymentMethod"
              name="paymentMethod"
              value="card"
            />

            <div class="form-section">
              <h3>Shipping Address</h3>

              <% addresses.forEach(address => { %>
              <input
                type="hidden"
                id="selectedAddressId"
                name="addressId"
                value="<%= address._id %>"
              />
              <div
                class="address-card <%= address.type === 'Home' ? 'selected' : '' %>"
                data-address-id="<%= address._id %>"
              >
                <span class="address-name"><%= address.type %></span>
                <div class="address-details">
                  <p>
                    <%= address.streetAddress %><br />
                    <%= address.city %>, <%= address.state %> <%=
                    address.zipCode %><br />
                    <%= address.country %>
                  </p>
                </div>
              </div>
              <% }); %>

              <div class="toggle-form">
                <button
                  type="button"
                  id="addAddressBtn"
                  class="btn btn-secondary"
                >
                  + Add Delivery Address
                </button>
              </div>
            </div>

            <div class="form-section">
              <h3>Payment Method</h3>

              <div class="tab-buttons">
                <div class="tab-btn" data-tab="cod" data-payment="cod">
                  Cash on Delivery
                </div>
                <div
                  class="tab-btn"
                  data-tab="razorpay"
                  data-payment="razorpay"
                >
                  Razorpay
                </div>
              </div>

              <div class="payment-methods">
                <div class="payment-tab active" id="cod">
                  <div class="tab-content">
                    <p>Pay with cash when your order is delivered.</p>
                    <p style="margin-top: 10px; color: #666; font-size: 0.9rem">
                      Additional fee of $2.99 will be applied for Cash on
                      Delivery.
                    </p>
                  </div>
                </div>

                <div class="payment-tab" id="razorpay">
                  <div class="tab-content">
                    <p>
                      You will be redirected to Razorpay's secure payment
                      gateway after placing your order.
                    </p>
                    <p style="margin-top: 10px; color: #666; font-size: 0.9rem">
                      Razorpay supports credit/debit cards, net banking, UPI,
                      and wallet payments.
                    </p>
                    <div class="payment-icons" style="margin-top: 15px">
                      <div class="payment-icon">Visa</div>
                      <div class="payment-icon">MC</div>
                      <div class="payment-icon">UPI</div>
                      <div class="payment-icon">Bank</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <button type="submit" class="btn">Complete Purchase</button>
          </form>
        </div>

        <div class="order-summary">
          <h3>Order Summary</h3>

          <div class="order-items">
            <% items.forEach(item =>{ %>
            <div class="order-item">
              <span><%= item.name %></span>
              <span>$<%= (item.price * item.quantity).toFixed(2) %></span>
            </div>
            <% }) %>
          </div>

          <div class="order-item">
            <span>Subtotal</span>
            <span>$<%= cart.subtotal.toFixed(2) %></span>
          </div>

          <div class="order-item">
            <span>Shipping</span>
            <span>$<%= cart.shipping.toFixed(2) %></span>
          </div>

          <div class="order-item">
            <span>Tax</span>
            <span>$<%= cart.tax.toFixed(2) %></span>
          </div>

          <div class="order-total">
            <span>Total</span>
            <span>$<%= cart.total.toFixed(2) %></span>
          </div>
          <div class="coupon-section" style="margin-top: 20px">
            <% if(coupons && coupons.length > 0) { %>
            <div
              class="available-coupons"
              style="
                margin-top: 15px;
                border-top: 1px dashed #ddd;
                padding-top: 12px;
              "
            >
              <h5 style="font-size: 0.9rem; color: #666; margin-bottom: 8px">
                Available Coupons:
              </h5>
              <div style="display: flex; flex-wrap: wrap; gap: 8px">
                <% coupons.forEach(coupon => { %>
                <div
                  class="coupon-chip"
                  style="
                    background-color: #f5f5f5;
                    border: 1px dashed #aaa;
                    border-radius: 4px;
                    padding: 5px 10px;
                    font-size: 0.85rem;
                    cursor: pointer;
                  "
                  onclick="document.getElementById('couponCode').value='<%= coupon.code %>'"
                >
                  <strong><%= coupon.code %></strong>
                  <% if(coupon.discountType === 'percentage') { %> - <%=
                  coupon.discountValue %>% off <% } else { %> - $<%=
                  coupon.discountValue %> off <% } %>
                </div>
                <% }) %>
              </div>
            </div>
            <% } %>
            <h4 style="font-size: 1rem; margin-bottom: 10px">Have a coupon?</h4>
            <div style="display: flex; gap: 8px; margin-bottom: 15px">
              <input
                type="text"
                id="couponCode"
                name="couponCode"
                placeholder="Enter coupon code"
                style="flex: 1"
              />
              <button
                type="button"
                id="applyCoupon"
                class="btn"
                style="width: auto; padding: 12px 15px"
              >
                Apply
              </button>
            </div>
            <div
              id="couponMessage"
              style="font-size: 0.9rem; margin-top: 5px; display: none"
            ></div>
            <div id="couponDiscount" class="order-item" style="display: none">
              <span>Discount</span>
              <span id="discountAmount">-$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('./partials/footer')%>
    <div
      class="modal fade"
      id="addressModal"
      tabindex="-1"
      aria-labelledby="addressModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addressModalLabel">Add New Address</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="newAddressForm" action="/address/add" method="post">
              <div class="form-group mb-3">
                <label for="streetAddress">Street Address</label>
                <input
                  type="text"
                  class="form-control"
                  id="streetAddress"
                  name="streetAddress"
                  required
                />
              </div>

              <div class="form-row">
                <div class="form-group mb-3 col-md-6">
                  <label for="city">City</label>
                  <input
                    type="text"
                    class="form-control"
                    id="city"
                    name="city"
                    required
                  />
                </div>

                <div class="form-group mb-3 col-md-6">
                  <label for="state">State/Province</label>
                  <input
                    type="text"
                    class="form-control"
                    id="state"
                    name="state"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group mb-3 col-md-6">
                  <label for="zipCode">ZIP/Postal Code</label>
                  <input
                    type="text"
                    class="form-control"
                    id="zipCode"
                    name="zipCode"
                    required
                  />
                </div>

                <div class="form-group mb-3 col-md-6">
                  <label for="country">Country</label>
                  <input
                    type="text"
                    class="form-control"
                    id="country"
                    name="country"
                    required
                  />
                </div>
              </div>

              <div class="form-group mb-3">
                <label for="phoneNumber">Phone Number</label>
                <input
                  type="tel"
                  class="form-control"
                  id="phoneNumber"
                  name="phoneNumber"
                  required
                />
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
            <button type="button" class="btn" id="saveAddressBtn">
              Save Address
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Add this script at the end of your body, with your other scripts -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        // Get modal elements
        const addAddressBtn = document.getElementById("addAddressBtn");
        const saveAddressBtn = document.getElementById("saveAddressBtn");
        const addressModal = new bootstrap.Modal(
          document.getElementById("addressModal")
        );

        // Open modal when Add Address button is clicked
        addAddressBtn.addEventListener("click", function () {
          addressModal.show();
        });

        // Handle form submission
        saveAddressBtn.addEventListener("click", function () {
          const form = document.getElementById("newAddressForm");

          // Check form validity
          if (form.checkValidity()) {
            // Get form data
            const formData = new FormData(form);
            const formDataObj = {};
            formData.forEach((value, key) => {
              formDataObj[key] = value;
            });

            // Submit form data via fetch
            fetch("/checkout/add-delivery-address", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify(formDataObj),
            })
              .then((response) => response.json())
              .then((data) => {
                if (data.status === "success") {
                  // Close modal
                  addressModal.hide();

                  // Show success message
                  Swal.fire({
                    icon: "success",
                    title: "Success",
                    text: "Address added successfully!",
                    confirmButtonText: "OK",
                  }).then(() => {
                    // Reload page to show new address
                    window.location.reload();
                  });
                } else {
                  // Show error message
                  Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: data.message || "Failed to add address",
                    confirmButtonText: "OK",
                  });
                }
              })
              .catch((error) => {
                console.error("Error:", error);
                Swal.fire({
                  icon: "error",
                  title: "Error",
                  text: "An unexpected error occurred",
                  confirmButtonText: "OK",
                });
              });
          } else {
            // Trigger HTML5 validation
            form.reportValidity();
          }
        });
      });
    </script>
