<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <title>Sign In | BestDeals</title>
  </head>

  <body class="min-h-screen">
    <!-- HEADER -->
    <%- include('./partials/headerPartial')%>

    <!-- MAIN -->
    <div class="flex items-center justify-center min-h-screen px-4">
      <div
        class="bg-white/95 backdrop-blur-md shadow-2xl rounded-2xl w-full max-w-md p-8"
      >
        <h2 class="text-3xl font-bold text-center mb-6 text-gray-800">
          Welcome Back
        </h2>

        <form id="signin-form" action="/signin" method="POST" class="space-y-4">
          <!-- Email -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Email Address
            </label>
            <input
              type="email"
              name="email"
              id="email"
              placeholder="you@example.com"
              class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none"
            />
            <small id="emailError" class="text-red-500 text-xs"></small>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Password
            </label>
            <input
              type="password"
              name="password"
              id="password"
              placeholder="********"
              class="w-full px-4 py-2 rounded-lg border focus:ring-2 focus:ring-indigo-500 outline-none"
            />
            <small id="passwordError" class="text-red-500 text-xs"></small>
          </div>

          <!-- Button -->
          <button
            type="submit"
            class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-lg transition"
          >
            Sign In
          </button>

          <!-- Links -->
          <div class="text-center space-y-2 text-sm mt-4">
            <a
              href="/forgot-password/verify-email"
              class="text-indigo-600 hover:underline block"
            >
              Forgot password?
            </a>

            <p>
              Don't have an account?
              <a
                href="/signup"
                class="text-indigo-600 font-medium hover:underline"
              >
                Sign Up
              </a>
            </p>
          </div>
        </form>

        <!-- Google -->
        <a
          href="/auth/google"
          class="mt-6 flex items-center justify-center gap-3 border rounded-lg py-2 hover:bg-gray-100 transition"
        >
          <img src="https://img.icons8.com/color/24/google-logo.png" />
          <span class="font-medium text-gray-700">Continue with Google</span>
        </a>
      </div>
    </div>

    <!-- FOOTER -->
    <%- include('./partials/footer')%>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function () {
        const form = $("#signin-form");

        form.on("submit", function (e) {
          e.preventDefault();

          const email = $("#email").val();
          const password = $("#password").val();

          $(".error-message").text("");

          $.ajax({
            url: "/signin",
            type: "POST",
            data: { email, password },
            dataType: "json",

            success: function (res) {
              if (res.status === "success") {
                Swal.fire("Success", res.message, "success").then(
                  () => (window.location.href = "/")
                );
              } else {
                Swal.fire("Error", res.message, "error");

                if (res.errors?.email) {
                  $("#emailError").text(res.errors.email);
                }
                if (res.errors?.password) {
                  $("#passwordError").text(res.errors.password);
                }
              }
            },

            error: function (xhr) {
              let msg = "Something went wrong";

              if (xhr.status === 403) msg = "You are blocked!";
              if (xhr.status === 400) msg = "Invalid credentials";
              if (xhr.status === 500) msg = "Server error";

              Swal.fire("Oops!", msg, "error");
            },
          });
        });
      });
    </script>
  </body>
</html>
