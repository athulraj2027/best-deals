<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="userCSS/partials/headerPartial.css" />
    <link rel="stylesheet" href="userCSS/partials/partials_css.css" />
    <link rel="stylesheet" href="userCSS/signInPage.css" />
    <title>Sign In</title>
    <style>
      .signin-container {
        max-width: 450px;
        margin: 2rem auto;
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }
      
      .social-signin-btn {
        width: 100%;
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
        border: none;
        transition: background-color 0.3s;
      }
      
      .google-btn {
        background-color: #4285f4;
        color: white;
      }
      
      .google-btn:hover {
        background-color: #357ae8;
      }
      
      .google-logo {
        margin-right: 10px;
        vertical-align: middle;
      }
      
      .links-container {
        display: flex;
        flex-direction: column;
        margin-top: 1rem;
      }
      
      .links-container a {
        margin: 0.5rem 0;
      }
      
      @media (max-width: 576px) {
        .signin-container {
          margin: 1rem;
          padding: 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <%- include('./partials/headerPartial')%>
    <div class="container">
      <div class="signin-container bg-light">
        <h2 class="text-center mb-4">Sign In</h2>
        <form id="signin-form" action="/signin" method="POST">
          <!-- Email Field -->
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="Enter your email"
            />
            <small
              class="error-message"
              id="emailError"
              style="color: red"
            ></small>
          </div>
          <!-- Password Field -->
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Enter your password"
            />
            <small
              class="error-message"
              id="passwordError"
              style="color: red"
            ></small>
          </div>
          <!-- Sign In Button -->
          <div class="d-grid">
            <button type="submit" class="btn btn-primary">Sign In</button>
          </div>
          
          <!-- Links -->
          <div class="links-container">
            <a
              href="/forgot-password/verify-email"
              class="forgot-password text-decoration-none"
              >Forgot Password?</a
            >
            <a href="/signup" class="signup-link text-decoration-none"
              >Don't have an account? Sign Up</a
            >
          </div>
        </form>
        
        <!-- Google Sign-in Button -->
        <div class="d-grid">
          <a href="/auth/google" class="text-decoration-none">
            <button class="social-signin-btn google-btn">
              <img
                src="https://img.icons8.com/color/16/000000/google-logo.png"
                alt="Google Logo"
                class="google-logo"
              />
              Sign in with Google
            </button>
          </a>
        </div>
      </div>
    </div>

    <%- include('./partials/footer')%>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      $(document).ready(function () {
        const form = $("#signin-form");

        form.on("submit", function (e) {
          e.preventDefault(); // Prevent default form submission

          const email = $("#email").val();
          const password = $("#password").val();

          // Clear previous error messages
          $(".error-message").text("");

          // AJAX request
          $.ajax({
            url: "/signin",
            type: "POST",
            data: { email, password },
            dataType: "json",

            success: function (response) {
              console.log(response); // Log the response for debugging

              if (response.status === "success") {
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'success'
                  confirmButtonText: "OK",
                }).then(() => {
                  window.location.href = "/"; // Redirect after successful login
                });
              } else {
                Swal.fire({
                  title: response.title,
                  text: response.message,
                  icon: response.status, // 'error'
                  confirmButtonText: "OK",
                });

                if (response.errors?.email) {
                  $("#emailError").text(response.errors.email);
                }
                if (response.errors?.password) {
                  $("#passwordError").text(response.errors.password);
                }
              }
            },

            error: function (xhr, status, error) {
              console.error("AJAX Error:", status, error);
              console.log("Error Response JSON:", xhr.responseJSON);

              let errorMessage =
                "An unexpected error occurred. Please try again.";

              if (xhr.responseJSON) {
                errorMessage = xhr.responseJSON.message || errorMessage;

                // Handle different error cases based on status code
                if (xhr.status === 400) {
                  errorMessage = "Invalid email or password.";
                } else if (xhr.status === 403) {
                  errorMessage = "You have been blocked by the admin.";
                } else if (xhr.status === 500) {
                  errorMessage = "Server error. Please try again later.";
                }
              }

              Swal.fire({
                title: "Oops!",
                text: errorMessage,
                icon: "error",
                confirmButtonText: "OK",
              });
            },
          });
        });
      });
    </script>
  </body>
</html>