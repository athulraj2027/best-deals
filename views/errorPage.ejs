<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        text-align: center;
        padding: 50px;
      }
      h1 {
        font-size: 4rem;
        color: #ff4757;
      }
      p {
        font-size: 1.2rem;
        color: #333;
      }
      a {
        text-decoration: none;
        color: #1e90ff;
        font-weight: bold;
      }
      a:hover {
        color: #3742fa;
      }
    </style>
  </head>
  <body>
    <h1>404</h1>
    <p>The page you are looking for does not exist.</p>
    <a href="/">Go back to Home</a>
  </body>
</html>
