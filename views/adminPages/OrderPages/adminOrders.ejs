<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Dashboard</title>
  </head>
  <body>
    <%- include('../partials/menu')%>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Orders</h1>
          </div>
          <div class="filter-section">
            <div
              class="d-flex justify-content-between align-items-center filter-controls gap-3 flex-wrap"
            >
              <!-- Filter by Status -->
              <form
                action="/admin/orders/filter"
                method="GET"
                class="flex-grow-1"
              >
                <div class="input-group">
                  <span class="input-group-text bg-white">
                    <i class="fas fa-filter text-secondary"></i>
                  </span>
                  <select
                    name="status"
                    class="form-select"
                    onchange="this.form.submit()"
                  >
                    <option value="">Filter by Status</option>
                    <option value="pending">Pending</option>
                    <option value="processing">Processing</option>
                    <option value="pending">Cancelled</option>
                    <option value="delivered">Delivered</option>
                   
                  </select>
                </div>
              </form>

              <!-- Sort by CreatedAt -->
              <form
                action="/admin/orders/sort"
                method="GET"
                class="flex-grow-1"
              >
                <div class="input-group">
                  <span class="input-group-text bg-white">
                    <i class="fas fa-sort text-secondary"></i>
                  </span>
                  <select
                    name="sort"
                    class="form-select"
                    onchange="this.form.submit()"
                  >
                  <option value="">Sort</option>
                    <option value="desc">Newest first</option>
                    <option value="asc">Oldest first</option>
                    <option value="asc_name">Name (A-Z)</option>
                    <option value="desc_name">Name (Z-A)</option>
                  </select>
                </div>
              </form>
            </div>
          </div>
          <!-- Orders Table -->
          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Payment Method</th>
                    <th>Status</th>
                    <th>Payment Status</th>
                    <th>Order Date</th>
                    <th>Actions</th>
                    <th>Change Delivery Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (orders && orders.length > 0) { %> <%
                  orders.forEach((order, index) => { %>
                  <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= order._id %></td>
                    <td><%= order.userId.name %></td>
                    <td><%= order.paymentMethod %></td>
                    <td class="text-center">
                      <span
                        class="badge <%= getStatusBadgeClass(order.status) %>"
                      >
                        <%= order.status %>
                      </span>
                    </td>
                    <td class="text-center">
                      <span
                        class="badge <%= getPaymentStatusBadgeClass(order.payment_status) %>"
                      >
                        <%= order.payment_status %>
                      </span>
                    </td>
                    <td><%= new Date(order.orderDate).toLocaleString() %></td>
                    <td class="text-center order-actions">
                      <% if (order.status !== 'cancelled' && order.status !==
                      'delivered') { %>
                      <form
                        action="/admin/orders/cancel/<%= order._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-danger">
                          Cancel
                        </button>
                      </form>
                      <% } %>
                    </td>
                    <td>
                      <form action="/admin/orders/update-status/<%= order._id %>" method="POST" class="d-inline">
                        <div class="input-group input-group-sm">
                          <select
                            name="status"
                            class="form-select form-select-sm"
                            aria-label="Change status"
                            onchange="this.form.submit()"
                          >
                            <option value="pending" class="text-warning" <%= order.status === 'pending' ? 'selected' : '' %>>
                              Pending
                            </option>
                            <option value="processing" class="text-info" <%= order.status === 'processing' ? 'selected' : '' %>>
                              Processing
                            </option>
                            <option value="delivered" class="text-success" <%= order.status === 'delivered' ? 'selected' : '' %>>
                              Delivered
                            </option>
                            <option value="cancelled" class="text-danger" <%= order.status === 'cancelled' ? 'selected' : '' %>>
                              Cancelled
                            </option>
                          </select>
                        </div>
                      </form>
                    </td>
                  </tr>
                  <% }); %> <% } else { %>
                  <tr>
                    <td colspan="8" class="text-center">No orders found.</td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
