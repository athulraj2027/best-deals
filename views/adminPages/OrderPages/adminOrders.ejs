<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Dashboard</title>
  </head>
  <body>
    <%- include('../partials/menu')%>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Orders</h1>
          </div>
          <div class="filter-section">
            <div
              class="d-flex justify-content-between align-items-center filter-controls gap-3 flex-wrap"
            >
              <!-- Filter by Status -->
              <form
                action="/admin/orders"
                method="GET"
                class="flex-grow-1"
              >
                <div class="input-group">
                  <span class="input-group-text bg-white">
                    <i class="fas fa-filter text-secondary"></i>
                  </span>
                  <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="" <%= !selectedStatus ? 'selected' : '' %>>Filter by Status</option>
                    <option value="pending" <%= selectedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                    <option value="processing" <%= selectedStatus === 'processing' ? 'selected' : '' %>>Processing</option>
                    <option value="cancelled" <%= selectedStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    <option value="delivered" <%= selectedStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
                </select>
                
                </div>
              </form>

              <!-- Sort by CreatedAt -->
              <form
                action="/admin/orders"
                method="GET"
                class="flex-grow-1"
              >
                <div class="input-group">
                  <span class="input-group-text bg-white">
                    <i class="fas fa-sort text-secondary"></i>
                  </span>
                  <select name="sort" class="form-select" onchange="this.form.submit()">
                    <option value="" <%= !selectedSort ? 'selected' : '' %>>Sort</option>
                    <option value="desc" <%= selectedSort === 'desc' ? 'selected' : '' %>>Newest first</option>
                    <option value="asc" <%= selectedSort === 'asc' ? 'selected' : '' %>>Oldest first</option>
                </select>
                
                </div>
              </form>
            </div>
          </div>
          <!-- Orders Table -->
          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Payment Method</th>
                    <th>Status</th>
                    <th>Payment Status</th>
                    <th>Order Date</th>
                    <!-- <th>Actions</th> -->
                    <th>Change Delivery Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (orders && orders.length > 0) { %> <%
                  orders.forEach((order, index) => { %>
                  <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= order._id %></td>
                    <td><%= order.userId.name %></td>
                    <td><%= order.paymentMethod %></td>
                    <td class="text-center">
                      <span
                        class="badge <%= getStatusBadgeClass(order.status) %>"
                      >
                        <%= order.status %>
                      </span>
                    </td>
                    <td class="text-center">
                      <span
                        class="badge <%= getPaymentStatusBadgeClass(order.payment_status) %>"
                      >
                        <%= order.payment_status %>
                      </span>
                    </td>
                    <td><%= new Date(order.orderDate).toLocaleString() %></td>
                    <!-- <td class="text-center order-actions">
                      <% if (order.status !== 'cancelled' && order.status !==
                      'delivered') { %>
                      <form
                        action="/admin/orders/cancel/<%= order._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-danger">
                          Cancel
                        </button>
                      </form>
                      <% } %>
                    </td> -->
                    <td>
                      <form action="/admin/orders/update-status/<%= order._id %>" method="POST" class="d-inline">
                        <div class="input-group input-group-sm">
                          <select
                            name="status"
                            class="form-select form-select-sm"
                            aria-label="Change status"
                            onchange="this.form.submit()"
                          >
                            <option value="pending" class="text-warning" <%= order.status === 'pending' ? 'selected' : '' %>>
                              Pending
                            </option>
                            <option value="processing" class="text-info" <%= order.status === 'processing' ? 'selected' : '' %>>
                              Processing
                            </option>
                            <option value="delivered" class="text-success" <%= order.status === 'delivered' ? 'selected' : '' %>>
                              Delivered
                            </option>
                            <option value="cancelled" class="text-danger" <%= order.status === 'cancelled' ? 'selected' : '' %>>
                              Cancelled
                            </option>
                          </select>
                        </div>
                      </form>
                    </td>
                  </tr>
                  <% }); %> <% } else { %>
                  <tr>
                    <td colspan="8" class="text-center">No orders found.</td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Include SweetAlert2 -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
   document.addEventListener('DOMContentLoaded', function() {
  // Handle status update forms
  const statusForms = document.querySelectorAll('form[action^="/admin/orders/update-status/"]');
  
  statusForms.forEach(form => {
    const selectElement = form.querySelector('select[name="status"]');
    const originalValue = selectElement.value;
    
    // Store original value
    selectElement.dataset.originalValue = originalValue;
    
    // Remove any existing onchange handlers
    selectElement.onchange = null;
    
    // Add new change handler
    selectElement.addEventListener('change', function(e) {
      e.preventDefault();
      
      const newStatus = this.value;
      const originalValue = this.dataset.originalValue;
      
      // Show confirmation
      Swal.fire({
        title: 'Update Status',
        text: `Change order status to ${newStatus}?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, update it',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          // User confirmed, proceed with AJAX
          
          // Show loading indicator
          Swal.fire({
            title: 'Updating...',
            text: 'Please wait',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            },
            showConfirmButton: false
          });
          
          // Send AJAX request with JSON data
          $.ajax({
            url: form.action,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ status: newStatus }),
            success: function(response) {
              // Update was successful
              Swal.fire({
                title: 'Success!',
                text: 'Status updated successfully',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
              }).then(() => {
                // Update the storage value and reload
                selectElement.dataset.originalValue = newStatus;
                window.location.reload();
              });
            },
            error: function(xhr, status, error) {
              console.error('Error:', error);
              // Show error message
              Swal.fire({
                title: 'Error',
                text: 'Failed to update the status',
                icon: 'error'
              });
              // Revert selection
              selectElement.value = originalValue;
            }
          });
        } else {
          // User cancelled, revert selection
          this.value = originalValue;
        }
      });
    });
  });
  
  // Handle cancel order buttons
  const cancelForms = document.querySelectorAll('form[action^="/admin/orders/cancel/"]');
  
  cancelForms.forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      Swal.fire({
        title: 'Cancel Order',
        text: 'Are you sure you want to cancel this order?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, cancel it',
        cancelButtonText: 'No, keep it'
      }).then((result) => {
        if (result.isConfirmed) {
          // Show loading
          Swal.fire({
            title: 'Processing...',
            text: 'Cancelling order...',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            },
            showConfirmButton: false
          });
          
          // AJAX for cancel
          $.ajax({
            url: form.action,
            type: 'POST',
            success: function(response) {
              Swal.fire({
                title: 'Success!',
                text: 'Order cancelled successfully',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
              }).then(() => {
                window.location.reload();
              });
            },
            error: function(xhr, status, error) {
              console.error('Error:', error);
              Swal.fire({
                title: 'Error',
                text: 'Failed to cancel the order',
                icon: 'error'
              });
            }
          });
        }
      });
    });
  });
});
    </script>
  </body>
</html>
