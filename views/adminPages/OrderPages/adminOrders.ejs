<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Dashboard</title>
  </head>
  <body>
    <%- include('../partials/menu')%>
    <div class="container-fluid mt-4">
        <div class="row">
          <!-- Gap for left menu -->
          <div class="col-md-2"></div>
      
          <!-- Main content -->
          <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h1 class="text-dark">Orders</h1>
              
            </div>
      
            <!-- Orders Table -->
            <div class="card border-light">
              <div class="card-body">
                <table class="table table-bordered table-hover">
                  <thead style="background-color: #f57c00; color: white;">
                    <tr class="text-center">
                      <th>#</th>
                      <th>Order ID</th>
                      <th>Customer</th>
                      <th>Order Date</th>
                      <th>Status</th>
                      <th>Total</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <!-- Example row -->
                    <tr>
                      <td>1</td>
                      <td>ORD12345</td>
                      <td>John Doe</td>
                      <td>2025-01-05</td>
                      <td>Completed</td>
                      <td>$150.00</td>
                      <td class="text-center">
                        <a href="/admin/orders/view/1" class="btn btn-sm text-white" style="background-color: #f57c00;">
                          View
                        </a>
                        <form action="/admin/orders/delete/1" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                      </td>
                    </tr>
                    <!-- Additional rows dynamically rendered -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
      
  </body>
</html>