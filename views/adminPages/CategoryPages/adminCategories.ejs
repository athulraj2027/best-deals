<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Categories</title>
    <style>
      :root {
        --primary-color: #f57c00;
        --primary-hover: #e65100;
        --light-bg: #fff9f0;
        --text-dark: #333;
        --sidebar-width: 250px;
        --sidebar-collapsed-width: 70px;
      }
      
      body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow-x: hidden;
      }
      
      /* Main layout structure */
      .main-content-wrapper {
        display: flex;
        width: 100%;
        min-height: 100vh;
      }
      
      /* Main content area that adjusts with sidebar */
      .main-content {
        flex: 1;
        padding: 20px;
        margin-left: var(--sidebar-width);
        transition: margin-left 0.3s ease;
        width: calc(100% - var(--sidebar-width));
      }
      
      .page-title {
        font-weight: 600;
        color: var(--text-dark);
        border-left: 5px solid var(--primary-color);
        padding-left: 15px;
      }
      
      .btn-primary-custom {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
        transition: all 0.3s;
      }
      
      .btn-primary-custom:hover {
        background-color: var(--primary-hover);
        border-color: var(--primary-hover);
      }
      
      .card {
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }
      
      .table-header {
        background-color: var(--primary-color);
        color: white;
      }
      
      .table-responsive {
        border-radius: 8px;
        overflow: hidden;
      }
      
      .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ced4da;
      }
      
      .form-control:focus, .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(245, 124, 0, 0.25);
      }
      
      .filter-section {
        background-color: var(--light-bg);
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
      }
      
      .status-badge {
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
      }
      
      .status-listed {
        background-color: #e7f5ea;
        color: #198754;
      }
      
      .status-unlisted {
        background-color: #fff3cd;
        color: #664d03;
      }
      
      /* Responsive adjustments */
      @media (max-width: 992px) {
        .filter-controls {
          flex-direction: column;
          gap: 10px;
        }
        
        .filter-controls > form {
          width: 100%;
        }
      }
      
      @media (max-width: 768px) {
        .main-content {
          margin-left: var(--sidebar-collapsed-width);
          width: calc(100% - var(--sidebar-collapsed-width));
        }
        
        body.sidebar-hidden .main-content {
          margin-left: 0;
          width: 100%;
        }
        
        .action-buttons {
          display: flex;
          flex-direction: column;
          gap: 5px;
          align-items: stretch;
        }
        
        .action-buttons form, 
        .action-buttons a {
          width: 100%;
        }
      }
      
      @media (max-width: 576px) {
        .main-content {
          margin-left: 0;
          width: 100%;
        }
        
        body.sidebar-expanded .main-content {
          margin-left: var(--sidebar-width);
          width: calc(100% - var(--sidebar-width));
        }
      }
    </style>
  </head>
  <body>
    <div class="main-content-wrapper">
      <!-- Include sidebar partial -->
      <%- include('../partials/menu') %>
      
      <!-- Main content area -->
      <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
          <h1 class="page-title mb-3 mb-md-0">Categories</h1>
          <a href="/admin/categories/add" class="btn btn-primary-custom">
            <i class="fas fa-plus me-2"></i>Add Category
          </a>
        </div>

        <!-- Filter, Sort, and Search Options -->
        <div class="filter-section">
          <div class="d-flex justify-content-between align-items-center filter-controls gap-3 flex-wrap">
            <!-- Filter by Status -->
            <form action="/admin/categories" method="GET" class="flex-grow-1">
              <div class="input-group">
                <span class="input-group-text bg-white">
                  <i class="fas fa-filter text-secondary"></i>
                </span>
                <select name="status" class="form-select" onchange="this.form.submit()">
                  <option value="">Filter by Status</option>
                  <option value="listed" <%= selectedStatus === 'listed' ? 'selected' : '' %>>Active</option>
                  <option value="unlisted" <%= selectedStatus === 'unlisted' ? 'selected' : '' %>>Inactive</option>
              </select>
              
              </div>
            </form>

            <!-- Sort by CreatedAt -->
            <form action="/admin/categories" method="GET" class="flex-grow-1">
              <div class="input-group">
                <span class="input-group-text bg-white">
                  <i class="fas fa-sort text-secondary"></i>
                </span>
                <select name="sort" class="form-select" onchange="this.form.submit()">
                  <option value="desc" <%= selectedSort === 'desc' ? 'selected' : '' %>>Newest first</option>
    <option value="asc" <%= selectedSort === 'asc' ? 'selected' : '' %>>Oldest first</option>
                </select>
              </div>
            </form>

            <!-- Search by Name -->
            <!-- <form action="/admin/categories/search" method="GET" class="flex-grow-1">
              <div class="input-group">
                <input type="text" name="query" placeholder="Search by name" class="form-control" />
                <button type="submit" class="btn btn-primary-custom">
                  <i class="fas fa-search"></i>
                </button>
              </div>
            </form> -->
          </div>
        </div>

        <!-- Categories Table -->
        <div class="card border-0">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover m-0">
                <thead class="table-header">
                  <tr class="text-center">
                    <th class="py-3">SI.No</th>
                    <th class="py-3">Name</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Created At</th>
                    <th class="py-3">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% categories.forEach((category, index) => { %>
                  <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= category.name %></td>
                    <td class="text-center">
                      <span class="status-badge <%= category.status === 'listed' ? 'status-listed' : 'status-unlisted' %>">
                        <%= category.status === 'listed' ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td class="text-center"><%= new Date(category.createdAt).toLocaleDateString() %></td>
                    <td>
                      <div class="d-flex justify-content-center gap-2 action-buttons">
                        <a href="/admin/categories/edit/<%= category._id %>" class="btn btn-sm btn-primary-custom">
                          <i class="fas fa-edit me-1"></i> Edit
                        </a>
                        <% if (category.status === 'listed') { %>
                        <!-- Unlist Button -->
                        <form action="/admin/categories/unlist/<%= category._id %>" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-warning w-100">
                            <i class="fas fa-eye-slash me-1"></i> Unlist
                          </button>
                        </form>
                        <% } else { %>
                        <!-- List Button -->
                        <form action="/admin/categories/list/<%= category._id %>" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-success w-100">
                            <i class="fas fa-eye me-1"></i> List
                          </button>
                        </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>