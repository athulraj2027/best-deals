<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Categories — Admin</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/adminCSS/partials/menu.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --brand:#f57c00;
      --brand-dark:#e65100;
      --ink:#1a1a2e;
      --muted:#6b7280;
      --border:#e5e7eb;
    }

    body { font-family:'Manrope',sans-serif; background:#f4f5f7; }
    .syne { font-family:'Syne',sans-serif; }

    .main-content { margin-left:250px; padding:28px 24px; }
    @media(max-width:768px){ .main-content{ margin-left:70px; } }
    @media(max-width:576px){ .main-content{ margin-left:0; } }

    .card {
      background:#fff;
      border:1px solid var(--border);
      border-radius:14px;
      box-shadow:0 2px 10px rgba(0,0,0,.05);
    }

    .tbl thead th {
      background:var(--ink);
      color:#fff;
      font-size:.75rem;
      text-transform:uppercase;
      padding:12px;
    }

    .tbl tbody td {
      padding:12px;
      font-size:.85rem;
    }

    .tbl tbody tr:hover {
      background:#fffbf5;
    }

    .badge {
      padding:4px 10px;
      border-radius:20px;
      font-size:.7rem;
      font-weight:700;
    }

    .badge-active {
      background:#dcfce7;
      color:#14532d;
    }

    .badge-inactive {
      background:#fee2e2;
      color:#7f1d1d;
    }

    .btn-primary {
      background:var(--brand);
      color:#fff;
      font-weight:700;
      border-radius:8px;
      padding:6px 12px;
      font-size:.8rem;
    }

    .btn-primary:hover {
      background:var(--brand-dark);
    }
  </style>
</head>

<body>
<div class="flex">
  <%- include('../partials/menu') %>

  <div class="main-content w-full">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-6 flex-wrap gap-3">
      <div>
        <h1 class="syne text-2xl font-extrabold">Categories</h1>
        <p class="text-sm text-gray-500">
          <%= categories.length %> categories found
        </p>
      </div>

      <a href="/admin/categories/add" class="btn-primary">
        + Add Category
      </a>
    </div>

    <!-- 🔍 SEARCH -->
    <form action="/admin/categories" method="GET" class="mb-4">
      <div class="flex gap-2">
        <input
          type="text"
          name="query"
          value="<%= query || '' %>"
          placeholder="Search categories..."
          class="flex-1 px-4 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-orange-200"
        />
        <button class="btn-primary px-4">Search</button>
      </div>
    </form>

    <!-- FILTER BAR -->
    <div class="card p-4 mb-5 flex flex-wrap gap-3">

      <!-- Status Filter -->
   <form action="/admin/categories" method="GET">
  <select 
    name="status"
    onchange="this.form.submit()"
    class="px-3 py-2 rounded-lg border text-sm"
  >
    <option value="" <%= !selectedStatus ? "selected" : "" %>>All Status</option>
    
    <option value="listed" 
      <%= selectedStatus === "listed" ? "selected" : "" %>>
      Active
    </option>
    
    <option value="unlisted" 
      <%= selectedStatus === "unlisted" ? "selected" : "" %>>
      Inactive
    </option>
  </select>
</form>

      <!-- Sort -->
    <form action="/admin/categories" method="GET">
  <select 
    name="sort"
    onchange="this.form.submit()"
    class="px-3 py-2 rounded-lg border text-sm"
  >
    <option value="desc" 
      <%= selectedSort === "desc" ? "selected" : "" %>>
      Newest
    </option>
    
    <option value="asc" 
      <%= selectedSort === "asc" ? "selected" : "" %>>
      Oldest
    </option>
  </select>
</form>

    </div>

    <!-- TABLE -->
    <div class="card overflow-hidden">
      <div class="overflow-y-auto max-h-[70vh]">

        <table class="w-full tbl">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (categories.length > 0) { %>

              <% categories.forEach((c, i) => { %>
              <tr>

                <td class="text-center text-gray-500"><%= i+1 %></td>

                <td class="font-semibold"><%= c.name %></td>

                <td>
                  <span class="badge <%= c.status==='listed' ? 'badge-active':'badge-inactive' %>">
                    <%= c.status==='listed' ? 'Active':'Inactive' %>
                  </span>
                </td>

                <td>
                  <%= new Date(c.createdAt).toLocaleDateString() %>
                </td>

                <td>
                  <div class="flex flex-col gap-1">

                    <a href="/admin/categories/edit/<%= c._id %>" class="btn-primary text-center">
                      Edit
                    </a>

                    <% if (c.status === 'listed') { %>
                      <form action="/admin/categories/unlist/<%= c._id %>" method="POST">
                        <button class="w-full bg-yellow-400 text-black text-xs py-1 rounded">
                          Unlist
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/admin/categories/list/<%= c._id %>" method="POST">
                        <button class="w-full bg-green-500 text-white text-xs py-1 rounded">
                          List
                        </button>
                      </form>
                    <% } %>

                  </div>
                </td>

              </tr>
              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="5" class="text-center py-10 text-gray-400">
                  No categories found
                </td>
              </tr>

            <% } %>
          </tbody>

        </table>
      </div>
    </div>

  </div>
</div>
</body>
</html>