<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Categories</title>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Categories</h1>
            <a
              href="/admin/categories/add"
              class="btn text-white"
              style="background-color: #f57c00"
            >
              Add Category
            </a>
          </div>

          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3">
            <!-- Filter by Status -->
            <form
              action="/admin/categories/filter"
              method="GET"
              class="d-inline"
            >
              <select
                name="status"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="">Filter by Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </form>

            <!-- Sort by CreatedAt -->
            <form action="/admin/categories/sort" method="GET" class="d-inline">
              <select
                name="sort"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="desc">Sort by Date (Newest first)</option>
                <option value="asc">Sort by Date (Oldest first)</option>
                <option value="asc_name">Sort by Name (Ascending)</option>
                <option value="desc_name">Sort by Name (Descending)</option>
              </select>
            </form>

            <!-- Search by Name -->
            <form
              action="/admin/categories/search"
              method="GET"
              class="d-inline"
            >
              <input
                type="text"
                name="query"
                placeholder="Search by name"
                class="form-control d-inline"
                style="width: 200px"
              />
              <button
                type="submit"
                class="btn btn-sm ms-2"
                style="background-color: #f57c00; color: white"
              >
                Search
              </button>
            </form>
          </div>

          <!-- Categories Table -->
          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>SI.No</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% categories.forEach((category, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= category.name %></td>
                    <!-- Show 'Listed' for true and 'Inactive' for false -->
                    <td><%= category.status %></td>
                    <td>
                      <%= new Date(category.createdAt).toLocaleDateString() %>
                    </td>
                    <td class="text-center">
                      <a
                        href="/admin/categories/edit/<%= category._id %>"
                        class="btn btn-sm text-white"
                        style="background-color: #f57c00"
                      >
                        Edit
                      </a>
                      <% if (category.status=== 'listed' ) { %>
                      <!-- Unlist Button -->
                      <form
                        action="/admin/categories/unlist/<%= category._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-warning">
                          Unlist
                        </button>
                      </form>
                      <% } else { %>
                      <!-- List Button -->
                      <form
                        action="/admin/categories/list/<%= category._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-success">
                          List
                        </button>
                      </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </body>
</html>
