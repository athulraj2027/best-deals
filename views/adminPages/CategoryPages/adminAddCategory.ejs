<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Category | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
      }
      .cropper-view-box,
      .cropper-face {
        border-radius: 8px;
      }
    </style>
  </head>

  <body class="bg-slate-50 text-slate-800 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <div class="max-w-3xl mx-auto py-12 px-4">
      <div class="mb-10 text-center">
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">
          Add New Category
        </h1>
        <p class="text-slate-500 mt-2">
          Create a new classification for your product catalog.
        </p>
      </div>

      <form
        id="addCategoryForm"
        enctype="multipart/form-data"
        class="space-y-6"
      >
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
          <h3
            class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-indigo-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              ></path>
            </svg>
            General Details
          </h3>

          <div class="space-y-6">
            <div>
              <label
                for="categoryName"
                class="block text-sm font-semibold text-slate-700 mb-2"
                >Category Name</label
              >
              <input
                type="text"
                id="categoryName"
                name="categoryName"
                placeholder="e.g. Mechanical Keyboards"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition-all"
              />
              <p
                id="categoryNameError"
                class="text-red-500 text-xs mt-2 hidden"
              ></p>
            </div>

            <div
              class="flex items-center justify-between p-4 bg-slate-50 rounded-xl border border-slate-100"
            >
              <div>
                <span class="block text-sm font-bold text-slate-700"
                  >Listing Status</span
                >
                <span
                  id="statusText"
                  class="text-xs font-semibold text-emerald-600 uppercase tracking-wider"
                  >Listed</span
                >
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  name="status"
                  id="statusToggle"
                  class="sr-only peer"
                  checked
                />
                <div
                  class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"
                ></div>
              </label>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
          <h3
            class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-indigo-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
            Category Image
          </h3>

          <div class="flex flex-col items-center">
            <div id="dropZone" class="w-full relative group">
              <label
                for="categoryImage"
                class="flex flex-col items-center justify-center w-full h-48 border-2 border-dashed border-slate-300 rounded-2xl cursor-pointer bg-slate-50 hover:bg-slate-100 hover:border-indigo-400 transition-all"
              >
                <div
                  class="flex flex-col items-center justify-center pt-5 pb-6"
                >
                  <svg
                    class="w-10 h-10 mb-3 text-slate-400 group-hover:text-indigo-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                    ></path>
                  </svg>
                  <p class="text-sm text-slate-500 font-medium">
                    Click to upload or drag and drop
                  </p>
                  <p class="text-xs text-slate-400 mt-1">
                    PNG, JPG or WebP (Max 5MB)
                  </p>
                </div>
                <input
                  type="file"
                  id="categoryImage"
                  name="categoryImage"
                  accept="image/*"
                  class="hidden"
                />
              </label>
            </div>

            <div id="previewWrapper" class="mt-6 relative hidden">
              <div class="relative inline-block">
                <img
                  id="imagePreview"
                  src=""
                  class="max-w-[280px] rounded-2xl shadow-lg border border-slate-200 object-cover aspect-square"
                />
                <button
                  type="button"
                  id="removeImageBtn"
                  class="absolute -top-3 -right-3 bg-red-500 text-white p-2 rounded-full hover:bg-red-600 shadow-xl transition-transform hover:scale-110"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"
                    ></path>
                  </svg>
                </button>
              </div>
              <button
                type="button"
                id="cropBtn"
                class="w-full mt-4 py-2.5 text-sm font-bold text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition-colors flex items-center justify-center gap-2"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758L5 19m0-14l4.121 4.121"
                  ></path>
                </svg>
                Adjust Crop
              </button>
            </div>
          </div>
        </div>

        <div
          class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-4"
        >
          <a
            href="/admin/categories"
            class="w-full sm:w-auto px-8 py-3 font-bold text-slate-600 bg-slate-200 rounded-xl hover:bg-slate-300 transition-all text-center"
          >
            Cancel
          </a>
          <button
            type="submit"
            class="w-full sm:w-auto px-10 py-3 font-bold text-white bg-indigo-600 rounded-xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95"
          >
            Create Category
          </button>
        </div>
      </form>
    </div>

    <div
      id="cropperModal"
      class="hidden fixed inset-0 z-[9999] bg-slate-900/90 flex items-center justify-center p-4 backdrop-blur-sm"
    >
      <div
        class="bg-white w-full max-w-2xl rounded-3xl overflow-hidden flex flex-col shadow-2xl"
      >
        <div class="p-5 border-b flex justify-between items-center">
          <h3 class="font-bold text-slate-800 text-xl">Crop Category Image</h3>
          <button
            type="button"
            onclick="closeCropper()"
            class="text-slate-400 hover:text-red-500 p-1"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"
              ></path>
            </svg>
          </button>
        </div>
        <div class="bg-black flex-1 max-h-[60vh] overflow-hidden">
          <img id="cropperImage" src="" class="max-w-full block" />
        </div>
        <div class="p-5 border-t flex justify-end gap-3 bg-slate-50">
          <button
            type="button"
            onclick="closeCropper()"
            class="px-6 py-2.5 font-semibold text-slate-600 bg-white border border-slate-200 rounded-xl hover:bg-slate-50"
          >
            Cancel
          </button>
          <button
            type="button"
            id="saveCropBtn"
            class="px-8 py-2.5 font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-md"
          >
            Apply Crop
          </button>
        </div>
      </div>
    </div>

    <script>
      let cropper = null;
      const categoryImage = document.getElementById("categoryImage");
      const imagePreview = document.getElementById("imagePreview");
      const previewWrapper = document.getElementById("previewWrapper");
      const removeImageBtn = document.getElementById("removeImageBtn");
      const statusToggle = document.getElementById("statusToggle");
      const statusText = document.getElementById("statusText");

      // Toggle Status Text
      statusToggle.addEventListener("change", function () {
        statusText.textContent = this.checked ? "Listed" : "Unlisted";
        statusText.className = `text-xs font-semibold uppercase tracking-wider ${this.checked ? "text-emerald-600" : "text-slate-500"}`;
      });

      // Handle Image Selection
      categoryImage.addEventListener("change", function (e) {
        const file = e.target.files[0];
        if (file) {
          if (file.size > 5 * 1024 * 1024) {
            return Swal.fire("Error", "Image is too large (Max 5MB)", "error");
          }
          const reader = new FileReader();
          reader.onload = (event) => {
            initCropper(event.target.result);
          };
          reader.readAsDataURL(file);
        }
      });

      function initCropper(src) {
        const modal = document.getElementById("cropperModal");
        const cropImg = document.getElementById("cropperImage");
        cropImg.src = src;
        modal.classList.remove("hidden");

        if (cropper) cropper.destroy();

        setTimeout(() => {
          cropper = new Cropper(cropImg, {
            aspectRatio: 1,
            viewMode: 2,
            guides: true,
            background: false,
            autoCropArea: 1,
          });
        }, 100);
      }

      document.getElementById("saveCropBtn").addEventListener("click", () => {
        const canvas = cropper.getCroppedCanvas({ width: 500, height: 500 });
        imagePreview.src = canvas.toDataURL("image/jpeg");
        previewWrapper.classList.remove("hidden");
        closeCropper();
      });

      function closeCropper() {
        document.getElementById("cropperModal").classList.add("hidden");
        if (cropper) cropper.destroy();
      }

      document.getElementById("cropBtn").addEventListener("click", () => {
        initCropper(imagePreview.src);
      });

      removeImageBtn.addEventListener("click", () => {
        imagePreview.src = "";
        previewWrapper.classList.add("hidden");
        categoryImage.value = "";
      });

      // Form Validation & Submission
      $("#addCategoryForm").on("submit", function (e) {
        e.preventDefault();
        const name = $("#categoryName").val().trim();

        if (name.length < 3) {
          $("#categoryNameError")
            .text("Name must be at least 3 characters")
            .removeClass("hidden");
          return;
        }

        Swal.fire({
          title: "Creating Category...",
          allowOutsideClick: false,
          didOpen: () => Swal.showLoading(),
        });

        const formData = new FormData(this);
        formData.set("categoryName", name);
        formData.set("status", statusToggle.checked ? "listed" : "unlisted");

        // If an image was cropped, we convert the preview base64 to a Blob
        if (imagePreview.src.startsWith("data:")) {
          const base64 = imagePreview.src.split(",")[1];
          const bin = atob(base64);
          const buffer = new Uint8Array(bin.length);
          for (let i = 0; i < bin.length; i++) buffer[i] = bin.charCodeAt(i);
          const blob = new Blob([buffer.buffer], { type: "image/jpeg" });
          formData.set("categoryImage", blob, "category.jpg");
        } else if (!categoryImage.files[0]) {
          Swal.close();
          return Swal.fire(
            "Required",
            "Please upload a category image",
            "warning",
          );
        }

        $.ajax({
          url: "/admin/categories/add",
          type: "POST",
          data: formData,
          processData: false,
          contentType: false,
          success: function (res) {
            if (res.status === "success") {
              Swal.fire(
                "Created!",
                "New category added successfully.",
                "success",
              ).then(() => (window.location.href = "/admin/categories"));
            } else {
              Swal.fire(
                "Error",
                res.message || "Failed to create category",
                "error",
              );
            }
          },
          error: function (xhr) {
            Swal.fire(
              "Error",
              xhr.responseJSON?.message || "Server error occurred",
              "error",
            );
          },
        });
      });
    </script>
  </body>
</html>
