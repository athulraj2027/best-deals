<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- FontAwesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />

    <!-- Google Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "Poppins", sans-serif;
      }
    </style>
  </head>

  <body class="bg-gray-100">
    <!-- Sidebar -->
    <%- include('./partials/menu') %>

    <!-- Main -->
    <div class="ml-[250px] p-6 max-w-[calc(100%-250px)]">
      <!-- Header -->
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Admin Dashboard</h2>

        <div class="relative">
          <button class="p-2 bg-white rounded-lg shadow">
            <i class="fa-solid fa-ellipsis-vertical"></i>
          </button>
        </div>
      </div>

      <!-- STAT CARDS -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- USERS -->
        <div
          class="bg-gradient-to-r from-indigo-600 to-blue-500 text-white rounded-2xl p-5 relative shadow"
        >
          <i
            class="fa-solid fa-users absolute right-5 top-5 text-5xl opacity-40"
          ></i>
          <p>Total Users</p>
          <h2 class="text-3xl font-bold"><%= totalUsers %></h2>
        </div>

        <!-- SALES -->
        <div
          class="bg-gradient-to-r from-emerald-500 to-teal-500 text-white rounded-2xl p-5 relative shadow"
        >
          <i
            class="fa-solid fa-chart-line absolute right-5 top-5 text-5xl opacity-40"
          ></i>
          <p>Total Sales</p>
          <h2 class="text-3xl font-bold">₹ <%= totalSales %></h2>
        </div>

        <!-- PENDING -->
        <div
          class="bg-gradient-to-r from-pink-500 to-purple-600 text-white rounded-2xl p-5 relative shadow"
        >
          <i
            class="fa-solid fa-list-check absolute right-5 top-5 text-5xl opacity-40"
          ></i>
          <p>Pending Orders</p>
          <h2 class="text-3xl font-bold"><%= pendingOrders %></h2>
        </div>

        <!-- PRODUCTS -->
        <div
          class="bg-gradient-to-r from-indigo-800 to-violet-700 text-white rounded-2xl p-5 relative shadow"
        >
          <i
            class="fa-solid fa-box absolute right-5 top-5 text-5xl opacity-40"
          ></i>
          <p>Total Products</p>
          <h2 class="text-3xl font-bold"><%= totalProducts %></h2>
        </div>
      </div>

      <!-- CONTENT -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
        <!-- REPORT FORM -->
        <div class="bg-white rounded-2xl shadow p-6">
          <h3 class="font-bold mb-4">Generate Sales Report</h3>

          <form action="/admin/sales-report" method="get" class="space-y-4">
            <select
              name="type"
              id="report-type"
              class="w-full p-2 border rounded"
            >
              <option value="daily">Daily</option>
              <option value="weekly">Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
              <option value="custom">Custom</option>
            </select>

            <!-- DAILY -->
            <div id="daily-input" class="hidden">
              <input
                type="date"
                name="date"
                class="w-full p-2 border rounded"
              />
            </div>

            <!-- WEEKLY -->
            <div id="weekly-input" class="hidden">
              <input
                type="date"
                name="start_date"
                class="w-full p-2 border rounded"
              />
            </div>

            <!-- MONTHLY -->
            <div id="monthly-input" class="hidden flex gap-3">
              <input
                type="number"
                name="year"
                placeholder="Year"
                class="w-full p-2 border rounded"
              />
              <input
                type="number"
                name="month"
                placeholder="Month"
                class="w-full p-2 border rounded"
              />
            </div>

            <!-- YEARLY -->
            <div id="yearly-input" class="hidden">
              <input
                type="number"
                name="year"
                placeholder="Year"
                class="w-full p-2 border rounded"
              />
            </div>

            <!-- CUSTOM -->
            <div id="custom-input" class="hidden flex gap-3">
              <input
                type="date"
                name="start_date"
                class="w-full p-2 border rounded"
              />
              <input
                type="date"
                name="end_date"
                class="w-full p-2 border rounded"
              />
            </div>

            <select name="download" class="w-full p-2 border rounded">
              <option value="">View</option>
              <option value="pdf">PDF</option>
              <option value="excel">Excel</option>
            </select>

            <button
              id="submitBtn"
              disabled
              class="w-full bg-indigo-600 text-white py-2 rounded transition disabled:opacity-50 disabled:cursor-not-allowed hover:bg-indigo-700"
            >
              Generate Report
            </button>
          </form>
        </div>

        <!-- CHART -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow p-6">
          <h3 class="font-bold mb-4">Sales Overview</h3>
          <canvas id="salesChart" height="120"></canvas>
        </div>
      </div>
    </div>

    <!-- ChartJS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
      document
        .getElementById("report-type")
        .addEventListener("change", function () {
          ["daily", "weekly", "monthly", "yearly", "custom"].forEach((id) => {
            document.getElementById(id + "-input")?.classList.add("hidden");
          });
          document
            .getElementById(this.value + "-input")
            ?.classList.remove("hidden");
        });

      const ctx = document.getElementById("salesChart");
      new Chart(ctx, {
        type: "line",
        data: {
          labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
          datasets: [
            {
              label: "Sales",
              data: [1200, 1500, 1100, 1800, 1400, 2000],
              borderColor: "#4f46e5",
              tension: 0.4,
            },
          ],
        },
      });
    </script>
    <script>
      const submitBtn = document.getElementById("submitBtn");
      const typeSelect = document.getElementById("report-type");

      function validateForm() {
        const type = typeSelect.value;
        let valid = false;

        if (type === "daily") {
          valid = !!document.querySelector("input[name='date']").value;
        }

        if (type === "weekly") {
          valid = !!document.querySelector("input[name='start_date']").value;
        }

        if (type === "monthly") {
          const year = document.querySelector(
            "#monthly-input input[name='year']",
          ).value;
          const month = document.querySelector(
            "#monthly-input input[name='month']",
          ).value;

          valid = !!year && !!month;
        }

        if (type === "yearly") {
          valid = !!document.querySelector("#yearly-input input[name='year']")
            .value;
        }

        if (type === "custom") {
          const start = document.querySelector(
            "#custom-input input[name='start_date']",
          ).value;
          const end = document.querySelector(
            "#custom-input input[name='end_date']",
          ).value;

          valid = !!start && !!end;
        }

        submitBtn.disabled = !valid;
      }

      // Listen for input changes
      document.querySelectorAll("input, select").forEach((el) => {
        el.addEventListener("input", validateForm);
        el.addEventListener("change", validateForm);
      });
    </script>
  </body>
</html>
