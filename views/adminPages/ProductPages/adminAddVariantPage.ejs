<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Variant | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .cropper-view-box, .cropper-face { border-radius: 8px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <div class="max-w-4xl mx-auto py-12 px-6">
        <div class="mb-10 text-center">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Add Product Variant</h1>
            <p class="text-slate-500 mt-2">Product: <span class="text-indigo-600 font-bold"><%= product.name %></span></p>
        </div>

        <form id="addVariantForm" action="/admin/products/<%= product._id %>/add-variant" method="POST" enctype="multipart/form-data" class="space-y-8">
            
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i class="fas fa-sliders-h"></i>
                    </div>
                    Variant Specifications
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Color Way</label>
                        <div class="relative">
                            <input list="color-options" id="color" name="color" placeholder="Select or type a color" 
                                class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold">
                            <datalist id="color-options">
                                <option value="Red">
                                <option value="Blue">
                                <option value="Black">
                                <option value="White">
                                <option value="Silver">
                                <option value="Space Gray">
                                <option value="Rose Gold">
                                <option value="Mint Green">
                                <option value="Navy Blue">
                            </datalist>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Size / Factor</label>
                        <select id="size" name="size" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold">
                            <option value="">Select Size</option>
                            <option value="65%">65% Compact</option>
                            <option value="75%">75% TKL</option>
                            <option value="Tenkeyless">Tenkeyless</option>
                            <option value="Fullsize">Fullsize</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Unit Price (₹)</label>
                        <input type="number" id="price" name="price" step="0.01" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" placeholder="0.00" />
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Stock Quantity</label>
                        <input type="number" id="quantity" name="quantity" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" placeholder="0" />
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-2 flex items-center gap-3">
                    <div class="w-10 h-10 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600">
                        <i class="fas fa-images"></i>
                    </div>
                    Product Gallery
                </h3>
                <p class="text-xs text-slate-400 mb-8 ml-13">Exactly 3 high-quality images are required.</p>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <% [1, 2, 3].forEach(index => { %>
                        <div class="image-upload-group" data-index="<%= index %>">
                            <div class="relative group aspect-square rounded-[2rem] overflow-hidden border-2 border-dashed border-slate-200 bg-slate-50 hover:bg-white hover:border-indigo-400 transition-all">
                                <img id="imgView<%= index %>" class="hidden w-full h-full object-cover" src="" />
                                <label for="imgInput<%= index %>" class="absolute inset-0 flex flex-col items-center justify-center cursor-pointer">
                                    <div class="upload-icon text-slate-400 text-center">
                                        <i class="fas fa-plus text-xl mb-2"></i>
                                        <p class="text-[10px] font-bold uppercase tracking-widest">Image <%= index %></p>
                                    </div>
                                </label>
                                <input type="file" id="imgInput<%= index %>" accept="image/*" class="hidden" onchange="handleFileSelect(event, <%= index %>)" />
                                <button type="button" onclick="removeImage(<%= index %>)" class="hidden absolute top-3 right-3 w-8 h-8 bg-red-500 text-white rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 remove-btn">
                                    <i class="fas fa-times text-xs"></i>
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-4">
                <a href="/admin/products" class="w-full sm:w-auto px-10 py-4 font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest text-xs transition-all text-center">Discard</a>
                <button type="submit" class="w-full sm:w-auto px-12 py-4 font-black text-white bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95 uppercase tracking-widest text-xs">
                    List Variant
                </button>
            </div>
        </form>
    </div>

    <div id="cropperModal" class="hidden fixed inset-0 z-[9999] bg-slate-900/90 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-2xl rounded-[2.5rem] overflow-hidden flex flex-col shadow-2xl">
            <div class="p-6 border-b flex justify-between items-center">
                <h3 class="font-bold text-slate-800 text-xl tracking-tight">Crop Image</h3>
                <button type="button" onclick="closeCropper()" class="text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
            </div>
            <div class="bg-black flex-1 max-h-[60vh] overflow-hidden">
                <img id="cropperImage" src="" class="max-w-full block" />
            </div>
            <div class="p-6 border-t flex justify-end gap-3 bg-slate-50">
                <button type="button" onclick="closeCropper()" class="px-6 py-2.5 font-bold text-slate-500 bg-white border border-slate-200 rounded-xl uppercase text-[10px] tracking-widest">Cancel</button>
                <button type="button" id="saveCropBtn" class="px-8 py-2.5 font-black text-white bg-indigo-600 rounded-xl uppercase text-[10px] tracking-widest shadow-lg">Apply Crop</button>
            </div>
        </div>
    </div>

    <script>
        let cropper = null;
        let currentIdx = null;
        const croppedImages = { 1: null, 2: null, 3: null };

        function handleFileSelect(event, index) {
            const file = event.target.files[0];
            if (file) {
                if (file.size > 5 * 1024 * 1024) return Swal.fire("Error", "Max size is 5MB", "error");
                const reader = new FileReader();
                reader.onload = (e) => {
                    currentIdx = index;
                    openCropper(e.target.result);
                };
                reader.readAsDataURL(file);
            }
        }

        function openCropper(src) {
            const modal = document.getElementById('cropperModal');
            const cropImg = document.getElementById('cropperImage');
            cropImg.src = src;
            modal.classList.remove('hidden');
            if (cropper) cropper.destroy();
            setTimeout(() => {
                cropper = new Cropper(cropImg, { aspectRatio: 1, viewMode: 2 });
            }, 100);
        }

        document.getElementById('saveCropBtn').addEventListener('click', () => {
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            const dataUrl = canvas.toDataURL('image/jpeg');
            const imgView = document.getElementById(`imgView${currentIdx}`);
            imgView.src = dataUrl;
            imgView.classList.remove('hidden');
            
            const group = document.querySelector(`.image-upload-group[data-index="${currentIdx}"]`);
            group.querySelector('.upload-icon').classList.add('hidden');
            group.querySelector('.remove-btn').classList.remove('hidden');

            canvas.toBlob((blob) => { croppedImages[currentIdx] = blob; }, 'image/jpeg');
            closeCropper();
        });

        function removeImage(index) {
            croppedImages[index] = null;
            const group = document.querySelector(`.image-upload-group[data-index="${index}"]`);
            document.getElementById(`imgInput${index}`).value = "";
            const imgView = document.getElementById(`imgView${index}`);
            imgView.src = "";
            imgView.classList.add('hidden');
            group.querySelector('.upload-icon').classList.remove('hidden');
            group.querySelector('.remove-btn').classList.add('hidden');
        }

        function closeCropper() {
            document.getElementById('cropperModal').classList.add('hidden');
            if (cropper) cropper.destroy();
        }

        $('#addVariantForm').on('submit', function(e) {
            e.preventDefault();
            
            const color = $('#color').val().trim();
            const size = $('#size').val();
            const price = $('#price').val();
            const quantity = $('#quantity').val();

            if (!color || !size || !price || !quantity) {
                return Swal.fire("Warning", "Please fill in all details.", "warning");
            }

            if (!croppedImages[1] || !croppedImages[2] || !croppedImages[3]) {
                return Swal.fire("Images Missing", "3 images are mandatory.", "warning");
            }

            Swal.fire({
                title: 'Listing Variant...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            const formData = new FormData();
            formData.append('color', color);
            formData.append('size', size);
            formData.append('price', price);
            formData.append('quantity', quantity);
            formData.append('images', croppedImages[1], 'v1.jpg');
            formData.append('images', croppedImages[2], 'v2.jpg');
            formData.append('images', croppedImages[3], 'v3.jpg');

            $.ajax({
                url: $(this).attr('action'),
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function(res) {
                    Swal.fire("Success", "Variant added.", "success").then(() => {
                        window.location.href = "/admin/products";
                    });
                },
                error: function(xhr) {
                    Swal.fire("Error", xhr.responseJSON?.message || "Failed to add variant", "error");
                }
            });
        });
    </script>
</body>
</html>