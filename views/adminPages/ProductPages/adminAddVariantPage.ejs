<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Variant | Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .cropper-view-box, .cropper-face { border-radius: 8px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <div class="max-w-4xl mx-auto py-12 px-6">
        <div class="mb-10 text-center">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Add Product Variant</h1>
            <p class="text-slate-500 mt-2">Configuring specifications for: <span class="text-indigo-600 font-bold"><%= product.name %></span></p>
        </div>

        <form id="addVariantForm" action="/admin/products/<%= product._id %>/add-variant" method="POST" enctype="multipart/form-data" class="space-y-8">
            
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i class="fas fa-sliders-h"></i>
                    </div>
                    Variant Specifications
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Color Way</label>
                        <select id="color" name="color" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold appearance-none cursor-pointer">
                            <option value="">Select Color</option>
                            <option value="red">Red</option>
                            <option value="blue">Blue</option>
                            <option value="black">Black</option>
                            <option value="white">White</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Size / Factor</label>
                        <select id="size" name="size" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold appearance-none cursor-pointer">
                            <option value="">Select Size</option>
                            <option value="65%">65% Compact</option>
                            <option value="75%">75% TKL</option>
                            <option value="Tenkeyless">Tenkeyless</option>
                            <option value="Fullsize">Fullsize</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Unit Price (₹)</label>
                        <input type="number" id="price" name="price" step="0.01" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" placeholder="0.00" />
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Stock Quantity</label>
                        <input type="number" id="quantity" name="quantity" class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold" placeholder="0" />
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-2 flex items-center gap-3">
                    <div class="w-10 h-10 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600">
                        <i class="fas fa-images"></i>
                    </div>
                    Media Gallery
                </h3>
                <p class="text-xs text-slate-400 mb-8 ml-13">Upload up to 5 high-resolution images. Crop them to 1:1 for best display.</p>

                <div class="space-y-6">
                    <div id="dropZone" class="relative group">
                        <label for="images" class="flex flex-col items-center justify-center w-full h-48 border-2 border-dashed border-slate-200 rounded-[2rem] cursor-pointer bg-slate-50 hover:bg-white hover:border-indigo-400 transition-all duration-300">
                            <div class="flex flex-col items-center justify-center pt-5 pb-6 text-slate-400 group-hover:text-indigo-500">
                                <i class="fas fa-cloud-upload-alt text-3xl mb-4"></i>
                                <p class="text-sm font-bold tracking-tight">Drop files here or click to browse</p>
                                <p class="text-[10px] uppercase font-black tracking-widest mt-2 opacity-60">PNG, JPG or WebP (Max 5MB)</p>
                            </div>
                            <input type="file" id="images" name="images" multiple accept="image/*" class="hidden" />
                        </label>
                    </div>

                    <div id="imagePreviewContainer" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4"></div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-4">
                <a href="/admin/products" class="w-full sm:w-auto px-10 py-4 font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest text-xs transition-all text-center">
                    Discard Changes
                </a>
                <button type="submit" class="w-full sm:w-auto px-12 py-4 font-black text-white bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95 uppercase tracking-widest text-xs">
                    List Variant
                </button>
            </div>
        </form>

        <div class="mt-16">
            <h3 class="text-xl font-extrabold text-slate-900 mb-6 px-2 italic underline decoration-indigo-200 underline-offset-8 text-center md:text-left">Existing Variants</h3>
            <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-200 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-100">
                            <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Specs</th>
                            <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Market Price</th>
                            <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Stock</th>
                            <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Thumbnail</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% product.variants.forEach(variant => { %>
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4 text-sm font-bold text-slate-800 capitalize"><%= variant.color %> (<%= variant.size %>)</td>
                            <td class="px-6 py-4 text-sm font-black text-slate-900">₹<%= variant.price.toLocaleString('en-IN') %></td>
                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 rounded-full text-[10px] font-bold <%= variant.quantity < 10 ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-600' %>">
                                    <%= variant.quantity %> Units
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <% if (variant.images && variant.images.length > 0) { %>
                                    <img src="<%= variant.images[0].url %>" class="w-12 h-12 rounded-xl object-cover ml-auto" />
                                <% } else { %>
                                    <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center ml-auto text-slate-300"><i class="fas fa-image"></i></div>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="cropperModal" class="hidden fixed inset-0 z-[9999] bg-slate-900/90 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-2xl rounded-[2.5rem] overflow-hidden flex flex-col shadow-2xl">
            <div class="p-6 border-b flex justify-between items-center">
                <h3 class="font-bold text-slate-800 text-xl tracking-tight">Adjust Image Frame</h3>
                <button type="button" onclick="closeCropper()" class="text-slate-400 hover:text-red-500 transition-colors"><i class="fas fa-times text-xl"></i></button>
            </div>
            <div class="bg-black flex-1 max-h-[60vh] overflow-hidden relative">
                <img id="cropperImage" src="" class="max-w-full block" />
            </div>
            <div class="p-6 border-t flex justify-end gap-3 bg-slate-50">
                <button type="button" onclick="closeCropper()" class="px-6 py-2.5 font-bold text-slate-500 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 text-xs uppercase tracking-widest">Cancel</button>
                <button type="button" id="saveCropBtn" class="px-8 py-2.5 font-black text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-100 text-xs uppercase tracking-widest">Apply Frame</button>
            </div>
        </div>
    </div>

    <script>
        let cropper = null;
        let finalFiles = []; 
        
        const imageInput = document.getElementById('images');
        const previewContainer = document.getElementById('imagePreviewContainer');
        const saveCropBtn = document.getElementById('saveCropBtn');

        // sequential cropping logic remains the same
        imageInput.addEventListener('change', async function(e) {
            const files = Array.from(e.target.files);
            if (files.length === 0) return;
            if (finalFiles.length + files.length > 5) {
                return Swal.fire("Limit Reached", "Max 5 images allowed per variant", "warning");
            }
            for (const file of files) {
                const reader = new FileReader();
                const result = await new Promise((resolve) => {
                    reader.onload = (event) => resolve(event.target.result);
                    reader.readAsDataURL(file);
                });
                await openCropperWorkflow(result, file.name);
            }
            imageInput.value = '';
        });

        function openCropperWorkflow(src, fileName) {
            return new Promise((resolve) => {
                const modal = document.getElementById('cropperModal');
                const cropImg = document.getElementById('cropperImage');
                cropImg.src = src;
                modal.classList.remove('hidden');
                if (cropper) cropper.destroy();
                setTimeout(() => {
                    cropper = new Cropper(cropImg, { aspectRatio: 1, viewMode: 2, background: false });
                }, 100);
                saveCropBtn.onclick = () => {
                    const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
                    canvas.toBlob((blob) => {
                        const url = URL.createObjectURL(blob);
                        addThumbnail(url, blob, fileName);
                        closeCropper();
                        resolve();
                    }, 'image/jpeg', 0.9);
                };
            });
        }

        function addThumbnail(url, blob, fileName) {
            const id = Date.now();
            finalFiles.push({ id, blob, fileName });
            const thumb = document.createElement('div');
            thumb.className = "relative group aspect-square rounded-2xl overflow-hidden border border-slate-200 shadow-sm transition-all hover:shadow-md";
            thumb.id = `thumb-${id}`;
            thumb.innerHTML = `<img src="${url}" class="w-full h-full object-cover">
                <button type="button" onclick="removeThumb(${id})" class="absolute top-2 right-2 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><i class="fas fa-times text-[10px]"></i></button>`;
            previewContainer.appendChild(thumb);
        }

        function removeThumb(id) {
            finalFiles = finalFiles.filter(f => f.id !== id);
            document.getElementById(`thumb-${id}`).remove();
        }

        function closeCropper() {
            document.getElementById('cropperModal').classList.add('hidden');
            if (cropper) cropper.destroy();
        }

        // --- NEW VALIDATION LOGIC ---
        function validateForm() {
            const color = document.getElementById('color').value;
            const size = document.getElementById('size').value;
            const price = document.getElementById('price').value;
            const quantity = document.getElementById('quantity').value;

            if (!color) return "Please select a color.";
            if (!size) return "Please select a size factor.";
            
            if (!price || isNaN(price) || parseFloat(price) <= 0) {
                return "Please enter a valid price greater than 0.";
            }

            if (!quantity || isNaN(quantity) || parseInt(quantity) < 0) {
                return "Quantity cannot be empty or negative.";
            }

            if (finalFiles.length === 0) {
                return "Please upload at least one image for this variant.";
            }

            return null; // Passes validation
        }

        $('#addVariantForm').on('submit', function(e) {
            e.preventDefault();
            
            // Trigger custom validations
            const error = validateForm();
            if (error) {
                return Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: error,
                    confirmButtonColor: '#4361ee'
                });
            }

            Swal.fire({
                title: 'Listing Variant...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            const formData = new FormData(this);
            finalFiles.forEach((fileObj) => {
                formData.append('images', fileObj.blob, fileObj.fileName);
            });

            $.ajax({
                url: $(this).attr('action'),
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function(res) {
                    Swal.fire("Success", "Variant added to inventory.", "success").then(() => {
                        window.location.reload();
                    });
                },
                error: function(xhr) {
                    Swal.fire("Error", xhr.responseJSON?.message || "Failed to add variant", "error");
                }
            });
        });
    </script>
</body>
</html>