<!DOCTYPE html>
<html>
<head>
    <title>Edit Product</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Add SweetAlert2 CSS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Then Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Then SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        .variant-container {
            border: 1px solid #ddd;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 5px;
        }
        .image-preview-container {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            flex-wrap: wrap;
        }
        .image-preview-wrapper {
            position: relative;
            width: 150px;
            height: 150px;
        }
        .image-preview {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 5px;
            border: 1px solid #ddd;
        }
        .image-order {
            position: absolute;
            top: 5px;
            left: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 12px;
        }
        .remove-image {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(255, 0, 0, 0.7);
            color: white;
            border: none;
            border-radius: 3px;
            padding: 2px 8px;
            font-size: 12px;
            cursor: pointer;
        }
        .drag-drop-zone {
            border: 2px dashed #ccc;
            border-radius: 5px;
            padding: 20px;
            text-align: center;
            margin-top: 10px;
            background: #f8f9fa;
            cursor: pointer;
        }
        .drag-drop-zone.dragover {
            background: #e9ecef;
            border-color: #0d6efd;
        }
        .image-preview-container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 10px;
        }
        
        .existing-image-wrapper {
            position: relative;
            width: 150px;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 5px;
        }
        
        .image-preview {
            width: 140px;
            height: 140px;
            object-fit: cover;
            border-radius: 3px;
        }
        
        .image-number {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 12px;
        }
        
        .delete-image {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 2px 8px;
            font-size: 12px;
        }

        .new-image-preview-container {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .new-image-wrapper {
            position: relative;
            width: 150px;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 5px;
        }
        
        .image-upload-container {
            margin-top: 15px;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }
        
        .single-image-upload {
            margin-bottom: 15px;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <div class="container mt-5">
        <h2>Edit Product</h2>
        <form id="editProductForm" action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
            <!-- Existing product fields -->
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" name="name" value="<%= product.name %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Brand</label>
                <input type="text" class="form-control" name="brand" value="<%= product.brand %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Actual Price</label>
                <input type="number" class="form-control" name="actualPrice" value="<%= product.actualPrice %>" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" name="category" required>
                    <% categories.forEach(category => { %>
                        <option value="<%= category.name %>" <%= product.category === category.name ? 'selected' : '' %>><%= category.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="true" <%= product.status ? 'selected' : '' %>>Listed</option>
                    <option value="false" <%= product.status ? '' : 'selected' %>>Unlisted</option>
                </select>
            </div>

            <div id="variants-container">
                <h4>Variants</h4>
                <% product.variants.forEach((variant, variantIndex) => { %>
                    <div class="variant-container" data-variant-index="<%= variantIndex %>">
                        <div class="row">
                            <div class="col-md-3">
                                <label class="form-label">Color</label>
                                <input type="text" class="form-control" name="variants[<%= variantIndex %>][color]" value="<%= variant.color %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Size</label>
                                <input type="text" class="form-control" name="variants[<%= variantIndex %>][size]" value="<%= variant.size %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Price</label>
                                <input type="number" class="form-control" name="variants[<%= variantIndex %>][price]" value="<%= variant.price %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Quantity</label>
                                <input type="number" class="form-control" name="variants[<%= variantIndex %>][quantity]" value="<%= variant.quantity %>" required>
                            </div>
                        </div>
                        
                        <!-- Existing Images Section with Replace Option -->
                        <div class="mt-3">
                            <label class="form-label">Current Images</label>
                            <div class="image-preview-container">
                                <% if (variant.images && variant.images.length > 0) { %>
                                    <% variant.images.forEach((image, imageIndex) => { %>
                                        <div class="existing-image-wrapper">
                                            <img src="<%= image.url %>" class="image-preview" alt="Variant image <%= imageIndex + 1 %>">
                                            <span class="image-number">Image <%= imageIndex + 1 %></span>
                                            <button type="button" class="btn btn-danger btn-sm delete-image" 
                                                    data-variant-index="<%= variantIndex %>" 
                                                    data-image-index="<%= imageIndex %>">
                                                Remove
                                            </button>
                                            <!-- Hidden input to track existing images -->
                                            <input type="hidden" 
                                                   name="variants[<%= variantIndex %>][existingImages][<%= imageIndex %>][url]" 
                                                   value="<%= image.url %>">
                                            <input type="hidden" 
                                                   name="variants[<%= variantIndex %>][existingImages][<%= imageIndex %>][position]" 
                                                   value="<%= imageIndex %>">
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <p class="text-muted">No images uploaded yet</p>
                                <% } %>
                            </div>
                        </div>
            
                        <!-- Individual Image Replacement Section -->
                        <div class="image-upload-container">
                            <h5>Replace Individual Images</h5>
                            <% for (let i = 0; i < 3; i++) { %>
                                <div class="single-image-upload">
                                    <label class="form-label">Image Position <%= i+1 %></label>
                                    <input type="file" 
                                           class="form-control" 
                                           name="variants[<%= variantIndex %>][replaceImage][<%= i %>]" 
                                           accept="image/*"
                                           data-variant-index="<%= variantIndex %>"
                                           data-position="<%= i %>"
                                           onchange="previewReplaceImage(this)">
                                    <div class="mt-2" id="replacePreview-<%= variantIndex %>-<%= i %>">
                                        <% if (variant.images && variant.images[i]) { %>
                                            <p class="text-muted">Will replace: Image <%= i+1 %></p>
                                        <% } else { %>
                                            <p class="text-muted">Will add as new image</p>
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
            
                        <button type="button" class="btn btn-danger btn-sm mt-3 remove-variant">Remove Variant</button>
                    </div>
                <% }); %>
            </div>

            <!-- <button type="button" class="btn btn-secondary mb-3" id="add-variant">Add New Variant</button> -->
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Update Product</button>
                <a href="/admin/products" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Initialize drag and drop for existing variants
        document.querySelectorAll('.drag-drop-zone').forEach(initializeDragDrop);
        
        function initializeDragDrop(dropZone) {
            const variantIndex = dropZone.id.split('-').pop();
            const fileInput = document.getElementById(`file-input-${variantIndex}`);
            
            dropZone.addEventListener('click', () => fileInput.click());
            
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('dragover');
            });
            
            dropZone.addEventListener('dragleave', () => {
                dropZone.classList.remove('dragover');
            });
            
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('dragover');
                handleFiles(e.dataTransfer.files, variantIndex);
            });
            
            fileInput.addEventListener('change', (e) => {
                handleFiles(e.target.files, variantIndex);
            });
        }

        function handleFiles(files, variantIndex) {
            const previewContainer = document.getElementById(`image-preview-${variantIndex}`);
            const currentImages = previewContainer.querySelectorAll('.image-preview-wrapper').length;
            
            if (currentImages + files.length > 3) {
                Swal.fire({
                    icon: 'error',
                    title: 'Too many images',
                    text: 'Maximum 3 images allowed per variant'
                });
                return;
            }

            Array.from(files).forEach((file, index) => {
                if (!file.type.startsWith('image/')) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid file type',
                        text: 'Please upload only images'
                    });
                    return;
                }

                const reader = new FileReader();
                reader.onload = (e) => {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'image-preview-wrapper';
                    wrapper.dataset.order = currentImages + index;
                    
                    wrapper.innerHTML = `
                        <img src="${e.target.result}" class="image-preview" alt="Variant image">
                        <span class="image-order">Image ${currentImages + index + 1}</span>
                        <button type="button" class="remove-image" data-variant="${variantIndex}" data-image="${currentImages + index}">×</button>
                        <input type="hidden" name="variants[${variantIndex}][images][${currentImages + index}][url]" value="${e.target.result}">
                        <input type="hidden" name="variants[${variantIndex}][images][${currentImages + index}][order]" value="${currentImages + index}">
                    `;
                    
                    previewContainer.appendChild(wrapper);
                };
                reader.readAsDataURL(file);
            });
        }

        // Add new variant functionality
        document.getElementById('add-variant').addEventListener('click', function() {
            const variantIndex = document.querySelectorAll('.variant-container').length;
            const container = document.createElement('div');
            container.className = 'variant-container';
            container.dataset.variantIndex = variantIndex;
            
            container.innerHTML = `
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Color</label>
                        <input type="text" class="form-control" name="variants[${variantIndex}][color]" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Size</label>
                        <input type="text" class="form-control" name="variants[${variantIndex}][size]" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Price</label>
                        <input type="number" class="form-control" name="variants[${variantIndex}][price]" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" name="variants[${variantIndex}][quantity]" required>
                    </div>
                </div>
                
                <div class="mt-3">
                    <label class="form-label">Images (Max 3)</label>
                    <div class="image-preview-container" id="image-preview-${variantIndex}"></div>
                    <div class="drag-drop-zone" id="drop-zone-${variantIndex}">
                        <p class="mb-0">Drag & drop images here or click to select</p>
                        <input type="file" class="d-none" id="file-input-${variantIndex}" 
                               accept="image/*" multiple data-variant="${variantIndex}">
                    </div>
                </div>
                
                <button type="button" class="btn btn-danger btn-sm mt-2 remove-variant">Remove Variant</button>
            `;
            
            document.getElementById('variants-container').appendChild(container);
            initializeDragDrop(container.querySelector('.drag-drop-zone'));
        });

        // Remove variant
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-variant')) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, remove it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        e.target.closest('.variant-container').remove();
                    }
                });
            }
            if (e.target.classList.contains('remove-image')) {
                e.target.closest('.image-preview-wrapper').remove();
            }
        });
        
        // Delete existing image
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('delete-image')) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to recover this image!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const wrapper = e.target.closest('.existing-image-wrapper');
                        const variantIndex = e.target.dataset.variantIndex;
                        const imageIndex = e.target.dataset.imageIndex;
                        
                        // Add hidden input to track deleted images
                        const deletedInput = document.createElement('input');
                        deletedInput.type = 'hidden';
                        deletedInput.name = `variants[${variantIndex}][deletedImages][]`;
                        deletedInput.value = wrapper.querySelector('input[name$="[url]"]').value;
                        wrapper.closest('.variant-container').appendChild(deletedInput);
                        
                        wrapper.remove();
                    }
                });
            }
        });

        // Preview replacement image
        function previewReplaceImage(input) {
            const variantIndex = input.dataset.variantIndex;
            const position = input.dataset.position;
            const previewDiv = document.getElementById(`replacePreview-${variantIndex}-${position}`);
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    previewDiv.innerHTML = `
                        <div class="mt-2 d-flex align-items-center">
                            <img src="${e.target.result}" alt="Preview" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
                            <div class="ms-3">
                                <p class="mb-0">New image selected</p>
                                <button type="button" class="btn btn-sm btn-outline-danger mt-1" 
                                        onclick="clearReplaceImage(${variantIndex}, ${position})">
                                    Cancel
                                </button>
                            </div>
                        </div>
                        <input type="hidden" name="variants[${variantIndex}][replaceImagePosition][${position}]" value="${position}">
                    `;
                };
                
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        // Clear replacement image
        function clearReplaceImage(variantIndex, position) {
            const input = document.querySelector(`input[name="variants[${variantIndex}][replaceImage][${position}]"]`);
            const previewDiv = document.getElementById(`replacePreview-${variantIndex}-${position}`);
            
            input.value = '';
            
            // Reset preview div
            const variantContainer = document.querySelector(`[data-variant-index="${variantIndex}"]`);
            const existingImages = variantContainer.querySelectorAll('.existing-image-wrapper').length;
            
            if (position < existingImages) {
                previewDiv.innerHTML = `<p class="text-muted">Will replace: Image ${Number(position) + 1}</p>`;
            } else {
                previewDiv.innerHTML = `<p class="text-muted">Will add as new image</p>`;
            }
        }
   // Replace the form submission with AJAX
document.getElementById('editProductForm').addEventListener('submit', async(e)=> {
    e.preventDefault();
    
    // // Show processing dialog
    // Swal.fire({
    //     title: 'Saving...',
    //     text: 'Updating product information',
    //     allowOutsideClick: false,
    //     didOpen: () => {
    //         Swal.showLoading();
    //     }
    // });
try{
    // Create FormData object from the form
    const formData = new FormData(e.target);
    const response = await fetch('/admin/products/edit/<%= product._id %>',{
        method:"POST",
        body:formData
    })

    const data = await response.json()

    if(data.success){
        await  Swal.fire({
            title: 'Success!',
            text: 'Product has been updated successfully',
            icon: 'success',
            confirmButtonColor: '#198754'
        }).then(()=>{
            window.location.href = '/admin/products'
        })
    }
    else{
        throw new Error(data.message|| "Failed to update product")
    }
  }
    catch(error) {
        // Show error message
        Swal.fire({
            title: 'Error!',
            text: 'There was a problem updating the product: ' + error.message,
            icon: 'error',
            confirmButtonColor: '#dc3545'
        });
    }
});
    </script>
    
</body>
</html>