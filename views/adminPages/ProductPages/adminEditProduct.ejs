<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Product | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.1/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .cropper-view-box, .cropper-face { border-radius: 8px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 antialiased pb-20">
    <%- include('../partials/menu') %>

    <div class="max-w-4xl mx-auto py-8 px-4">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight">Edit Product</h1>
                <p class="text-slate-500 text-xs">Update general specs and variant inventory below.</p>
            </div>
            <a href="/admin/products" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-widest">
                <i class="fas fa-arrow-left mr-1"></i> Back
            </a>
        </div>

        <form id="editProductForm" class="space-y-6">
            <section class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-200">
                <h3 class="text-sm font-bold text-slate-800 mb-6 flex items-center gap-2">
                    <i class="fas fa-info-circle text-indigo-500"></i> General Information
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1.5 ml-1">Product Name</label>
                        <input type="text" name="name" value="<%= product.name %>" required class="w-full px-4 py-2.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-semibold" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1.5 ml-1">Brand</label>
                        <input type="text" name="brand" value="<%= product.brand %>" required class="w-full px-4 py-2.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-semibold" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1.5 ml-1">Category</label>
                        <select name="category" required class="w-full px-4 py-2.5 rounded-xl border border-slate-100 bg-slate-50 outline-none text-sm font-bold appearance-none">
                            <% categories.forEach(category => { %>
                                <option value="<%= category._id %>" <%= String(product.category) === String(category._id) ? 'selected' : '' %>><%= category.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-[10px] font-bold uppercase text-slate-400 mb-1.5 ml-1">Description</label>
                        <textarea name="description" rows="3" required class="w-full px-4 py-2.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-medium"><%= product.description %></textarea>
                    </div>
                    <div class="md:col-span-2 flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <span class="text-xs font-bold text-slate-600">Product Visibility (Live on Store)</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="statusToggle" class="sr-only peer" <%= product.status ? 'checked' : '' %>>
                            <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-checked:bg-emerald-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
                        </label>
                    </div>
                </div>
            </section>

            <div id="variants-list" class="space-y-6">
                <h3 class="text-sm font-bold text-slate-800 ml-2 uppercase tracking-widest">Product Variants</h3>
                
                <% product.variants.forEach((variant, vIdx) => { %>
                <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-200">
                    <input type="hidden" name="variants[<%= vIdx %>][_id]" value="<%= variant._id %>">
                    <div class="flex items-center justify-between mb-6">
                        <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-black rounded-lg uppercase">Variant #<%= vIdx + 1 %></span>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                        <div>
                            <label class="block text-[9px] font-bold text-slate-400 uppercase mb-1">Color</label>
                            <input type="text" name="variants[<%= vIdx %>][color]" value="<%= variant.color %>" class="w-full px-3 py-2 rounded-lg border border-slate-100 bg-slate-50 text-sm font-bold outline-none" />
                        </div>
                        <div>
                            <label class="block text-[9px] font-bold text-slate-400 uppercase mb-1">Size</label>
                            <input type="text" name="variants[<%= vIdx %>][size]" value="<%= variant.size %>" class="w-full px-3 py-2 rounded-lg border border-slate-100 bg-slate-50 text-sm font-bold outline-none" />
                        </div>
                        <div>
                            <label class="block text-[9px] font-bold text-slate-400 uppercase mb-1">Price (₹)</label>
                            <input type="number" name="variants[<%= vIdx %>][price]" value="<%= variant.price %>" step="0.01" class="w-full px-3 py-2 rounded-lg border border-slate-100 bg-slate-50 text-sm font-bold outline-none" />
                        </div>
                        <div>
                            <label class="block text-[9px] font-bold text-slate-400 uppercase mb-1">Stock</label>
                            <input type="number" name="variants[<%= vIdx %>][quantity]" value="<%= variant.quantity %>" class="w-full px-3 py-2 rounded-lg border border-slate-100 bg-slate-50 text-sm font-bold outline-none" />
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label class="block text-[9px] font-bold text-slate-400 uppercase">Gallery (Click to Replace)</label>
                        <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
                            <% for (let i = 0; i < 3; i++) { 
                                const hasImg = variant.images[i];
                            %>
                            <div class="relative group aspect-square rounded-2xl overflow-hidden border border-slate-100 bg-slate-50 cursor-pointer" 
                                 onclick="document.getElementById('file-<%= vIdx %>-<%= i %>').click()">
                                
                                <img id="prev-<%= vIdx %>-<%= i %>" 
                                     src="<%= hasImg ? hasImg.url : '' %>" 
                                     class="<%= hasImg ? '' : 'hidden' %> w-full h-full object-cover">
                                
                                <div id="empty-<%= vIdx %>-<%= i %>" class="<%= hasImg ? 'hidden' : 'flex' %> absolute inset-0 flex-col items-center justify-center text-slate-300">
                                    <i class="fas fa-plus text-xs"></i>
                                </div>

                                <div class="absolute inset-0 bg-indigo-600/80 opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center text-white">
                                    <i class="fas fa-sync-alt text-xs"></i>
                                </div>

                                <input type="file" id="file-<%= vIdx %>-<%= i %>" class="hidden" 
                                       onchange="handleImageUpdate(this, '<%= vIdx %>', '<%= i %>')" accept="image/*">
                                
                                <% if(hasImg) { %>
                                    <input type="hidden" name="variants[<%= vIdx %>][existingImages][<%= i %>][url]" value="<%= hasImg.url %>">
                                <% } %>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

            <div class="flex items-center justify-end gap-4 mt-12 bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                <button type="button" onclick="window.location.href='/admin/products'" class="px-6 py-3 text-xs font-bold text-slate-400 uppercase">Discard</button>
                <button type="submit" class="px-12 py-3 text-xs font-black text-white bg-indigo-600 rounded-xl shadow-lg hover:bg-indigo-700 uppercase tracking-widest transition-all">Save Changes</button>
            </div>
        </form>
    </div>

    <div id="cropperModal" class="hidden fixed inset-0 z-[9999] bg-slate-900/95 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-xl rounded-[2rem] overflow-hidden shadow-2xl">
            <div class="p-4 border-b flex justify-between items-center bg-slate-50">
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Crop Image (1:1)</span>
                <button type="button" onclick="closeCropper()" class="text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
            </div>
            <div class="bg-slate-900 aspect-square flex items-center justify-center overflow-hidden">
                <img id="cropperImage" src="" class="max-w-full">
            </div>
            <div class="p-4 flex justify-end gap-2 bg-slate-50">
                <button type="button" onclick="closeCropper()" class="px-6 py-2 text-[10px] font-bold text-slate-400 uppercase">Cancel</button>
                <button type="button" onclick="commitCrop()" class="px-8 py-2 text-[10px] font-black text-white bg-indigo-600 rounded-xl uppercase tracking-widest">Apply Crop</button>
            </div>
        </div>
    </div>

    <script>
        let cropper = null;
        let activeV = null, activeP = null;
        const croppedBlobs = {};

        function handleImageUpdate(input, vIdx, pIdx) {
            if (!input.files || !input.files[0]) return;
            activeV = vIdx; activeP = pIdx;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                $('#cropperImage').attr('src', e.target.result);
                $('#cropperModal').removeClass('hidden');
                if (cropper) cropper.destroy();
                setTimeout(() => {
                    cropper = new Cropper(document.getElementById('cropperImage'), {
                        aspectRatio: 1, viewMode: 1
                    });
                }, 50);
            };
            reader.readAsDataURL(input.files[0]);
        }

        function commitCrop() {
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            canvas.toBlob((blob) => {
                croppedBlobs[`${activeV}-${activeP}`] = blob;
                const dataURL = canvas.toDataURL('image/jpeg');
                $(`#prev-${activeV}-${activeP}`).attr('src', dataURL).removeClass('hidden');
                $(`#empty-${activeV}-${activeP}`).addClass('hidden');
                closeCropper();
            }, 'image/jpeg', 0.9);
        }

        function closeCropper() {
            $('#cropperModal').addClass('hidden');
            if (cropper) cropper.destroy();
        }

        $('#editProductForm').submit(async function(e) {
            e.preventDefault();
            Swal.fire({ title: 'Updating Catalog...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

            const formData = new FormData(this);
            formData.append('status', $('#statusToggle').is(':checked'));

            // Attach cropped blobs with structured keys
            for (const [key, blob] of Object.entries(croppedBlobs)) {
                const [vIdx, pIdx] = key.split('-');
                formData.set(`variants[${vIdx}][replaceImage][${pIdx}]`, blob, `v${vIdx}_p${pIdx}.jpg`);
            }

            $.ajax({
                url: "/admin/products/edit/<%= product._id %>",
                type: "POST", 
                data: formData, 
                processData: false, 
                contentType: false,
                success: (res) => {
                    if (res.status === 'success') {
                        Swal.fire("Success", "Product updated", "success").then(() => window.location.href = "/admin/products");
                    } else {
                        Swal.fire("Error", res.message, "error");
                    }
                },
                error: (xhr) => Swal.fire("Error", xhr.responseJSON?.message || "Internal Server Error", "error")
            });
        });
    </script>
</body>
</html>