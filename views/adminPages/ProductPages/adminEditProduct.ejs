<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Product</title>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
      :root {
        --primary-color: #4361ee;
        --secondary-color: #3f37c9;
        --accent-color: #4895ef;
        --success-color: #4cc9f0;
        --danger-color: #dc3545;
        --text-color: #2b2d42;
        --bg-color: #f8f9fa;
        --card-bg: #ffffff;
        --border-radius: 12px;
        --transition: all 0.3s ease;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Segoe UI", system-ui, sans-serif;
      }

      body {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        color: var(--text-color);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem;
      }

      .container {
        width: 100%;
        max-width: 900px;
        background: var(--card-bg);
        padding: 2rem;
        border-radius: var(--border-radius);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        margin-top: 2rem;
        margin-bottom: 2rem;
      }

      .header {
        text-align: center;
        margin-bottom: 2rem;
      }

      .header h1 {
        font-size: 2.5rem;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
      }

      .header p {
        color: #6c757d;
        font-size: 1.1rem;
      }

      .form-section {
        background: var(--bg-color);
        padding: 1.5rem;
        border-radius: var(--border-radius);
        margin-bottom: 1.5rem;
      }

      .form-section h3 {
        color: var(--secondary-color);
        margin-bottom: 1.5rem;
        font-size: 1.2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      label {
        display: block;
        margin-bottom: 0.5rem;
        color: var(--text-color);
        font-weight: 500;
      }

      input,
      select,
      textarea {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: var(--transition);
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
        outline: none;
      }

      .file-upload {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .file-upload-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
        background: #f8f9fa;
        border: 2px dashed #ced4da;
        border-radius: 8px;
        cursor: pointer;
        transition: var(--transition);
      }

      .file-upload-label:hover {
        background: #e9ecef;
        border-color: var(--accent-color);
      }

      .file-upload-label svg {
        width: 48px;
        height: 48px;
        margin-bottom: 1rem;
        color: var(--primary-color);
      }

      .file-upload input[type="file"] {
        display: none;
      }

      .variant-container {
        background: var(--bg-color);
        padding: 1.5rem;
        border-radius: var(--border-radius);
        margin-bottom: 1.5rem;
        border: none;
      }

      .image-preview-container {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-top: 10px;
      }

      .existing-image-wrapper {
        position: relative;
        width: 150px;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 5px;
        overflow: hidden;
      }

      .image-preview {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border-radius: 4px;
      }

      .image-number {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
      }

      .delete-image {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255, 0, 0, 0.7);
        color: white;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-size: 16px;
        transition: var(--transition);
      }

      .delete-image:hover {
        background: rgba(255, 0, 0, 0.9);
        transform: scale(1.1);
      }

      .image-upload-container {
        margin-top: 15px;
      }

      .single-image-upload {
        margin-bottom: 15px;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #e9ecef;
      }

      .submit-btn {
        background: var(--primary-color);
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        width: 100%;
        margin-top: 1rem;
      }

      .submit-btn:hover {
        background: var(--secondary-color);
        transform: translateY(-2px);
      }

      .cancel-btn {
        background: var(--danger-color);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        width: 100%;
        margin-top: 1rem;
        max-width: 150px;
        display: block;
        margin-left: auto;
        margin-right: auto;
      }

      .cancel-btn:hover {
        background: #c82333;
        transform: translateY(-2px);
      }

      .status-toggle {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.5rem;
        background: #f8f9fa;
        border-radius: 8px;
      }

      .status-toggle label {
        margin: 0;
        cursor: pointer;
      }

      .toggle-switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 34px;
      }

      .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
      }

      .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.4s;
        border-radius: 34px;
      }

      .slider:before {
        position: absolute;
        content: "";
        height: 26px;
        width: 26px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: 0.4s;
        border-radius: 50%;
      }

      input:checked + .slider {
        background-color: var(--success-color);
      }

      input:checked + .slider:before {
        transform: translateX(26px);
      }

      .row {
        display: flex;
        flex-wrap: wrap;
        margin: -0.5rem;
      }

      .col {
        flex: 1;
        padding: 0.5rem;
        min-width: 200px;
      }

      .btn-add-variant {
        background: var(--accent-color);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        margin-bottom: 1.5rem;
      }

      .btn-add-variant:hover {
        background: var(--secondary-color);
        transform: translateY(-2px);
      }
      
      .remove-variant {
        background: var(--danger-color);
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition);
        margin-top: 1rem;
      }

      .remove-variant:hover {
        background: #c82333;
      }

      .variant-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
      }

      .variant-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--secondary-color);
      }

      .error-message {
        color: var(--danger-color);
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: none;
      }

      @media (max-width: 768px) {
        .container {
          padding: 1rem;
        }

        .header h1 {
          font-size: 2rem;
        }

        .col {
          flex: 100%;
        }
      }
    </style>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container">
      <div class="header">
        <h1>Edit Product</h1>
        <p>Update your product details and variants</p>
      </div>

      <form id="editProductForm" action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
        <div class="form-section">
          <h3>Basic Information</h3>
          <div class="row">
            <div class="col">
              <div class="form-group">
                <label for="name">Product Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="Enter product name"
                  value="<%= product.name %>"
                  required
                />
                <div id="nameError" class="error-message"></div>
              </div>
            </div>
            <div class="col">
              <div class="form-group">
                <label for="brand">Brand</label>
                <input
                  type="text"
                  id="brand"
                  name="brand"
                  placeholder="Enter brand name"
                  value="<%= product.brand %>"
                  required
                />
                <div id="brandError" class="error-message"></div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col">
              <div class="form-group">
                <label for="actualPrice">Actual Price</label>
                <input
                  type="number"
                  id="actualPrice"
                  name="actualPrice"
                  placeholder="Enter actual price"
                  value="<%= product.actualPrice %>"
                  required
                />
                <div id="priceError" class="error-message"></div>
              </div>
            </div>
            <div class="col">
              <div class="form-group">
                <label for="category">Category</label>
                <select id="category" name="category" required>
                  <% categories.forEach(category => { %>
                  <option value="<%= category.name %>" <%= product.category === category.name ? 'selected' : '' %>><%= category.name %></option>
                  <% }) %>
                </select>
                <div id="categoryError" class="error-message"></div>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>Product Status</label>
            <div class="status-toggle">
              <label class="toggle-switch">
                <input type="checkbox" name="status" id="statusToggle" <%= product.status ? 'checked' : '' %> />
                <span class="slider"></span>
              </label>
              <span id="statusText"><%= product.status ? 'Listed' : 'Unlisted' %></span>
            </div>
          </div>
        </div>

        <div id="variants-container">
          <h3 style="margin-bottom: 1rem; color: var(--secondary-color);">Variants</h3>
          <% product.variants.forEach((variant, variantIndex) => { %>
          <div class="variant-container" data-variant-index="<%= variantIndex %>">
            <div class="variant-header">
              <div class="variant-title">Variant #<%= variantIndex + 1 %></div>
            </div>
            
            <div class="row">
              <div class="col">
                <div class="form-group">
                  <label>Color</label>
                  <input 
                    type="text" 
                    name="variants[<%= variantIndex %>][color]" 
                    value="<%= variant.color %>" 
                    placeholder="Enter color"
                    required
                  />
                </div>
              </div>
              <div class="col">
                <div class="form-group">
                  <label>Size</label>
                  <input 
                    type="text" 
                    name="variants[<%= variantIndex %>][size]" 
                    value="<%= variant.size %>" 
                    placeholder="Enter size"
                    required
                  />
                </div>
              </div>
            </div>
            
            <div class="row">
              <div class="col">
                <div class="form-group">
                  <label>Price</label>
                  <input 
                    type="number" 
                    name="variants[<%= variantIndex %>][price]" 
                    value="<%= variant.price %>" 
                    placeholder="Enter price"
                    required
                  />
                </div>
              </div>
              <div class="col">
                <div class="form-group">
                  <label>Quantity</label>
                  <input 
                    type="number" 
                    name="variants[<%= variantIndex %>][quantity]" 
                    value="<%= variant.quantity %>" 
                    placeholder="Enter quantity"
                    required
                  />
                </div>
              </div>
            </div>

            <!-- Existing Images Section -->
            <div class="form-group">
              <label>Current Images</label>
              <div class="image-preview-container">
                <% if (variant.images && variant.images.length > 0) { %>
                  <% variant.images.forEach((image, imageIndex) => { %>
                    <div class="existing-image-wrapper">
                      <img 
                        src="<%= image.url %>" 
                        class="image-preview" 
                        alt="Variant image <%= imageIndex + 1 %>"
                      >
                      <span class="image-number">Image <%= imageIndex + 1 %></span>
                      <button 
                        type="button" 
                        class="delete-image" 
                        data-variant-index="<%= variantIndex %>" 
                        data-image-index="<%= imageIndex %>"
                      >&times;</button>
                      <!-- Hidden input to track existing images -->
                      <input 
                        type="hidden" 
                        name="variants[<%= variantIndex %>][existingImages][<%= imageIndex %>][url]" 
                        value="<%= image.url %>"
                      >
                      <input 
                        type="hidden" 
                        name="variants[<%= variantIndex %>][existingImages][<%= imageIndex %>][position]" 
                        value="<%= imageIndex %>"
                      >
                    </div>
                  <% }); %>
                <% } else { %>
                  <p style="color: #6c757d; font-style: italic;">No images uploaded yet</p>
                <% } %>
              </div>
            </div>

            <!-- Individual Image Replacement Section -->
            <div class="image-upload-container">
              <h4 style="margin-bottom: 1rem; color: var(--text-color);">Replace or Add Images</h4>
              <% for (let i = 0; i < 3; i++) { %>
                <div class="single-image-upload">
                  <label>Image Position <%= i+1 %></label>
                  <div class="file-upload">
                    <label class="file-upload-label" for="file-input-<%= variantIndex %>-<%= i %>">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="17 8 12 3 7 8" />
                        <line x1="12" y1="3" x2="12" y2="15" />
                      </svg>
                      <span>Click to browse or drop image here</span>
                    </label>
                    <input
                      type="file"
                      id="file-input-<%= variantIndex %>-<%= i %>"
                      name="variants[<%= variantIndex %>][replaceImage][<%= i %>]"
                      accept="image/*"
                      data-variant-index="<%= variantIndex %>"
                      data-position="<%= i %>"
                      onchange="previewReplaceImage(this)"
                    />
                  </div>
                  <div class="mt-2" id="replacePreview-<%= variantIndex %>-<%= i %>">
                    <% if (variant.images && variant.images[i]) { %>
                      <p style="color: #6c757d; margin-top: 0.5rem;">Will replace: Image <%= i+1 %></p>
                    <% } else { %>
                      <p style="color: #6c757d; margin-top: 0.5rem;">Will add as new image</p>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>

            <button type="button" class="remove-variant">Remove Variant</button>
          </div>
          <% }); %>
        </div>

        <button type="button" class="btn-add-variant" id="add-variant">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 8px;">
            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
          </svg>
          Add New Variant
        </button>
        
        <button type="submit" class="submit-btn">Update Product</button>
      </form>
      <form action="/admin/products" method="get">
        <button type="submit" class="cancel-btn">Cancel</button>
      </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
      // Validation Rules Constants
      const VALIDATION_RULES = {
        productName: {
          minLength: 3,
          maxLength: 100,
        },
        brand: {
          minLength: 2,
          maxLength: 50,
        },
        price: {
          min: 0.01
        },
        image: {
          maxSize: 5 * 1024 * 1024, // 5MB
          allowedTypes: ["image/jpeg", "image/png", "image/webp", "image/gif"],
        },
      };

      // Status toggle handling
      const statusToggle = document.getElementById("statusToggle");
      const statusText = document.getElementById("statusText");

      statusToggle.addEventListener("change", function () {
        statusText.textContent = this.checked ? "Listed" : "Unlisted";
        this.value = this.checked ? "true" : "false";
      });

      // Image upload and preview functionality
      function previewReplaceImage(input) {
        const variantIndex = input.dataset.variantIndex;
        const position = input.dataset.position;
        const previewDiv = document.getElementById(`replacePreview-${variantIndex}-${position}`);
        
        if (input.files && input.files[0]) {
          // Validate image
          const file = input.files[0];
          if (!validateImage(file)) {
            input.value = '';
            return;
          }
          
          const reader = new FileReader();
          
          reader.onload = function(e) {
            previewDiv.innerHTML = `
              <div style="display: flex; align-items: center; margin-top: 0.5rem;">
                <img src="${e.target.result}" alt="Preview" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
                <div style="margin-left: 1rem;">
                  <p style="margin: 0; font-size: 0.9rem;">New image selected</p>
                  <button type="button" style="background: var(--danger-color); color: white; border: none; border-radius: 4px; padding: 0.25rem 0.5rem; margin-top: 0.5rem; cursor: pointer;" 
                    onclick="clearReplaceImage(${variantIndex}, ${position})">
                    Cancel
                  </button>
                </div>
              </div>
              <input type="hidden" name="variants[${variantIndex}][replaceImagePosition][${position}]" value="${position}">
            `;
          };
          
          reader.readAsDataURL(input.files[0]);
        }
      }
      
      function clearReplaceImage(variantIndex, position) {
        const input = document.querySelector(`input[name="variants[${variantIndex}][replaceImage][${position}]"]`);
        const previewDiv = document.getElementById(`replacePreview-${variantIndex}-${position}`);
        
        input.value = '';
      
        const variantContainer = document.querySelector(`[data-variant-index="${variantIndex}"]`);
        const existingImages = variantContainer.querySelectorAll('.existing-image-wrapper').length;
        
        if (position < existingImages) {
          previewDiv.innerHTML = `<p style="color: #6c757d; margin-top: 0.5rem;">Will replace: Image ${Number(position) + 1}</p>`;
        } else {
          previewDiv.innerHTML = `<p style="color: #6c757d; margin-top: 0.5rem;">Will add as new image</p>`;
        }
      }

      // Delete existing image
      document.addEventListener('click', function(e) {
        if (e.target.classList.contains('delete-image')) {
          Swal.fire({
            title: 'Remove Image',
            text: "Are you sure you want to remove this image?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, remove it!',
            reverseButtons: true
          }).then((result) => {
            if (result.isConfirmed) {
              const wrapper = e.target.closest('.existing-image-wrapper');
              const variantIndex = e.target.dataset.variantIndex;
              const imageIndex = e.target.dataset.imageIndex;
              
              // Add hidden input to track deleted images
              const deletedInput = document.createElement('input');
              deletedInput.type = 'hidden';
              deletedInput.name = `variants[${variantIndex}][deletedImages][]`;
              deletedInput.value = wrapper.querySelector('input[name$="[url]"]').value;
              wrapper.closest('.variant-container').appendChild(deletedInput);
              
              wrapper.remove();
              
              Swal.fire('Removed!', 'The image has been removed.', 'success');
            }
          });
        }
      });

      // Add new variant functionality
      document.getElementById('add-variant').addEventListener('click', function() {
        const variantIndex = document.querySelectorAll('.variant-container').length;
        const container = document.createElement('div');
        container.className = 'variant-container';
        container.dataset.variantIndex = variantIndex;
        
        container.innerHTML = `
          <div class="variant-header">
            <div class="variant-title">Variant #${variantIndex + 1}</div>
          </div>
          
          <div class="row">
            <div class="col">
              <div class="form-group">
                <label>Color</label>
                <input 
                  type="text" 
                  name="variants[${variantIndex}][color]" 
                  placeholder="Enter color"
                  required
                />
              </div>
            </div>
            <div class="col">
              <div class="form-group">
                <label>Size</label>
                <input 
                  type="text" 
                  name="variants[${variantIndex}][size]" 
                  placeholder="Enter size"
                  required
                />
              </div>
            </div>
          </div>
          
          <div class="row">
            <div class="col">
              <div class="form-group">
                <label>Price</label>
                <input 
                  type="number" 
                  name="variants[${variantIndex}][price]" 
                  placeholder="Enter price"
                  required
                />
              </div>
            </div>
            <div class="col">
              <div class="form-group">
                <label>Quantity</label>
                <input 
                  type="number" 
                  name="variants[${variantIndex}][quantity]" 
                  placeholder="Enter quantity"
                  required
                />
              </div>
            </div>
          </div>

          <!-- Image Upload for New Variant -->
          <div class="image-upload-container">
            <h4 style="margin-bottom: 1rem; color: var(--text-color);">Add Images</h4>
            <% for (let i = 0; i < 3; i++) { %>
              <div class="single-image-upload">
                <label>Image Position ${i+1}</label>
                <div class="file-upload">
                  <label class="file-upload-label" for="file-input-${variantIndex}-${i}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                      <polyline points="17 8 12 3 7 8" />
                      <line x1="12" y1="3" x2="12" y2="15" />
                    </svg>
                    <span>Click to browse or drop image here</span>
                  </label>
                  <input
                    type="file"
                    id="file-input-${variantIndex}-${i}"
                    name="variants[${variantIndex}][newImage][${i}]"
                    accept="image/*"
                    data-variant-index="${variantIndex}"
                    data-position="${i}"
                    onchange="previewNewImage(this)"
                  />
                </div>
                <div class="mt-2" id="newImagePreview-${variantIndex}-${i}">
                  <p style="color: #6c757d; margin-top: 0.5rem;">No image selected</p>
                </div>
              </div>
            <% } %>
          </div>
          
          <button type="button" class="remove-variant">Remove Variant</button>
        `;
        
        document.getElementById('variants-container').appendChild(container);
        
        // Define previewNewImage function if it doesn't exist
        if (typeof previewNewImage !== 'function') {
          window.previewNewImage = function(input) {
            const variantIndex = input.dataset.variantIndex;
            const position = input.dataset.position;
            const previewDiv = document.getElementById(`newImagePreview-${variantIndex}-${position}`);
            
            if (input.files && input.files[0]) {
              // Validate image
              const file = input.files[0];
              if (!validateImage(file)) {
                input.value = '';
                return;
              }
              
              const reader = new FileReader();
              
              reader.onload = function(e) {
                previewDiv.innerHTML = `
                  <div style="display: flex; align-items: center; margin-top: 0.5rem;">
                    <img src="${e.target.result}" alt="Preview" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
                    <div style="margin-left: 1rem;">
                      <p style="margin: 0; font-size: 0.9rem;">Image selected</p>
                      <button type="button" style="background: var(--danger-color); color: white; border: none; border-radius: 4px; padding: 0.25rem 0.5rem; margin-top: 0.5rem; cursor: pointer;" 
                        onclick="clearNewImage(${variantIndex}, ${position})">
                        Cancel
                      </button>
                    </div>
                  </div>
                  <input type="hidden" name="variants[${variantIndex}][newImagePosition][${position}]" value="${position}">
                `;
              };
              
              reader.readAsDataURL(input.files[0]);
            }
          };
        }
        
        // Define clearNewImage function if it doesn't exist
        if (typeof clearNewImage !== 'function') {
          window.clearNewImage = function(variantIndex, position) {
            const input = document.querySelector(`input[name="variants[${variantIndex}][newImage][${position}]"]`);
            const previewDiv = document.getElementById(`newImagePreview-${variantIndex}-${position}`);
            
            input.value = '';
            previewDiv.innerHTML = `<p style="color: #6c757d; margin-top: 0.5rem;">No image selected</p>`;
          };
        }
      });

      // Remove variant functionality
      document.addEventListener('click', function(e) {
        if (e.target.classList.contains('remove-variant')) {
          const variantContainer = e.target.closest('.variant-container');
          
          Swal.fire({
            title: 'Remove Variant',
            text: "Are you sure you want to remove this variant?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, remove it!',
            reverseButtons: true
          }).then((result) => {
            if (result.isConfirmed) {
              // Add a hidden input to track deleted variants for existing variants
              const variantIndex = variantContainer.dataset.variantIndex;
              
              // Only add tracking for existing variants that were loaded from the database
              if (variantIndex < <%= product.variants.length %>) {
                const deletedInput = document.createElement('input');
                deletedInput.type = 'hidden';
                deletedInput.name = 'deletedVariants[]';
                deletedInput.value = variantIndex;
                document.getElementById('editProductForm').appendChild(deletedInput);
              }
              
              variantContainer.remove();
              
              // Update variant numbers
              document.querySelectorAll('.variant-container').forEach((container, index) => {
                container.querySelector('.variant-title').textContent = `Variant #${index + 1}`;
              });
            }
          });
        }
      });

      // Image validation function
      function validateImage(file) {
        const rules = VALIDATION_RULES.image;
        
        // Check file type
        if (!rules.allowedTypes.includes(file.type)) {
          Swal.fire({
            icon: 'error',
            title: 'Invalid file type',
            text: 'Please upload only JPEG, PNG, WebP or GIF images.',
          });
          return false;
        }
        
        // Check file size
        if (file.size > rules.maxSize) {
          Swal.fire({
            icon: 'error',
            title: 'File too large',
            text: 'Image size should not exceed 5MB.',
          });
          return false;
        }
        
        return true;
      }

      // Form validation
      const editProductForm = document.getElementById('editProductForm');
      
      editProductForm.addEventListener('submit', function(e) {
        let isValid = true;
        
        // Validate product name
        const nameInput = document.getElementById('name');
        const nameError = document.getElementById('nameError');
        const nameRules = VALIDATION_RULES.productName;
        
        if (nameInput.value.length < nameRules.minLength) {
          nameError.textContent = `Product name must be at least ${nameRules.minLength} characters.`;
          nameError.style.display = 'block';
          isValid = false;
        } else if (nameInput.value.length > nameRules.maxLength) {
          nameError.textContent = `Product name must not exceed ${nameRules.maxLength} characters.`;
          nameError.style.display = 'block';
          isValid = false;
        } else {
          nameError.style.display = 'none';
        }
        
        // Validate brand
        const brandInput = document.getElementById('brand');
        const brandError = document.getElementById('brandError');
        const brandRules = VALIDATION_RULES.brand;
        
        if (brandInput.value.length < brandRules.minLength) {
          brandError.textContent = `Brand name must be at least ${brandRules.minLength} characters.`;
          brandError.style.display = 'block';
          isValid = false;
        } else if (brandInput.value.length > brandRules.maxLength) {
          brandError.textContent = `Brand name must not exceed ${brandRules.maxLength} characters.`;
          brandError.style.display = 'block';
          isValid = false;
        } else {
          brandError.style.display = 'none';
        }
        
        // Validate price
        const priceInput = document.getElementById('actualPrice');
        const priceError = document.getElementById('priceError');
        const priceRules = VALIDATION_RULES.price;
        
        if (parseFloat(priceInput.value) < priceRules.min) {
          priceError.textContent = `Price must be at least ${priceRules.min}.`;
          priceError.style.display = 'block';
          isValid = false;
        } else {
          priceError.style.display = 'none';
        }
        
        if (!isValid) {
          e.preventDefault();
          
          // Scroll to the first error
          const firstError = document.querySelector('.error-message[style="display: block;"]');
          if (firstError) {
            firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          
          Swal.fire({
            icon: 'error',
            title: 'Validation Error',
            text: 'Please check the form for errors.',
          });
        } else {
          // Show loading state
          Swal.fire({
            title: 'Updating Product',
            text: 'Please wait while we update your product...',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            }
          });
          
    // Create FormData object
    const formData = new FormData(editProductForm);
    const formObject = {};

formData.forEach((value, key) => {
  formObject[key] = value;
});

formObject.active = statusToggle.checked;

    
    fetch('/admin/products/edit/<%= product._id %>', {
      method: 'POST', headers: {
    'Content-Type': 'application/json'
  },
      body: JSON.stringify(formObject)
    })
    .then(data=>data.json())
    .then(data => {
      if(data.status==='success'){
        Swal.fire({
        icon: 'success',
        title: 'Success!',
        text: data.message || 'Product updated successfully',
        confirmButtonText: 'OK'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/admin/products';
        }
      });
      }
      else{
        Swal.fire({
        icon: 'error',
        title: 'Error!',
        text: data.message || 'Product updation failed',
        confirmButtonText: 'OK'
      }
        )}
      
    })
    .catch(error => {
      // Handle error
      console.error('Error:', error);
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: 'Failed to update Product. Please try again later.'
      });
    });
        }
      });
    </script>
  </body>
</html>