<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Product | Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.1/sweetalert2.all.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .cropper-view-box, .cropper-face { border-radius: 8px; }
        .hide-input { display: none !important; }
    </style>
</head>

<body class="bg-slate-50 text-slate-800 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <div class="max-w-5xl mx-auto py-12 px-6">
        <div class="mb-10 flex flex-col md:flex-row justify-between items-end gap-4">
            <div>
                <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Edit Product</h1>
                <p class="text-slate-500 mt-1 text-sm">Update specific variants, pricing, and high-quality imagery.</p>
            </div>
            <a href="/admin/products" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors uppercase tracking-widest mb-1">
                <i class="fas fa-arrow-left mr-1"></i> Back to Catalog
            </a>
        </div>

        <form id="editProductForm" class="space-y-8">
            <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600 text-lg">
                        <i class="fas fa-edit"></i>
                    </div>
                    <h3 class="text-lg font-bold text-slate-800">General Specs</h3>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="md:col-span-2">
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Product Name</label>
                        <input type="text" id="name" name="name" value="<%= product.name %>" required class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium" />
                        <p id="nameError" class="text-red-500 text-xs mt-2 hidden"></p>
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Description</label>
                        <textarea id="description" name="description" rows="3" required class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium"><%= product.description %></textarea>
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Brand</label>
                        <input type="text" id="brand" name="brand" value="<%= product.brand %>" required class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium" />
                    </div>

                    <div>
                        <label class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Category</label>
                        <select name="category" required class="w-full px-5 py-4 rounded-2xl border border-slate-100 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold appearance-none bg-white">
                            <% categories.forEach(category => { %>
                                <option value="<%= category.name %>" <%= product.category === category.name ? 'selected' : '' %>><%= category.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="flex items-center justify-between p-5 bg-slate-50 rounded-[1.5rem] border border-slate-100 md:col-span-2">
                        <div>
                            <span class="block text-[11px] font-black uppercase tracking-widest text-slate-400">Visibility Status</span>
                            <span id="statusText" class="text-sm font-bold <%= product.status ? 'text-emerald-600' : 'text-slate-400' %>">
                                <%= product.status ? 'Listed (Live)' : 'Unlisted (Hidden)' %>
                            </span>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="statusToggle" class="sr-only peer" <%= product.status ? 'checked' : '' %>>
                            <div class="w-14 h-7 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                        </label>
                    </div>
                </div>
            </section>

            <div id="variants-container" class="space-y-10">
                <h3 class="text-xl font-bold text-slate-800 ml-4">Product Variants</h3>
                
                <% product.variants.forEach((variant, variantIndex) => { %>
                <div class="variant-card bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200 relative group transition-all" data-variant-index="<%= variantIndex %>">
                    <div class="flex justify-between items-center mb-8">
                        <h4 class="text-sm font-black text-indigo-600 uppercase tracking-[0.2em] flex items-center gap-3">
                            <span class="w-8 h-8 bg-indigo-600 text-white rounded-xl flex items-center justify-center text-[10px] shadow-lg shadow-indigo-100">0<%= variantIndex + 1 %></span>
                            Variant Settings
                        </h4>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Color</label>
                            <input type="text" name="variants[<%= variantIndex %>][color]" value="<%= variant.color %>" required class="w-full px-4 py-3.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-bold" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Size</label>
                            <input type="text" name="variants[<%= variantIndex %>][size]" value="<%= variant.size %>" required class="w-full px-4 py-3.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-bold" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Price (₹)</label>
                            <input type="number" name="variants[<%= variantIndex %>][price]" value="<%= variant.price %>" step="0.01" required class="w-full px-4 py-3.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-bold" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Stock</label>
                            <input type="number" name="variants[<%= variantIndex %>][quantity]" value="<%= variant.quantity %>" required class="w-full px-4 py-3.5 rounded-xl border border-slate-100 bg-slate-50 outline-none focus:ring-2 focus:ring-indigo-400 text-sm font-bold" />
                        </div>
                    </div>

                    <div class="space-y-6">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400">Variant Gallery</label>
                        
                        <div class="flex flex-wrap gap-6 mb-8">
                            <% variant.images.forEach((image, imageIndex) => { %>
                                <div class="existing-image-wrapper relative group/img w-32 h-32 rounded-2xl overflow-hidden border-2 border-slate-100 shadow-sm transition-all hover:border-indigo-400">
                                    <img src="<%= image.url %>" class="w-full h-full object-cover" />
                                    <button type="button" class="delete-image absolute inset-0 bg-red-500/80 text-white flex items-center justify-center opacity-0 group-hover/img:opacity-100 transition-all text-xs font-bold uppercase tracking-tighter" data-variant-index="<%= variantIndex %>">
                                        <i class="fas fa-trash-alt mr-2"></i> Remove
                                    </button>
                                    <input type="hidden" name="variants[<%= variantIndex %>][existingImages][<%= imageIndex %>][url]" value="<%= image.url %>">
                                </div>
                            <% }); %>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                            <% for (let i = 0; i < 3; i++) { %>
                                <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100 group/upload relative">
                                    <div class="aspect-square w-full rounded-2xl border-2 border-dashed border-slate-200 bg-white flex flex-col items-center justify-center overflow-hidden relative transition-all group-hover/upload:border-indigo-300">
                                        <img id="slotPreview-<%= variantIndex %>-<%= i %>" class="hidden w-full h-full object-cover z-10" />
                                        <div id="placeholder-<%= variantIndex %>-<%= i %>" class="flex flex-col items-center gap-3 text-slate-300">
                                            <i class="fas fa-plus-circle text-2xl"></i>
                                            <span class="text-[9px] font-black uppercase tracking-tighter"><%= variant.images[i] ? 'Replace Image ' + (i+1) : 'Add Image ' + (i+1) %></span>
                                        </div>
                                        <input type="file" class="hidden" id="file-input-<%= variantIndex %>-<%= i %>" name="variants[<%= variantIndex %>][replaceImage][<%= i %>]" accept="image/*" data-variant-index="<%= variantIndex %>" data-position="<%= i %>" onchange="handleFileSelect(this)" />
                                        <button type="button" onclick="document.getElementById('file-input-<%= variantIndex %>-<%= i %>').click()" class="absolute inset-0 z-20"></button>
                                    </div>
                                    <div class="flex gap-2 mt-4 opacity-0 group-hover/upload:opacity-100 transition-all">
                                        <button type="button" onclick="openCropper('<%= variantIndex %>', '<%= i %>', 'replace')" class="flex-1 py-2 bg-indigo-50 text-indigo-600 rounded-xl text-[10px] font-black uppercase hover:bg-indigo-600 hover:text-white transition-all">Crop</button>
                                        <button type="button" onclick="clearSlot('<%= variantIndex %>','<%= i %>','replace')" class="px-4 py-2 text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>

            <div class="flex items-center justify-end gap-4 pt-8">
                <button type="button" onclick="window.location.href='/admin/products'" class="px-8 py-4 text-xs font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest transition-all">Discard Changes</button>
                <button type="submit" class="px-12 py-4 text-xs font-black text-white bg-indigo-600 hover:bg-indigo-700 rounded-2xl shadow-xl shadow-indigo-100 transition-all active:scale-95 uppercase tracking-[0.2em]">Update Product</button>
            </div>
        </form>
    </div>

    <div id="cropperModalOverlay" class="hidden fixed inset-0 z-[9999] bg-slate-900/90 flex flex-col items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white w-full max-w-4xl h-[85vh] rounded-[2.5rem] overflow-hidden flex flex-col relative shadow-2xl">
            <div class="p-6 border-b flex justify-between items-center bg-slate-50">
                <h3 class="font-bold text-lg text-slate-800 tracking-tight">Adjust Image Frame</h3>
                <button type="button" onclick="cancelCrop()" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-400 hover:text-red-500 transition-all shadow-sm">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <div class="flex-1 bg-slate-900 flex items-center justify-center overflow-hidden">
                <img id="cropperImage" src="" class="max-w-full block" />
            </div>
            <div class="p-6 bg-slate-50 border-t flex justify-end gap-3">
                <button type="button" onclick="cancelCrop()" class="px-8 py-3 text-xs font-bold text-slate-500 bg-white border border-slate-200 rounded-xl hover:bg-slate-100 uppercase tracking-widest">Cancel</button>
                <button type="button" onclick="saveCrop()" class="px-10 py-3 text-xs font-black text-white bg-emerald-600 rounded-xl hover:bg-emerald-700 shadow-lg uppercase tracking-widest">Save Crop</button>
            </div>
        </div>
    </div>

    <script>
        let currentCropper = null;
        let currentVariantIndex = null, currentPosition = null, currentSlotType = null;
        const croppedDataURLs = {};

        // Status Switch
        $('#statusToggle').change(function() {
            const isListed = this.checked;
            $('#statusText').text(isListed ? 'Listed (Live)' : 'Unlisted (Hidden)').toggleClass('text-emerald-600', isListed).toggleClass('text-slate-400', !isListed);
        });

        // Image Selection Logic
        function handleFileSelect(input) {
            const vIdx = input.dataset.variantIndex, pIdx = input.dataset.position;
            if (!input.files || !input.files[0]) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                $(`#slotPreview-${vIdx}-${pIdx}`).attr('src', e.target.result).removeClass('hidden');
                $(`#placeholder-${vIdx}-${pIdx}`).addClass('hidden');
            };
            reader.readAsDataURL(input.files[0]);
        }

        function openCropper(vIdx, pIdx, type) {
            const src = $(`#slotPreview-${vIdx}-${pIdx}`).attr('src');
            if (!src) return Swal.fire("Select Image", "Upload a file before cropping.", "info");

            currentVariantIndex = vIdx; currentPosition = pIdx; currentSlotType = type;
            $('#cropperImage').attr('src', src);
            $('#cropperModalOverlay').removeClass('hidden');

            if (currentCropper) currentCropper.destroy();
            setTimeout(() => {
                currentCropper = new Cropper(document.getElementById('cropperImage'), {
                    aspectRatio: 1, viewMode: 1, background: false
                });
            }, 50);
        }

        function saveCrop() {
            const canvas = currentCropper.getCroppedCanvas({ width: 800, height: 800 });
            const dataURL = canvas.toDataURL('image/jpeg', 0.9);
            const key = `${currentVariantIndex}-${currentPosition}-${currentSlotType}`;
            croppedDataURLs[key] = dataURL;
            $(`#slotPreview-${currentVariantIndex}-${currentPosition}`).attr('src', dataURL);
            cancelCrop();
        }

        function cancelCrop() {
            $('#cropperModalOverlay').addClass('hidden');
            if (currentCropper) currentCropper.destroy();
        }

        function clearSlot(vIdx, pIdx) {
            $(`#slotPreview-${vIdx}-${pIdx}`).attr('src', '').addClass('hidden');
            $(`#placeholder-${vIdx}-${pIdx}`).removeClass('hidden');
            $(`#file-input-${vIdx}-${pIdx}`).val('');
            delete croppedDataURLs[`${vIdx}-${pIdx}-replace`];
        }

        // Delete Existing Logic
        $(document).on('click', '.delete-image', function() {
            const wrapper = $(this).closest('.existing-image-wrapper');
            const vIdx = $(this).data('variant-index');
            Swal.fire({
                title: 'Delete image?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', confirmButtonText: 'Yes, delete'
            }).then((res) => {
                if (res.isConfirmed) {
                    const url = wrapper.find('input[type="hidden"]').val();
                    $(this).closest('.variant-card').append(`<input type="hidden" name="variants[${vIdx}][deletedImages][]" value="${url}">`);
                    wrapper.remove();
                }
            });
        });

        // Form Submit
        $('#editProductForm').submit(async function(e) {
            e.preventDefault();
            Swal.fire({ title: 'Syncing Changes...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

            const formData = new FormData(this);
            formData.append('status', $('#statusToggle').is(':checked'));

            // Inject Crops as Blobs
            for (const [key, dataURL] of Object.entries(croppedDataURLs)) {
                const [vIdx, pIdx] = key.split('-');
                const res = await fetch(dataURL);
                const blob = await res.blob();
                formData.set(`variants[${vIdx}][replaceImage][${pIdx}]`, blob, `crop_${vIdx}_${pIdx}.jpg`);
            }

            $.ajax({
                url: "/admin/products/edit/<%= product._id %>",
                type: "POST", data: formData, processData: false, contentType: false,
                success: (res) => {
                    if (res.status === 'success') Swal.fire("Updated", "Product updated successfully.", "success").then(() => window.location.href = "/admin/products");
                    else Swal.fire("Error", res.message, "error");
                },
                error: (xhr) => Swal.fire("Server Error", xhr.responseJSON?.message || "Something went wrong.", "error")
            });
        });
    </script>
</body>
</html>