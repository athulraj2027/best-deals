<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Product</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.7.1/sweetalert2.all.min.js"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css"
    />
    <style>
      :root {
        --primary-color: #4a90e2;
        --secondary-color: #2c3e50;
        --accent-color: #e74c3c;
        --success-color: #2ecc71;
        --background-color: #f5f7fa;
        --card-background: #ffffff;
        --border-radius: 12px;
        --box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }

      body {
        background: linear-gradient(135deg, #f6f8fa 0%, #e9ecef 100%);
        color: var(--secondary-color);
        min-height: 100vh;
        padding: 2rem;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        background: var(--card-background);
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
        padding: 2rem;
      }

      .page-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #eee;
      }

      .form-section {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: var(--border-radius);
        border: 1px solid #e9ecef;
        margin-bottom: 2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
      }

      input,
      select,
      textarea {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.3s ease;
      }

      .variant-container {
        background: white;
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        border: 1px solid #e9ecef;
        position: relative;
      }

      .variant-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
      }

      .btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .btn-primary {
        background: var(--primary-color);
        color: white;
      }
      .btn-danger {
        background: var(--accent-color);
        color: white;
      }
      .btn-success {
        background: var(--success-color);
        color: white;
      }

      .image-preview-container {
        margin-top: 1rem;
        width: 100%;
        max-width: 300px;
        border-radius: 8px;
        overflow: hidden;
        background: #f8f9fa;
        border: 2px dashed #ced4da;
      }

      .image-preview {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: none;
      }

      .cropper-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.8);
        z-index: 1000;
        padding: 2rem;
      }

      .remove-variant {
        position: absolute;
        top: 1rem;
        right: 1rem;
      }

      .actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        margin-top: 2rem;
      }

      @media (max-width: 768px) {
        .container {
          padding: 1rem;
        }
        .form-section {
          padding: 1rem;
        }
      }
      .variant-images-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-top: 1rem;
      }

      .variant-image-wrapper {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
        border: 1px solid #e9ecef;
      }

      .variant-image-wrapper h5 {
        margin-bottom: 1rem;
        color: #2c3e50;
        font-size: 0.9rem;
      }

      .preview-placeholder {
        width: 100%;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
        color: #6c757d;
        border: 2px dashed #ced4da;
        border-radius: 8px;
      }

      .image-preview {
        display: none;
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 8px;
      }

      .btn-group {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }
      .cropper-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.85);
        z-index: 1000;
        padding: 2rem;
      }

      .cropper-container {
        background: white;
        max-width: 900px;
        width: 90%;
        height: 90vh;
        margin: 0 auto;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        position: relative;
        top: 50%;
        transform: translateY(-50%);
      }

      .cropper-header {
        padding: 1rem;
        border-bottom: 1px solid #e9ecef;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .cropper-header h3 {
        margin: 0;
        color: #2c3e50;
      }

      .btn-close {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.5rem;
        color: #666;
      }

      .cropper-content {
        flex: 1;
        padding: 1rem;
        background: #f8f9fa;
        position: relative;
        overflow: hidden;
      }

      .cropper-img-container {
        height: 100%;
        background: #000;
      }

      .cropper-img-container img {
        max-width: 100%;
        max-height: 100%;
      }

      .cropper-controls {
        padding: 1rem;
        border-top: 1px solid #e9ecef;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
      }

      /* Cropper.js custom styles */
      .cropper-view-box,
      .cropper-face {
        border-radius: 8px;
      }

      .cropper-point {
        width: 10px;
        height: 10px;
        background-color: #4a90e2;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="page-header">
        <h1>Add New Product</h1>
        <p>Create a new product with variants and images</p>
      </div>

      <form id="addProductForm">
        <!-- Basic Information Section -->
        <div class="form-section">
          <h3>Basic Information</h3>
          <div class="form-group">
            <label for="productName">Product Name</label>
            <input type="text" id="productName" name="name" required />
          </div>
          <div class="form-group">
            <label for="productDescription">Product Description</label>
            <input type="text" id="productDescription" name="description" required />
          </div>

          <div class="form-group">
            <label for="brand">Brand</label>
            <input type="text" id="brand" name="brand" required />
          </div>

          <div class="form-group">
            <label for="actualPrice">Base Price</label>
            <input
              type="number"
              id="actualPrice"
              name="actualPrice"
              min="0.01"
              step="0.01"
              required
            />
          </div>

          <div class="form-group">
            <label for="category">Category</label>
            <select id="category" name="category" required>
              <option value="">Select Category</option>
              <% categories.forEach(category => { %>
              <option value="<%= category.name %>"><%= category.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label for="status">Status</label>
            <select id="status" name="status" required>
              <option value="">Select Status</option>
              <option value="true">Listed</option>
              <option value="false">Unlisted</option>
            </select>
          </div>
        </div>

        <!-- Variants Section -->
        <div class="form-section">
          <div class="variant-header">
            <h3>Product Variants</h3>
            <button
              type="button"
              class="btn btn-primary"
              onclick="addVariant()"
            >
              Add Variant
            </button>
          </div>

          <div id="variants"></div>
        </div>

        <div class="actions">
          <button
            type="button"
            class="btn btn-danger"
            onclick="window.location.href='/admin/products'"
          >
            Cancel
          </button>
          <button type="submit" class="btn btn-success">Save Product</button>
        </div>
      </form>
    </div>

    <div class="cropper-modal" id="cropperModal">
      <div class="cropper-container">
        <div class="cropper-header">
          <h3>Crop Image</h3>
          <button type="button" class="btn-close" onclick="cancelCrop()">
            &times;
          </button>
        </div>
        <div class="cropper-content">
          <div class="cropper-img-container">
            <img src="" alt="Crop preview" id="cropperImage" />
          </div>
        </div>
        <div class="cropper-controls">
          <button type="button" class="btn btn-danger" onclick="cancelCrop()">
            Cancel
          </button>
          <button type="button" class="btn btn-success" onclick="saveCrop()">
            Save Crop
          </button>
        </div>
      </div>
    </div>

    <script>
      let variantCount = 0;
      let currentCropper = null;
      let currentImageElement = null;

      // Add initial variant on page load
      document.addEventListener("DOMContentLoaded", () => {
        addVariant();
      });

      function addVariant() {
        const variantContainer = document.createElement("div");
        variantContainer.className = "variant-container";
        variantContainer.id = `variant-${variantCount}`;

        variantContainer.innerHTML = `
                <button type="button" class="btn btn-danger remove-variant" onclick="removeVariant(${variantCount})">
                    Remove
                </button>
                <h4>Variant ${variantCount + 1}</h4>
                
                <div class="form-group">
                    <label>Color</label>
                    <select name="variants[${variantCount}][color]" required>
                        <option value="">Select Color</option>
                        <option value="red">Red</option>
                        <option value="blue">Blue</option>
                        <option value="black">Black</option>
                        <option value="white">White</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Size</label>
                    <select name="variants[${variantCount}][size]" required>
                        <option value="">Select Size</option>
                        <option value="65%">65% </option>
                        <option value="75%">75%</option>
                        <option value="Tenkeyless">Tenkeyless</option>
                        <option value="Fullsize">Fullsize</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Price</label>
                    <input type="number" name="variants[${variantCount}][price]" 
                           min="0.01" step="0.01" required>
                </div>

                <div class="form-group">
                    <label>Stock Quantity</label>
                    <input type="number" name="variants[${variantCount}][quantity]" 
                           min="1" required>
                </div>
<div class="form-group">
    <label>Variant Images (Select up to 3 images)</label>
    <div class="variant-images-container">
        <!-- Image 1 -->
        <div class="variant-image-wrapper">
            <h5>Primary Image</h5>
            <input type="file" 
                   name="variants[${variantCount}][images][]" 
                   class="variant-image" 
                   accept="image/*"
                   onchange="handleImageInput(event, ${variantCount}, 0)" 
                   required>
            
            <div class="image-preview-container">
                <img src="" 
                     alt="Preview" 
                     id="preview-${variantCount}-0" 
                     class="image-preview">
                <div class="preview-placeholder" id="placeholder-${variantCount}-0">
                    <span>No image selected</span>
                </div>
            </div>
            
            <div class="btn-group mt-2">
                <button type="button" 
                        class="btn btn-primary btn-sm" 
                        onclick="openCropper(${variantCount}, 0)">Crop</button>
                <button type="button" 
                        class="btn btn-danger btn-sm" 
                        onclick="removeImage(${variantCount}, 0)">Remove</button>
            </div>
        </div>

        <!-- Image 2 -->
        <div class="variant-image-wrapper">
            <h5>Secondary Image</h5>
            <input type="file" 
                   name="variants[${variantCount}][images][]" 
                   class="variant-image" 
                   accept="image/*"
                   onchange="handleImageInput(event, ${variantCount}, 1)">
            
            <div class="image-preview-container">
                <img src="" 
                     alt="Preview" 
                     id="preview-${variantCount}-1" 
                     class="image-preview">
                <div class="preview-placeholder" id="placeholder-${variantCount}-1">
                    <span>No image selected</span>
                </div>
            </div>
            
            <div class="btn-group mt-2">
                <button type="button" 
                        class="btn btn-primary btn-sm" 
                        onclick="openCropper(${variantCount}, 1)">Crop</button>
                <button type="button" 
                        class="btn btn-danger btn-sm" 
                        onclick="removeImage(${variantCount}, 1)">Remove</button>
            </div>
        </div>

        <!-- Image 3 -->
        <div class="variant-image-wrapper">
            <h5>Additional Image</h5>
            <input type="file" 
                   name="variants[${variantCount}][images][]" 
                   class="variant-image" 
                   accept="image/*"
                   onchange="handleImageInput(event, ${variantCount}, 2)">
            
            <div class="image-preview-container">
                <img src="" 
                     alt="Preview" 
                     id="preview-${variantCount}-2" 
                     class="image-preview">
                <div class="preview-placeholder" id="placeholder-${variantCount}-2">
                    <span>No image selected</span>
                </div>
            </div>
            
            <div class="btn-group mt-2">
                <button type="button" 
                        class="btn btn-primary btn-sm" 
                        onclick="openCropper(${variantCount}, 2)">Crop</button>
                <button type="button" 
                        class="btn btn-danger btn-sm" 
                        onclick="removeImage(${variantCount}, 2)">Remove</button>
            </div>
        </div>
    </div>
</div>
            `;

        document.getElementById("variants").appendChild(variantContainer);
        variantCount++;
      }

      function removeVariant(index) {
        Swal.fire({
          title: "Remove Variant?",
          text: "This action cannot be undone",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#d33",
          cancelButtonColor: "#3085d6",
          confirmButtonText: "Yes, remove it",
        }).then((result) => {
          if (result.isConfirmed) {
            document.getElementById(`variant-${index}`).remove();
          }
        });
      }

      function handleImageInput(event, variantIndex, imageIndex) {
        const file = event.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = function (e) {
            const preview = document.getElementById(
              `preview-${variantIndex}-${imageIndex}`
            );
            const placeholder = document.getElementById(
              `placeholder-${variantIndex}-${imageIndex}`
            );
            preview.src = e.target.result;
            preview.style.display = "block";
            placeholder.style.display = "none";
          };
          reader.readAsDataURL(file);
        }
      }

      function openCropper(variantIndex, imageIndex) {
        const preview = document.getElementById(
          `preview-${variantIndex}-${imageIndex}`
        );
        if (!preview.src) {
          Swal.fire({
            icon: "warning",
            title: "No Image",
            text: "Please select an image first",
          });
          return;
        }

        document.getElementById("cropperModal").style.display = "block";
        document.getElementById("cropperImage").src = preview.src;
        currentImageElement = preview;

        if (currentCropper) currentCropper.destroy();

        currentCropper = new Cropper(document.getElementById("cropperImage"), {
          aspectRatio: 1,
          viewMode: 2,
          dragMode: "move",
          autoCropArea: 1,
          restore: false,
          guides: true,
          center: true,
          highlight: false,
          cropBoxMovable: true,
          cropBoxResizable: true,
          toggleDragModeOnDblclick: false,
        });
      }

      function removeImage(variantIndex, imageIndex) {
        const preview = document.getElementById(
          `preview-${variantIndex}-${imageIndex}`
        );
        const placeholder = document.getElementById(
          `placeholder-${variantIndex}-${imageIndex}`
        );
        const input = document.querySelector(
          `input[name="variants[${variantIndex}][images][]"]`
        );

        preview.src = "";
        preview.style.display = "none";
        placeholder.style.display = "flex";
        input.value = "";
      }

      function cancelCrop() {
        document.getElementById("cropperModal").style.display = "none";
        if (currentCropper) {
          currentCropper.destroy();
          currentCropper = null;
        }
      }

      function saveCrop() {
        if (!currentCropper || !currentImageElement) return;

        const canvas = currentCropper.getCroppedCanvas();
        currentImageElement.src = canvas.toDataURL("image/jpeg");

        cancelCrop();
      }

      function removeImage(variantIndex, imageIndex) {
        const preview = document.getElementById(
          `preview-${variantIndex}-${imageIndex}`
        );
        const placeholder = document.getElementById(
          `placeholder-${variantIndex}-${imageIndex}`
        );
        const input = document.querySelector(
          `input[name="variants[${variantIndex}][images][]"]`
        );

        preview.src = "";
        preview.style.display = "none";
        placeholder.style.display = "flex";
        input.value = "";
      }
      $("#addProductForm").submit(function (e) {
        e.preventDefault();

        // Show loading state
        Swal.fire({
          title: "Adding Product...",
          text: "Please wait while we process your request",
          allowOutsideClick: false,
          showConfirmButton: false,
          willOpen: () => {
            Swal.showLoading();
          },
        });
        const formData = new FormData(this);
        $.ajax({
          url: "/admin/products/add",
          type: "POST",
          data: formData,
          processData: false,
          contentType: false,
          success: function (response) {
            if (response.success) {
              Swal.fire({
                icon: "success",
                title: "Success!",
                text: "Product added successfully",
                showConfirmButton: true,
              }).then((result) => {
                if (result.isConfirmed) {
                  window.location.href = "/admin/products";
                }
              });
            } else {
              Swal.fire({
                icon: "error",
                title: "Failed!",
                text: response.message || "Failed to add product",
                showConfirmButton: true,
              });
            }
          },
          error: function (xhr, status, error) {
            console.error("AJAX Error:", status, error);
            console.log("Response:", xhr.responseJSON);

            let errorMessage =
              "An unexpected error occurred. Please try again.";

            if (xhr.responseJSON && xhr.responseJSON.message) {
              errorMessage = xhr.responseJSON.message;
            } else {
              // Handle specific HTTP status codes
              switch (xhr.status) {
                case 400:
                  errorMessage = "Invalid data or product already exists.";
                  break;
                case 401:
                  errorMessage = "Please login to continue.";
                  break;
                case 403:
                  errorMessage =
                    "You don't have permission to perform this action.";
                  break;
                case 404:
                  errorMessage = "Resource not found.";
                  break;
                case 413:
                  errorMessage =
                    "Files are too large. Please reduce image sizes.";
                  break;
                case 500:
                  errorMessage = "Server error. Please try again later.";
                  break;
              }
            }

            Swal.fire({
              icon: "error",
              title: "Error!",
              text: errorMessage,
              showConfirmButton: true,
            });
          },
          complete: function () {
            // Additional cleanup if needed
          },
        });
      });
    </script>
  </body>
</html>
