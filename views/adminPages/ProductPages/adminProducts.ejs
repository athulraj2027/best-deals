<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Products</title>
  </head>
  <body>
    <%- include('../partials/menu')%>
    <div class="container-fluid mt-4">
      <div class="row">
        <div class="col-md-2"></div>
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Products</h1>
            <a
              href="/admin/products/add"
              class="btn text-white"
              style="background-color: #f57c00"
            >
              Add Product
            </a>
          </div>

          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3">
            <!-- Filter by Category -->
            <form action="/admin/products/filter" method="GET" class="d-inline">
              <select
                name="category"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="">Filter by Category</option>
                <option value="men">Men</option>
                <option value="women">Women</option>
                <option value="kids">Kids</option>
              </select>
            </form>

            <!-- Sort Options -->
            <form action="/admin/products/sort" method="GET" class="d-inline">
              <select
                name="sort"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="newest">Sort by Date (Newest first)</option>
                <option value="oldest">Sort by Date (Oldest first)</option>
                <option value="price_high">Sort by Price (High to Low)</option>
                <option value="price_low">Sort by Price (Low to High)</option>
              </select>
            </form>

            <!-- Search by Product Name or Brand -->
            <form action="/admin/products/search" method="GET" class="d-inline">
              <input
                type="text"
                name="query"
                placeholder="Search by name or brand"
                class="form-control d-inline"
                style="width: 200px"
              />
              <button
                type="submit"
                class="btn btn-sm ms-2"
                style="background-color: #f57c00; color: white"
              >
                Search
              </button>
            </form>
          </div>

          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Brand</th>
                    <th>Base Price</th>
                    <th>Category</th>
                    <th>Variants</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (products && products.length > 0) { %> <%
                  products.forEach((product, index) => { %>
                  <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= product.name %></td>
                    <td><%= product.brand %></td>
                    <td>$<%= product.actualPrice.toFixed(2) %></td>
                    <td><%= product.category.name %></td>
                    <td class="text-center">
                      <!-- Variants count with dropdown toggle -->
                      <div class="dropdown">
                        <button
                          class="btn btn-sm btn-secondary dropdown-toggle"
                          type="button"
                          data-bs-toggle="dropdown"
                        >
                          <%= product.variants.length %> Variants
                        </button>
                        <ul class="dropdown-menu">
                          <% product.variants.forEach(variant => { %>
                          <li class="dropdown-item">
                            <%= variant.color %> - <%= variant.size %>
                            <br />
                            Price: $<%= variant.price.toFixed(2) %>
                            <br />
                            Stock: <%= variant.quantity %>
                            <br />
                          </li>
                          <% }); %>
                        </ul>
                      </div>
                    </td>
                    <td class="text-center">
                      <%= product.status ? 'Listed' : 'Unlisted' %>
                    </td>
                    <td class="text-center">
                      <a
                        href="/admin/products/edit/<%= product._id %>"
                        class="btn btn-sm text-white"
                        style="background-color: #f57c00"
                      >
                        Edit
                      </a>
                      <a
                        href="/admin/products/<%=product._id%>/add-variant"
                        class="btn btn-sm text-white"
                        style="background-color: #f57c00"
                      >Add Variant</a>

                      <% if (product.status) { %>
                      <form
                        action="/admin/products/unlist/<%= product._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-warning">
                          Unlist
                        </button>
                      </form>
                      <% } else { %>
                      <form
                        action="/admin/products/list/<%= product._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button type="submit" class="btn btn-sm btn-success">
                          List
                        </button>
                      </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }); %> <% } else { %>
                  <tr>
                    <td colspan="8" class="text-center">No products found.</td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div>
      <% if (hasPrevPage) { %>
      <a href="/admin/products?page=<%= prevPage %>&limit=10">Previous</a>
      <% } %> Page <%= currentPage %> of <%= totalPages %> <% if (hasNextPage) {
      %>
      <a href="/admin/products?page=<%= nextPage %>&limit=10">Next</a>
      <% } %>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
