<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Products Management | Tech Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .main-content { margin-left: 250px; }
        @media(max-width: 768px) { .main-content { margin-left: 0; } }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
<div class="flex">
    <%- include('../partials/menu') %>

    <div class="main-content w-full p-6 md:p-10">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight">Products</h1>
                <p class="text-slate-500 text-sm mt-1">Manage your inventory, prices, and stock levels.</p>
            </div>
            <a href="/admin/products/add" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold transition-all shadow-lg shadow-indigo-200 active:scale-95 text-sm">
                <i class="fas fa-plus"></i>
                <span>Add New Product</span>
            </a>
        </div>

        <div class="bg-white p-5 rounded-[2rem] shadow-sm border border-slate-200 mb-8">
            <form action="/admin/products" method="GET" class="flex flex-col lg:flex-row gap-4">
                <div class="relative flex-1 group">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
                    <input type="text" name="query" value="<%= query || '' %>" placeholder="Search products or brands..." 
                           class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium">
                </div>

                <div class="flex flex-wrap items-center gap-3">
                    <select name="category" onchange="this.form.submit()" 
                            class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer">
                        <option value="">All Categories</option>
                        <% categories.forEach(c => { %>
                            <option value="<%= c._id %>" <%= String(selectedCategory) === String(c._id) ? "selected" : "" %>>
                                <%= c.name %>
                            </option>
                        <% }) %>
                    </select>

                    <select name="sort" onchange="this.form.submit()" 
                            class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer">
                        <option value="">Sort By</option>
                        <option value="price_low" <%= selectedSort === "price_low" ? "selected" : "" %>>Price: Low to High</option>
                        <option value="price_high" <%= selectedSort === "price_high" ? "selected" : "" %>>Price: High to Low</option>
                        <option value="newest" <%= selectedSort === "newest" ? "selected" : "" %>>Newest First</option>
                    </select>

                    <a href="/admin/products" class="text-slate-400 hover:text-red-500 font-bold text-sm px-2 transition-colors">Reset</a>
                </div>
            </form>
        </div>

        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200">
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">#</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Product</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Brand</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Category</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Variants</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Status</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (products.length > 0) { %>
                            <% products.forEach((p, i) => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-4 text-xs font-bold text-slate-400"><%= i+1 %></td>
                                
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-12 h-12 rounded-xl overflow-hidden bg-slate-100 border border-slate-200 flex-shrink-0">
                                            <img src="<%= p.variants?.[0]?.images?.[0]?.url || 'https://placehold.co/100x100?text=No+Img' %>" 
                                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                                        </div>
                                        <span class="text-sm font-bold text-slate-800 line-clamp-1"><%= p.name %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-4">
                                    <span class="text-xs font-semibold text-slate-500"><%= p.brand %></span>
                                </td>

                                <td class="px-6 py-4">
                                    <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-[10px] font-bold uppercase tracking-wider border border-blue-100">
                                        <%= p.category.name %>
                                    </span>
                                </td>

                                <td class="px-6 py-4">
                                    <details class="cursor-pointer group/details">
                                        <summary class="text-xs font-bold text-indigo-600 list-none flex items-center gap-1 hover:underline">
                                            <i class="fas fa-chevron-right text-[8px] group-open/details:rotate-90 transition-transform"></i>
                                            <%= p.variants.length %> Variants
                                        </summary>
                                        <div class="absolute z-10 mt-2 p-3 bg-white border border-slate-200 shadow-xl rounded-2xl w-64">
                                            <div class="space-y-2">
                                                <% p.variants.forEach(v => { %>
                                                <div class="text-[10px] border-b border-slate-50 last:border-0 pb-1">
                                                    <p class="font-bold text-slate-700 uppercase"><%= v.color %> / <%= v.size %></p>
                                                    <div class="flex justify-between text-slate-500">
                                                        <span>₹<%= v.price %></span>
                                                        <span class="<%= v.quantity < 10 ? 'text-red-500 font-bold' : '' %>">Stock: <%= v.quantity %></span>
                                                    </div>
                                                </div>
                                                <% }) %>
                                            </div>
                                        </div>
                                    </details>
                                </td>

                                <td class="px-6 py-4">
                                    <% if (p.status) { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-600 border border-emerald-100">
                                            Active
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-slate-100 text-slate-500 border border-slate-200">
                                            Inactive
                                        </span>
                                    <% } %>
                                </td>

                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <a href="/admin/products/edit/<%= p._id %>" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="Edit Product">
                                            <i class="fas fa-pen-to-square text-xs"></i>
                                        </a>
                                        <a href="/admin/products/<%= p._id %>/add-variant" class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all" title="Manage Variants">
                                            <i class="fas fa-layer-group text-xs"></i>
                                        </a>

                                        <% if (p.status) { %>
                                            <form action="/admin/products/unlist/<%= p._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-xl transition-all" title="Unlist Product">
                                                    <i class="fas fa-eye-slash text-xs"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/products/list/<%= p._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-xl transition-all" title="List Product">
                                                    <i class="fas fa-eye text-xs"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="px-6 py-20 text-center">
                                    <i class="fas fa-box-open text-4xl text-slate-200 mb-4"></i>
                                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No products found</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 flex justify-center">
            <nav class="flex items-center gap-2 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                <% } %>

                <div class="px-4 text-xs font-bold text-slate-500 uppercase tracking-widest">
                    Page <%= currentPage %> <span class="text-slate-300 mx-1">/</span> <%= totalPages %>
                </div>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                <% } %>
            </nav>
        </div>

    </div>
</div>
</body>
</html>