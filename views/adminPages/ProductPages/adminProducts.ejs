<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Products</title>
    <style>
      :root {
        --sidebar-width: 250px;
        --sidebar-collapsed-width: 70px;
        --primary-color: #f57c00;
      }
      
      body {
        overflow-x: hidden;
        /* font-family: 'Poppins', sans-serif; */
      }
      
      .main-content {
        margin-left: var(--sidebar-width);
        transition: margin-left 0.3s ease;
        width: calc(100% - var(--sidebar-width));
        padding: 20px;
      }
      
      body.sidebar-collapsed .main-content {
        margin-left: var(--sidebar-collapsed-width);
        width: calc(100% - var(--sidebar-collapsed-width));
      }
      
      body.sidebar-hidden .main-content {
        margin-left: 0;
        width: 100%;
      }
      
      .product-actions .btn {
        margin-bottom: 5px;
      }
      
      @media (max-width: 992px) {
        .search-container {
          margin-top: 10px;
        }
        
        .filter-sort-container {
          flex-direction: column;
        }
        
        .filter-sort-container > form {
          margin-bottom: 10px;
          width: 100%;
        }
      }
      
      @media (max-width: 768px) {
        .main-content {
          margin-left: var(--sidebar-collapsed-width);
          width: calc(100% - var(--sidebar-collapsed-width));
        }
        
        body.sidebar-expanded .main-content {
          margin-left: var(--sidebar-width);
          width: calc(100% - var(--sidebar-width));
        }
      }
      
      @media (max-width: 576px) {
        .main-content {
          margin-left: 0;
          width: 100%;
          padding: 15px;
        }
        
        body.sidebar-expanded .main-content {
          margin-left: var(--sidebar-width);
          width: calc(100% - var(--sidebar-width));
        }
        
        .action-buttons-container {
          flex-direction: column;
          align-items: flex-start !important;
        }
        
        .action-buttons-container .btn {
          margin-top: 10px;
          width: 100%;
        }
        
        .table-responsive {
          font-size: 14px;
        }
      }
      
      .pagination-container {
        display: flex; 
        justify-content: center; 
        align-items: center; 
        gap: 12px; 
        margin: 20px 0; 
        font-size: 16px;
      }
      
      .pagination-button {
        padding: 8px 14px; 
        background-color: #007bff; 
        color: white; 
        text-decoration: none; 
        border-radius: 6px; 
        transition: background 0.3s ease-in-out; 
        font-weight: bold;
      }
      
      .pagination-button:hover {
        background-color: #0056b3;
        color: white;
        text-decoration: none;
      }
      
      .page-info {
        font-weight: bold; 
        color: #333;
      }
    </style>
  </head>
  <body>
    <!-- Include the sidebar partial with EJS -->
    <%- include('../partials/menu') %>

    <!-- Main content area -->
    <div class="main-content">
      <div class="container-fluid p-0">
        <div class="d-flex justify-content-between align-items-center mb-4 action-buttons-container">
          <h1 class="text-dark">Products</h1>
          <a
            href="/admin/products/add"
            class="btn text-white"
            style="background-color: var(--primary-color)"
          >
            Add Product
          </a>
        </div>

        <!-- Filter, Sort, and Search Options -->
        <div class="row mb-3">
          <div class="col-lg-8">
            <div class="d-flex flex-wrap filter-sort-container">
              <!-- Filter by Category -->
              <form action="/admin/products/filter" method="GET" class="me-2 mb-2 mb-md-0">
                <select
                  name="category"
                  class="form-select"
                  onchange="this.form.submit()"
                >
                  <option value="">Filter by Category</option>
                  <option value="men">Men</option>
                  <option value="women">Women</option>
                  <option value="kids">Kids</option>
                </select>
              </form>

              <!-- Sort Options -->
              <form action="/admin/products/sort" method="GET" class="me-2">
                <select
                  name="sort"
                  class="form-select"
                  onchange="this.form.submit()"
                >
                  <option value="newest">Sort by Date (Newest first)</option>
                  <option value="oldest">Sort by Date (Oldest first)</option>
                  <option value="price_high">Sort by Price (High to Low)</option>
                  <option value="price_low">Sort by Price (Low to High)</option>
                </select>
              </form>
            </div>
          </div>
          
          <div class="col-lg-4">
            <!-- Search by Product Name or Brand -->
            <form action="/admin/products/search" method="GET" class="d-flex search-container">
              <input
                type="text"
                name="query"
                placeholder="Search by name or brand"
                class="form-control me-2"
              />
              <button
                type="submit"
                class="btn"
                style="background-color: var(--primary-color); color: white"
              >
                <i class="fas fa-search"></i>
              </button>
            </form>
          </div>
        </div>

        <div class="card border-light">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-bordered table-hover">
                <thead style="background-color: var(--primary-color); color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Brand</th>
                    <th>Base Price</th>
                    <th>Category</th>
                    <th>Variants</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (products && products.length > 0) { %>
                    <% products.forEach((product, index) => { %>
                      <tr>
                        <td class="text-center"><%= index + 1 %></td>
                        <td><%= product.name %></td>
                        <td><%= product.brand %></td>
                        <td>$<%= product.actualPrice.toFixed(2) %></td>
                        <td><%= product.category.name %></td>
                        <td class="text-center">
                          <!-- Variants count with dropdown toggle -->
                          <div class="dropdown">
                            <button
                              class="btn btn-sm btn-secondary dropdown-toggle"
                              type="button"
                              data-bs-toggle="dropdown"
                            >
                              <%= product.variants.length %> Variants
                            </button>
                            <ul class="dropdown-menu">
                              <% product.variants.forEach(variant => { %>
                                <li class="dropdown-item">
                                  <%= variant.color %> - <%= variant.size %>
                                  <br />
                                  Price: $<%= variant.price.toFixed(2) %>
                                  <br />
                                  Stock: <%= variant.quantity %>
                                </li>
                              <% }); %>
                            </ul>
                          </div>
                        </td>
                        <td class="text-center">
                          <%= product.status ? 'Listed' : 'Unlisted' %>
                        </td>
                        <td class="text-center product-actions">
                          <a
                            href="/admin/products/edit/<%= product._id %>"
                            class="btn btn-sm text-white mb-1"
                            style="background-color: var(--primary-color)"
                          >
                            Edit
                          </a>
                          <a
                            href="/admin/products/<%= product._id %>/add-variant"
                            class="btn btn-sm text-white mb-1"
                            style="background-color: var(--primary-color)"
                          >
                            Add Variant
                          </a>
                          <% if (product.status) { %>
                            <form
                              action="/admin/products/unlist/<%= product._id %>"
                              method="POST"
                              class="d-inline"
                            >
                              <button type="submit" class="btn btn-sm btn-warning">
                                Unlist
                              </button>
                            </form>
                          <% } else { %>
                            <form
                              action="/admin/products/list/<%= product._id %>"
                              method="POST"
                              class="d-inline"
                            >
                              <button type="submit" class="btn btn-sm btn-success">
                                List
                              </button>
                            </form>
                          <% } %>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="8" class="text-center">No products found.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        
        <!-- Pagination section -->
        <div class="pagination-container">
          <% if (hasPrevPage) { %>
            <a href="/admin/products?page=<%= prevPage %>&limit=10" class="pagination-button">
              Previous
            </a>
          <% } %>
          
          <span class="page-info">
            Page <%= currentPage %> of <%= totalPages %>
          </span>
          
          <% if (hasNextPage) { %>
            <a href="/admin/products?page=<%= nextPage %>&limit=10" class="pagination-button">
              Next
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Get the sidebar toggle button
        const sidebarToggle = document.getElementById('sidebarToggle');
        const mobileToggle = document.querySelector('.mobile-menu-toggle');
        
        // Function to toggle sidebar
        function toggleSidebar() {
          document.body.classList.toggle('sidebar-expanded');
          
          if (window.innerWidth <= 576) {
            // For mobile view
            if (document.body.classList.contains('sidebar-expanded')) {
              document.body.classList.remove('sidebar-hidden');
            }
          } else if (window.innerWidth <= 768) {
            // For tablet view
            document.body.classList.toggle('sidebar-collapsed');
          }
        }
        
        // Add click event to sidebar toggle
        if (sidebarToggle) {
          sidebarToggle.addEventListener('click', toggleSidebar);
        }
        
        // Add click event to mobile toggle if it exists
        if (mobileToggle) {
          mobileToggle.addEventListener('click', toggleSidebar);
        } else {
          // Create mobile toggle if it doesn't exist
          const mobileToggle = document.createElement('button');
          mobileToggle.className = 'mobile-menu-toggle d-sm-none';
          mobileToggle.innerHTML = '<span></span><span></span><span></span>';
          document.body.appendChild(mobileToggle);
          mobileToggle.addEventListener('click', toggleSidebar);
        }
        
        // Handle resize events to reset menu state
        window.addEventListener('resize', function() {
          const width = window.innerWidth;
          
          if (width > 768) {
            // Desktop view
            document.body.classList.remove('sidebar-expanded');
            document.body.classList.remove('sidebar-collapsed');
            document.body.classList.remove('sidebar-hidden');
          } else if (width > 576 && width <= 768) {
            // Tablet view - collapsed by default
            document.body.classList.add('sidebar-collapsed');
            document.body.classList.remove('sidebar-expanded');
            
            if (document.body.classList.contains('sidebar-hidden')) {
              document.body.classList.remove('sidebar-hidden');
            }
          } else {
            // Mobile view - hidden by default
            document.body.classList.add('sidebar-hidden');
            if (!document.body.classList.contains('sidebar-expanded')) {
              document.body.classList.remove('sidebar-collapsed');
            }
          }
        });
        
        // Trigger resize event on load to set initial state
        window.dispatchEvent(new Event('resize'));
      });
    </script>
  </body>
</html>