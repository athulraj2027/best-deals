<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Products — Admin</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/adminCSS/partials/menu.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --brand:#f57c00;
      --brand-dark:#e65100;
      --ink:#1a1a2e;
      --muted:#6b7280;
      --border:#e5e7eb;
    }
    body { font-family:'Manrope',sans-serif; background:#f4f5f7; }
    .syne { font-family:'Syne',sans-serif; }

    .main-content { margin-left:250px; padding:28px 24px; }
    @media(max-width:768px){ .main-content{ margin-left:70px; } }
    @media(max-width:576px){ .main-content{ margin-left:0; } }

    .card {
      background:#fff;
      border:1px solid var(--border);
      border-radius:14px;
      box-shadow:0 2px 10px rgba(0,0,0,.05);
    }

    .tbl thead th {
      background:var(--ink);
      color:#fff;
      font-size:.75rem;
      text-transform:uppercase;
      letter-spacing:.05em;
      padding:12px;
    }

    .tbl tbody td {
      padding:12px;
      font-size:.85rem;
    }

    .tbl tbody tr:hover {
      background:#fffbf5;
    }

    .badge {
      padding:4px 10px;
      border-radius:20px;
      font-size:.7rem;
      font-weight:700;
    }

    .badge-active {
      background:#dcfce7;
      color:#14532d;
    }

    .badge-inactive {
      background:#fee2e2;
      color:#7f1d1d;
    }

    .btn-primary {
      background:var(--brand);
      color:#fff;
      font-weight:700;
      border-radius:8px;
      padding:6px 12px;
      font-size:.8rem;
    }

    .btn-primary:hover {
      background:var(--brand-dark);
    }
  </style>
</head>

<body>
<div class="flex">
  <%- include('../partials/menu') %>

  <div class="main-content w-full">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-6 flex-wrap gap-3">
      <div>
        <h1 class="syne text-2xl font-extrabold">Products</h1>
        <p class="text-sm text-gray-500">
          <%= products.length %> products found
        </p>
      </div>

      <a href="/admin/products/add" class="btn-primary">
        + Add Product
      </a>
    </div>

    <!-- 🔍 SEARCH BAR -->
    <form action="/admin/products" method="GET" class="mb-4">
      <div class="flex gap-2">
        <input
          type="text"
          name="query"
          placeholder="Search products, brand..."
          class="flex-1 px-4 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-orange-200"
        />
        <button class="btn-primary px-4">Search</button>
      </div>
    </form>

    <!-- FILTER BAR -->
    <div class="card p-4 mb-5 flex flex-wrap gap-3">

      <!-- Category -->
      <form action="/admin/products" method="GET">
        <select name="category"
          onchange="this.form.submit()"
          class="px-3 py-2 rounded-lg border text-sm">
          <option value="">All Categories</option>
          <% categories.forEach(c => { %>
            <option value="<%= c._id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </form>

      <!-- Sort -->
      <form action="/admin/products" method="GET">
        <select name="sort"
          onchange="this.form.submit()"
          class="px-3 py-2 rounded-lg border text-sm">
          <option value="">Sort</option>
          <option value="price_low">Price Low → High</option>
          <option value="price_high">Price High → Low</option>
          <option value="newest">Newest</option>
        </select>
      </form>

    </div>

    <!-- TABLE -->
    <div class="card overflow-hidden">
      <div class="overflow-y-auto max-h-[70vh]">

        <table class="w-full tbl">
          <thead>
            <tr>
              <th>#</th>
              <th>Product</th>
              <th>Brand</th>
              <th>Price</th>
              <th>Category</th>
              <th>Variants</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (products.length > 0) { %>

              <% products.forEach((p, i) => { %>
              <tr>

                <td class="text-center text-gray-500"><%= i+1 %></td>

                <!-- Product -->
                <td>
                  <div class="font-semibold"><%= p.name %></div>
                </td>

                <td><%= p.brand %></td>

                <td class="font-bold">₹<%= p.actualPrice.toFixed(2) %></td>

                <td><%= p.category.name %></td>

                <!-- Variants -->
                <td>
                  <details class="cursor-pointer">
                    <summary class="text-sm font-semibold text-orange-600">
                      <%= p.variants.length %> variants
                    </summary>
                    <div class="mt-2 space-y-1 text-xs text-gray-600">
                      <% p.variants.forEach(v => { %>
                        <div>
                          <b><%= v.color %> / <%= v.size %></b> —
                          ₹<%= v.price %> | Stock: <%= v.quantity %>
                        </div>
                      <% }) %>
                    </div>
                  </details>
                </td>

                <!-- Status -->
                <td>
                  <span class="badge <%= p.status ? 'badge-active':'badge-inactive' %>">
                    <%= p.status ? 'Active':'Inactive' %>
                  </span>
                </td>

                <!-- Actions -->
                <td>
                  <div class="flex flex-col gap-1">

                    <a href="/admin/products/edit/<%= p._id %>" class="btn-primary text-center">
                      Edit
                    </a>

                    <a href="/admin/products/<%= p._id %>/add-variant" class="btn-primary text-center">
                      Variant
                    </a>

                    <% if (p.status) { %>
                      <form action="/admin/products/unlist/<%= p._id %>" method="POST">
                        <button class="w-full bg-yellow-400 text-black text-xs py-1 rounded">
                          Unlist
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/admin/products/list/<%= p._id %>" method="POST">
                        <button class="w-full bg-green-500 text-white text-xs py-1 rounded">
                          List
                        </button>
                      </form>
                    <% } %>

                  </div>
                </td>

              </tr>
              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="8" class="text-center py-10 text-gray-400">
                  No products found
                </td>
              </tr>

            <% } %>
          </tbody>

        </table>
      </div>
    </div>

    <!-- PAGINATION -->
    <div class="flex justify-center items-center gap-4 mt-6">

      <% if (hasPrevPage) { %>
        <a href="?page=<%= prevPage %>" class="btn-primary">Prev</a>
      <% } %>

      <span class="text-sm font-semibold">
        Page <%= currentPage %> of <%= totalPages %>
      </span>

      <% if (hasNextPage) { %>
        <a href="?page=<%= nextPage %>" class="btn-primary">Next</a>
      <% } %>

    </div>

  </div>
</div>
</body>
</html>