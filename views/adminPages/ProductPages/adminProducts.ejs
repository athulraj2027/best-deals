<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Products</title>
  </head>
  <body>
    <%- include('../partials/menu')%>
    <div class="container-fluid mt-4">
      <div class="row">
        <div class="col-md-2"></div>
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Products</h1>
            <a
              href="/admin/products/add"
              class="btn text-white"
              style="background-color: #f57c00"
            >
              Add Product
            </a>
          </div>
          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3">
            <!-- Filter by Status -->
            <form action="/admin/coupons/filter" method="GET" class="d-inline">
              <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">Filter by Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </form>

            <!-- Sort by Discount or CreatedAt -->
            <form action="/admin/coupons/sort" method="GET" class="d-inline">
              <select name="sort" class="form-select" onchange="this.form.submit()">
                <option value="desc">Sort by Date (Newest first)</option>
                <option value="asc">Sort by Date (Oldest first)</option>
                <option value="asc_discount">Sort by Discount (Ascending)</option>
                <option value="desc_discount">Sort by Discount (Descending)</option>
              </select>
            </form>

            <!-- Search by Coupon Code -->
            <form action="/admin/coupons/search" method="GET" class="d-inline">
              <input
                type="text"
                name="query"
                placeholder="Search by code"
                class="form-control d-inline"
                style="width: 200px;"
              />
              <button type="submit" class="btn btn-sm ms-2" style="background-color: #f57c00; color: white;">
                Search
              </button>
            </form>
          </div>

          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (products && products.length > 0) { %>
                    <% products.forEach((product, index) => { %>
                      <tr>
                        <td class="text-center"><%= index + 1 %></td>
                        <td><%= product.name %></td>
                        <td>
                          <%= product.category ? product.category.name : 'No Category' %>
                        </td>
                        <td>$<%= product.price.toFixed(2) %></td>
                        <td class="text-center"><%= product.stock %></td>
                        <td class="text-center">
                          <%= product.status ? 'Listed' : 'Inactive' %>
                        </td>
                        <td class="text-center">
                          <a
                            href="/admin/products/edit/<%= product._id %>"
                            class="btn btn-sm text-white"
                            style="background-color: #f57c00"
                          >
                            Edit
                          </a>
                          <!-- <form
                            action="/admin/products/listing/<%= product._id %>"
                            method="post"
                            onsubmit="return confirm('Are you sure you want to delete this product?');"
                            class="d-inline"
                          > --> 
                          <% if (product.status) { %>
                            <!-- Unlist Button -->
                            <form action="/admin/products/unlist/<%= product._id %>" method="POST" class="d-inline">
                              <button type="submit" class="btn btn-sm btn-warning">Unlist</button>
                            </form>
                          <% } else { %>
                            <!-- List Button -->
                            <form action="/admin/products/list/<%= product._id %>" method="POST" class="d-inline">
                              <button type="submit" class="btn btn-sm btn-success">List</button>
                            </form>
                          <% } %>
                          </form>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="7" class="text-center">No products found.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
