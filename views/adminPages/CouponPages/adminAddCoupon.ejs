<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Coupon | Tech Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        /* Custom styling for multi-select to match tech theme */
        select[multiple] {
            background-image: none;
            scrollbar-width: thin;
            scrollbar-color: #cbd5e1 #f8fafc;
        }
        select[multiple]::-webkit-scrollbar { width: 6px; }
        select[multiple]::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <div class="max-w-4xl mx-auto py-12 px-6">
        <div class="mb-10 text-center">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Create <span class="text-indigo-600">New Coupon</span></h1>
            <p class="text-slate-500 mt-2">Generate unique discount codes for your marketing campaigns.</p>
        </div>

        <form id="addCouponForm" class="space-y-8">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i class="fas fa-ticket-alt"></i>
                    </div>
                    Core Configurations
                </h3>

                <div class="space-y-6">
                    <div>
                        <label for="couponCode" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Coupon Code</label>
                        <input type="text" id="couponCode" name="code" placeholder="e.g. TECHSAVVY25" 
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold uppercase tracking-widest" />
                        <p id="couponCodeError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>

                    <div>
                        <label for="description" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Campaign Description</label>
                        <textarea id="description" name="description" placeholder="Describe the offer (e.g. Summer Sale 2026)..." rows="2"
                                  class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium"></textarea>
                        <p id="descriptionError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    Target Scope
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label for="appliedCategories" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Target Categories</label>
                        <select id="appliedCategories" name="appliedCategories" multiple class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-xs font-bold h-32">
                            <% categories.forEach(function(category) { %>
                                <option value="<%= category._id %>" class="py-1"><%= category.name %></option>
                            <% }); %>
                        </select>
                        <p class="text-[10px] text-slate-400 mt-3 italic">Ctrl+Click to select multiples. Empty = Global</p>
                    </div>

                    <div>
                        <label for="appliedProducts" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Target Specific Products</label>
                        <select id="appliedProducts" name="appliedProducts" multiple class="w-full px-4 py-3 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-xs font-bold h-32">
                            <% products.forEach(function(product) { %>
                                <option value="<%= product._id %>" class="py-1"><%= product.name %></option>
                            <% }); %>
                        </select>
                        <p class="text-[10px] text-slate-400 mt-3 italic">Leave empty to apply to all products.</p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600">
                        <i class="fas fa-coins"></i>
                    </div>
                    Discount Economics
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label for="discountType" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2">Benefit Type</label>
                        <select id="discountType" name="discountType" class="w-full px-4 py-4 rounded-xl border border-slate-200 bg-slate-50 text-sm font-bold outline-none focus:border-indigo-400 appearance-none cursor-pointer">
                            <option value="">Select Type</option>
                            <option value="percentage">Percentage (%)</option>
                            <option value="fixed">Fixed Amount (₹)</option>
                        </select>
                        <p id="discountTypeError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>

                    <div>
                        <label for="discountValue" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2">Discount Value</label>
                        <input type="number" id="discountValue" name="discountValue" step="0.01" placeholder="0.00"
                               class="w-full px-4 py-4 rounded-xl border border-slate-200 bg-slate-50 text-sm font-black outline-none focus:border-indigo-400" />
                        <p id="discountValueError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>

                    <div>
                        <label for="minPurchase" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2">Min. Cart Value</label>
                        <input type="number" id="minPurchase" name="minPurchase" value="0" step="0.01"
                               class="w-full px-4 py-4 rounded-xl border border-slate-200 bg-slate-50 text-sm font-black outline-none focus:border-indigo-400" />
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    Validity Window
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                    <div>
                        <label for="startDate" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Live From</label>
                        <input type="datetime-local" id="startDate" name="startDate" 
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-bold" />
                    </div>
                    <div>
                        <label for="expiryDate" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Expires On</label>
                        <input type="datetime-local" id="expiryDate" name="expiryDate" 
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-bold" />
                        <p id="expiryDateError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>
                </div>

                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-3xl border border-slate-100">
                    <div class="flex items-center gap-6">
                        <div>
                            <label for="usageLimit" class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Global Usage Limit</label>
                            <input type="number" id="usageLimit" name="usageLimit" placeholder="∞" min="1"
                                   class="w-32 px-4 py-2 rounded-xl border border-white bg-white text-sm font-black outline-none focus:ring-2 focus:ring-indigo-200" />
                        </div>
                        <div class="h-10 w-[1px] bg-slate-200"></div>
                        <div>
                            <span class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Initial Status</span>
                            <div class="flex items-center gap-3 mt-2">
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="active" id="statusToggle" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-slate-300 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                                </label>
                                <span id="statusText" class="text-xs font-black uppercase tracking-tighter text-emerald-600">Active</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-4">
                <a href="/admin/coupons" class="w-full sm:w-auto px-10 py-4 font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest text-xs transition-all text-center">
                    Discard
                </a>
                <button type="submit" class="w-full sm:w-auto px-12 py-4 font-black text-white bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95 uppercase tracking-widest text-xs">
                    Authorize Coupon
                </button>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Set default dates
        document.addEventListener("DOMContentLoaded", function () {
            const now = new Date();
            const localDatetime = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            document.getElementById("startDate").value = localDatetime;

            const thirtyDaysLater = new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000);
            const expiryLocalDatetime = new Date(thirtyDaysLater.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            document.getElementById("expiryDate").value = expiryLocalDatetime;
        });

        // Toggle Status Text
        document.getElementById('statusToggle').addEventListener('change', function() {
            const statusText = document.getElementById("statusText");
            statusText.textContent = this.checked ? "Active" : "Inactive";
            statusText.className = `text-xs font-black uppercase tracking-tighter ${this.checked ? 'text-emerald-600' : 'text-slate-400'}`;
        });

        // Placeholder logic for discount type
        document.getElementById("discountType").addEventListener("change", function () {
            const valInput = document.getElementById("discountValue");
            if (this.value === "percentage") {
                valInput.setAttribute("max", "100");
                valInput.placeholder = "Enter percentage (0-100)";
            } else {
                valInput.removeAttribute("max");
                valInput.placeholder = "Enter amount in ₹";
            }
        });

        // Validation helpers
        function showError(id, msg) {
            $(`#${id}Error`).text(msg).fadeIn();
        }
        function hideError(id) {
            $(`#${id}Error`).hide();
        }

        // Form Submission
        $("#addCouponForm").on("submit", function (e) {
            e.preventDefault();
            $(".error-message").hide();

            const code = $("#couponCode").val().trim();
            const desc = $("#description").val().trim();
            const type = $("#discountType").val();
            const val = parseFloat($("#discountValue").val());
            const start = new Date($("#startDate").val());
            const expiry = new Date($("#expiryDate").val());

            let isValid = true;

            if (!code || code.length < 3) { showError("couponCode", "Invalid Code (Min 3 characters)"); isValid = false; }
            if (!desc || desc.length < 10) { showError("description", "Provide a detailed description"); isValid = false; }
            if (!type) { showError("discountType", "Select benefit type"); isValid = false; }
            if (isNaN(val) || val <= 0) { showError("discountValue", "Enter valid positive value"); isValid = false; }
            if (type === 'percentage' && val > 100) { showError("discountValue", "Percentage cannot exceed 100%"); isValid = false; }
            if (expiry <= start) { showError("expiryDate", "Expiry must be after start date"); isValid = false; }

            if (!isValid) return;

            Swal.fire({
                title: "Deploying Coupon...",
                didOpen: () => Swal.showLoading(),
                allowOutsideClick: false,
            });

            const formData = $(this).serializeArray();
            const jsonData = {};
            formData.forEach(item => {
                if (item.name === 'appliedCategories' || item.name === 'appliedProducts') {
                    if (!jsonData[item.name]) jsonData[item.name] = [];
                    if (item.value) jsonData[item.name].push(item.value);
                } else {
                    jsonData[item.name] = item.value;
                }
            });
            jsonData.active = $("#statusToggle").is(":checked");

            $.ajax({
                url: "/admin/coupons/add",
                type: "POST",
                data: JSON.stringify(jsonData),
                contentType: "application/json",
                success: function (res) {
                    if (res.status === "success") {
                        Swal.fire("Success!", "Coupon is now live.", "success").then(() => window.location.href = "/admin/coupons");
                    } else {
                        Swal.fire("Error", res.message, "error");
                    }
                },
                error: (xhr) => Swal.fire("Error", xhr.responseJSON?.message || "Server connection failed", "error")
            });
        });
    </script>
</body>
</html>