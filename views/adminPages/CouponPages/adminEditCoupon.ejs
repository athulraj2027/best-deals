<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />
    <title>Edit Coupon</title>
    <link rel="stylesheet" href="/adminCSS/editCoupon.css">
</head>
<body>
    <div class="container mt-4">
        <h1 class="text-center">Edit Coupon</h1>
        <h2 class="mb-4">Update Coupon Details</h2>

        <!-- Form for editing the coupon -->
        <form action="/admin/coupons/edit/<%= coupon._id %>" method="POST">
            <!-- Coupon Code -->
            <div class="mb-3">
                <label for="couponCode" class="form-label">Coupon Code</label>
                <input type="text" id="couponCode" name="couponCode" class="form-control" value="<%= coupon.code %>" placeholder="Enter coupon code" required>
            </div>

            <!-- Discount Percentage -->
            <div class="mb-3">
                <label for="discount" class="form-label">Discount (%)</label>
                <input type="number" id="discount" name="discount" class="form-control" value="<%= coupon.discount %>" placeholder="Enter discount percentage" min="1" max="100" required>
            </div>

            <!-- Description (optional) -->
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="description" class="form-control" placeholder="Enter description (optional)"><%= coupon.description || '' %></textarea>
            </div>

            <!-- Coupon Type -->
            <div class="mb-3">
                <label for="couponType" class="form-label">Coupon Type</label>
                <select id="couponType" name="couponType" class="form-select" required>
                    <option value="percentage" <%= coupon.couponType === 'percentage' ? 'selected' : '' %>>Percentage</option>
                    <option value="fixed" <%= coupon.couponType === 'fixed' ? 'selected' : '' %>>Fixed Amount</option>
                    <option value="free-shipping" <%= coupon.couponType === 'free-shipping' ? 'selected' : '' %>>Free Shipping</option>
                </select>
            </div>

            <!-- Usage Limit -->
            <div class="mb-3">
                <label for="usageLimit" class="form-label">Usage Limit</label>
                <input type="number" id="usageLimit" name="usageLimit" class="form-control" value="<%= coupon.usageLimit || '' %>" placeholder="Enter usage limit (optional)" min="1">
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select" required>
                    <option value="active" <%= coupon.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="inactive" <%= coupon.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    <option value="expired" <%= coupon.status === 'expired' ? 'selected' : '' %>>Expired</option>
                </select>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary">Update Coupon</button>
        </form>
    </div>
</body>
</html>
