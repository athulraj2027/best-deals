<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Coupon | Tech Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <%- include('../partials/menu') %>

    <% 
        // Helper to format date for the <input type="datetime-local">
        // It accounts for the +05:30 offset to show the correct local time in the field
        function formatForInput(dateString) {
            if (!dateString) return '';
            const date = new Date(dateString);
            // If the date is valid, adjust it to local ISO format for the input
            const offset = date.getTimezoneOffset() * 60000;
            const localISOTime = (new Date(date - offset)).toISOString().slice(0, 16);
            return localISOTime;
        }
    %>

    <div class="max-w-4xl mx-auto py-12 px-6">
        <div class="mb-10 text-center">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight italic">Modify <span class="text-indigo-600">Coupon Logic</span></h1>
            <p class="text-slate-500 mt-2 font-medium">Update configuration and validity for campaign: <span class="font-bold text-slate-700"><%= coupon.code %></span></p>
        </div>

        <form id="editCouponForm" class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
                <div class="bg-white p-5 rounded-3xl shadow-sm border border-slate-200">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Redemptions</p>
                    <h4 class="text-2xl font-black text-indigo-600"><%= coupon.usageCount %></h4>
                </div>
                <div class="bg-white p-5 rounded-3xl shadow-sm border border-slate-200">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Quota Remaining</p>
                    <h4 class="text-2xl font-black text-slate-700"><%= coupon.usageLimit ? coupon.usageLimit - coupon.usageCount : '∞' %></h4>
                </div>
                <div class="bg-white p-5 rounded-3xl shadow-sm border border-slate-200">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Fill Velocity</p>
                    <h4 class="text-2xl font-black text-slate-700"><%= coupon.usageLimit ? Math.floor((coupon.usageCount / coupon.usageLimit) * 100) : 0 %>%</h4>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i class="fas fa-fingerprint"></i>
                    </div>
                    Identity & Type
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-6">
                    <div>
                        <label for="code" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Coupon Code</label>
                        <input type="text" id="code" name="code" value="<%= coupon.code %>" 
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-bold uppercase tracking-widest" />
                        <p id="codeError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>

                    <div>
                        <label for="discountType" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Discount Model</label>
                        <select id="discountType" name="discountType" class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:border-indigo-400 appearance-none cursor-pointer text-sm font-bold">
                            <option value="percentage" <%= coupon.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                            <option value="fixed" <%= coupon.discountType === 'fixed' ? 'selected' : '' %>>Fixed Amount (₹)</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label for="description" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Campaign Narrative</label>
                    <textarea id="description" name="description" rows="2" class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 transition-all text-sm font-medium"><%= coupon.description %></textarea>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600">
                        <i class="fas fa-coins"></i>
                    </div>
                    Value Parameters
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label for="discountValue" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Benefit Value</label>
                        <input type="number" id="discountValue" name="discountValue" value="<%= coupon.discountValue %>" step="0.01"
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-black" />
                        <p id="discountValueError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>

                    <div>
                        <label for="minPurchase" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Min. Entry</label>
                        <input type="number" id="minPurchase" name="minPurchase" value="<%= coupon.minPurchase %>" step="0.01"
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-black" />
                    </div>

                    <div>
                        <label for="usageLimit" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Max Quota</label>
                        <input type="number" id="usageLimit" name="usageLimit" value="<%= coupon.usageLimit %>" placeholder="∞"
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-black" />
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200">
                <h3 class="text-lg font-bold text-slate-800 mb-8 flex items-center gap-3">
                    <div class="w-10 h-10 bg-amber-50 rounded-2xl flex items-center justify-center text-amber-600">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    Deployment Schedule
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                    <div>
                        <label for="startDate" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Live Date</label>
                        <input type="datetime-local" id="startDate" name="startDate" 
                               value="<%= formatForInput(coupon.startDate) %>"
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-bold" />
                    </div>
                    <div>
                        <label for="expiryDate" class="block text-[11px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Expiration</label>
                        <input type="datetime-local" id="expiryDate" name="expiryDate" 
                               value="<%= formatForInput(coupon.expiryDate) %>"
                               class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 outline-none focus:ring-4 focus:ring-indigo-50 text-sm font-bold" />
                        <p id="expiryDateError" class="text-red-500 text-[10px] mt-2 hidden font-bold"></p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center justify-between p-6 bg-slate-900 rounded-3xl border border-slate-800 shadow-xl shadow-indigo-900/10 gap-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-white backdrop-blur-md border border-white/10">
                            <i class="fas fa-power-off"></i>
                        </div>
                        <div>
                            <span class="block text-[10px] font-black uppercase tracking-widest text-slate-500">Execution Status</span>
                            <span id="statusText" class="text-xs font-black uppercase tracking-tighter <%= coupon.active ? 'text-emerald-400' : 'text-slate-400' %>">
                                <%= coupon.active ? 'Active Operation' : 'System Offline' %>
                            </span>
                        </div>
                    </div>

                    <div class="flex items-center gap-6">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="active" id="statusToggle" class="sr-only peer" <%= coupon.active ? 'checked' : '' %> />
                            <div class="w-14 h-7 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500 shadow-inner"></div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-4">
                <a href="/admin/coupons" class="w-full sm:w-auto px-10 py-4 font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest text-xs transition-all text-center">
                    Cancel Sync
                </a>
                <button type="submit" class="w-full sm:w-auto px-12 py-4 font-black text-white bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all active:scale-95 uppercase tracking-widest text-xs">
                    Update Campaign
                </button>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const statusToggle = document.getElementById("statusToggle");
        const statusText = document.getElementById("statusText");

        statusToggle.addEventListener("change", function () {
            statusText.textContent = this.checked ? "Active Operation" : "System Offline";
            statusText.className = `text-xs font-black uppercase tracking-tighter ${this.checked ? 'text-emerald-400' : 'text-slate-500'}`;
        });

        $("#editCouponForm").on("submit", function (e) {
            e.preventDefault();
            $('.text-red-500').addClass('hidden');
            
            const codeVal = $('#code').val().toUpperCase().trim();
            const val = parseFloat($('#discountValue').val());
            const start = new Date($('#startDate').val());
            const end = new Date($('#expiryDate').val());

            let isValid = true;

            if (codeVal.length < 3) {
                $('#codeError').text(`Code too short`).removeClass('hidden');
                isValid = false;
            }

            if ($('#discountType').val() === 'percentage' && (val < 1 || val > 100)) {
                $('#discountValueError').text('Range: 1-100%').removeClass('hidden');
                isValid = false;
            }

            if (end <= start) {
                $('#expiryDateError').text('Expiry must be after Start Date').removeClass('hidden');
                isValid = false;
            }

            if (!isValid) return;

            Swal.fire({ title: 'Updating...', didOpen: () => Swal.showLoading() });

            const formData = {
                code: codeVal,
                discountType: $('#discountType').val(),
                discountValue: val,
                minPurchase: parseFloat($('#minPurchase').val()) || 0,
                description: $('#description').val().trim(),
                startDate: $('#startDate').val(),
                expiryDate: $('#expiryDate').val(),
                usageLimit: $('#usageLimit').val() ? parseInt($('#usageLimit').val()) : null,
                active: statusToggle.checked
            };

            fetch('/admin/coupons/edit/<%= coupon._id %>', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') {
                    Swal.fire({ icon: 'success', title: 'Success', text: 'Coupon updated successfully' })
                    .then(() => window.location.href = '/admin/coupons');
                } else {
                    Swal.fire({ icon: 'error', title: 'Update Failed', text: data.message });
                }
            })
            .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Network failure' }));
        });
    </script>
</body>
</html>