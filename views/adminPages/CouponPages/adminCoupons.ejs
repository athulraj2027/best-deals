<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Coupon Management | Tech Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .main-content { margin-left: 250px; }
        @media(max-width: 768px) { .main-content { margin-left: 0; } }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        /* Ticket effect for coupon code */
        .coupon-tag {
            position: relative;
            padding: 4px 12px;
            background: #eef2ff;
            color: #4f46e5;
            font-family: monospace;
            font-weight: 800;
            border: 1px dashed #4f46e5;
            border-radius: 4px;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
<div class="flex">
    <%- include('../partials/menu') %>

    <div class="main-content w-full p-6 md:p-10">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight italic">Marketing <span class="text-indigo-600">Coupons</span></h1>
                <p class="text-slate-500 text-sm mt-1">Manage promotional discounts and campaign visibility.</p>
            </div>
            <a href="/admin/coupons/add" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold transition-all shadow-lg shadow-indigo-200 active:scale-95 text-sm uppercase tracking-widest">
                <i class="fas fa-plus"></i>
                <span>Create Coupon</span>
            </a>
        </div>

        <div class="bg-white p-5 rounded-[2rem] shadow-sm border border-slate-200 mb-8">
            <div class="flex flex-col lg:flex-row gap-4">
                <form method="GET" class="relative flex-1 group">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
                    <input type="text" name="query" value="<%= query || '' %>" placeholder="Search by code or description..." 
                           class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium">
                </form>

                <div class="flex flex-wrap items-center gap-3">
                    <form method="GET">
                        <select name="status" onchange="this.form.submit()" 
                                class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer appearance-none min-w-[140px]">
                            <option value="">All Status</option>
                            <option value="active" <%= selectedStatus==='active'?'selected':'' %>>Active</option>
                            <option value="expired" <%= selectedStatus==='expired'?'selected':'' %>>Expired</option>
                            <option value="inactive" <%= selectedStatus==='inactive'?'selected':'' %>>Inactive</option>
                        </select>
                    </form>

                    <form method="GET">
                        <input type="hidden" name="status" value="<%= selectedStatus || '' %>">
                        <select name="sort" onchange="this.form.submit()" 
                                class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer appearance-none min-w-[140px]">
                            <option value="creation_desc" <%= !selectedSort || selectedSort === "creation_desc" ? "selected" : "" %>>Newest First</option>
                            <option value="creation_asc" <%= selectedSort === "creation_asc" ? "selected" : "" %>>Oldest First</option>
                            <option value="expiry_asc" <%= selectedSort === "expiry_asc" ? "selected" : "" %>>Expiry (Nearest)</option>
                            <option value="expiry_desc" <%= selectedSort === "expiry_desc" ? "selected" : "" %>>Expiry (Furthest)</option>
                        </select>
                    </form>

                    <a href="/admin/coupons" class="text-xs font-bold text-slate-400 hover:text-red-500 px-2 transition-colors uppercase">Reset</a>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200">
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400 text-center">#</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Coupon Code</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Discount</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Threshold</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Expiry</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Status</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if(coupons.length > 0){ %>
                            <% coupons.forEach((coupon, index)=>{ %>
                            <% 
                                let statusStyles = 'bg-slate-100 text-slate-500 border-slate-200';
                                let statusText = 'Inactive';

                                if(coupon.active){
                                    const now = new Date();
                                    const expiry = new Date(coupon.expiryDate);
                                    if(now > expiry){
                                        statusStyles = 'bg-red-50 text-red-600 border-red-100';
                                        statusText = 'Expired';
                                    } else {
                                        statusStyles = 'bg-emerald-50 text-emerald-600 border-emerald-100';
                                        statusText = 'Active';
                                    }
                                }
                            %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-5 text-center text-xs font-bold text-slate-300"><%= index+1 %></td>
                                
                                <td class="px-6 py-5">
                                    <div class="flex flex-col">
                                        <span class="coupon-tag w-fit mb-1"><%= coupon.code %></span>
                                        <span class="text-[10px] text-slate-400 font-bold uppercase truncate max-w-[150px]"><%= coupon.description %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <span class="text-sm font-black text-slate-900">
                                        <%= coupon.discountType === 'percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue.toLocaleString('en-IN') %>
                                    </span>
                                </td>

                                <td class="px-6 py-5">
                                    <span class="text-[11px] font-bold text-slate-500 italic">Min: ₹<%= coupon.minPurchase.toLocaleString('en-IN') %></span>
                                </td>

                                <td class="px-6 py-5">
                                    <div class="flex flex-col">
                                        <span class="text-xs font-bold text-slate-700"><%= new Date(coupon.expiryDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %></span>
                                        <span class="text-[10px] text-slate-400 font-medium"><%= new Date(coupon.expiryDate).getFullYear() %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider border <%= statusStyles %>">
                                        <%= statusText %>
                                    </span>
                                </td>

                                <td class="px-6 py-5 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <a href="/admin/coupons/edit/<%= coupon._id %>" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="Edit">
                                            <i class="fas fa-edit text-xs"></i>
                                        </a>

                                        <% if(coupon.active){ %>
                                            <form action="/admin/coupons/deactivate/<%= coupon._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-xl transition-all" title="Deactivate">
                                                    <i class="fas fa-toggle-on text-xs"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/coupons/activate/<%= coupon._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-xl transition-all" title="Activate">
                                                    <i class="fas fa-toggle-off text-xs"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="px-6 py-20 text-center">
                                    <i class="fas fa-ticket-alt text-4xl text-slate-200 mb-4"></i>
                                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No coupons found</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 flex justify-center">
            <nav class="flex items-center gap-2 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                <% if(hasPrevPage){ %>
                    <a href="?page=<%= prevPage %>&query=<%= query %>&status=<%= selectedStatus %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                <% } %>

                <div class="px-4 text-xs font-bold text-slate-500 uppercase tracking-widest">
                    Page <%= currentPage %> <span class="text-slate-300 mx-1">/</span> <%= totalPages %>
                </div>

                <% if(hasNextPage){ %>
                    <a href="?page=<%= nextPage %>&query=<%= query %>&status=<%= selectedStatus %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                <% } %>
            </nav>
        </div>

    </div>
</div>
</body>
</html>