<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Coupons</title>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Coupons</h1>
            <a href="/admin/coupons/add" class="btn text-white" style="background-color: #f57c00;">
              Add Coupon
            </a>
          </div>

          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3">
            <!-- Filter by Status -->
            <form action="/admin/coupons/filter" method="GET" class="d-inline">
              <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">Filter by Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </form>

            <!-- Sort by Discount or CreatedAt -->
            <form action="/admin/coupons/sort" method="GET" class="d-inline">
              <select name="sort" class="form-select" onchange="this.form.submit()">
                <option value="desc">Sort by Date (Newest first)</option>
                <option value="asc">Sort by Date (Oldest first)</option>
                <option value="asc_discount">Sort by Discount (Ascending)</option>
                <option value="desc_discount">Sort by Discount (Descending)</option>
              </select>
            </form>

            <!-- Search by Coupon Code -->
            <form action="/admin/coupons/search" method="GET" class="d-inline">
              <input
                type="text"
                name="query"
                placeholder="Search by code"
                class="form-control d-inline"
                style="width: 200px;"
              />
              <button type="submit" class="btn btn-sm ms-2" style="background-color: #f57c00; color: white;">
                Search
              </button>
            </form>
          </div>

          <!-- Coupons Table -->
          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white;">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Coupon Code</th>
                    <th>Discount</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (coupons && coupons.length > 0) { %>
                    <% coupons.forEach((coupon, index) => { %>
                      <tr>
                        <td><%= index + 1 %></td>
                        <td><%= coupon.code %></td>
                        <td><%= coupon.discount %></td>
                        <td><%= coupon.status === 'active' ? 'Active' : 'Inactive' %></td>
                        <td class="text-center">
                          <a href="/admin/coupons/edit/<%= coupon._id %>" class="btn btn-sm text-white" style="background-color: #f57c00;">
                            Edit
                          </a>
                          <form action="/admin/coupons/toggle/<%= coupon._id %>" method="POST" class="d-inline">
                            <form action="/admin/coupons/toggle/<%= coupon._id %>" method="POST" class="d-inline">
                              <button 
                                type="submit" 
                                class="btn btn-sm" 
                                style="background-color: '#dc3545' ">
                                <%= coupon.isActive ? 'Unlist' : 'List' %>
                              </button>
                            </form>
                            
                          </form>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="5" class="text-center">No coupons available.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
