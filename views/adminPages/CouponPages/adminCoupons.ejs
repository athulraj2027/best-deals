<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Coupons — Admin</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/adminCSS/partials/menu.css"/>

  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --brand:#f57c00;
      --brand-dark:#e65100;
      --ink:#1a1a2e;
      --border:#e5e7eb;
    }

    body { font-family:'Manrope',sans-serif; background:#f4f5f7; }
    .syne { font-family:'Syne',sans-serif; }

    .main-content { margin-left:250px; padding:28px 24px; }
    @media(max-width:768px){ .main-content{ margin-left:70px; } }
    @media(max-width:576px){ .main-content{ margin-left:0; } }

    .card {
      background:#fff;
      border:1px solid var(--border);
      border-radius:14px;
      box-shadow:0 2px 10px rgba(0,0,0,.05);
    }

    .tbl thead th {
      background:var(--ink);
      color:#fff;
      font-size:.75rem;
      text-transform:uppercase;
      padding:12px;
    }

    .tbl tbody td {
      padding:12px;
      font-size:.85rem;
    }

    .tbl tbody tr:hover {
      background:#fffbf5;
    }

    .badge {
      padding:4px 10px;
      border-radius:20px;
      font-size:.7rem;
      font-weight:700;
    }

    .badge-active { background:#dcfce7; color:#14532d; }
    .badge-expired { background:#fee2e2; color:#7f1d1d; }
    .badge-inactive { background:#fef9c3; color:#854d0e; }

    .btn-primary {
      background:var(--brand);
      color:#fff;
      font-weight:700;
      border-radius:8px;
      padding:6px 12px;
      font-size:.8rem;
    }

    .btn-primary:hover {
      background:var(--brand-dark);
    }
  </style>
</head>

<body>
<div class="flex">

  <%- include('../partials/menu') %>

  <div class="main-content w-full">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-6 flex-wrap gap-3">
      <div>
        <h1 class="syne text-2xl font-extrabold">Coupons</h1>
        <p class="text-sm text-gray-500">
          <%= coupons.length %> coupons found
        </p>
      </div>

      <a href="/admin/coupons/add" class="btn-primary">
        + Add Coupon
      </a>
    </div>

    <!-- 🔍 SEARCH -->
    <form method="GET" class="mb-4">
      <div class="flex gap-2">
        <input
          type="text"
          name="query"
          value="<%= query || '' %>"
          placeholder="Search coupons..."
          class="flex-1 px-4 py-2 rounded-lg border text-sm focus:ring-2 focus:ring-orange-200"
        />
        <button class="btn-primary px-4">Search</button>
      </div>
    </form>

    <!-- FILTER BAR -->
    <div class="card p-4 mb-5 flex flex-wrap gap-3">

      <!-- STATUS -->
      <form method="GET">
        <select name="status"
          onchange="this.form.submit()"
          class="px-3 py-2 rounded-lg border text-sm">
          <option value="">All Status</option>
          <option value="active" <%= selectedStatus==='active'?'selected':'' %>>Active</option>
          <option value="expired" <%= selectedStatus==='expired'?'selected':'' %>>Expired</option>
          <option value="inactive" <%= selectedStatus==='inactive'?'selected':'' %>>Inactive</option>
        </select>
      </form>

      <!-- SORT -->
     <form method="GET">
  <!-- preserve other filters -->
  <input type="hidden" name="status" value="<%= selectedStatus || '' %>">
  <input type="hidden" name="query" value="<%= query || '' %>">

  <select 
    name="sort"
    onchange="this.form.submit()"
    class="px-3 py-2 rounded-lg border text-sm"
  >
    <option value="creation_desc" 
      <%= !selectedSort || selectedSort === "creation_desc" ? "selected" : "" %>>
      Newest
    </option>

    <option value="creation_asc" 
      <%= selectedSort === "creation_asc" ? "selected" : "" %>>
      Oldest
    </option>

    <option value="expiry_asc" 
      <%= selectedSort === "expiry_asc" ? "selected" : "" %>>
      Expiry ↑
    </option>

    <option value="expiry_desc" 
      <%= selectedSort === "expiry_desc" ? "selected" : "" %>>
      Expiry ↓
    </option>
  </select>
</form>

    </div>

    <!-- TABLE -->
    <div class="card overflow-hidden">
      <div class="overflow-y-auto max-h-[70vh]">

        <table class="w-full tbl text-center">
          <thead>
            <tr>
              <th>#</th>
              <th>Code</th>
              <th>Description</th>
              <th>Discount</th>
              <th>Min</th>
              <th>Expiry</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>

            <% if(coupons.length > 0){ %>

              <% coupons.forEach((coupon, index)=>{ %>

              <% 
                let statusClass = 'badge-inactive';
                let statusText = 'Inactive';

                if(coupon.active){
                  const now = new Date();
                  const expiry = new Date(coupon.expiryDate);

                  if(now > expiry){
                    statusClass = 'badge-expired';
                    statusText = 'Expired';
                  } else {
                    statusClass = 'badge-active';
                    statusText = 'Active';
                  }
                }
              %>

              <tr>

                <td class="text-gray-500"><%= index+1 %></td>

                <td>
                  <span class="bg-gray-100 px-2 py-1 rounded font-mono font-semibold">
                    <%= coupon.code %>
                  </span>
                </td>

                <td class="text-left"><%= coupon.description %></td>

                <td>
                  <%= coupon.discountType === 'percentage' 
                    ? coupon.discountValue + '%' 
                    : '₹' + coupon.discountValue %>
                </td>

                <td>₹<%= coupon.minPurchase || 0 %></td>

                <td>
                  <%= new Date(coupon.expiryDate).toLocaleDateString() %>
                </td>

                <td>
                  <span class="badge <%= statusClass %>">
                    <%= statusText %>
                  </span>
                </td>

                <td>
                  <div class="flex flex-col gap-1 items-center">

                    <a href="/admin/coupons/edit/<%= coupon._id %>" 
                       class="btn-primary text-center w-full">
                      Edit
                    </a>

                    <% if(coupon.active){ %>
                      <form action="/admin/coupons/deactivate/<%= coupon._id %>" method="POST" class="w-full">
                        <button class="w-full bg-yellow-500 text-white text-xs py-1 rounded">
                          Deactivate
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/admin/coupons/activate/<%= coupon._id %>" method="POST" class="w-full">
                        <button class="w-full bg-green-500 text-white text-xs py-1 rounded">
                          Activate
                        </button>
                      </form>
                    <% } %>

                  </div>
                </td>

              </tr>

              <% }) %>

            <% } else { %>

              <tr>
                <td colspan="8" class="text-center py-10 text-gray-400">
                  No coupons found
                </td>
              </tr>

            <% } %>

          </tbody>

        </table>
      </div>
    </div>

    <!-- PAGINATION -->
    <div class="flex justify-center items-center gap-4 mt-6">

      <% if(hasPrevPage){ %>
        <a href="?page=<%= prevPage %>" class="btn-primary">Prev</a>
      <% } %>

      <span class="text-sm font-semibold">
        Page <%= currentPage %> of <%= totalPages %>
      </span>

      <% if(hasNextPage){ %>
        <a href="?page=<%= nextPage %>" class="btn-primary">Next</a>
      <% } %>

    </div>

  </div>
</div>
</body>
</html>