<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Offer Management | Tech Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .main-content { margin-left: 250px; }
        @media(max-width: 768px) { .main-content { margin-left: 0; } }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

        .offer-row:hover { background-color: rgba(79, 70, 229, 0.02); }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
<div class="flex">
    <%- include('../partials/menu') %>

    <div class="main-content w-full p-6 md:p-10">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-extrabold tracking-tight">Campaign <span class="text-indigo-600">Offers</span></h1>
                <p class="text-slate-500 text-sm mt-1">Boost sales with product and category-wide discounts.</p>
            </div>
            <a href="/admin/offers/add" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold transition-all shadow-lg shadow-indigo-200 active:scale-95 text-sm uppercase tracking-widest">
                <i class="fas fa-plus"></i>
                <span>Create New Offer</span>
            </a>
        </div>

        <div class="bg-white p-5 rounded-[2rem] shadow-sm border border-slate-200 mb-8">
            <div class="flex flex-col lg:flex-row gap-4">
                <form action="/admin/offers" method="GET" class="relative flex-1 group">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
                    <input type="text" name="query" value="<%= query || '' %>" placeholder="Search campaigns..." 
                           class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium">
                </form>

                <div class="flex flex-wrap items-center gap-3">
                    <form action="/admin/offers" method="GET">
                        <select name="status" onchange="this.form.submit()" 
                                class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer appearance-none min-w-[140px]">
                            <option value="">All Status</option>
                            <option value="active" <%= selectedStatus==='active'?'selected':'' %>>Active</option>
                            <option value="expired" <%= selectedStatus==='expired'?'selected':'' %>>Expired</option>
                            <option value="upcoming" <%= selectedStatus==='upcoming'?'selected':'' %>>Upcoming</option>
                            <option value="inactive" <%= selectedStatus==='inactive'?'selected':'' %>>Inactive</option>
                        </select>
                    </form>

                    <form action="/admin/offers" method="GET">
                        <input type="hidden" name="status" value="<%= selectedStatus || '' %>">
                        <select name="sort" onchange="this.form.submit()" 
                                class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer appearance-none min-w-[140px]">
                            <option value="creation_desc" <%= !selectedSort || selectedSort === "creation_desc" ? "selected" : "" %>>Newest First</option>
                            <option value="creation_asc" <%= selectedSort === "creation_asc" ? "selected" : "" %>>Oldest First</option>
                            <option value="discount_high" <%= selectedSort === "discount_high" ? "selected" : "" %>>Highest Discount</option>
                            <option value="expiry_asc" <%= selectedSort === "expiry_asc" ? "selected" : "" %>>Expiring Soon</option>
                        </select>
                    </form>

                    <a href="/admin/offers" class="text-xs font-bold text-slate-400 hover:text-red-500 px-2 transition-colors uppercase tracking-widest">Reset</a>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200">
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">#</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Campaign Details</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Benefit</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Timeline</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Status</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (offers && offers.length > 0) { %>
                            <% offers.forEach((offer, index) => { %>
                            <% 
                                let badgeClass = 'bg-slate-100 text-slate-500 border-slate-200';
                                let statusText = 'Inactive';
                                if (offer.active) {
                                    const now = new Date();
                                    const expiry = new Date(offer.expiryDate);
                                    const start = new Date(offer.startDate || offer.createdAt);
                                    if (now > expiry) {
                                        badgeClass = 'bg-red-50 text-red-600 border-red-100';
                                        statusText = 'Expired';
                                    } else if (now < start) {
                                        badgeClass = 'bg-blue-50 text-blue-600 border-blue-100';
                                        statusText = 'Upcoming';
                                    } else {
                                        badgeClass = 'bg-emerald-50 text-emerald-600 border-emerald-100';
                                        statusText = 'Active';
                                    }
                                }
                            %>
                            <tr class="offer-row transition-colors group">
                                <td class="px-6 py-5 text-center text-xs font-bold text-slate-300"><%= index + 1 %></td>
                                
                                <td class="px-6 py-5">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-slate-800 group-hover:text-indigo-600 transition-colors"><%= offer.name %></span>
                                        <span class="text-[11px] text-slate-400 font-medium line-clamp-1 max-w-[200px] italic"><%= offer.description %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 rounded-xl border border-indigo-100">
                                        <i class="fas fa-tag text-[10px] text-indigo-400"></i>
                                        <span class="text-sm font-black text-indigo-600 uppercase">
                                            <%= offer.offerType === 'percentage' ? offer.offerValue + '%' : '₹' + offer.offerValue.toLocaleString('en-IN') %>
                                        </span>
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <div class="flex flex-col items-center">
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="text-[10px] font-bold text-slate-400">EXP:</span>
                                            <span class="text-xs font-bold text-slate-700 uppercase"><%= new Date(offer.expiryDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %></span>
                                        </div>
                                        <div class="w-16 h-1 bg-slate-100 rounded-full overflow-hidden">
                                            <div class="h-full bg-indigo-400" style="width: 65%"></div>
                                        </div>
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider border <%= badgeClass %>">
                                        <%= statusText %>
                                    </span>
                                </td>

                                <td class="px-6 py-5 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <a href="/admin/offers/edit/<%= offer._id %>" class="p-2.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="Edit Campaign">
                                            <i class="fas fa-pen-to-square text-xs"></i>
                                        </a>

                                        <% if (offer.active) { %>
                                            <form action="/admin/offers/deactivate/<%= offer._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2.5 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-xl transition-all" title="Pause Campaign">
                                                    <i class="fas fa-pause text-xs"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/offers/activate/<%= offer._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2.5 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-xl transition-all" title="Resume Campaign">
                                                    <i class="fas fa-play text-xs"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="px-6 py-24 text-center">
                                    <div class="flex flex-col items-center">
                                        <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4 text-slate-200 text-3xl">
                                            <i class="fas fa-percentage"></i>
                                        </div>
                                        <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Zero active campaigns found</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 flex justify-center">
            <nav class="flex items-center gap-2 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                <% if (hasPrevPage) { %>
                    <a href="/admin/offers?page=<%= prevPage %>&query=<%= query %>&status=<%= selectedStatus %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                <% } %>

                <div class="px-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">
                    Page <%= currentPage %> <span class="text-slate-300 mx-1">/</span> <%= totalPages %>
                </div>

                <% if (hasNextPage) { %>
                    <a href="/admin/offers?page=<%= nextPage %>&query=<%= query %>&status=<%= selectedStatus %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                <% } %>
            </nav>
        </div>

    </div>
</div>
</body>
</html>