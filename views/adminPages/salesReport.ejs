<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Advanced Sales Analytics | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .hide-input { display: none !important; }
    </style>
</head>

<body class="bg-[#f8fafc]">
    <div class="flex">
        <%- include('./partials/menu') %>

        <main class="ml-[250px] p-8 w-full min-h-screen">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Sales Report</h1>
                    <p class="text-slate-500 mt-1">Detailed overview of your store's financial performance.</p>
                </div>
                <div class="flex gap-3">
                    <button onclick="document.getElementById('report-section').scrollIntoView({behavior: 'smooth'})" 
                        class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-xl font-semibold shadow-sm hover:bg-slate-50 transition-all">
                        Filter Data
                    </button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Gross Revenue</p>
                    <h3 class="text-2xl font-bold text-slate-900 mt-1">₹<%= total_sales_amount.toLocaleString('en-IN', {minimumFractionDigits: 2}) %></h3>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    </div>
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Total Orders</p>
                    <h3 class="text-2xl font-bold text-slate-900 mt-1"><%= sales_count %></h3>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    </div>
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Items Sold</p>
                    <h3 class="text-2xl font-bold text-slate-900 mt-1"><%= total_items_sold %></h3>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    </div>
                    <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">Avg. Order Value</p>
                    <h3 class="text-2xl font-bold text-indigo-600 mt-1">₹<%= (total_sales_amount / (sales_count || 1)).toLocaleString('en-IN', {maximumFractionDigits: 0}) %></h3>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
                <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-bold text-slate-800 text-lg">Revenue Trend</h3>
                        <span class="text-xs font-semibold bg-slate-100 px-2 py-1 rounded text-slate-500">Auto-calculated</span>
                    </div>
                    <div class="h-[300px]">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                    <h3 class="font-bold text-slate-800 text-lg mb-6">Best Sellers</h3>
                    <div class="space-y-4">
                        <% 
                        let products = typeof topProducts === 'string' ? JSON.parse(topProducts) : topProducts;
                        products.slice(0, 5).forEach((p, index) => { %>
                            <div class="flex items-center justify-between group">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center text-sm font-bold text-slate-400 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
                                        <%= index + 1 %>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-700 truncate w-32"><%= p.name %></span>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm font-bold text-slate-900">₹<%= p.revenue.toLocaleString() %></p>
                                    <p class="text-[10px] text-slate-400 font-medium uppercase"><%= p.quantity %> Units</p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-8">
                <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                    <h3 class="font-bold text-slate-800">Recent Transactions</h3>
                    <a href="/admin/orders" class="text-indigo-600 text-xs font-bold hover:underline">View All</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50/50">
                            <tr class="text-slate-400 text-[11px] uppercase tracking-widest border-b border-slate-100">
                                <th class="px-6 py-4 font-bold">Order ID</th>
                                <th class="px-6 py-4 font-bold">Customer</th>
                                <th class="px-6 py-4 font-bold">Status</th>
                                <th class="px-6 py-4 font-bold text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% orders.forEach(o => { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 font-mono text-xs text-slate-500">#<%= o.orderId %></td>
                                    <td class="px-6 py-4">
                                        <p class="text-sm font-semibold text-slate-700"><%= o.userId?.name || "Guest Customer" %></p>
                                    </td>
                                    <td class="px-6 py-4">
                                        <% 
                                            const statusColors = {
                                                'delivered': 'bg-green-100 text-green-700',
                                                'pending': 'bg-amber-100 text-amber-700',
                                                'cancelled': 'bg-red-100 text-red-700',
                                                'processing': 'bg-blue-100 text-blue-700'
                                            }
                                        %>
                                        <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase <%= statusColors[o.status] || 'bg-slate-100 text-slate-600' %>">
                                            <%= o.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right text-sm font-bold text-slate-900">
                                        ₹<%= o.grandTotal.toLocaleString() %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="report-section" class="bg-white rounded-2xl shadow-lg border border-indigo-100 p-8 max-w-2xl mx-auto">
                <div class="text-center mb-8">
                    <h3 class="text-xl font-bold text-slate-900">Generate Report</h3>
                    <p class="text-slate-500 text-sm">Download your sales data in PDF or Excel format.</p>
                </div>

                <form action="/admin/sales-report/download" method="get" id="reportForm" class="space-y-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Reporting Period</label>
                        <select name="type" id="report-type" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                            <option value="daily">Daily Report</option>
                            <option value="weekly">Weekly Report</option>
                            <option value="monthly">Monthly Report</option>
                            <option value="yearly">Yearly Report</option>
                            <option value="custom">Custom Range</option>
                        </select>
                    </div>

                    <div id="input-container" class="space-y-4">
                        <div id="daily-input" class="date-group">
                            <input type="date" name="date" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                        </div>
                        <div id="weekly-input" class="date-group hide-input">
                            <label class="text-[10px] text-slate-400 font-bold uppercase ml-1">Select Starting Date</label>
                            <input type="date" name="start_date" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                        </div>
                        <div id="monthly-input" class="date-group hide-input grid grid-cols-2 gap-4">
                            <input type="number" name="year" placeholder="Year (2026)" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                            <select name="month" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl">
                                <% ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].forEach((m, i) => { %>
                                    <option value="<%= i+1 %>"><%= m %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div id="yearly-input" class="date-group hide-input">
                            <input type="number" name="year" placeholder="Year" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                        </div>
                        <div id="custom-input" class="date-group hide-input grid grid-cols-2 gap-4">
                            <input type="date" name="start_date" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                            <input type="date" name="end_date" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Format</label>
                            <select name="download" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl font-semibold text-slate-600">
                                <!-- <option value="">Web View</option> -->
                                <option value="pdf">PDF Document</option>
                                <option value="excel">Excel Spreadsheet</option>
                            </select>
                        </div>
                        <div class="flex items-end">
                            <button type="submit" id="generateBtn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-indigo-200 transition-all active:scale-[0.98]">
                                Generate
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // --- CHART LOGIC ---
        const salesData = <%- dailySales %>;
        const labels = Object.keys(salesData);
        const revenue = labels.map(d => salesData[d].revenue);

        const ctx = document.getElementById('salesChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(79, 70, 229, 0.2)');
        gradient.addColorStop(1, 'rgba(79, 70, 229, 0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Revenue',
                    data: revenue,
                    borderColor: '#4f46e5',
                    borderWidth: 3,
                    fill: true,
                    backgroundColor: gradient,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#4f46e5',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { borderDash: [5, 5] }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });

        // --- FORM LOGIC (From Merged Request) ---
        const typeSelect = document.getElementById('report-type');
        const groups = document.querySelectorAll('.date-group');
        const button = document.getElementById('generateBtn');

        const inputs = {
            daily: document.querySelector("#daily-input input"),
            weekly: document.querySelector("#weekly-input input"),
            monthlyYear: document.querySelector("#monthly-input input[name='year']"),
            monthlyMonth: document.querySelector("#monthly-input select[name='month']"),
            yearly: document.querySelector("#yearly-input input"),
            customStart: document.querySelector("#custom-input input[name='start_date']"),
            customEnd: document.querySelector("#custom-input input[name='end_date']"),
        };

        function hideAll() {
            groups.forEach(g => g.classList.add("hide-input"));
        }

        function validate() {
            let type = typeSelect.value;
            let valid = false;

            if (type === "daily") valid = !!inputs.daily.value;
            if (type === "weekly") valid = !!inputs.weekly.value;
            if (type === "monthly") valid = (inputs.monthlyYear.value && inputs.monthlyMonth.value);
            if (type === "yearly") valid = !!inputs.yearly.value;
            if (type === "custom") {
                const start = inputs.customStart.value;
                const end = inputs.customEnd.value;
                valid = start && end && new Date(start) <= new Date(end);
            }

            button.disabled = !valid;
            button.classList.toggle("opacity-50", !valid);
            button.classList.toggle("cursor-not-allowed", !valid);
        }

        function handleTypeChange() {
            const type = typeSelect.value;
            hideAll();

            if (type === "daily") document.getElementById("daily-input").classList.remove("hide-input");
            if (type === "weekly") document.getElementById("weekly-input").classList.remove("hide-input");
            if (type === "monthly") document.getElementById("monthly-input").classList.remove("hide-input");
            if (type === "yearly") document.getElementById("yearly-input").classList.remove("hide-input");
            if (type === "custom") document.getElementById("custom-input").classList.remove("hide-input");

            validate();
        }

        typeSelect.addEventListener("change", handleTypeChange);
        document.querySelectorAll("input, select").forEach(el => {
            el.addEventListener("input", validate);
        });

        // INIT
        handleTypeChange();
    </script>
</body>
</html>