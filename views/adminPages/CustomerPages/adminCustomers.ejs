<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Customer Management | Tech Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .main-content { margin-left: 250px; }
        @media(max-width: 768px) { .main-content { margin-left: 0; } }
        
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
<div class="flex">
    <%- include('../partials/menu') %>

    <div class="main-content w-full p-6 md:p-10">

        <div class="mb-8">
            <h1 class="text-3xl font-extrabold tracking-tight">Customers</h1>
            <p class="text-slate-500 text-sm mt-1">Monitor user activity, account status, and registration details.</p>
        </div>

        <div class="bg-white p-5 rounded-[2rem] shadow-sm border border-slate-200 mb-8">
            <div class="flex flex-col lg:flex-row gap-4">
                <form action="/admin/customers" method="GET" class="relative flex-1 group">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
                    <input type="text" name="query" value="<%= query || '' %>" placeholder="Search by name or email..." 
                           class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 transition-all text-sm font-medium">
                </form>

                <div class="flex flex-wrap items-center gap-3">
                    <form action="/admin/customers" method="GET">
                        <input type="hidden" name="query" value="<%= query || '' %>">
                        <select name="sort" onchange="this.form.submit()" 
                                class="px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold outline-none focus:border-indigo-400 cursor-pointer appearance-none min-w-[140px]">
                            <option value="desc" <%= selectedSort === "desc" ? "selected" : "" %>>Newest First</option>
                            <option value="asc" <%= selectedSort === "asc" ? "selected" : "" %>>Oldest First</option>
                            <option value="name_asc" <%= selectedSort === "name_asc" ? "selected" : "" %>>Name A-Z</option>
                            <option value="name_desc" <%= selectedSort === "name_desc" ? "selected" : "" %>>Name Z-A</option>
                        </select>
                    </form>

                    <a href="/admin/customers" class="bg-slate-100 text-slate-600 px-6 py-3 rounded-xl font-bold text-sm hover:bg-slate-200 transition-colors">
                        Reset
                    </a>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/80 border-b border-slate-200">
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">#</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Customer</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Contact Info</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Status</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400">Join Date</th>
                            <th class="px-6 py-4 text-[11px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% if (customers.length > 0) { %>
                            <% customers.forEach((c, i) => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-4 text-xs font-bold text-slate-400"><%= i+1 %></td>
                                
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xs border border-indigo-200">
                                            <%= c.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <span class="text-sm font-bold text-slate-800"><%= c.name %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-sm text-slate-700 font-medium"><%= c.email %></span>
                                        <span class="text-[10px] text-slate-400 font-bold tracking-tight"><%= c.phone || 'NO PHONE ADDED' %></span>
                                    </div>
                                </td>

                                <td class="px-6 py-4">
                                    <% if (!c.isBlocked) { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-emerald-50 text-emerald-600 border border-emerald-100">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-600"></span>
                                            Active
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider bg-red-50 text-red-600 border border-red-100">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span>
                                            Blocked
                                        </span>
                                    <% } %>
                                </td>

                                <td class="px-6 py-4 text-sm text-slate-500 font-medium">
                                    <%= new Date(c.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </td>

                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/admin/customers/view/<%= c._id %>" class="p-2.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="View Customer Details">
                                            <i class="fas fa-eye text-xs"></i>
                                        </a>

                                        <% if (!c.isBlocked) { %>
                                            <form action="/admin/customers/block/<%= c._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all" title="Block Customer">
                                                    <i class="fas fa-user-slash text-xs"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/customers/unblock/<%= c._id %>" method="POST" class="inline">
                                                <button type="submit" class="p-2.5 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-xl transition-all" title="Unblock Customer">
                                                    <i class="fas fa-user-check text-xs"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="px-6 py-20 text-center">
                                    <i class="fas fa-users-slash text-4xl text-slate-200 mb-4"></i>
                                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No customers found</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8 flex justify-center">
            <nav class="flex items-center gap-2 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                <% if (hasPrevPage) { %>
                    <a href="?page=<%= prevPage %>&query=<%= query %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                <% } %>

                <div class="px-4 text-xs font-bold text-slate-500 uppercase tracking-widest">
                    Page <%= currentPage %> <span class="text-slate-300 mx-1">/</span> <%= totalPages %>
                </div>

                <% if (hasNextPage) { %>
                    <a href="?page=<%= nextPage %>&query=<%= query %>&sort=<%= selectedSort %>" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 text-slate-600 transition-colors">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                <% } %>
            </nav>
        </div>

        <div class="mt-6 flex justify-end px-4">
            <p class="text-[10px] font-black text-slate-300 uppercase tracking-[0.2em]">
                DATABASE SYNCED: <%= customers.length %> RECORDS LOADED
            </p>
        </div>

    </div>
</div>
</body>
</html>