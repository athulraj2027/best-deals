<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <title>Dashboard</title>
    <style>
      /* Responsive styles */
      @media (max-width: 991px) {
        .filter-controls {
          flex-direction: column;
          gap: 10px;
        }
        
        .filter-controls form,
        .filter-controls .search-form {
          width: 100%;
        }
        
        .search-form {
          display: flex;
        }
        
        .search-form input {
          flex: 1;
        }
        
        .table-responsive {
          overflow-x: auto;
        }
      }
      
      @media (max-width: 767px) {
        .content-wrapper {
          margin-left: 0;
          padding-left: 15px;
          padding-right: 15px;
        }
      }
    </style>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Main content - will take full width on mobile and adapt based on menu visibility -->
        <div class="col-lg-10 col-md-9 col-sm-12 offset-lg-2 offset-md-3 offset-sm-0 content-wrapper">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Customers</h1>
          </div>
          
          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3 filter-controls">
            <!-- Filter by Status -->
            <form action="/admin/coupons/filter" method="GET" class="mb-2 mb-md-0">
              <select
                name="status"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="">Filter by Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </form>

            <!-- Sort by Discount or CreatedAt -->
            <form action="/admin/coupons/sort" method="GET" class="mb-2 mb-md-0">
              <select
                name="sort"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="desc">Sort by Date (Newest first)</option>
                <option value="asc">Sort by Date (Oldest first)</option>
                <option value="asc_discount">
                  Sort by Discount (Ascending)
                </option>
                <option value="desc_discount">
                  Sort by Discount (Descending)
                </option>
              </select>
            </form>

            <!-- Search by Coupon Code -->
            <form action="/admin/coupons/search" method="GET" class="search-form">
              <input
                type="text"
                name="query"
                placeholder="Search by code"
                class="form-control"
              />
              <button
                type="submit"
                class="btn btn-sm ms-2"
                style="background-color: #f57c00; color: white"
              >
                Search
              </button>
            </form>
          </div>
          
          <!-- Customers Table -->
          <div class="card border-light">
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead style="background-color: #f57c00; color: white">
                    <tr class="text-center">
                      <th>#</th>
                      <th>Customer Name</th>
                      <th>Email</th>
                      <th>Phone</th>
                      <th>Joined Date</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <!-- Loop through customers array passed from the server -->
                    <% customers.forEach((customer, index) => { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><%= customer.name %></td>
                      <td><%= customer.email %></td>
                      <td><%= customer.phone ? customer.phone : "Nil" %></td>
                      <td class="d-none d-md-table-cell">
                        <%= customer.createdAt.toLocaleString('en-US', { year:
                        'numeric', month: 'long', day: 'numeric', hour: '2-digit',
                        minute: '2-digit', second: '2-digit' }) %>
                      </td>
                      <!-- Simplified date format for mobile -->
                      <td class="d-table-cell d-md-none">
                        <%= customer.createdAt.toLocaleString('en-US', { 
                        year: 'numeric', month: 'short', day: 'numeric' }) %>
                      </td>
                      <td class="text-center">
                        <div class="btn-group">
                          <a
                            href="/admin/customers/view/<%= customer._id %>"
                            class="btn btn-sm text-white"
                            style="background-color: #f57c00"
                          >
                            View
                          </a>

                          <% if (customer.isBlocked === false) { %>
                          <!-- Block Button -->
                          <form
                            action="/admin/customers/block/<%= customer._id %>"
                            method="POST"
                            class="d-inline"
                          >
                            <button
                              type="submit"
                              class="btn btn-sm btn-danger block-btn"
                            >
                              Block
                            </button>
                          </form>
                          <% } else if(customer.isBlocked === true) { %>
                          <!-- Unblock Button -->
                          <form
                            action="/admin/customers/unblock/<%= customer._id %>"
                            method="POST"
                            class="d-inline"
                          >
                            <button
                              type="submit"
                              class="btn btn-sm btn-success unblock-btn"
                            >
                              Unblock
                            </button>
                          </form>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                    <!-- If there are no customers -->
                    <% if (customers.length === 0) { %>
                    <tr>
                      <td colspan="7" class="text-center">No customers found</td>
                    </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
              
              <!-- Pagination -->
              <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                  <ul class="pagination">
                    <% if (hasPrevPage) { %>
                    <li class="page-item">
                      <a class="page-link" href="/admin/customers?page=<%= prevPage %>&limit=10" aria-label="Previous">
                        <span aria-hidden="true">&laquo; Previous</span>
                      </a>
                    </li>
                    <% } %>
                    
                    <li class="page-item disabled">
                      <span class="page-link">Page <%= currentPage %> of <%= totalPages %></span>
                    </li>
                    
                    <% if (hasNextPage) { %>
                    <li class="page-item">
                      <a class="page-link" href="/admin/customers?page=<%= nextPage %>&limit=10" aria-label="Next">
                        <span aria-hidden="true">Next &raquo;</span>
                      </a>
                    </li>
                    <% } %>
                  </ul>
                </nav>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" 
      crossorigin="anonymous"></script>
  </body>
</html>