<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>Customers</title>
    <style>
      :root {
        --primary-color: #f57c00;
        --primary-hover: #e65100;
        --light-bg: #fff9f0;
        --text-dark: #333;
        --sidebar-width: 250px;
        --sidebar-collapsed-width: 70px;
      }
      
      body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow-x: hidden;
      }
      
      /* Main layout structure */
      .main-content-wrapper {
        display: flex;
        width: 100%;
        min-height: 100vh;
      }
      
      /* Main content area that adjusts with sidebar */
      .main-content {
        flex: 1;
        padding: 20px;
        margin-left: var(--sidebar-width);
        transition: margin-left 0.3s ease;
        width: calc(100% - var(--sidebar-width));
      }
      
      .page-title {
        font-weight: 600;
        color: var(--text-dark);
        border-left: 5px solid var(--primary-color);
        padding-left: 15px;
      }
      
      .btn-primary-custom {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
        transition: all 0.3s;
      }
      
      .btn-primary-custom:hover {
        background-color: var(--primary-hover);
        border-color: var(--primary-hover);
      }
      
      .card {
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }
      
      .table-header {
        background-color: var(--primary-color);
        color: white;
      }
      
      .table-responsive {
        border-radius: 8px;
        overflow: hidden;
      }
      
      .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ced4da;
      }
      
      .form-control:focus, .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(245, 124, 0, 0.25);
      }
      
      .filter-section {
        background-color: var(--light-bg);
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
      }
      
      .status-badge {
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
      }
      
      .status-active {
        background-color: #e7f5ea;
        color: #198754;
      }
      
      .status-blocked {
        background-color: #f8d7da;
        color: #dc3545;
      }
      
      /* Responsive adjustments */
      @media (max-width: 992px) {
        .filter-controls {
          flex-direction: column;
          gap: 10px;
        }
        
        .filter-controls > form {
          width: 100%;
        }
      }
      
      @media (max-width: 768px) {
        .main-content {
          margin-left: var(--sidebar-collapsed-width);
          width: calc(100% - var(--sidebar-collapsed-width));
        }
        
        body.sidebar-hidden .main-content {
          margin-left: 0;
          width: 100%;
        }
        
        .action-buttons {
          display: flex;
          flex-direction: column;
          gap: 5px;
          align-items: stretch;
        }
        
        .action-buttons form, 
        .action-buttons a {
          width: 100%;
        }
      }
      
      @media (max-width: 576px) {
        .main-content {
          margin-left: 0;
          width: 100%;
        }
        
        body.sidebar-expanded .main-content {
          margin-left: var(--sidebar-width);
          width: calc(100% - var(--sidebar-width));
        }
      }
    </style>
  </head>
  <body>
    <div class="main-content-wrapper">
      <!-- Include sidebar partial -->
      <%- include('../partials/menu') %>
      
      <!-- Main content area -->
      <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
          <h1 class="page-title mb-3 mb-md-0">Customers</h1>
        </div>

        <!-- Filter, Sort, and Search Options -->
        <div class="filter-section">
          <div class="d-flex justify-content-between align-items-center filter-controls gap-3 flex-wrap">
            <!-- Sort Option -->
            <form action="/admin/customers" method="GET" class="flex-grow-1">
              <div class="input-group">
                <span class="input-group-text bg-white">
                  <i class="fas fa-sort text-secondary"></i>
                </span>
                <select name="sort" class="form-select" onchange="this.form.submit()">
                  <option value="desc" <%= selectedSort === 'desc' ? 'selected' : '' %>>Date (Newest first)</option>
                  <option value="asc" <%= selectedSort === 'asc' ? 'selected' : '' %>>Date (Oldest first)</option>
                  <option value="name_asc" <%= selectedSort === 'name_asc' ? 'selected' : '' %>>Name (A to Z)</option>
                  <option value="name_desc" <%= selectedSort === 'name_desc' ? 'selected' : '' %>>Name (Z to A)</option>
                </select>
              </div>
            </form>

            <!-- Search by Name - Uncomment if needed -->
            <!-- <form action="/admin/customers/search" method="GET" class="flex-grow-1">
              <div class="input-group">
                <input type="text" name="query" placeholder="Search by name" class="form-control" />
                <button type="submit" class="btn btn-primary-custom">
                  <i class="fas fa-search"></i>
                </button>
              </div>
            </form> -->
          </div>
        </div>

        <!-- Customers Table -->
        <div class="card border-0">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover m-0">
                <thead class="table-header">
                  <tr class="text-center">
                    <th class="py-3">SI.No</th>
                    <th class="py-3">Customer Name</th>
                    <th class="py-3">Email</th>
                    <th class="py-3">Phone</th>
                    <th class="py-3">Status</th>
                    <th class="py-3">Joined Date</th>
                    <th class="py-3">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% customers.forEach((customer, index) => { %>
                  <tr>
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= customer.name %></td>
                    <td><%= customer.email %></td>
                    <td><%= customer.phone ? customer.phone : "Nil" %></td>
                    <td class="text-center">
                      <span class="status-badge <%= customer.isBlocked ? 'status-blocked' : 'status-active' %>">
                        <%= customer.isBlocked ? 'Blocked' : 'Active' %>
                      </span>
                    </td>
                    <td class="text-center"><%= new Date(customer.createdAt).toLocaleDateString() %></td>
                    <td>
                      <div class="d-flex justify-content-center gap-2 action-buttons">
                        <a href="/admin/customers/view/<%= customer._id %>" class="btn btn-sm btn-primary-custom">
                          <i class="fas fa-eye me-1"></i> View
                        </a>
                        <% if (!customer.isBlocked) { %>
                        <!-- Block Button -->
                        <form action="/admin/customers/block/<%= customer._id %>" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-danger w-100">
                            <i class="fas fa-ban me-1"></i> Block
                          </button>
                        </form>
                        <% } else { %>
                        <!-- Unblock Button -->
                        <form action="/admin/customers/unblock/<%= customer._id %>" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-success w-100">
                            <i class="fas fa-check me-1"></i> Unblock
                          </button>
                        </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                  <% }); %>
                  <!-- If there are no customers -->
                  <% if (customers.length === 0) { %>
                  <tr>
                    <td colspan="7" class="text-center">
                      No customers found
                    </td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        
        <!-- Pagination -->
        <div class="d-flex justify-content-center mt-4">
          <nav aria-label="Page navigation">
            <ul class="pagination">
              <% if (hasPrevPage) { %>
              <li class="page-item">
                <a class="page-link" href="/admin/customers?page=<%= prevPage %>&limit=10" aria-label="Previous">
                  <span aria-hidden="true">&laquo; Previous</span>
                </a>
              </li>
              <% } %>

              <li class="page-item disabled">
                <span class="page-link">Page <%= currentPage %> of <%= totalPages %></span>
              </li>

              <% if (hasNextPage) { %>
              <li class="page-item">
                <a class="page-link" href="/admin/customers?page=<%= nextPage %>&limit=10" aria-label="Next">
                  <span aria-hidden="true">Next &raquo;</span>
                </a>
              </li>
              <% } %>
            </ul>
          </nav>
        </div>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>