<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <title>Dashboard</title>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-dark">Customers</h1>
          </div>
          <!-- Filter, Sort, and Search Options -->
          <div class="d-flex justify-content-between mb-3">
            <!-- Filter by Status -->
            <form action="/admin/coupons/filter" method="GET" class="d-inline">
              <select
                name="status"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="">Filter by Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </form>

            <!-- Sort by Discount or CreatedAt -->
            <form action="/admin/coupons/sort" method="GET" class="d-inline">
              <select
                name="sort"
                class="form-select"
                onchange="this.form.submit()"
              >
                <option value="desc">Sort by Date (Newest first)</option>
                <option value="asc">Sort by Date (Oldest first)</option>
                <option value="asc_discount">
                  Sort by Discount (Ascending)
                </option>
                <option value="desc_discount">
                  Sort by Discount (Descending)
                </option>
              </select>
            </form>

            <!-- Search by Coupon Code -->
            <form action="/admin/coupons/search" method="GET" class="d-inline">
              <input
                type="text"
                name="query"
                placeholder="Search by code"
                class="form-control d-inline"
                style="width: 200px"
              />
              <button
                type="submit"
                class="btn btn-sm ms-2"
                style="background-color: #f57c00; color: white"
              >
                Search
              </button>
            </form>
          </div>
          <!-- Customers Table -->
          <div class="card border-light">
            <div class="card-body">
              <table class="table table-bordered table-hover">
                <thead style="background-color: #f57c00; color: white">
                  <tr class="text-center">
                    <th>#</th>
                    <th>Customer Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Joined Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <!-- Loop through customers array passed from the server -->
                  <% customers.forEach((customer, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= customer.name %></td>
                    <td><%= customer.email %></td>
                    <td><%= customer.phone %></td>
                    <td><%= customer.joinedDate %></td>
                    <td><%= customer.status %></td>
                    <td class="text-center">
                      <a
                        href="/admin/customers/view/<%= customer._id %>"
                        class="btn btn-sm text-white"
                        style="background-color: #f57c00"
                      >
                        View
                      </a>

                      <% if (customer.isActive === true) { %>
                      <!-- Block Button -->
                      <form
                        action="/admin/customers/block/<%= customer._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button
                          type="submit"
                          class="btn btn-sm btn-danger block-btn"
                        >
                          Block
                        </button>
                      </form>
                      <% } else if(customer.isActive === false) { %>
                      <!-- Unblock Button -->
                      <form
                        action="/admin/customers/unblock/<%= customer._id %>"
                        method="POST"
                        class="d-inline"
                      >
                        <button
                          type="submit"
                          class="btn btn-sm btn-success unblock-btn"
                        >
                          Unblock
                        </button>
                      </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %>
                  <!-- If there are no customers -->
                  <% if (customers.length === 0) { %>
                  <tr>
                    <td colspan="7" class="text-center">No customers found</td>
                  </tr>
                  <% } %>
                </tbody>
              </table>
              <div class="d-flex justify-content-center mt-4">
                <% if (customers.hasPrevPage) { %>
                <a
                  href="/admin/customers?page=<%= customers.prevPage %>"
                  class="btn btn-sm btn-secondary"
                  >Previous</a
                >
                <% } %>
                <span class="mx-2"
                  >Page <%= customers.page %> of <%= customers.totalPages
                  %></span
                >
                <% if (customers.hasNextPage) { %>
                <a
                  href="/admin/customers?page=<%= customers.nextPage %>"
                  class="btn btn-sm btn-secondary"
                  >Next</a
                >
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div>
      <% if (hasPrevPage) { %>
      <a href="/admin/customers?page=<%= prevPage %>&limit=10">Previous</a>
      <% } %> Page <%= currentPage %> of <%= totalPages %> <% if (hasNextPage) {
      %>
      <a href="/admin/customers?page=<%= nextPage %>&limit=10">Next</a>
      <% } %>
    </div>
  </body>
</html>
