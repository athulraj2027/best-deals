<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/adminCSS/partials/menu.css" />
    <title>User Details</title>
  </head>
  <body>
    <%- include('../partials/menu') %>
    <div class="container mt-4">
      <div class="row">
        <!-- Gap for left menu -->
        <div class="col-md-2"></div>

        <!-- Main content -->
        <div class="col-md-10">
          <div class="card border-light">
            <div class="card-header">
              <h3>User Details</h3>
            </div>
            <div class="card-body">
              <div class="row mb-3">
                <div class="col-md-3">
                  <strong>Name:</strong>
                </div>
                <div class="col-md-9">
                  <%= user.name %>
                </div>
              </div>

              <div class="row mb-3">
                <div class="col-md-3">
                  <strong>Email:</strong>
                </div>
                <div class="col-md-9">
                  <%= user.email %>
                </div>
              </div>

              <div class="row mb-3">
                <div class="col-md-3">
                  <strong>Verified:</strong>
                </div>
                <div class="col-md-9">
                  <%= user.isVerified ? 'Yes' : 'No' %>
                </div>
              </div>

              <div class="row mb-3">
                <div class="col-md-3">
                  <strong>Google Authenticated:</strong>
                </div>
                <div class="col-md-9">
                  <%= user.googleId ? 'Yes' : 'No' %>
                </div>
              </div>

              <div class="d-flex justify-content-between">
                <a href="/admin/customers" class="btn btn-secondary">Back to Users</a>

               
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
