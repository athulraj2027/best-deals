        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
      </button>
    </form>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap');
  
  /* Using CSS variables from the main page */
  :root {
    --sidebar-width: 250px;
    --sidebar-collapsed-width: 70px;
  }
  
  .admin-sidebar {
    width: var(--sidebar-width);
    height: 100vh;
    background: linear-gradient(180deg, #2c3e50, #1a252f);
    color: #fff;
    position: fixed;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
    z-index: 1000;
  }
  
  .sidebar-header {
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .sidebar-header h3 {
    font-size: 22px;
    font-weight: 600;
    color: #3498db;
    margin: 0;
  }
  
  .menu-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 25px;
    height: 20px;
  }
  
  .menu-toggle span {
    display: block;
    height: 3px;
    width: 100%;
    background: #fff;
    border-radius: 3px;
    transition: all 0.3s ease;
  }
  
  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 15px 0;
  }
  
  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .nav-item {
    margin-bottom: 5px;
  }
  
  .nav-item a {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    color: #ecf0f1;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .nav-item a:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #3498db;
  }
  
  .nav-item.active a {
    background: rgba(52, 152, 219, 0.2);
    color: #3498db;
    border-left: 4px solid #3498db;
  }
  
  .nav-item i {
    font-size: 18px;
    width: 30px;
  }
  
  .sidebar-footer {
    padding: 15px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .logout-btn {
    width: 100%;
    padding: 10px;
    border: none;
    background: rgba(231, 76, 60, 0.8);
    color: white;
    border-radius: 5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  
  .logout-btn:hover {
    background: #e74c3c;
  }
  
  .logout-btn i {
    margin-right: 10px;
  }
  
  /* Responsive styles */
  @media screen and (max-width: 768px) {
    .admin-sidebar {
      width: var(--sidebar-collapsed-width);
    }
    
    .sidebar-header h3,
    .nav-item span,
    .logout-btn span {
      display: none;
    }
    
    .nav-item i {
      width: auto;
    }
    
    body.sidebar-expanded .admin-sidebar {
      width: var(--sidebar-width);
    }
    
    body.sidebar-expanded .admin-sidebar .sidebar-header h3,
    body.sidebar-expanded .admin-sidebar .nav-item span,
    body.sidebar-expanded .admin-sidebar .logout-btn span {
      display: inline-block;
    }
  }
  
  @media screen and (max-width: 576px) {
    .admin-sidebar {
      width: 0;
      overflow: hidden;
    }
    
    body.sidebar-expanded .admin-sidebar {
      width: var(--sidebar-width);
    }
    
    /* Mobile menu toggle - always visible */
    .mobile-menu-toggle {
      position: fixed;
      top: 15px;
      left: 15px;
      z-index: 1001;
      background: #2c3e50;
      border-radius: 5px;
      padding: 10px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      width: 25px;
      height: 20px;
      border: none;
      cursor: pointer;
    }
    
    .mobile-menu-toggle span {
      display: block;
      height: 3px;
      width: 100%;
      background: #fff;
      border-radius: 3px;
      transition: all 0.3s ease;
    }
    
    body.sidebar-expanded .mobile-menu-toggle span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }
    
    body.sidebar-expanded .mobile-menu-toggle span:nth-child(2) {
      opacity: 0;
    }
    
    body.sidebar-expanded .mobile-menu-toggle span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Get the sidebar toggle button
    const sidebarToggle = document.getElementById('sidebarToggle');
    
    // Create mobile toggle button for small screens
    const mobileToggle = document.createElement('button');
    mobileToggle.className = 'mobile-menu-toggle';
    mobileToggle.innerHTML = '<span></span><span></span><span></span>';
    document.body.appendChild(mobileToggle);
    
    // Function to toggle sidebar
    function toggleSidebar() {
      document.body.classList.toggle('sidebar-expanded');
      
      if (window.innerWidth <= 576) {
        // For mobile view
        if (document.body.classList.contains('sidebar-expanded')) {
          document.body.classList.remove('sidebar-hidden');
        }
      } else if (window.innerWidth <= 768) {
        // For tablet view
        document.body.classList.toggle('sidebar-hidden');
      }
    }
    
    // Add click event to both toggles
    sidebarToggle.addEventListener('click', toggleSidebar);
    mobileToggle.addEventListener('click', toggleSidebar);
    
    // Handle resize events to reset menu state
    window.addEventListener('resize', function() {
      const width = window.innerWidth;
      
      if (width > 768) {
        // Desktop view
        document.body.classList.remove('sidebar-expanded');
        document.body.classList.remove('sidebar-hidden');
      } else if (width > 576 && width <= 768) {
        // Tablet view - collapsed by default
        document.body.classList.remove('sidebar-expanded');
        
        if (document.body.classList.contains('sidebar-hidden')) {
          document.body.classList.remove('sidebar-hidden');
        }
      } else {
        // Mobile view - hidden by default
        if (!document.body.classList.contains('sidebar-expanded')) {
          document.body.classList.remove('sidebar-hidden');
        }
      }
    });
  });
</script>